s = get_shell
c = s.host_computer
m = function(filePath, content, isNew)
    segments = filePath.split("/")[1:]
    fileName = segments.pop
    for segment in segments
        __segment_idx = segments.indexOf(segment)
        parentPath = "/" + segments[:__segment_idx].join("/")
        if parentPath == "/" then
            folderPath = "/" + segment
        else
            folderPath = parentPath + "/" + segment
        end if
        folderHandle = c.File(folderPath)
        if folderHandle == null then
            result = c.create_folder(parentPath, segment)
            if result != 1 then
                exit("Could not create folder: " + folderPath)
            end if
        end if
    end for
    parentPath = "/" + segments.join("/")
    fileEntity = c.File(filePath)
    if fileEntity == null then
        result = c.touch(parentPath, fileName)
        if result != 1 then
            exit("Could not create file: " + filePath)
        end if
        fileEntity = c.File(filePath)
    end if
    if isNew then
        fileEntity.set_content(content)
        print("Written: " + filePath)
    else
        fileEntity.set_content(fileEntity.get_content + content)
        print("Appended: " + filePath)
    end if
end function
m("/Corvid/source/commands_1.txt","// ============================================================\n// CORVID 2.0 | commands\n// All command registrations. Called once from main after\n// all managers are wired to the mediator.\n// ============================================================\n\nregisterAllCommands = function(mediator, commandManager)\n\n// ============================================================\n// NAVIGATION\n// ============================================================\n\n// --- ls ---\n_cmd = new Command\n_cmd.name = \"ls\"\n_cmd.description = \"List files in current or given directory\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": false, \"default\": \".\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        handler        = sessionManager.currentSession.handler\n        file           = handler.getFile(params.path)\n        if file isa Error then\n            return file\n        end if\n        kids = file.children()\n        if kids isa Error then\n            return kids\n        end if\n        ui.ls(kids)\n    end function\ncommandManager.register(_cmd)\n\n// --- cd ---\n_cmd = new Command\n_cmd.name = \"cd\"\n_cmd.description = \"Change directory\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        handler        = sessionManager.currentSession.handler\n        return handler.goTo(params.path)\n    end function\ncommandManager.register(_cmd)\n\n// --- pwd ---\n_cmd = new Command\n_cmd.name = \"pwd\"\n_cmd.description = \"Print working directory\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        return sessionManager.currentSession.handler.path()\n    end function\ncommandManager.register(_cmd)\n\n// --- back ---\n_cmd = new Command\n_cmd.name = \"back\"\n_cmd.description = \"Return to previous session\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        result = sessionManager.back()\n        if result isa Error then\n            return result\n        end if\n        ui.info(\"Returned to: \" + sessionManager.currentSession.label)\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// FILE OPERATIONS\n// ============================================================\n\n// --- cat ---\n_cmd = new Command\n_cmd.name = \"cat\"\n_cmd.description = \"Print file contents\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        handler        = sessionManager.currentSession.handler\n        file           = handler.getFile(params.path)\n        if file isa Error then\n            return file\n        end if\n        return file.content()\n    end function\ncommandManager.register(_cmd)\n\n// --- write ---\n_cmd = new Command\n_cmd.name = \"write\"\n_cmd.description = \"Write content to a file. Use > to overwrite, >> to append\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\",    \"required\": true}),OptionsParameter.New({\"name\": \"mode\", \"required\": true, \"options\": {\">\": \">\", \">>\": \">>\"}}),RestParameter.New({\"name\": \"content\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        handler        = sessionManager.currentSession.handler\n        file           = handler.getFile(params.path)\n        if file isa Error then\n            return file\n        end if\n        if params.mode == \">\" then\n            return file.setContent(params.content)\n        end if\n        return file.appendContent(params.content)\n    end function\ncommandManager.register(_cmd)\n\n// --- rm ---\n_cmd = new Command\n_cmd.name = \"rm\"\n_cmd.description = \"Delete a file or directory\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.delete(params.path)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Deleted: \" + params.path)\n    end function\ncommandManager.register(_cmd)\n\n// --- mkdir ---\n_cmd = new Command\n_cmd.name = \"mkdir\"\n_cmd.description = \"Create a directory\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"computer\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.createFolder(params.path)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Created: \" + params.path)\n    end function\ncommandManager.register(_cmd)\n\n// --- touch ---\n_cmd = new Command\n_cmd.name = \"touch\"\n_cmd.description = \"Create an empty file\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"computer\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.createFile(params.path)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Created: \" + params.path)\n    end function\ncommandManager.register(_cmd)\n\n// --- mv ---\n_cmd = new Command\n_cmd.name = \"mv\"\n_cmd.description = \"Move or rename a file\"\n_cmd.parameters = [StringParameter.New({\"name\": \"src\",  \"required\": true}),StringParameter.New({\"name\": \"dest\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.move(params.src, params.dest)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Moved: \" + params.src + \" -> \" + params.dest)\n    end function\ncommandManager.register(_cmd)\n\n// --- cp ---\n_cmd = new Command\n_cmd.name = \"cp\"\n_cmd.description = \"Copy a file\"\n_cmd.parameters = [StringParameter.New({\"name\": \"src\",  \"required\": true}),StringParameter.New({\"name\": \"dest\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.copy(params.src, params.dest)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Copied: \" + params.src + \" -> \" + params.dest)\n    end function\ncommandManager.register(_cmd)\n\n// --- chmod ---\n_cmd = new Command\n_cmd.name = \"chmod\"\n_cmd.description = \"Change file permissions\"\n_cmd.parameters = [FlagParameter.New({\"name\": \"recursive\", \"flag\": \"-R\"}),StringParameter.New({\"name\": \"perms\", \"required\": true}),StringParameter.New({\"name\": \"path\",  \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.setPermissions(params.path, params.perms, params.recursive)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Permissions set: \" + params.path)\n    end function\ncommandManager.register(_cmd)\n\n// --- chown ---\n_cmd = new Command\n_cmd.name = \"chown\"\n_cmd.description = \"Change file owner\"\n_cmd.parameters = [FlagParameter.New({\"name\": \"recursive\", \"flag\": \"-R\"}),StringParameter.New({\"name\": \"owner\", \"required\": true}),StringParameter.New({\"name\": \"path\",  \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"root\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.setOwner(params.path, params.owner, params.recursive)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Owner set: \" + params.path)\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// SESSION MANAGEMENT\n// ============================================================\n\n// --- sessions ---\n_cmd = new Command\n_cmd.name = \"sessions\"\n_cmd.description = \"List all open sessions\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        ui.sessions(sessionManager.listSessions())\n    end function\ncommandManager.register(_cmd)\n\n// --- use ---\n_cmd = new Command\n_cmd.name = \"use\"\n_cmd.description = \"Switch to a session by index\"\n_cmd.parameters = [StringParameter.New({\"name\": \"id\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        result         = sessionManager.setCurrentSession(params.id.val)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Switched to session: \" + str(params.id.val))\n    end function\ncommandManager.register(_cmd)\n\n// --- pivot ---\n_cmd = new Command\n_cmd.name = \"pivot\"\n_cmd.description = \"Set pivot session by index\"\n_cmd.parameters = [StringParameter.New({\"name\": \"id\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        result         = sessionManager.setPivotSession(params.id.val)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Pivot set to session: \" + str(params.id.val))\n    end function\ncommandManager.register(_cmd)\n\n// --- activate ---\n_cmd = new Command\n_cmd.name = \"activate\"\n_cmd.description = \"Open an interactive terminal on the current session\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        dbManager      = mediator.getExtension(\"databaseManager\")\n        handler        = sessionManager.currentSession.handler\n        if not (handler isa ShellSession) then\n            return Error.New(\"activate requires a shell session\", \"NOT_SHELL\")\n        end if\n        handler.activate()\n        // After returning from native terminal, check session is still alive\n        // A reboot during activate will kill the shell - fall back gracefully\n        rawShell = handler.shell.shell\n        sessionDead = false\n        if rawShell == null then\n            sessionDead = true\n        else\n            testComp = rawShell.host_computer\n            if testComp == null then\n                sessionDead = true\n            end if\n        end if\n        if sessionDead then\n            ui.warning(\"Session lost after activate (machine may have rebooted) - falling back\")\n            sessionManager.back()\n            dbManager.save()\n        end if\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// SYSTEM\n// ============================================================\n\n// --- ps ---\n_cmd = new Command\n_cmd.name = \"ps\"\n_cmd.description = \"List running processes\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"computer\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        procs          = handler.showProcs()\n        if procs isa Error then\n            return procs\n        end if\n        ui.processes(procs)\n    end function\ncommandManager.register(_cmd)\n\n// --- kill ---\n_cmd = new Command\n_cmd.name = \"kill\"\n_cmd.description = \"Terminate a process by PID\"\n_cmd.parameters = [StringParameter.New({\"name\": \"pid\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"computer\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        pid            = params.pid.trim.val\n        if pid <= 0 then\n            return Error.New(\"Invalid PID: \" + params.pid, \"INVALID_PID\")\n        end if\n        result = handler.closeProcess(pid)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Process terminated: \" + str(pid))\n    end function\ncommandManager.register(_cmd)\n\n// --- adduser ---\n_cmd = new Command\n_cmd.name = \"adduser\"\n_cmd.description = \"Create a new user on the current machine\"\n_cmd.parameters = [StringParameter.New({\"name\": \"username\", \"required\": true}),StringParameter.New({\"name\": \"password\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"computer\"\n_cmd.permissions.privilege = \"root\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.addUser(params.username, params.password)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"User created: \" + params.username)\n    end function\ncommandManager.register(_cmd)\n\n// --- deluser ---\n_cmd = new Command\n_cmd.name = \"deluser\"\n_cmd.description = \"Delete a user from the current machine\"\n_cmd.parameters = [StringParameter.New({\"name\": \"username\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"computer\"\n_cmd.permissions.privilege = \"root\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.deleteUser(params.username)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"User deleted: \" + params.username)\n    end function\ncommandManager.register(_cmd)\n\n// --- passwd ---\n_cmd = new Command\n_cmd.name = \"passwd\"\n_cmd.description = \"Change a user's password\"\n_cmd.parameters = [StringParameter.New({\"name\": \"username\", \"required\": true}),StringParameter.New({\"name\": \"password\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"computer\"\n_cmd.permissions.privilege = \"root\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        result         = handler.changePassword(params.username, params.password)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Password changed for: \" + params.username)\n    end function\ncommandManager.register(_cmd)\n\n// --- corruptlogs ---\n_cmd = new Command\n_cmd.name = \"corruptlogs\"\n_cmd.description = \"Wipe system.log, trigger a benign regen entry, then open LogViewer to manually clear it.\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"root\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        rawShell       = handler.shell.shell\n        rawComp        = rawShell.host_computer\n\n        // Step 1: wipe system.log with move trick\n        result = handler.corruptLogs()\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Log wiped.\")\n\n        // Step 2: touch and delete a temp file to regenerate system.log\n        // with a single benign entry before we open LogViewer\n        rawComp.touch(\"/var\", \"corvid_tmp\")\n        tmpFile = rawComp.File(\"/var/corvid_tmp\")\n        if tmpFile != null then\n            tmpFile.delete()\n        end if\n        ui.info(\"Log regenerated with single entry.\")\n\n        // Step 3: launch LogViewer so user can manually clear the last entry\n        ui.info(\"Opening LogViewer — delete the remaining entry, then save.\")\n        logViewerPath = \"/usr/bin/LogViewer.exe\"\n        lvFile = rawComp.File(logViewerPath)\n        if lvFile == null then\n            logViewerPath = \"/bin/LogViewer.exe\"\n            lvFile = rawComp.File(logViewerPath)\n        end if\n        if lvFile == null then\n            ui.warning(\"LogViewer.exe not found — clear the remaining log entry manually.\")\n        else\n            rawShell.launch(logViewerPath)\n        end if\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// NETWORK\n// ============================================================\n\n// --- nmap ---\n_cmd = new Command\n_cmd.name = \"nmap\"\n_cmd.description = \"Scan a target IP and display ports\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui        = mediator.getExtension(\"corvidUi\")\n        dbManager = mediator.getExtension(\"databaseManager\")\n        ip        = params.ip\n\n        if not is_valid_ip(ip) then\n            return Error.New(\"Invalid IP address: \" + ip, \"INVALID_IP\")\n        end if\n\n        // Detect private/LAN IP ranges - get_router() always uses Nest context\n        // so nmapping a LAN IP from a remote session returns Nest data, not target data\n        isPrivate = false\n        if ip.indexOf(\"192.168.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"10.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.16.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.17.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.18.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.19.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.20.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.21.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.22.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.23.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.24.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.25.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.26.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.27.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.28.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.29.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.30.\") == 0 then\n            isPrivate = true\n        end if\n        if ip.indexOf(\"172.31.\") == 0 then\n            isPrivate = true\n        end if\n\n        if isPrivate then\n            ui.warning(\"Cannot nmap LAN IP \" + ip + \" directly - nmap always runs from your Nest context\")\n            ui.info(\"To scan LAN machines, use: attack <public_ip> <lan_ip>\")\n            ui.info(\"Or use portattack <public_ip> <port> <lan_ip> from inside the network\")\n            ui.print(\"\")\n            // Show any cached data from DB for this LAN IP\n            cached = dbManager.findTarget(ip)\n            if cached.len > 0 then\n                ui.highlight(\"CACHED DATA FOR \" + ip)\n                ui.separator()\n                for tgt in cached\n                    if tgt.hasIndex(\"ports\") and tgt.ports.len > 0 then\n                        ui.info(\"  Source public IP: \" + tgt.public_ip)\n                        for pr in tgt.ports\n                            fwdStr = \"0\"\n                            if pr.forwarded then\n                                fwdStr = \"1\"\n                            end if\n                            ui.print(\"  port \" + str(pr.port) + \"  \" + pr.service + \"  \" + pr.version + \"  forwarded:\" + fwdStr)\n                        end for\n                    end if\n                end for\n                ui.separator()\n            else\n                ui.dim(\"No cached data for \" + ip + \" in DB\")\n            end if\n            return\n        end if\n\n        router = Router.New(ip)\n        if router isa Error then\n            router = Router.Local()\n            if router isa Error then\n                return router\n            end if\n        end if\n\n        ui.info(\"Router: \" + router.publicIp() + \" | \" + router.localIp() + \" | kernel \" + router.kernelVersion())\n        rules = router.firewallRules()\n        if rules.len > 0 then\n            ui.warning(\"Firewall rules: \" + rules.join(\", \"))\n        else\n            ui.success(\"No firewall rules\")\n        end if\n        print()\n\n        devices = router.devices()\n        if devices isa Error then\n            return devices\n        end if\n\n        // Display each device and its ports as a table\n        for kv in devices\n            deviceIp = kv.key\n            ports    = kv.value\n            ui.info(\"Device: \" + deviceIp)\n\n            rows = []\n            keys = [\"port\", \"service\", \"version\", \"forwarded\", \"open\"]\n            for port in ports\n                fwdColor = \"#555555\"\n                if port.forwarded then\n                    fwdColor = \"#00ff00\"\n                end if\n                openColor = \"#555555\"\n                if port.open then\n                    openColor = \"#00ff00\"\n                end if\n                row = {}\n                row.port = {}\n                row.port.text = str(port.port)\n                row.port.color = \"#FFFC33\"\n                row.service = {}\n                row.service.text = port.service\n                row.service.color = \"#058FAB\"\n                row.version = {}\n                row.version.text = port.version\n                row.version.color = \"#555555\"\n                row.forwarded = {}\n                row.forwarded.text = str(port.forwarded)\n                row.forwarded.color = fwdColor\n                row.open = {}\n                row.open.text = str(port.open)\n                row.open.color = openColor\n                rows.push(row)\n\n                // Auto-feed target database\n                targetData = {}\n                targetData.public_ip = ip\n                targetData.lan_ip    = deviceIp\n                targetData.router_ip = router.publicIp()\n                portRecord = {}\n                portRecord.port      = port.port\n                portRecord.service   = port.service\n                portRecord.version   = port.version\n                portRecord.forwarded = port.forwarded\n                portRecord.exploited = false\n                targetData.ports = [portRecord]\n                // Flag machines with native SSH for bounce revival sweep\n                if port.service == \"ssh\" then\n                    targetData.ssh_default = true\n                end if\n                dbManager.upsertTarget(targetData)\n            end for\n            ui.table(keys, rows)\n        end for\n        dbManager.save()\n    end function\ncommandManager.register(_cmd)\n\n// --- whois ---\n_cmd = new Command\n_cmd.name = \"whois\"\n_cmd.description = \"Run whois on an IP and save results to intel database. Omit IP to whois current session.\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        intelManager   = mediator.getExtension(\"intelManager\")\n        sessionManager = mediator.getExtension(\"sessionManager\")\n\n        targetIp = params.ip.trim\n        if targetIp.len == 0 then\n            targetIp = sessionManager.currentSession.data.ip.public\n            ui.info(\"Whois on current session: \" + targetIp)\n        end if\n\n        if not is_valid_ip(targetIp) then\n            return Error.New(\"Invalid IP: \" + targetIp, \"INVALID_IP\")\n        end if\n\n        result = intelManager.harvestWhois(targetIp)\n        if result isa Error then\n            return result\n        end if\n        ui.whois(result)\n    end function\ncommandManager.register(_cmd)\n\n// --- ssh ---\n_cmd = new Command\n_cmd.name = \"ssh\"\n_cmd.description = \"Connect to a remote machine via SSH\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\",       \"required\": true}),StringParameter.New({\"name\": \"username\",  \"required\": true}),StringParameter.New({\"name\": \"password\",  \"required\": true}),StringParameter.New({\"name\": \"port\",     \"required\": false, \"default\": \"22\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        handler        = sessionManager.currentSession.handler\n        newSession     = handler.connectTo(params.ip, params.port.val, params.username, params.password, \"ssh\")\n        if newSession isa Error then\n            return newSession\n        end if\n        session = sessionManager.addSession(newSession.shell.shell, params.username + \"@\" + params.ip)\n        if session isa Error then\n            return session\n        end if\n        sessionManager.setCurrentSession(session)\n        ui.success(\"Connected: \" + params.username + \"@\" + params.ip + \":\" + str(params.port.val))\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// LIBRARY MANAGEMENT\n// ============================================================\n\n// --- libs ---\n_cmd = new Command\n_cmd.name = \"libs\"\n_cmd.description = \"List all loaded libraries\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        libManager = mediator.getExtension(\"libManager\")\n        ui         = mediator.getExtension(\"corvidUi\")\n        ui.libs(libManager.allLibs(), libManager.currentLibs, libManager.pivotLibs)\n    end function\ncommandManager.register(_cmd)\n\n// --- addlib ---\n_cmd = new Command\n_cmd.name = \"addlib\"\n_cmd.description = \"Load a library from the given path\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        libManager     = mediator.getExtension(\"libManager\")\n        ui             = mediator.getExtension(\"corvidUi\")\n        rawLib = include_lib(params.path)\n        if rawLib == null then\n            return Error.New(\"Could not load library: \" + params.path, \"LOAD_ERROR\")\n        end if\n        ipData = {}\n        ipData.ip   = sessionManager.currentSession.data.ip\n        ipData.path = params.path\n        result = libManager.addLib(rawLib, ipData)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Library loaded: \" + params.path)\n    end function\ncommandManager.register(_cmd)\n\n// --- uselib ---\n_cmd = new Command\n_cmd.name = \"uselib\"\n_cmd.description = \"Set a loaded library as current by index\"\n_cmd.parameters = [StringParameter.New({\"name\": \"id\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        libManager = mediator.getExtension(\"libManager\")\n        ui         = mediator.getExtension(\"corvidUi\")\n        lib = libManager.getLibById(params.id.val)\n        if lib isa Error then\n            return lib\n        end if\n        libManager.setCurrentLib(lib)\n        ui.success(\"Current lib set to: \" + lib.type + \" [\" + str(params.id.val) + \"]\")\n    end function\ncommandManager.register(_cmd)\n\n// --- pivotlib ---\n_cmd = new Command\n_cmd.name = \"pivotlib\"\n_cmd.description = \"Set a loaded library as pivot by index\"\n_cmd.parameters = [StringParameter.New({\"name\": \"id\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        libManager = mediator.getExtension(\"libManager\")\n        ui         = mediator.getExtension(\"corvidUi\")\n        lib = libManager.getLibById(params.id.val)\n        if lib isa Error then\n            return lib\n        end if\n        libManager.setPivotLib(lib.type, lib)\n        ui.success(\"Pivot lib set to: \" + lib.type + \" [\" + str(params.id.val) + \"]\")\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// ATTACK\n// ============================================================\n\n// --- scan ---\n_cmd = new Command\n_cmd.name = \"scan\"\n_cmd.description = \"Scan and test all exploits on target IP:port. Results saved to database\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\",   \"required\": true}),StringParameter.New({\"name\": \"port\", \"required\": true}),StringParameter.New({\"name\": \"lanip\",    \"required\": false, \"default\": \"unknown\"}),StringParameter.New({\"name\": \"routerip\", \"required\": false, \"default\": \"unknown\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui            = mediator.getExtension(\"corvidUi\")\n        attackManager = mediator.getExtension(\"attackManager\")\n\n        // Auto-whois if enabled\n        configManager = mediator.getExtension(\"configManager\")\n        autoWhois     = configManager.get(\"autoWhois\")\n        if not (autoWhois isa Error) and autoWhois then\n            intelManager = mediator.getExtension(\"intelManager\")\n            intelManager.harvestWhois(params.ip)\n        end if\n\n        results = attackManager.runScan(params.ip, params.port.val, params.lanip, params.routerip)\n        if results isa Error then\n            return results\n        end if\n        ui.exploitResults(results)\n    end function\ncommandManager.register(_cmd)\n\n// --- exploit ---\n_cmd = new Command\n_cmd.name = \"exploit\"\n_cmd.description = \"Run a stored exploit by index. Omit index to auto-select best\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\",   \"required\": true}),StringParameter.New({\"name\": \"port\", \"required\": true}),StringParameter.New({\"name\": \"lanip\",    \"required\": false, \"default\": \"unknown\"}),StringParameter.New({\"name\": \"routerip\", \"required\": false, \"default\": \"unknown\"}),StringParameter.New({\"name\": \"index\",    \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui            = mediator.getExtension(\"corvidUi\")\n        attackManager = mediator.getExtension(\"attackManager\")\n        result        = attackManager.exploit(params.ip, params.port.val, params.lanip, params.routerip, params.index)\n        if result isa Error then\n            return result\n        end if\n    end function\ncommandManager.register(_cmd)\n\n// --- hack ---\n_cmd = new Command\n_cmd.name = \"hack\"\n_cmd.description = \"Scan and immediately exploit best result on target IP:port\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\",   \"required\": true}),StringParameter.New({\"name\": \"port\", \"required\": true}),StringParameter.New({\"name\": \"lanip\",    \"required\": false, \"default\": \"unknown\"}),StringParameter.New({\"name\": \"routerip\", \"required\": false, \"default\": \"unknown\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui            = mediator.getExtension(\"corvidUi\")\n        attackManager = mediator.getExtension(\"attackManager\")\n\n        // Auto-whois if enabled\n        configManager = mediator.getExtension(\"configManager\")\n        autoWhois     = configManager.get(\"autoWhois\")\n        if not (autoWhois isa Error) and autoWhois then\n            intelManager = mediator.getExtension(\"intelManager\")\n            intelManager.harvestWhois(params.ip)\n        end if\n\n        ui.info(\"Scanning \" + params.ip + \":\" + str(params.port.val) + \"...\")\n        scanResults = attackManager.runScan(params.ip, params.port.val, params.lanip, params.routerip)\n        if scanResults isa Error then\n            return scanResults\n        end if\n        ui.exploitResults(scanResults)\n\n        ui.info(\"Exploiting best result...\")\n        result = attackManager.exploit(params.ip, params.port.val, params.lanip, params.routerip, null)\n        if result isa Error then\n            return result\n        end if\n    end function\ncommandManager.register(_cmd)\n\n// --- escalate ---\n_cmd = new Command\n_cmd.name = \"escalate\"\n_cmd.description = \"Attempt privilege escalation on current session\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        attackManager = mediator.getExtension(\"attackManager\")\n        return attackManager.escalate()\n    end function\ncommandManager.register(_cmd)\n\n// --- msfconsole ---\n_cmd = new Command\n_cmd.name = \"msfconsole\"\n_cmd.description = \"Interactive exploit session  -  manually select and run exploits\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\",   \"required\": true}),StringParameter.New({\"name\": \"port\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        attackManager  = mediator.getExtension(\"attackManager\")\n        dbManager      = mediator.getExtension(\"databaseManager\")\n        metaxManager   = mediator.getExtension(\"metaxploitManager\")\n        sessionManager = mediator.getExtension(\"sessionManager\")\n\n        metaxploit = metaxManager.getMetaxploit()\n        if metaxploit isa Error then\n            return metaxploit\n        end if\n        session    = metaxploit.netUse(params.ip, params.port.val)\n        if session isa Error then\n            return session\n        end if\n        rawLib     = session.dump_lib()\n        if rawLib == null then\n            return Error.New(\"Could not get target library\", \"DUMP_LIB_ERROR\")\n        end if\n        libKey     = rawLib.lib_name + \"_\" + rawLib.version\n\n        targets = dbManager.findTarget(params.ip)\n        if targets.len == 0 then\n            return Error.New(\"No scan data for \" + params.ip + \". Run scan first.\", \"NO_SCAN_DATA\")\n        end if\n\n        target  = targets[0]\n        results = dbManager.getExploits(target.id, libKey)\n        if results.len == 0 then\n            return Error.New(\"No exploits for \" + libKey + \". Run scan first.\", \"NO_SCAN_DATA\")\n        end if\n\n        while true\n            ui.exploitResults(results)\n            input = user_input(ui.prompt(sessionManager.currentSession) + \"msfconsole [id/exit]: \")\n            trimmedInput = input.trim\n            if trimmedInput == \"exit\" or trimmedInput == \"q\" then\n                break\n            end if\n            idx = input.val\n            if typeof(idx) == \"string\" then\n                ui.error(\"Invalid selection\")\n                continue\n            end if\n            result = attackManager.exploit(params.ip, params.port.val, \"unknown\", \"unknown\", idx)\n            if result isa Error then\n                ui.error(result.message)\n            else\n                break\n            end if\n        end while\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// INTEL / HARVEST\n// ============================================================\n\n// --- fs ---\n_cmd = new Command\n_cmd.name = \"fs\"\n_cmd.description = \"Browse file system of current session with permission indicators. Usage: fs [path]\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": false, \"default\": \"/\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n\n    session = sessionManager.currentSession\n    if session == null then\n        return Error.New(\"No active session\", \"NO_SESSION\")\n    end if\n\n    handler = session.handler\n    startPath = params.path.trim\n    if startPath.len == 0 then\n        startPath = \"/\"\n    end if\n\n    // Get raw computer object for file access - avoids facade get_files/get_folders issue\n    // ShellSession gives us shell.shell.host_computer for raw game API\n    rawComp = null\n    if session.handler isa ShellSession then\n        rawComp = session.handler.shell.shell.host_computer\n    end if\n    if rawComp == null then\n        return Error.New(\"fs requires a shell session\", \"NOT_SHELL\")\n    end if\n\n    // Get starting file via raw computer File() method\n    startFile = rawComp.File(startPath)\n    if startFile == null then\n        return Error.New(\"Cannot access path: \" + startPath, \"PATH_ERROR\")\n    end if\n\n    ui.separator()\n    ui.highlight(\"FILE SYSTEM  [\" + startPath + \"]\")\n    ui.separator()\n\n    // Recursive tree printer - uses raw game file objects (.name .path as properties)\n    // maxDepth kept low to avoid hitting GreyScript execution time limit\n    maxDepth = 2\n    fsPrint = function(f, depth, prefix)\n        if depth > maxDepth then\n            return\n        end if\n        if f == null then\n            return\n        end if\n\n        // Raw game file objects: has_permission is a method\n        readable = f.has_permission(\"r\")\n        writable = f.has_permission(\"w\")\n        execable = f.has_permission(\"x\")\n\n        r = \" \" ; w = \" \" ; x = \" \"\n        if readable then\n            r = \"r\"\n        end if\n        if writable then\n            w = \"w\"\n        end if\n        if execable then\n            x = \"x\"\n        end if\n        permLabel = \"[\" + r + w + x + \"]\"\n\n        // .name and .is_folder are properties on raw game file objects\n        fname = f.name\n        if f.is_folder then\n            fname = fname + \"/\"\n        end if\n\n        sizeStr = \"\"\n        if not f.is_folder then\n            sizeStr = \"  \" + f.size\n        end if\n\n        if readable and writable then\n            ui.success(prefix + fname + \"  \" + permLabel + sizeStr)\n        else if readable then\n            ui.info(prefix + fname + \"  \" + permLabel + sizeStr)\n        else\n            ui.dim(prefix + fname + \"  \" + permLabel + sizeStr)\n        end if\n\n        // Only recurse into readable folders\n        if f.is_folder and readable then\n            childPrefix = prefix + \"  \"\n            subFolders = f.get_folders\n            subFiles   = f.get_files\n            if subFolders != null and subFolders.len > 0 then\n                for sf in subFolders\n                    fsPrint(sf, depth + 1, childPrefix)\n                end for\n            end if\n            if subFiles != null and subFiles.len > 0 then\n                for fl in subFiles\n                    fsPrint(fl, depth + 1, childPrefix)\n                end for\n            end if\n        end if\n    end function\n\n    fsPrint(startFile, 0, \"  \")\n    ui.print(\"\")\n    ui.dim(\"  [rwx] = read/write/execute  |  green=writable  cyan=readable  dim=no access\")\n    ui.dim(\"  Depth: \" + str(maxDepth) + \"  |  Use: fs /lib  fs /home  fs /etc for specific paths\")\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// --- harvest ---\n_cmd = new Command\n_cmd.name = \"harvest\"\n_cmd.description = \"Harvest passwd, mail, bank from current session. IP optional - defaults to current session.\"\n_cmd.parameters = [StringParameter.New({\"name\": \"publicip\", \"required\": false, \"default\": \"\"}), StringParameter.New({\"name\": \"lanip\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"computer\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    intelManager   = mediator.getExtension(\"intelManager\")\n\n    publicIp = params.publicip.trim\n    lanIp    = params.lanip.trim\n\n    // Default to current session IP if not provided\n    if publicIp.len == 0 then\n        publicIp = sessionManager.currentSession.data.ip.public\n        lanIp    = sessionManager.currentSession.data.ip.local\n    end if\n\n    ui.separator()\n    ui.highlight(\"HARVESTING \" + publicIp)\n    ui.separator()\n    result = intelManager.harvestAll(publicIp, lanIp)\n    if result isa Error then\n        ui.warning(\"Harvest error: \" + result.message)\n        return result\n    end if\nend function\ncommandManager.register(_cmd)\n\n// --- getpass ---\n_cmd = new Command\n_cmd.name = \"getpass\"\n_cmd.description = \"Crack all passwords on current session and display results\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"computer\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        intelManager   = mediator.getExtension(\"intelManager\")\n        handler        = sessionManager.currentSession.handler\n        ip             = sessionManager.currentSession.data.ip\n\n        result = intelManager.harvestPasswd(handler, ip.public, ip.local)\n        if result isa Error then\n            return result\n        end if\n\n        dbManager = mediator.getExtension(\"databaseManager\")\n        creds     = dbManager.findCredentialsByIp(ip.public)\n        ui.credentials(creds)\n    end function\ncommandManager.register(_cmd)\n\n// --- decipher ---\n// Crack a hash string directly without needing a session.\n// Accepts either a raw hash, a full \"username:hash\" passwd line,\n// or a file path - reads the file and deciphers each line.\n// Usage: decipher <hash>  or  decipher <username:hash>  or  decipher <filepath>\n_cmd = new Command\n_cmd.name = \"decipher\"\n_cmd.description = \"Crack a password hash. Accepts hash, username:hash, or a file path to decipher all lines.\"\n_cmd.parameters = [StringParameter.New({\"name\": \"input\", \"required\": true, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        intelManager   = mediator.getExtension(\"intelManager\")\n        sessionManager = mediator.getExtension(\"sessionManager\")\n\n        input = params.input.trim\n        if input.len == 0 then\n            return Error.New(\"Provide a hash, username:hash, or file path\", \"MISSING_PARAM\")\n        end if\n\n        // Detect file path - starts with / or ./ and exists on current session\n        lines = []\n        if input.indexOf(\"/\") == 0 or input.indexOf(\"./\") == 0 then\n            handler = sessionManager.currentSession.handler\n            f = handler.getFile(input)\n            if not (f isa Error) then\n                content = f.content()\n                if not (content isa Error) and content.len > 0 then\n                    for line in content.split(char(10))\n                        line = line.trim\n                        if line.len > 0 then\n                            lines.push(line)\n                        end if\n                    end for\n                end if\n            end if\n        end if\n\n        // If not a file or file empty, treat input as a single hash\n        if lines.len == 0 then\n            lines.push(input)\n        end if\n\n        ui.separator()\n        cracked = 0\n        failed  = 0\n        for line in lines\n            username = \"\"\n            hash = line\n            colonIdx = line.indexOf(\":\")\n            atIdx = line.indexOf(\"@\")\n            // \"user@domain.com:hash\" - email format, split on last colon\n            // \"username:hash\" - passwd format\n            if colonIdx != null then\n                if atIdx != null and atIdx < colonIdx then\n                    // email:hash format\n                    username = line[:colonIdx]\n                    hash = line[colonIdx + 1:]\n                else if atIdx == null then\n                    // username:hash format\n                    username = line[:colonIdx]\n                    hash = line[colonIdx + 1:]\n                end if\n            end if\n\n            if hash.len == 0 then\n                continue\n            end if\n\n            if username.len > 0 then\n                ui.info(\"Deciphering: \" + username)\n            else\n                ui.info(\"Deciphering hash: \" + hash[:20] + \"...\")\n            end if\n\n            result = intelManager.crackHash(username, hash)\n            if result isa Error then\n                ui.warning(\"  Could not crack\")\n                failed = failed + 1\n            else\n                if username.len > 0 then\n                    ui.success(\"  \" + username + \" : \" + result)\n                else\n  ",1)
m("/Corvid/source/commands_1.txt","                  ui.success(\"  Password: \" + result)\n                end if\n                cracked = cracked + 1\n            end if\n        end for\n\n        if lines.len > 1 then\n            ui.print(\"\")\n            ui.info(\"Cracked: \" + str(cracked) + \"  Failed: \" + str(failed))\n        end if\n        ui.separator()\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// DATABASE QUERIES\n// ============================================================\n\n// --- persons ---\n_cmd = new Command\n_cmd.name = \"persons\"\n_cmd.description = \"List or search persons database. Omit term to list all\"\n_cmd.parameters = [StringParameter.New({\"name\": \"term\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui        = mediator.getExtension(\"corvidUi\")\n        dbManager = mediator.getExtension(\"databaseManager\")\n        if params.term.len > 0 then\n            results = dbManager.findPerson(params.term)\n        else\n            results = dbManager.allPersons()\n        end if\n        if results.len == 0 then\n            ui.warning(\"No persons found\")\n            return\n        end if\n        ui.persons(results)\n    end function\ncommandManager.register(_cmd)\n\n// --- orgs ---\n_cmd = new Command\n_cmd.name = \"orgs\"\n_cmd.description = \"List or search organisations database. Omit term to list all\"\n_cmd.parameters = [StringParameter.New({\"name\": \"term\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui        = mediator.getExtension(\"corvidUi\")\n        dbManager = mediator.getExtension(\"databaseManager\")\n        if params.term.len > 0 then\n            results = dbManager.findOrg(params.term)\n        else\n            results = dbManager.allOrgs()\n        end if\n        if results.len == 0 then\n            ui.warning(\"No organisations found\")\n            return\n        end if\n        ui.orgs(results)\n    end function\ncommandManager.register(_cmd)\n\n// --- creds ---\n_cmd = new Command\n_cmd.name = \"creds\"\n_cmd.description = \"List credentials for current session. Use 'creds all' to show all, or filter by type/term.\"\n_cmd.parameters = [StringParameter.New({\"name\": \"term\", \"required\": false, \"default\": \"\"}),OptionsParameter.New({\"name\": \"type\", \"required\": false, \"default\": \"\",\"options\": {\"system\": \"system\", \"mail\": \"mail\", \"bank\": \"bank\", \"all\": \"\"}})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n\n    showAll = params.term.trim.lower == \"all\" or params.type.trim.lower == \"all\"\n\n    if showAll then\n        // creds all - show everything\n        if params.type.len > 0 and params.type != \"all\" then\n            results = dbManager.findCredentialsByType(params.type)\n        else if params.term.len > 0 and params.term != \"all\" then\n            results = dbManager.findCredentials(params.term)\n        else\n            results = dbManager.allCredentials()\n        end if\n        ui.info(\"All credentials (\" + str(results.len) + \" total):\")\n    else\n        // Default: filter to current session PUBLIC IP only\n        // Deliberately exclude LAN IP - LAN subnets are shared across many machines\n        // and would cause creds from other sessions to bleed in\n        sessionIp = sessionManager.currentSession.data.ip.public\n        if params.type.len > 0 then\n            allOfType = dbManager.findCredentialsByType(params.type)\n            results = []\n            for cr in allOfType\n                crIp = \"\"\n                if cr.hasIndex(\"public_ip\") then\n                    crIp = cr.public_ip\n                end if\n                if crIp == sessionIp then\n                    results.push(cr)\n                end if\n            end for\n        else if params.term.len > 0 then\n            results = dbManager.findCredentials(params.term)\n        else\n            results = dbManager.findCredentialsByIp(sessionIp)\n        end if\n        ui.info(\"Credentials for \" + sessionIp + \" (use 'creds all' for full DB):\")\n    end if\n\n    if results.len == 0 then\n        ui.warning(\"No credentials found\")\n        return\n    end if\n    ui.credentials(results)\nend function\ncommandManager.register(_cmd)\n\n// --- targets ---\n_cmd = new Command\n_cmd.name = \"targets\"\n_cmd.description = \"List or search targets database. Omit term to list all\"\n_cmd.parameters = [StringParameter.New({\"name\": \"term\", \"required\": false, \"default\": \"\"}),OptionsParameter.New({\"name\": \"status\", \"required\": false, \"default\": \"\",\"options\": {\"unknown\": \"unknown\", \"scanned\": \"scanned\",\"exploited\": \"exploited\", \"owned\": \"owned\",\"bounce\": \"bounce\", \"all\": \"\"}})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui        = mediator.getExtension(\"corvidUi\")\n        dbManager = mediator.getExtension(\"databaseManager\")\n        if params.status.len > 0 then\n            results = dbManager.findTargetsByStatus(params.status)\n        else if params.term.len > 0 then\n            results = dbManager.findTarget(params.term)\n        else\n            results = dbManager.allTargets()\n        end if\n        if results.len == 0 then\n            ui.warning(\"No targets found\")\n            return\n        end if\n        ui.targets(results)\n    end function\ncommandManager.register(_cmd)\n\n// --- note ---\n_cmd = new Command\n_cmd.name = \"note\"\n_cmd.description = \"Add a note to a database record\"\n_cmd.parameters = [OptionsParameter.New({\"name\": \"collection\", \"required\": true,\"options\": {\"person\": \"person\", \"org\": \"org\", \"target\": \"target\"}}),StringParameter.New({\"name\": \"id\",   \"required\": true}),RestParameter.New({\"name\":   \"note\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui        = mediator.getExtension(\"corvidUi\")\n        dbManager = mediator.getExtension(\"databaseManager\")\n        result    = dbManager.addNote(params.collection, params.id, params.note)\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Note added to \" + params.collection + \" \" + params.id)\n    end function\ncommandManager.register(_cmd)\n\n// --- kbstats ---\n_cmd = new Command\n_cmd.name = \"kbstats\"\n_cmd.description = \"Show exploit knowledge base statistics and known lib/version coverage\"\n_cmd.parameters = [StringParameter.New({\"name\": \"libname\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui        = mediator.getExtension(\"corvidUi\")\n    dbManager = mediator.getExtension(\"databaseManager\")\n\n    filterLib = params.libname.trim\n\n    ui.separator()\n    ui.highlight(\"EXPLOIT KNOWLEDGE BASE\")\n    ui.separator()\n\n    stats = dbManager.kbStats()\n    ui.info(\"Total records   : \" + str(stats.total))\n    ui.info(\"Successful      : \" + str(stats.successes))\n    ui.info(\"Constraint-blocked : \" + str(stats.blocked))\n    ui.info(\"Uncertain       : \" + str(stats.uncertain))\n    ui.info(\"Lib/versions covered: \" + str(stats.libVersions))\n    ui.print(\"\")\n\n    // Show per-lib breakdown\n    allRecords = dbManager.getExploitKb().db.all()\n    // Group by lib_name + lib_version\n    groups = {}\n    for r in allRecords\n        if not r.hasIndex(\"lib_name\") then\n            continue\n        end if\n        if filterLib.len > 0 and r.lib_name.indexOf(filterLib) == null then\n            continue\n        end if\n        key = r.lib_name + \" v\" + r.lib_version\n        if not groups.hasIndex(key) then\n            groups[key] = {\"success\": 0, \"blocked\": 0, \"uncertain\": 0, \"total\": 0}\n        end if\n        groups[key].total = groups[key].total + 1\n        o = \"uncertain\"\n        if r.hasIndex(\"outcome\") then\n            o = r.outcome\n        end if\n        if o == \"success\" then\n            groups[key].success = groups[key].success + 1\n        else if o == \"constraint_blocked\" then\n            groups[key].blocked = groups[key].blocked + 1\n        else\n            groups[key].uncertain = groups[key].uncertain + 1\n        end if\n    end for\n\n    if groups.indexes.len == 0 then\n        if filterLib.len > 0 then\n            ui.warning(\"No KB records matching: \" + filterLib)\n        else\n            ui.warning(\"No exploit KB records yet - run attacks to populate\")\n        end if\n        return\n    end if\n\n    ui.highlight(\"LIB/VERSION BREAKDOWN\")\n    ui.separator()\n    for key in groups.indexes\n        g = groups[key]\n        statusStr = \"\"\n        if g.success > 0 then\n            statusStr = statusStr + str(g.success) + \" success  \"\n        end if\n        if g.blocked > 0 then\n            statusStr = statusStr + str(g.blocked) + \" blocked  \"\n        end if\n        if g.uncertain > 0 then\n            statusStr = statusStr + str(g.uncertain) + \" uncertain\"\n        end if\n        if g.success > 0 then\n            ui.success(\"  \" + key + \"  [\" + statusStr.trim + \"]\")\n        else if g.blocked > 0 then\n            ui.warning(\"  \" + key + \"  [\" + statusStr.trim + \"]\")\n        else\n            ui.dim(\"  \" + key + \"  [\" + statusStr.trim + \"]\")\n        end if\n    end for\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// --- dbstats ---\n_cmd = new Command\n_cmd.name = \"dbstats\"\n_cmd.description = \"Show database record counts\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui        = mediator.getExtension(\"corvidUi\")\n        dbManager = mediator.getExtension(\"databaseManager\")\n        ui.dbStats(dbManager.stats())\n    end function\ncommandManager.register(_cmd)\n\n// --- dbsave ---\n_cmd = new Command\n_cmd.name = \"dbsave\"\n_cmd.description = \"Force save all databases to disk\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui        = mediator.getExtension(\"corvidUi\")\n        dbManager = mediator.getExtension(\"databaseManager\")\n        result    = dbManager.save()\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Databases saved.\")\n    end function\ncommandManager.register(_cmd)\n\n// --- dbmigrate ---\n_cmd = new Command\n_cmd.name = \"dbmigrate\"\n_cmd.description = \"Migrate existing credential records to add native_pass and source tags. Safe to run multiple times.\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui        = mediator.getExtension(\"corvidUi\")\n    dbManager = mediator.getExtension(\"databaseManager\")\n\n    ui.separator()\n    ui.highlight(\"DATABASE MIGRATION\")\n    ui.separator()\n    ui.info(\"Scanning credential records for migration...\")\n\n    allCreds = dbManager.allCredentials()\n    updated  = 0\n    skipped  = 0\n\n    for rec in allCreds\n        needsUpdate = false\n\n        // Add native_pass field if missing\n        if not rec.hasIndex(\"native_pass\") then\n            rec.native_pass = \"\"\n            needsUpdate = true\n        end if\n\n        // Tag source field if missing or unknown\n        if not rec.hasIndex(\"source\") or rec.source.len == 0 or rec.source == \"unknown\" then\n            // Assume existing untagged records are native passwords\n            // (Corvid-generated passwords would have been tagged going forward)\n            rec.source = \"native\"\n            needsUpdate = true\n        end if\n\n        // If source is \"harvest\" (old tag) convert to \"native\"\n        if rec.hasIndex(\"source\") and rec.source == \"harvest\" then\n            rec.source = \"native\"\n            needsUpdate = true\n        end if\n\n        // If source is \"bounce\" (old tag) convert to \"hardened\"\n        if rec.hasIndex(\"source\") and rec.source == \"bounce\" then\n            rec.source = \"hardened\"\n            needsUpdate = true\n        end if\n\n        // If source is one of the old router scan tags, convert to \"native\"\n        if rec.hasIndex(\"source\") then\n            if rec.source == \"router_scan\" or rec.source == \"router_lib_exploit\" or rec.source == \"router_lib_home\" or rec.source == \"router_home_scan\" or rec.source == \"portattack_lib\" or rec.source == \"portattack_home\" then\n                rec.source = \"native\"\n                needsUpdate = true\n            end if\n        end if\n\n        if needsUpdate then\n            dbManager.updateCredentialRecord(rec)\n            updated = updated + 1\n        else\n            skipped = skipped + 1\n        end if\n    end for\n\n    dbManager.save()\n    ui.print(\"\")\n    ui.success(\"Migration complete.\")\n    ui.info(\"  Updated : \" + str(updated) + \" records\")\n    ui.info(\"  Skipped : \" + str(skipped) + \" (already migrated)\")\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// --- dbclean ---\n_cmd = new Command\n_cmd.name = \"dbclean\"\n_cmd.description = \"Deduplicate bloated notes fields across all target records\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui        = mediator.getExtension(\"corvidUi\")\n    dbManager = mediator.getExtension(\"databaseManager\")\n\n    ui.separator()\n    ui.highlight(\"DATABASE CLEAN\")\n    ui.separator()\n\n    targets = dbManager.allTargets()\n    cleaned = 0\n    totalSaved = 0\n\n    for target in targets\n        if not target.hasIndex(\"notes\") then\n            continue\n        end if\n        notes = target.notes\n        if notes == null or notes.len == 0 then\n            continue\n        end if\n\n        // Deduplicate notes - process line by line\n        lines = notes.split(\"\n\")\n        seenLines = []\n        cleanLines = []\n\n        for line in lines\n            line = line.trim\n            if line.len == 0 then\n                continue\n            end if\n\n            // For bounce: lines - strip duplicate source: and health: tokens\n            if line.indexOf(\"bounce:\") == 0 then\n                parts = line.split(\" \")\n                cleanParts = []\n                seenSource = false\n                seenHealth = false\n                for part in parts\n                    if part.indexOf(\"source:\") == 0 then\n                        if not seenSource then\n                            cleanParts.push(part)\n                            seenSource = true\n                        end if\n                    else if part.indexOf(\"health:\") == 0 then\n                        if not seenHealth then\n                            cleanParts.push(part)\n                            seenHealth = true\n                        end if\n                    else\n                        cleanParts.push(part)\n                    end if\n                end for\n                line = cleanParts.join(\" \")\n            end if\n\n            // Skip duplicate whole lines\n            alreadySeen = false\n            for seen in seenLines\n                if seen == line then\n                    alreadySeen = true\n                end if\n            end for\n            if not alreadySeen then\n                cleanLines.push(line)\n                seenLines.push(line)\n            end if\n        end for\n\n        newNotes = cleanLines.join(\"\n\")\n        if newNotes != notes then\n            saved = notes.len - newNotes.len\n            totalSaved = totalSaved + saved\n            target.notes = newNotes\n            dbManager.targetDb.db.set(target.id, target)\n            dbManager.targetDb.db.dirty = true\n            cleaned = cleaned + 1\n            ui.info(\"  Cleaned \" + target.id + \" (\" + str(saved) + \" chars removed)\")\n        end if\n    end for\n\n    if cleaned > 0 then\n        dbManager.save()\n        ui.success(\"Cleaned \" + str(cleaned) + \" records\")\n        ui.success(\"Removed \" + str(totalSaved) + \" characters of duplicate data\")\n    else\n        ui.info(\"No bloated records found - DB is clean\")\n    end if\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// ============================================================\n// BOUNCE\n// ============================================================\n",0)
m("/Corvid/source/commands_2.txt","// --- bounce ---// ============================================================\n// RSHELL\n// ============================================================\n\n// --- flock ---\n_cmd = new Command\n_cmd.name = \"flock\"\n_cmd.description = \"Reverse shell management. Subcommands: setup, send, list, wait, deploy, callback\"\n_cmd.parameters = [OptionsParameter.New({\"name\": \"subcommand\", \"required\": true, \"options\": {\"list\": \"list\", \"adopt\": \"adopt\", \"deploy\": \"deploy\", \"build\": \"build\", \"status\": \"status\"}}), StringParameter.New({\"name\": \"arg\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    metaxManager   = mediator.getExtension(\"metaxploitManager\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    configManager  = mediator.getExtension(\"configManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n\n    rshellPort = configManager.get(\"rshellPort\")\n    if rshellPort isa Error then\n        rshellPort = 1222\n    end if\n\n    // ── build ────────────────────────────────────────────────────────────\n    if params.subcommand == \"build\" then\n        ui.separator()\n        ui.highlight(\"BUILDING FLOCK CLIENT\")\n        ui.separator()\n\n        // Get server IP from local router\n        router = Router.Local()\n        serverIp = \"\"\n        if not (router isa Error) then\n            serverIp = router.publicIp()\n        end if\n        if serverIp.len == 0 then\n            serverIp = user_input(\"  Enter your Nest public IP: \").trim\n        end if\n\n        // Get apt repo from config, with fallback\n        configManager = mediator.getExtension(\"configManager\")\n        aptRepo = configManager.get(\"flockAptRepo\")\n        if aptRepo == \"\" or aptRepo == null then\n            aptRepo = \"30.225.197.154\"  // Default repo\n        end if\n\n        // Generate flock client source\n        // Phones home to Nest with a disguised process name.\n        // Requires root on target.\n        q = char(34)\n        nl = char(10)\n        srcLines = []\n        srcLines.push(\"processNames = [\" + q + \"stick\" + q + \",\" + q + \"shiny\" + q + \",\" + q + \"grub\" + q + \",\" + q + \"wing\" + q + \"]\")\n        srcLines.push(\"idx = floor(time * 13) % processNames.len\")\n        srcLines.push(\"procName = processNames[idx]\")\n        srcLines.push(\"meta = include_lib(\" + q + \"/lib/metaxploit.so\" + q + \")\")\n        srcLines.push(\"if meta == null then\")\n        srcLines.push(\"    apt = include_lib(\" + q + \"/lib/aptclient.so\" + q + \")\")\n        srcLines.push(\"    if apt != null then\")\n        srcLines.push(\"        apt.add_repo(\" + q + aptRepo + q + \")\")\n        srcLines.push(\"        apt.update\")\n        srcLines.push(\"        apt.install(\" + q + \"metaxploit.so\" + q + \")\")\n        srcLines.push(\"        meta = include_lib(\" + q + \"/lib/metaxploit.so\" + q + \")\")\n        srcLines.push(\"    end if\")\n        srcLines.push(\"end\" + \" if\")\n        srcLines.push(\"if meta == null then\")\n        srcLines.push(\"    exit(\" + q + \"metaxploit not available\" + q + \")\")\n        srcLines.push(\"end\" + \" if\")\n        srcLines.push(\"meta.rshell_client(\" + q + serverIp + q + \", \" + str(rshellPort) + \", procName)\")\n        src = srcLines.join(nl)\n\n        // Write and compile on Nest\n        pivotHandler = sessionManager.pivotSession.handler\n        pivotComp = pivotHandler.shell.shell.host_computer\n\n        toolsDir = pivotHandler.getFile(\"/Corvid/tools\")\n        if toolsDir isa Error then\n            pivotComp.create_folder(\"/Corvid\", \"tools\")\n        end if\n\n        pivotComp.touch(\"/Corvid/tools\", \"flock-client.src\")\n        srcFile = pivotComp.File(\"/Corvid/tools/flock-client.src\")\n        if srcFile == null then\n            return Error.New(\"Could not create source file\", \"FILE_ERROR\")\n        end if\n        srcFile.set_content(src)\n        ui.success(\"Source written to /Corvid/tools/flock-client.src\")\n\n        ui.info(\"Compiling...\")\n        buildResult = pivotHandler.shell.shell.build(\"/Corvid/tools/flock-client.src\", \"/Corvid/tools\")\n        if typeof(buildResult) == \"string\" and buildResult.len > 0 then\n            return Error.New(\"Build failed: \" + buildResult, \"BUILD_ERROR\")\n        end if\n\n        cbFile = pivotHandler.getFile(\"/Corvid/tools/flock-client\")\n        if cbFile isa Error then\n            return Error.New(\"Binary not found after build\", \"BUILD_ERROR\")\n        end if\n\n        ui.success(\"flock-client compiled at /Corvid/tools/flock-client\")\n        ui.info(\"Server: \" + serverIp + \":\" + str(rshellPort))\n        ui.info(\"Run: flock deploy  (when on a root session)\")\n        ui.separator()\n\n    // ── status ───────────────────────────────────────────────────────────\n    else if params.subcommand == \"status\" then\n        ui.separator()\n        ui.highlight(\"FLOCK STATUS\")\n        ui.separator()\n\n        router = Router.Local()\n        if router isa Error then\n            ui.warning(\"Could not check local router: \" + router.message)\n        else\n            usedPorts = router.usedPorts()\n            portFound = false\n            for p in usedPorts\n                if p.port_number == rshellPort then\n                    portFound = true\n                end if\n            end for\n            if portFound then\n                ui.success(\"Port \" + str(rshellPort) + \" forwarded ✓\")\n            else\n                ui.warning(\"Port \" + str(rshellPort) + \" NOT forwarded - fix via Browser.exe > router\")\n            end if\n            ui.info(\"Nest public IP: \" + router.publicIp())\n        end if\n\n        handler = sessionManager.pivotSession.handler\n        rshellServer = handler.getFile(\"/usr/bin/rshell-server\")\n        if rshellServer isa Error then\n            ui.warning(\"rshell-server not found in /usr/bin - download from HackShop\")\n        else\n            ui.success(\"rshell-server found ✓\")\n        end if\n\n        clientFile = handler.getFile(\"/Corvid/tools/flock-client\")\n        if clientFile isa Error then\n            ui.warning(\"flock-client not built - run: flock build\")\n        else\n            ui.success(\"flock-client ready ✓\")\n        end if\n\n        meta = include_lib(\"/lib/metaxploit.so\")\n        if meta != null then\n            shells = meta.rshell_server()\n            if shells == null or shells.len == 0 then\n                ui.info(\"Active flock connections: 0\")\n            else\n                ui.info(\"Active flock connections: \" + str(shells.len))\n            end if\n        end if\n        ui.separator()\n\n    // ── deploy ───────────────────────────────────────────────────────────\n    // Upload and launch flock-client on current root session.\n    // The client phones home to Nest. Run flock adopt when it arrives.\n    else if params.subcommand == \"deploy\" then\n        currentSession = sessionManager.currentSession\n        pivotSession   = sessionManager.pivotSession\n\n        if currentSession == pivotSession then\n            return Error.New(\"Cannot deploy to Nest - must be on a remote root session\", \"IS_PIVOT\")\n        end if\n\n        currentPriv = currentSession.handler.privilege()\n        if currentPriv != \"root\" then\n            return Error.New(\"Deploy requires root on current session\", \"NOT_ROOT\")\n        end if\n\n        if not (currentSession.handler isa ShellSession) then\n            return Error.New(\"Current session must be a shell session\", \"NOT_SHELL\")\n        end if\n\n        pivotHandler = pivotSession.handler\n        cbFile = pivotHandler.getFile(\"/Corvid/tools/flock-client\")\n        if cbFile isa Error then\n            return Error.New(\"flock-client not built - run: flock build first\", \"NOT_BUILT\")\n        end if\n\n        targetHandler = currentSession.handler\n        targetIp = currentSession.data.ip.public\n\n        ui.separator()\n        ui.highlight(\"FLOCK DEPLOY — \" + targetIp)\n        ui.separator()\n        ui.info(\"Uploading flock-client to target...\")\n\n        uploadPaths = [\"/root\", \"/tmp\"]\n        uploadedPath = \"\"\n        for uploadDir in uploadPaths\n            scpResult = pivotHandler.shell.shell.scp(\"/Corvid/tools/flock-client\", uploadDir, targetHandler.shell.shell)\n            if typeof(scpResult) != \"string\" or scpResult.len == 0 then\n                uploadedPath = uploadDir + \"/flock-client\"\n                ui.success(\"Uploaded to \" + uploadedPath)\n                break\n            end if\n            ui.dim(\"  \" + uploadDir + \" failed - trying next...\")\n        end for\n\n        if uploadedPath.len == 0 then\n            return Error.New(\"Upload failed on all paths\", \"UPLOAD_ERROR\")\n        end if\n\n        ui.info(\"Launching flock-client...\")\n        targetHandler.shell.shell.launch(uploadedPath)\n        ui.success(\"flock-client launched on \" + targetIp)\n        ui.info(\"Target will phone home. Run: flock adopt  when ready.\")\n        ui.separator()\n\n    // ── list ─────────────────────────────────────────────────────────────\n    else if params.subcommand == \"list\" then\n        ui.separator()\n        ui.highlight(\"ACTIVE FLOCK CONNECTIONS\")\n        ui.separator()\n\n        meta = include_lib(\"/lib/metaxploit.so\")\n        if meta == null then\n            ui.warning(\"metaxploit.so not available\")\n            return\n        end if\n\n        shells = meta.rshell_server()\n        if shells == null or shells.len == 0 then\n            ui.warning(\"No active flock connections\")\n            return\n        end if\n\n        for i in range(0, shells.len - 1)\n            sh = shells[i]\n            priv = \"unknown\"\n            shIp = \"unknown\"\n            if typeof(sh) == \"shell\" then\n                comp = sh.host_computer\n                if comp != null then\n                    shIp = comp.local_ip\n                    pubIp = comp.public_ip\n                    if pubIp != shIp then\n                        shIp = pubIp + \" / \" + shIp\n                    end if\n                end if\n            end if\n            ui.info(\"[\" + str(i) + \"] \" + shIp)\n        end for\n        ui.separator()\n\n    // ── adopt ────────────────────────────────────────────────────────────\n    // List active flock connections and adopt one as a Corvid session\n    else if params.subcommand == \"adopt\" then\n        meta = include_lib(\"/lib/metaxploit.so\")\n        if meta == null then\n            ui.warning(\"metaxploit.so not available\")\n            return\n        end if\n\n        shells = meta.rshell_server()\n        if shells == null or shells.len == 0 then\n            ui.warning(\"No active flock connections - send Funny Game first\")\n            return\n        end if\n\n        ui.separator()\n        ui.highlight(\"ACTIVE FLOCK CONNECTIONS\")\n        ui.separator()\n        for i in range(0, shells.len - 1)\n            sh = shells[i]\n            shIp = \"unknown\"\n            if typeof(sh) == \"shell\" then\n                comp = sh.host_computer\n                if comp != null then\n                    pubIp = comp.public_ip\n                    locIp = comp.local_ip\n                    if pubIp != locIp then\n                        shIp = pubIp + \" / \" + locIp\n                    else\n                        shIp = pubIp\n                    end if\n                end if\n            end if\n            ui.info(\"  [\" + str(i) + \"]  \" + shIp)\n        end for\n        ui.print(\"\")\n\n        idxStr = params.arg.trim\n        if idxStr.len == 0 then\n            idxStr = user_input(\"  Adopt which connection (0-\" + str(shells.len - 1) + \", enter to cancel): \").trim\n        end if\n        if idxStr.len == 0 then\n            return\n        end if\n\n        idx = idxStr.val\n        if idx < 0 or idx >= shells.len then\n            ui.warning(\"Invalid index: \" + idxStr)\n            return\n        end if\n\n        sh = shells[idx]\n        if typeof(sh) != \"shell\" then\n            ui.warning(\"Connection \" + idxStr + \" is not a valid shell\")\n            return\n        end if\n\n        comp   = sh.host_computer\n        connIp = \"unknown\"\n        if comp != null then\n            pubIp = comp.public_ip\n            locIp = comp.local_ip\n            if pubIp != locIp then\n                connIp = pubIp + \" / \" + locIp\n            else\n                connIp = pubIp\n            end if\n        end if\n\n        label      = connIp + \" [flock]\"\n        newSession = sessionManager.addSession(sh, label)\n        if newSession isa Error then\n            ui.warning(\"Could not adopt session: \" + newSession.message)\n            return\n        end if\n        sessionManager.setCurrentSession(newSession)\n        ui.success(\"Session adopted: \" + label)\n        ui.info(\"Run: roost convert  to register as a persistent roost node\")\n        ui.info(\"Run: leave  when done\")\n        ui.separator()\n\n    // ── deploy (legacy - deploy rshell_client from current session) ───────\n    else if params.subcommand == \"deploy\" then\n        router   = Router.Local()\n        serverIp = params.arg\n        if serverIp.len == 0 then\n            if not (router isa Error) then\n                serverIp = router.publicIp()\n            end if\n        end if\n        processName = user_input(\"Process name (default: dsession): \")\n        if processName.len == 0 then\n            processName = \"dsession\"\n        end if\n        meta = include_lib(\"/lib/metaxploit.so\")\n        if meta == null then\n            ui.warning(\"metaxploit.so not available\")\n            return\n        end if\n        meta.rshell_client(serverIp, rshellPort, processName)\n        ui.success(\"Rshell client deployed -> \" + serverIp + \":\" + str(rshellPort))\n        ui.info(\"Run: flock list  to adopt the incoming connection\")\n    end if\nend function\ncommandManager.register(_cmd)\n\n// ============================================================\n// MACRO\n// ============================================================\n\n// --- macro ---\n_cmd = new Command\n_cmd.name = \"macro\"\n_cmd.description = \"Macro management. Subcommands: run list\"\n_cmd.parameters = [OptionsParameter.New({\"name\": \"subcommand\", \"required\": true,\"options\": {\"run\": \"run\", \"list\": \"list\"}}),StringParameter.New({\"name\": \"name\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui           = mediator.getExtension(\"corvidUi\")\n        macroManager = mediator.getExtension(\"macroManager\")\n\n        if params.subcommand == \"list\" then\n            names = macroManager.listMacros()\n            if names.len == 0 then\n                ui.warning(\"No macros found in /Config/Macros/\")\n                return\n            end if\n            for name in names\n                ui.print(\"  \" + name)\n            end for\n\n        else if params.subcommand == \"run\" then\n            if params.name.len == 0 then\n                return Error.New(\"Provide a macro name\", \"MISSING_PARAM\")\n            end if\n            result = macroManager.runMacro(params.name)\n            if result isa Error then\n                return result\n            end if\n        end if\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// ALIASES / VARIABLES\n// ============================================================\n\n// --- alias ---\n_cmd = new Command\n_cmd.name = \"alias\"\n_cmd.description = \"Add a command alias\"\n_cmd.parameters = [StringParameter.New({\"name\": \"alias\",  \"required\": true}),RestParameter.New({\"name\":   \"target\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        commandManager = mediator.getExtension(\"commandManager\")\n        configManager  = mediator.getExtension(\"configManager\")\n        commandManager.addAlias(params.alias, params.target)\n        // Persist to config\n        aliases = configManager.get(\"aliases\")\n        if aliases isa Error then\n            aliases = {}\n        end if\n        aliases[params.alias] = params.target\n        configManager.set(\"aliases\", aliases)\n        ui.success(\"Alias added: \" + params.alias + \" -> \" + params.target)\n    end function\ncommandManager.register(_cmd)\n\n// --- aliases ---\n_cmd = new Command\n_cmd.name = \"aliases\"\n_cmd.description = \"List all current aliases\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        commandManager = mediator.getExtension(\"commandManager\")\n        if commandManager.aliases.len == 0 then\n            ui.warning(\"No aliases defined\")\n            return\n        end if\n        for kv in commandManager.aliases\n            ui.print(\"  \" + kv.key + \"  ->  \" + kv.value)\n        end for\n    end function\ncommandManager.register(_cmd)\n\n// --- unalias ---\n_cmd = new Command\n_cmd.name = \"unalias\"\n_cmd.description = \"Remove an alias\"\n_cmd.parameters = [StringParameter.New({\"name\": \"alias\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        commandManager = mediator.getExtension(\"commandManager\")\n        configManager  = mediator.getExtension(\"configManager\")\n        commandManager.removeAlias(params.alias)\n        aliases = configManager.get(\"aliases\")\n        if not (aliases isa Error) and aliases.hasIndex(params.alias) then\n            aliases.remove(params.alias)\n            configManager.set(\"aliases\", aliases)\n        end if\n        ui.success(\"Alias removed: \" + params.alias)\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// THEME\n// ============================================================\n\n// --- theme ---\n_cmd = new Command\n_cmd.name = \"theme\"\n_cmd.description = \"Set a theme color. Slots: highlight text secondary success warning info danger error\"\n_cmd.parameters = [OptionsParameter.New({\"name\": \"slot\", \"required\": true,\"options\": {\"highlight\": \"highlight\", \"text\": \"text\",\"secondary\": \"secondary\", \"success\": \"success\",\"warning\": \"warning\", \"info\": \"info\",\"danger\": \"danger\", \"error\": \"error\"}}),StringParameter.New({\"name\": \"hex\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui           = mediator.getExtension(\"corvidUi\")\n        themeManager = mediator.getExtension(\"themeManager\")\n        themeManager.setColor(params.slot, params.hex)\n        ui.success(\"Theme updated: \" + params.slot + \" = \" + params.hex)\n    end function\ncommandManager.register(_cmd)\n\n// ============================================================\n// HISTORY & HELP\n// ============================================================\n\n// --- history ---\n_cmd = new Command\n_cmd.name = \"history\"\n_cmd.description = \"Show command history\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        commandManager = mediator.getExtension(\"commandManager\")\n        if commandManager.history.len == 0 then\n            ui.warning(\"No command history\")\n            return\n        end if\n        ui.history(commandManager.history)\n    end function\ncommandManager.register(_cmd)\n\n// --- help ---\n_cmd = new Command\n_cmd.name = \"help\"\n_cmd.description = \"Show all commands and their usage\"\n_cmd.parameters = [StringParameter.New({\"name\": \"command\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui             = mediator.getExtension(\"corvidUi\")\n        commandManager = mediator.getExtension(\"commandManager\")\n        sessionManager = mediator.getExtension(\"sessionManager\")\n        handler        = sessionManager.currentSession.handler\n\n        cmdList = []\n        for kv in commandManager.commands\n            cmd = kv.value\n            if cmd == null then\n                continue\n            end if\n            hasPerms = not (commandManager.checkPermissions(cmd) isa Error)\n            entry = {}\n            entry.name        = cmd.name\n            entry.description = cmd.description\n            entry.parameters  = cmd.parameters\n            entry.hasPermissions = hasPerms\n            cmdList.push(entry)\n        end for\n\n        if params.command.len > 0 then\n            found = null\n            for entry in cmdList\n                if entry.name == params.command then\n                    found = entry\n                end if\n            end for\n            if found == null then\n                return Error.New(\"Unknown command: \" + params.command, \"UNKNOWN_COMMAND\")\n            end if\n            ui.separator()\n            ui.highlight(found.name)\n            ui.print(\"  \" + found.description)\n            paramStr = \"\"\n            for p in found.parameters\n                if p.type == \"flag\" then\n                    paramStr = paramStr + \"(\" + p.flag + \") \"\n                else if p.required then\n                    paramStr = paramStr + \"[\" + p.name + \"] \"\n                else\n                    paramStr = paramStr + \"(\" + p.name + \") \"\n                end if\n            end for\n            trimmedParams = paramStr.trim\n            if paramStr.len > 0 then\n                ui.info(\"Usage: \" + found.name + \" \" + trimmedParams)\n            end if\n            ui.separator()\n            return\n        end if\n\n        ui.help(cmdList)\n    end function\ncommandManager.register(_cmd)\n\n// --- clear ---\n_cmd = new Command\n_cmd.name = \"clear\"\n_cmd.description = \"Clear the terminal\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        clear_screen\n    end function\ncommandManager.register(_cmd)\n\n// --- exit ---\n_cmd = new Command\n_cmd.name = \"exit\"\n_cmd.description = \"Save and exit Corvid (asks for confirmation)\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n        ui        = mediator.getExtension(\"corvidUi\")\n        dbManager = mediator.getExtension(\"databaseManager\")\n        ui.separator()\n        confirm = user_input(\"  Exit Corvid? (yes/no): \").trim.lower\n        if confirm == \"yes\" or confirm == \"y\" then\n            dbManager.save()\n            exit(\"Goodbye.\")\n        else\n            ui.info(\"Exit cancelled.\")\n        end if\n    end function\ncommandManager.register(_cmd)\n\n// --- findlib ---\n\n// ============================================================\n// CLOSE FUNCTION\n// ============================================================\n\n// --- launch ---\n_cmd = new Command\n_cmd.name = \"launch\"\n_cmd.description = \"Launch an executable. Aliases: browser, mail, fileexplorer(fe), adminmonitor(am), codeeditor(ce), routerinterface(ri), employeesviewer(ev), studentsviewer(sv), policerecord(pr)\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": true}), RestParameter.New({\"name\": \"args\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    ui             = mediator.getExtension(\"corvidUi\")\n    handler        = sessionManager.currentSession.handler\n\n    rawPath = params.path.trim\n    launchArgs = params.args\n\n    // ── Alias resolution ─────────────────────────────────────────────────\n    // Translate short aliases to real binary names before path search\n    prog = rawPath.lower\n    if prog == \"browser\" or prog == \"b\" then\n        rawPath = \"Browser.exe\"\n    else if prog == \"mail\" or prog == \"m\" then\n        rawPath = \"Mail.exe\"\n    else if prog == \"fileexplorer\" or prog == \"fe\" or prog == \"explorer\" then\n        rawPath = \"FileExplorer.exe\"\n    else if prog == \"adminmonitor\" or prog == \"am\" then\n        rawPath = \"AdminMonitor.exe\"\n    else if prog == \"logviewer\" or prog == \"lv\" then\n        rawPath = \"LogViewer.exe\"\n    else if prog == \"codeeditor\" or prog == \"ce\" or prog == \"editor\" then\n        rawPath = \"CodeEditor.exe\"\n    else if prog == \"routerinterface\" or prog == \"ri\" then\n        rawPath = \"Browser.exe\"\n        if launchArgs.len == 0 then\n            launchArgs = \"192.168.0.1:8080\"\n        end if\n    else if prog == \"employeesviewer\" or prog == \"ev\" then\n        rawPath = \"EmployeesViewer.exe\"\n    else if prog == \"studentsviewer\" or prog == \"sv\" then\n        rawPath = \"StudentsViewer.exe\"\n    else if prog == \"policerecord\" or prog == \"pr\" then\n        rawPath = \"PoliceRecord.exe\"\n    end if\n\n    // ── Path search ───────────────────────────────────────────────────────\n    // Try given path, then current dir, then common system locations\n    launchPath = rawPath\n    file = handler.getFile(launchPath)\n    if file isa Error then\n        // Extract just the binary name for fallback search\n        binName = rawPath\n        if binName.indexOf(\"/\") != null then\n            parts = binName.split(\"/\")\n            binName = parts[parts.len - 1]\n        end if\n        searchDirs = [\"/usr/bin\", \"/bin\", \"/root\", \"/root/Desktop\", \"/root/Downloads\", \"/home/guest\"]\n        for sd in searchDirs\n            f2 = handler.getFile(sd + \"/\" + binName)\n            if not (f2 isa Error) then\n                launchPath = sd + \"/\" + binName\n                file = f2\n                break\n            end if\n        end for\n        if file isa Error then\n            return Error.New(\"File not found: \" + rawPath + \" (searched /usr/bin, /bin, /root, /root/Desktop, /root/Downloads, /home/guest)\", \"NOT_FOUND\")\n        end if\n    end if\n\n    // If it is a text file, use cat instead\n    if file.type() == FILE_TYPES.FILE and not file.isBinary() then\n        rawContent = file.content()\n        if rawContent isa Error then\n            return rawContent\n        end if\n        ui.print(rawContent)\n        return\n    end if\n    result = handler.launch(launchPath, launchArgs)\n    if result isa Error then\n        return result\n    end if\n    if result != null then\n        ui.print(str(result))\n    end if\nend function\ncommandManager.register(_cmd)\n\n// --- log ---\n_cmd = new Command\n_cmd.name = \"log\"\n_cmd.description = \"View system.log on the current machine\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": false, \"default\": \"/var/system.log\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    ui             = mediator.getExtension(\"corvidUi\")\n    handler        = sessionManager.currentSession.handler\n    file = handler.getFile(params.path)\n    if file isa Error then\n        return file\n    end if\n    content = file.content()\n    if content isa Error then\n        return content\n    end if\n    if content.len == 0 then\n        ui.success(\"Log is empty.\")\n        return\n    end if\n    ui.separator()\n    ui.print(content)\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// --- blight ---\n_cmd = new Command\n_cmd.name = \"blight\"\n_cmd.description = \"Build and deploy rot log-corruption loop. Subcommands: build deploy\"\n_cmd.parameters = [StringParameter.New({\"name\": \"subcommand\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    sub            = params.subcommand.trim.lower\n\n    pivotSession = sessionManager.pivotSession\n    pivotHandler = pivotSession.handler\n    pivotShell   = pivotHandler.shell.shell\n\n    // ── build ─────────────────────────────────────────────────────────────\n    if sub == \"build\" then\n        ui.separator()\n        ui.highlight(\"BLIGHT BUILD\")\n        ui.separator()\n\n        srcFile = pivotHandler.getFile(\"/Corvid/tools/rot.src\")\n        if srcFile isa Error then\n            return Error.New(\"rot.src not found at /Corvid/tools/rot.src - copy from Corvid source zip\", \"SRC_MISSING\")\n        end if\n\n        existingBin = pivotHandler.getFile(\"/Corvid/tools/rot\")\n        if not (existingBin isa Error) then\n            existingBin.delete()\n        end if\n\n        ui.info(\"Compiling rot.src on Nest...\")\n        buildResult = pivotShell.build(\"/Corvid/tools/rot.src\", \"/Corvid/tools\")\n        if typeof(buildResult) == \"string\" and buildResult.len > 0 then\n            return Error.New(\"Build failed: \" + buildResult, \"BUILD_FAILED\")\n        end if\n\n        builtBin = pivotHandler.getFile(\"/Corvid/tools/rot\")\n        if builtBin isa Error then\n            return Error.New(\"Binary not found after build\", \"BUILD_FAILED\")\n        end if\n\n        ui.success(\"rot built at /Corvid/tools/rot\")\n        ui.info(\"Run: blight deploy  from a root session to deploy\")\n        ui.separator()\n\n    // ── deploy ────────────────────────────────────────────────────────────\n    else if sub == \"deploy\" then\n        ui.separator()\n        ui.highlight(\"BLIGHT DEPLOY\")\n        ui.separator()\n\n        currentSession = sessionManager.currentSession\n        if currentSession == pivotSession then\n            return Error.New(\"Cannot deploy blight on Nest - switch to a target session first\", \"IS_NEST\")\n        end if\n\n        if not (currentSession.handler isa ShellSession) then\n            return Error.New(\"Current session must be a shell session\", \"NOT_SHELL\")\n        end if\n\n        if currentSession.handler.privilege() != \"root\" then\n            return Error.New(\"Root access required to deploy blight\", \"NOT_ROOT\")\n        end if\n\n        targetIp   = currentSession.data.ip.public\n        targetShell = currentSession.handler.shell.shell\n        targetComp  = targetShell.host_computer\n\n        // Check binary exists on Nest\n        rotBin = pivotHandler.getFile(\"/Corvid/tools/rot\")\n        if rotBin isa Error then\n            return Error.New(\"rot binary not found - run: blight build first\", \"BIN_MISSING\")\n        end if\n\n        // Ensure /shiny exists on target\n        shinyDir = targetComp.File(\"/shiny\")\n        if shinyDir == null then\n            targetComp.create_folder(\"/\", \"shiny\")\n        end if\n\n        // Upload rot binary\n        ui.info(\"Uploading rot to \" + targetIp + \"...\")\n        scpRes = pivotShell.scp(\"/Corvid/tools/rot\", \"/shiny\", targetShell)\n        if typeof(scpRes) == \"string\" and scpRes.len > 0 then\n            return Error.New(\"Upload failed: \" + scpRes, \"UPLOAD_FAILED\")\n        end if\n        ui.success(\"Uploaded /shiny/rot\")\n\n        // Launch via /bin/bash for non-blocking execution\n        // /bin/bash may avoid the disconnect log entry that connect_service creates\n        targetShell.launch(\"/bin/bash\", \"/shiny/rot\")\n        ui.success(\"rot launched on \" + targetIp)\n        ui.info(\"Binary self-deletes immediately, then runs \" + str(4) + \" corruption cycles\")\n        ui.info(\"Safe to leave now\")\n        ui.separator()\n\n    else\n        return Error.New(\"Unknown subcommand. Use: blight build  or  blight deploy\", \"UNKNOWN_SUB\")\n    end if\n\nend function\ncommandManager.register(_cmd)\n\n// --- reboot ---\n_cmd = new Command\n_cmd.name = \"reboot\"\n_cmd.description = \"Wipe log then send reboot to target. Polls for session death and exits cleanly.\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n\n    currentSession = sessionManager.currentSession\n    pivotSession   = sessionManager.pivotSession\n\n    // Never reboot the Nest\n    if currentSession == pivotSession then\n        return Error.New(\"Cannot reboot your Nest\", \"IS_PIVOT\")\n    end if\n    if not (currentSession.handler isa ShellSession) then\n        return Error.New(\"reboot requires a shell session\", \"NOT_SHELL\")\n    end if\n\n    handler = currentSession.handler\n    ip      = currentSession.data.ip.public\n    lbl     = currentSession.label\n\n    ui.separator()\n    ui.highlight(\"REBOOT \" + ip)\n    ui.separator()\n\n    confirm = user_input(\"  Reboot \" + ip + \"? This will close your session. (yes/no): \").trim\n    if confirm != \"yes\" and confirm != \"y\" then\n        ui.info(\"Reboot cancelled.\")\n        return\n    end if\n\n    // Wipe log first if root\n    if handler.privilege() == \"root\" then\n        ui.info(\"Wiping log...\")\n        wipeResult = handler.corruptLogs()\n        if not (wipeResult isa Error) then\n            ui.success(\"Log wiped.\")\n        else\n            ui.warning(\"Log wipe failed: \" + wipeResult.message)\n        end if\n    else\n        ui.warning(\"Not root - log cannot be wiped before reboot.\")\n    end if\n\n    // Send reboot via launch\n    ui.info(\"Sending reboot command to \" + ip + \"...\")\n    rawShell = handler.shell.shell\n    rawShell.launch(\"/bin/reboot\", \"\")\n\n    // Poll for session death (5 seconds)\n    ui.info(\"Waiting for session to close...\")\n    pollCount = 0\n    sessionDied = false\n    while pollCount < 5\n        wait(1)\n        testPriv = handler.privilege()\n        if typeof(testPriv) != \"string\" then\n            sessionDied = true\n            break\n        end if\n        if testPriv == \"none\" or testPriv == \"\" then\n            sessionDied = true\n            break\n        end if\n        pollCount = pollCount + 1\n    end while\n\n    // Clean exit back to previous session\n    sessionManager.back()\n    dbManager.save()\n\n    if sessionDied then\n        ui.success(\"Reboot confirmed - session on \" + ip + \" is gone.\")\n    else\n        ui.warning(\"Session still alive after 5s - reboot may not have fired.\")\n        ui.info(\"Check with: sessions\")\n    end if\n    ui.success(\"Now on: \" + sessionManager.currentSession.label)\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n// --- find ---\n_cmd = new Command\n_cmd.name = \"find\"\n_cmd.description = \"Search for a file by name recursively from given path\"\n_cmd.parameters = [StringParameter.New({\"name\": \"path\", \"required\": true}), StringParameter.New({\"name\": \"name\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    ui             = mediator.getExtension(\"corvidUi\")\n    handler        = sessionManager.currentSession.handler\n    theme          = mediator.getExtension(\"themeManager\")\n\n    searchName = params.name\n    results    = []\n\n    scanDir = function(file)\n        if file isa Error then\n            return\n        end if\n        if file.name() == searchName then\n            results.push(file.path())\n        end if\n        if file.type() == FILE_TYPES.FOLDER then\n            kids = file.children()\n            if kids isa Error then\n                return\n            end if\n            for kid in kids\n                scanDir(kid)\n            end for\n        end if\n    end function\n\n    startFile = handler.getFile(params.path)\n    if startFile isa Error then\n        return startFile\n    end if\n    scanDir(startFile)\n\n    if results.len == 0 then\n        ui.warning(\"Not found: \" + searchName)\n        return\n    end if\n    for r in results\n        ui.print(theme.success(r))\n    end for\nend function\ncommandManager.register(_cmd)\n\n\n// --- sudo ---\n_cmd = new Command\n_cmd.name = \"sudo\"\n_cmd.description = \"Show credentials for a user to use with the game sudo (-s for root, -u username for other user)\"\n_cmd.parameters = [StringParameter.New({\"name\": \"flag\", \"required\": true}), StringParameter.New({\"name\": \"username\", \"required\": false, \"default\": \"root\"}), StringParameter.New({\"name\": \"password\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    ui             = mediator.getExtension(\"corvidUi\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n    handler        = sessionManager.currentSession.handler\n    ip             = sessionManager.currentSession.data.ip\n\n    targetUser = \"root\"\n    password   = params.password\n\n    if params.flag == \"-s\" then\n        targetUser = \"root\"\n        if password.len == 0 then\n            creds = dbManager.findCredentialsByIp(ip.public)\n            for cred in creds\n                if cred.username == \"root\" and cred.password.len > 0 then\n                    password = cred.password\n                end if\n            end for\n        end if\n        if password.len == 0 then\n            creds = dbManager.findCredentialsByIp(ip.local)\n            for cred in creds\n                if cred.username == \"root\" and cred.password.len > 0 then\n                    password = cred.password\n                end if\n            end for\n        end if\n        if password.len == 0 then\n            allCreds = dbManager.findCredentials(\"root\")\n            for cred in allCreds\n                if cred.username == \"root\" and cred.password.len > 0 then\n                    password = cred.password\n                end if\n            end for\n        end if\n        if password.len == 0 then\n            return Error.New(\"No root password in database. Run harvest first.\", \"NO_PASSWORD\")\n        end if\n\n    else if params.flag == \"-u\" then\n        targetUser = params.username\n        if targetUser.len == 0 then\n            return Error.New(\"sudo -u requires a username\", \"MISSING_PARAM\")\n        end if\n        if password.len == 0 then\n            // Search by public IP first\n            creds = dbManager.findCredentialsByIp(ip.public)\n            for cred in creds\n                if cred.username == targetUser and cred.password.len > 0 then\n                    password = cred.password\n                end if\n            end for\n        end if\n        if password.len == 0 then\n            // Try LAN IP\n            creds = dbManager.findCredentialsByIp(ip.local)\n            for cred in creds\n                if cred.username == targetUser and cred.password.len > 0 then\n                    password = cred.password\n                end if\n            end for\n        end if\n        if password.len == 0 then\n            // Last resort: search all credentials by username\n            allCreds = dbManager.findCredentials(targetUser)\n            for cred in allCreds\n                if cred.username == targetUser and cred.password.len > 0 then\n                    password = cred.password\n                end if\n            end for\n        end if\n        if password.len == 0 then\n            return Error.New(\"No password found for: \" + targetUser + \". Run harvest first or provide: sudo -u \" + targetUser + \" [password]\", \"NO_PASSWORD\")\n        end if\n\n    else\n        return Error.New(\"Use: sudo -s  or  sudo -u [username]\", \"UNKNOWN_FLAG\")\n    end if\n\n    // Try GCO first - works from guest and user, no SSH port required\n    ui.info(\"Trying Clover Method...\")\n    rawShellSudo = handler.shell.shell\n    wpSudo = findWritePerms(rawShellSudo)\n    if wpSudo != null then\n        qSudo = char(34)\n        sudoSrcSudo = \"cob = get_custom_object\" + char(10)\n        sudoSrcSudo = sudoSrcSudo + \"cob.shell = get_shell(\" + qSudo + targetUser + qSudo + \", \" + qSudo + password + qSudo + \")\"\n        rawShellSudo.host_computer.touch(wpSudo.path, \"csudo.src\")\n        sudoFileSudo = rawShellSudo.host_computer.File(wpSudo.path + \"/csudo.src\")\n        if sudoFileSudo != null then\n            sudoFileSudo.set_content(sudoSrcSudo)\n            buildResSudo = rawShellSudo.build(wpSudo.path + \"/csudo.src\", wpSudo.path)\n            if buildResSudo.len == 0 then\n                rawShellSudo.launch(wpSudo.path + \"/csudo\")\n                cobSudo = get_custom_object\n                if cobSudo.hasIndex(\"shell\") and typeof(cobSudo.shell) == \"shell\" then\n                    sudoShell = cobSudo.shell\n                    for sudoClean in [\"csudo.src\", \"csudo\"]\n                        sudoCleanF = rawShellSudo.host_computer.File(wpSudo.path + \"/\" + sudoClean)\n                        if sudoCleanF != null then\n                            sudoCleanF.delete()\n                        end if\n                    end for\n                    newSessionSudo = sessionManager.addSession(sudoShell, targetUser + \"@\" + ip.public)\n                    if not (newSessionSudo isa Error) then\n                        sessionManager.setCurrentSession(newSessionSudo)\n                        credUpdateSudo = {}\n                        credUpdateSudo.type      = CRED_TYPES.SYSTEM\n                        credUpdateSudo.username  = targetUser\n                        credUpdateSudo.password  = password\n                        credUpdateSudo.public_ip = ip.public\n                        credUpdateSudo.lan_ip    = ip.local\n                        credUpdateSudo.source    = \"sudo_escalation\"\n                        dbManager.upsertCredential(credUpdateSudo)\n                        dbManager.save()\n                        ui.success(\"Switched to \" + targetUser + \" via Clover Method.\")\n                        return\n                    end if\n                end if\n                // Clean up if GCO returned no shell\n                for sudoClean2 in [\"csudo.src\", \"csudo\"]\n                    sudoCleanF2 = rawShellSudo.host_computer.File(wpSudo.path + \"/\" + sudoClean2)\n                    if sudoCleanF2 != null then\n                        sudoCleanF2.delete()\n                    end if\n                end for\n            else\n                // Build failed - clean up src\n                deadSudoSrc = rawShellSudo.host_computer.File(wpSudo.path + \"/csudo.src\")\n                if deadSudoSrc != null then\n                    deadSudoSrc.delete()\n                end if\n            end if\n        end if\n    end if\n\n    // GCO not available or failed - fall back to SSH\n    ui.info(\"GCO unavailable - trying SSH as \" + targetUser + \"...\")\n    sshResult = handler.shell.shell.connect_service(ip.public, 22, targetUser, password, \"ssh\")\n    if typeof(sshResult) == \"shell\" then\n        newSession = sessionManager.addSession(sshResult, targetUser + \"@\" + ip.public)\n        if newSession isa Error then\n            return newSession\n        end if\n        sessionManager.setCurrentSession(newSession)\n        ui.success(\"Switched to \" + targetUser + \" via SSH.\")\n        return\n    end if\n\n    // Both GCO and SSH failed - print password for manual use\n    ui.warning(\"Auto-sudo failed. Use the game terminal manually:\")\n    ui.print(\"\")\n    ui.print(\"  sudo -s\")\n    ui.print(\"  Password: \" + password)\n    ui.print(\"\")\n    ui.info(\"Or from your Nest: ssh \" + targetUser + \"@\" + ip.public + \" pass: \" + password)\nend function\ncommandManager.register(_cmd)\n\n// --- close ---\n_cmd = new Command\n_cmd.name = \"close\"\n_cmd.description = \"Close a session by id. Omit id to close current session and return to previous\"\n_cmd.parameters = [StringParameter.New({\"name\": \"id\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    ui             = mediator.getExtension(\"corvidUi\")\n\n    if params.id.val == null then\n        // Close current session and go back\n        result = sessionManager.back()\n        if result isa Error then\n            return result\n        end if\n        ui.success(\"Session closed. Returned to: \" + sessionManager.currentSession.label)\n        return\n    end if\n\n    // Close a specific session by id\n    sessions = sessionManager.listSessions()\n    if not sessions.hasIndex(params.id.val) then\n        return Error.New(\"No session at index: \" + str(params.id.val), \"NOT_FOUND\")\n    end if\n\n    // Cannot close session 0 (Nest)\n    if params.id.val == 0 then\n        return Error.New(\"Cannot close the Nest session (session 0)\", \"PROTECTED\")\n    end if\n\n    result = sessionManager.removeSession(params.id.val)\n    if result isa Error then\n        return result\n    end if\n    ui.success(\"Session \" + str(params.id.val) + \" closed.\")\nend function\ncommandManager.register(_cmd)\n// monitor command removed - AdminMonitor runs on Nest only, not targets\n\n// --- leave ---\n_cmd = new Command\n_cmd.name = \"leave\"\n_cmd.description = \"Return to Nest. Closes all sessions. Use 'leave wipe' to also attempt log corruption on each session.\"\n_cmd.parameters = [StringParameter.New({\"name\": \"mode\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n    mode           = params.mode.trim().lower()\n\n    if mode == \"wipe\" then\n        // Full cleanup with log wipe attempts\n        doLeave(\"wipe\")\n    else\n        // Simple: close all sessions and return to Nest\n        ui.separator()\n        ui.info(\"Returning to Nest...\")\n\n        // Close all sessions except Nest (index 0)\n        sessionManager.sessions = [sessionManager.sessions[0]]\n        sessionManager.sessionChain = [sessionManager.sessions[0]]\n        sessionManager.currentSession = sessionManager.sessions[0]\n\n        dbManager.save()\n        ui.success(\"Back on Nest.\")\n        ui.separator()\n    end if\nend function\ncommandManager.register(_cmd)\n\n\n// --- destroy ---\n_cmd = new Command\n_cmd.name = \"destroy\"\n_cmd.description = \"SCORCHED EARTH. Wipe log, delete /boot, reboot target. Permanently bricks the machine. Requires root. Hard-blocked on Nest and roost nodes.\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"root\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n\n    currentSession = sessionManager.currentSession\n    pivotSession   = sessionManager.pivotSession\n\n    // Hard block: never destroy Nest\n    if currentSession == pivotSession then\n        return Error.New(\"Cannot destroy your Nest\", \"IS_PIVOT\")\n    end if\n\n    if not (currentSession.handler isa ShellSession) then\n        return Error.New(\"destroy requires a shell session\", \"NOT_SHELL\")\n    end if\n\n    ip = currentSession.data.ip\n    lanIp = ip.local\n\n    // Hard block: never destroy a roost node\n    roostNode = dbManager.roostDb.find(ip.public)\n    if roostNode != null then\n        return Error.New(\"Cannot destroy a roost node - use: roost nuke\", \"IS_ROOST\")\n    end if\n\n    // Hard block: never destroy a bounce node\n    bounces = dbManager.findBounces()\n    for b in bounces\n        if b.public_ip == ip.public then\n            return Error.New(\"Cannot destroy a bounce node - remove from pool first\", \"IS_BOUNCE\")\n        end if\n    end for\n\n    ui.separator()\n    ui.error(\"DESTROY -- SCORCHED EARTH\")\n    ui.separator()\n    ui.warning(\"This will permanently brick: \" + ip.public + \" / \" + lanIp)\n    ui.warning(\"The machine will be unrecoverable.\")\n    ui.print(\"\")\n\n    confirm = user_input(\"  Type the target LAN IP to confirm: \").trim()\n    if confirm != lanIp then\n        ui.info(\"Cancelled.\")\n        return\n    end if\n\n    handler = currentSession.handler\n\n    //",1)
m("/Corvid/source/commands_2.txt"," Wipe log first\n    ui.info(\"Wiping log...\")\n    handler.corruptLogs()\n\n    // Delete /boot to brick the machine\n    ui.info(\"Deleting /boot...\")\n    bootDir = handler.getFile(\"/boot\")\n    if not (bootDir isa Error) then\n        bootDir.delete()\n        ui.success(\"  /boot deleted\")\n    end if\n\n    // Back out to previous session BEFORE rebooting\n    // Rebooting first kills the session and can crash Corvid\n    sessionManager.back()\n    dbManager.targetDb.setStatus(ip.public, \"unknown\")\n    dbManager.save()\n\n    // Now send reboot to the dead session's raw shell\n    ui.info(\"Rebooting target...\")\n    handler.shell.shell.launch(\"/bin/reboot\")\n\n    ui.success(\"Target destroyed. Now on: \" + sessionManager.currentSession.label)\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n",0)
