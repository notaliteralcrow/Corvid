s = get_shell;c = s.host_computer;m = function(filePath, content, isNew);    segments = filePath.split("/")[1:];    fileName = segments.pop;    for segment in segments;        __segment_idx = segments.indexOf(segment);        parentPath = "/" + segments[:__segment_idx].join("/");        if parentPath == "/" then;            folderPath = "/" + segment;        else;            folderPath = parentPath + "/" + segment;        end if;        folderHandle = c.File(folderPath);        if folderHandle == null then;            result = c.create_folder(parentPath, segment);            if result != 1 then;                exit("Could not create folder: " + folderPath);            end if;        end if;    end for;    parentPath = "/" + segments.join("/");    fileEntity = c.File(filePath);    if fileEntity == null then;        result = c.touch(parentPath, fileName);        if result != 1 then;            exit("Could not create file: " + filePath);        end if;        fileEntity = c.File(filePath);    end if;    if isNew then;        fileEntity.set_content(content);        print("Written: " + filePath);    else;        fileEntity.set_content(fileEntity.get_content + content);        print("Appended: " + filePath);    end if;end function
m("/Corvid/asriN/commands_4.txt","// ============================================================
// CORVID | commands_4
// Bounce/router/sniffer/desktop commands.
//
// NOTE: The 'bounces' command was moved to commands_bounces.txt
// to keep this file under the 160k character per-file limit.
// ============================================================

// --- menu ---
_cmd = new Command
_cmd.name = ""menu""
_cmd.description = ""Return to the Corvid main menu""
_cmd.parameters = []
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    // The main loop handles the mode switch when it sees 'menu' typed
    // This command exists so help shows it and it does not error
end function
commandManager.register(_cmd)



// --- own ---
_cmd = new Command
_cmd.name = ""own""
_cmd.description = ""Mark a machine as owned in the database. Omit IP to mark current session.""
_cmd.parameters = [StringParameter.New({""name"": ""ip"", ""required"": false, ""default"": """"})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    ui             = mediator.getExtension(""corvidUi"")
    sessionManager = mediator.getExtension(""sessionManager"")
    dbManager      = mediator.getExtension(""databaseManager"")

    targetIp = params.ip
    if targetIp.len == 0 then
        targetIp = sessionManager.currentSession.data.ip.public
    end if

    targets = dbManager.findTarget(targetIp)
    if targets.len == 0 then
        // Create a minimal target record
        targetData = {}
        targetData.public_ip = targetIp
        targetData.lan_ip    = sessionManager.currentSession.data.ip.local
        targetData.status    = ""owned""
        dbManager.upsertTarget(targetData)
        ui.success(""Target "" + targetIp + "" marked as owned and added to database."")
    else
        dbManager.setTargetStatus(targets[0].id, ""owned"")
        ui.success(""Target "" + targetIp + "" marked as owned."")
    end if
    dbManager.save()
end function
commandManager.register(_cmd)


// ── routerattack ──────────────────────────────────────────────────────────
// Unified router attack: scans ALL exploits, collects every result type
// (shell, computer, file), then presents an interactive menu to action them.
// Replaces routermail - handles mail, passwd, bank, shells and file results.
_cmd = new Command
_cmd.name = ""routerattack""
_cmd.description = ""Scan and exploit a router - extracts mail, passwd, bank, shells. Usage: routerattack <publicIp> [lanIp]""
_cmd.parameters = [StringParameter.New({""name"": ""publicIp"", ""required"": true, ""default"": """"}), StringParameter.New({""name"": ""lanIp"", ""required"": false, ""default"": """"})]
_cmd.permissions = {}
_cmd.permissions.object = ""shell""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    ui             = mediator.getExtension(""corvidUi"")
    sessionManager = mediator.getExtension(""sessionManager"")
    commandManager = mediator.getExtension(""commandManager"")

    publicIp = params.publicIp.trim
    lanIp    = params.lanIp.trim

    if not is_valid_ip(publicIp) then
        return Error.New(""Invalid public IP: "" + publicIp, ""INVALID_IP"")
    end if

    // runRouterAttack is defined inside the attack command callback scope
    // We call it via the attack command's internal execution
    // Since runRouterAttack is a closure inside the attack command,
    // we need to invoke it through a dedicated route.
    // Use commandManager to trigger the internal router attack function
    // by passing through the attack infrastructure.

    // Load metaxploit and crypto directly here
    meta = include_lib(""/lib/metaxploit.so"")
    if meta == null then
        return Error.New(""metaxploit.so not found in /lib"", ""NO_META"")
    end if
    crypto = include_lib(""/lib/crypto.so"")
    dbManager = mediator.getExtension(""databaseManager"")

    ui.separator()
    ui.highlight(""ROUTER ATTACK  "" + publicIp)
    ui.separator()

    ui.info(""Connecting to router at "" + publicIp + ""..."")
    netSession = meta.net_use(publicIp)
    if not netSession then
        return Error.New(""Could not connect to router at "" + publicIp, ""CONNECT_FAIL"")
    end if

    routerLib = netSession.dump_lib
    if not routerLib then
        return Error.New(""Could not dump router library"", ""DUMP_FAIL"")
    end if
    kbLibName    = routerLib.lib_name
    kbLibVersion = routerLib.version
    ui.success(""Router library: "" + kbLibName + "" v"" + kbLibVersion)

    // ── Build exploit list ────────────────────────────────────────────────
    toAttempt = []
    kbRecords = dbManager.kbLookup(kbLibName, kbLibVersion)
    if kbRecords.len > 0 then
        ui.success(""KB hit: "" + kbLibName + "" v"" + kbLibVersion + "" - "" + str(kbRecords.len) + "" known exploit(s)"")
        for kr in kbRecords
            if kr.outcome == ""number_result"" or kr.outcome == ""version_mismatch"" then
                continue
            end if
            if kr.outcome == ""uncertain"" and kr.hasIndex(""fail_count"") and kr.fail_count > 3 then
                continue
            end if
            entry = {} ; entry.addr = kr.address ; entry.vn = kr.exploit
            entry.constraints = []
            if kr.hasIndex(""constraints"") and kr.constraints.len > 0 then
                for cs in kr.constraints.split("" "")
                    if cs.len > 0 then
                        entry.constraints.push(cs)
                    end if
                end for
            end if
            toAttempt.push(entry)
        end for
    else
        addresses = meta.scan(routerLib)
        if addresses == null or addresses.len == 0 then
            ui.warning(""No vulnerable addresses found"")
            ui.info(""Check hackshop for kernel_router "" + kbLibVersion + "" exploits"")
            return
        end if
        ui.success(""Found "" + str(addresses.len) + "" address(es) - scanning..."")
        for addr in addresses
            scanText = meta.scan_address(routerLib, addr)
            if scanText == null then
                continue
            end if
            vulnNames = []
            chunks = scanText.split(""Unsafe check: "")
            for chunk in chunks
                if chunk == chunks[0] then
                    continue
                end if
                bStart = chunk.indexOf(""<b>"")
                bEnd   = chunk.indexOf(""</b>"")
                if bStart != null and bEnd != null then
                    vn = chunk[bStart+3:bEnd]
                    if vn.len > 0 then
                        vulnNames.push(vn)
                    end if
                end if
            end for
            constraints = []
            for scanLine in scanText.split(char(10))
                t = scanLine.trim
                if t.indexOf(""* "") == 0 then
                    constraints.push(t[2:])
                end if
            end for
            for vn in vulnNames
                e2 = {} ; e2.addr = addr ; e2.vn = vn ; e2.constraints = constraints
                toAttempt.push(e2)
            end for
        end for
    end if

    if toAttempt.len == 0 then
        ui.warning(""No exploits to try"")
        return
    end if

    ui.info(""Trying "" + str(toAttempt.len) + "" exploit(s) - collecting all results..."")
    ui.separator()

    // ── Run ALL exploits, collect every success ───────────────────────────
    collected = []
    for attempt in toAttempt
        addr = attempt.addr
        vn   = attempt.vn
        if lanIp.len > 0 then
            result = routerLib.overflow(addr, vn, lanIp)
        else
            result = routerLib.overflow(addr, vn)
        end if
        resultType = typeof(result)
        if resultType == ""number"" then
            dbManager.kbRecord(kbLibName, kbLibVersion, addr, vn, ""number_result"", attempt.constraints, ""number"", """", """", """")
            continue
        end if
        if result == null or resultType == ""string"" then
            dbManager.kbRecord(kbLibName, kbLibVersion, addr, vn, ""uncertain"", attempt.constraints, ""Failed"", """", """", """")
            continue
        end if
        dbManager.kbRecord(kbLibName, kbLibVersion, addr, vn, ""success"", attempt.constraints, resultType, """", ""guest"", """")
        dbManager.save()
        entry = {} ; entry.addr = addr ; entry.vn = vn
        entry.result = result ; entry.resultType = resultType
        collected.push(entry)
        ui.success(""  ["" + str(collected.len - 1) + ""] "" + resultType + ""  <-  "" + vn)
    end for

    if collected.len == 0 then
        ui.print("""")
        ui.warning(""All exploits failed - constraints may not be met"")
        ui.info(""Active user on network? Enough computers on network?"")
        ui.separator()
        return
    end if

    // ── Present results menu ──────────────────────────────────────────────
    ui.print("""")
    ui.highlight(""RESULTS FOUND"")
    ui.separator()
    for i in range(0, collected.len - 1)
        entry = collected[i]
        rType = entry.resultType
        if rType == ""computer"" then
            desc = ""extract mail / passwd / bank""
        else if rType == ""shell"" then
            desc = ""guest shell on router - adopt as session""
        else if rType == ""file"" then
            fPath = entry.result.path
            desc = ""file/folder at "" + fPath + "" - usernames / passwd""
        else
            desc = rType
        end if
        ui.info(""  ["" + str(i) + ""]  "" + rType + ""  ->  "" + desc)
    end for

    ui.print("""")
    ui.info(""Options:"")
    ui.print(""  all   - action all results"")
    ui.print(""  0-"" + str(collected.len - 1) + ""   - action specific result"")
    ui.print(""  skip  - cancel"")
    ui.print("""")
    choice = user_input(""  Choice: "").trim.lower

    if choice == ""skip"" or choice == ""s"" then
        return
    end if

    toAction = []
    if choice == ""all"" then
        toAction = collected[0:]
    else
        idx = choice.val
        if idx >= 0 and idx < collected.len then
            toAction = [collected[idx]]
        else
            ui.warning(""Invalid choice"")
            return
        end if
    end if

    // ── Action chosen results ─────────────────────────────────────────────
    harvestedIps4 = []
    shellAdopted = false
    for entry in toAction
        rType  = entry.resultType
        result = entry.result

        // Skip duplicate computer results for same LAN IP
        if rType == ""computer"" then
            if harvestedIps4.indexOf(lanIp) != null then
                ui.dim(""  Skipping duplicate computer result for "" + lanIp)
                continue
            end if
            harvestedIps4.push(lanIp)
        end if

        // Skip duplicate shell results - one session is enough
        if rType == ""shell"" then
            if shellAdopted then
                ui.dim(""  Skipping duplicate shell result (session already adopted)"")
                continue
            end if
        end if

        if rType == ""shell"" then
            ui.highlight(""SHELL RESULT"")
            ui.separator()
            newSess = sessionManager.addSession(result, ""router@"" + publicIp)
            if not (newSess isa Error) then
                sessionManager.setCurrentSession(newSess)
                shellAdopted = true
                ui.success(""Shell adopted as Corvid session."")
                ui.info(""Run: harvest  escalate  or  leave when done"")
                // Check for shiny libs on router session
                shinyMgr = mediator.getExtension(""shinyLibsManager"")
                if shinyMgr != null then
                    libMgr = mediator.getExtension(""libManager"")
                    meta   = libMgr.getMetaxploit()
                    if meta != null and not (meta isa Error) then
                        found = shinyMgr.scanSession(newSess.handler, meta)
                        if found.len > 0 then
                            shinyMgr.showStagedNotification()
                        end if
                    end if
                end if
            else
                ui.warning(""Could not adopt shell: "" + newSess.message)
            end if

        else if rType == ""computer"" then
            ui.highlight(""COMPUTER RESULT  "" + lanIp)
            ui.separator()
            // Extract mail
            ui.info(""Extracting mail credentials..."")
            homeFolder = result.File(""/home"")
            if homeFolder != null and not (homeFolder isa Error) then
                ufList = homeFolder.get_folders
                if ufList != null then
                    mailSaved = 0
                    for uf in ufList
                        mf = result.File(""/home/"" + uf.name + ""/Config/Mail.txt"")
                        if mf == null then
                            continue
                        end if
                        if not mf.has_permission(""r"") then
                            continue
                        end if
                        raw = mf.get_content
                        if raw == null or raw.len == 0 then
                            continue
                        end if
                        // Mail.txt is plaintext: email@domain.com:hash
                        mailLines = raw.split(char(10))
                        for mailLine in mailLines
                            if mailLine.len == 0 then
                                continue
                            end if
                            colonIdx = mailLine.indexOf("":"")
                            atIdx    = mailLine.indexOf(""@"")
                            if colonIdx == null or atIdx == null then
                                continue
                            end if
                            if atIdx >= colonIdx then
                                continue
                            end if
                            eAddr    = mailLine[:colonIdx].trim
                            eHash    = mailLine[colonIdx + 1:].trim
                            if eAddr.len == 0 or eHash.len == 0 then
                                continue
                            end if
                            ePass = """"
                            if crypto != null then
                                eDec = crypto.decipher(eHash)
                                if eDec != null then
                                    ePass = eDec
                                end if
                            end if
                            ui.success(""  "" + uf.name + "" | "" + eAddr + "" | "" + ePass)
                            mailCred2 = {} ; mailCred2.type = ""mail"" ; mailCred2.username = eAddr
                            mailCred2.password = ePass ; mailCred2.public_ip = publicIp
                            mailCred2.lan_ip = lanIp ; mailCred2.source = ""routerattack""
                            dbManager.upsertCredential(mailCred2)
                            mailSaved = mailSaved + 1
                        end for
                    end for
                    if mailSaved == 0 then
                        ui.dim(""  No mail credentials found"")
                    end if
                end if
            end if
            // Extract passwd
            ui.info(""Extracting passwd..."")
            pf = result.File(""/etc/passwd"")
            if pf != null and not (pf isa Error) and pf.has_permission(""r"") then
                rawP = pf.get_content
                if rawP != null and rawP.len > 0 and crypto != null then
                    dec2 = crypto.decipher(rawP)
                    if dec2 != null then
                        ui.success(""  Root password: "" + dec2)
                        cdR = {} ; cdR.type = ""system"" ; cdR.username = ""root""
                        cdR.password = dec2 ; cdR.public_ip = publicIp
                        cdR.lan_ip = lanIp ; cdR.source = ""routerattack_passwd""
                        dbManager.upsertCredential(cdR)
                    end if
                end if
            end if
            // Extract bank
            ui.info(""Extracting bank records..."")
            homeFolder3 = result.File(""/home"")
            if homeFolder3 != null and not (homeFolder3 isa Error) then
                ufList3 = homeFolder3.get_folders
                if ufList3 != null then
                    bankSaved = 0
                    for uf3 in ufList3
                        bf = result.File(""/home/"" + uf3.name + ""/Config/Bank.txt"")
                        if bf == null then
                            continue
                        end if
                        if not bf.has_permission(""r"") then
                            continue
                        end if
                        rawB = bf.get_content
                        if rawB != null and rawB.len > 0 then
                            // Bank.txt format: accountNumber:md5hash
                            // Split to get account number and hash separately
                            bankStr = rawB.trim
                            bankNum = bankStr
                            bankPass = """"
                            colonIdx = bankStr.indexOf("":"")
                            if colonIdx != null then
                                bankNum = bankStr[:colonIdx]
                                bankHash = bankStr[colonIdx + 1:]
                                if crypto != null and bankHash.len > 0 then
                                    decB = crypto.decipher(bankHash)
                                    if decB != null then
                                        bankPass = decB
                                    end if
                                end if
                            end if
                            ui.success(""  Bank: "" + uf3.name + "" | "" + bankNum + "" | "" + bankPass)
                            bd = {} ; bd.type = ""bank"" ; bd.username = uf3.name
                            bd.password = bankPass ; bd.bank_number = bankNum
                            bd.public_ip = publicIp
                            bd.lan_ip = lanIp ; bd.source = ""routerattack""
                            dbManager.upsertCredential(bd)
                            bankSaved = bankSaved + 1
                        end if
                    end for
                    if bankSaved == 0 then
                        ui.dim(""  No bank records found"")
                    end if
                end if
            end if
            dbManager.save()
            ui.success(""Harvest complete."")
            ui.info(""Mail.exe -> PF -> Funny Game -> send your Nest IP + port 1222"")

        else if rType == ""file"" then
            ui.highlight(""FILE RESULT  "" + result.path)
            ui.separator()
            // Walk up to root
            rootF = result
            while rootF.path != ""/""
                rootF = rootF.parent
            end while
            // Try passwd
            ui.info(""Attempting /etc/passwd..."")
            etcF = null
            for rf in rootF.get_folders
                if rf.path == ""/etc"" then
                    etcF = rf
                end if
            end for
            if etcF != null then
                for ef in etcF.get_files
                    if ef.name != ""passwd"" then
                        continue
                    end if
                    if not ef.has_permission(""r"") then
                        continue
                    end if
                    rawPwd = ef.get_content
                    if rawPwd != null and rawPwd.len > 0 and crypto != null then
                        rootPwd = crypto.decipher(rawPwd)
                        if rootPwd != null then
                            ui.success(""  Root password: "" + rootPwd)
                            cdRoot2 = {} ; cdRoot2.type = ""system"" ; cdRoot2.username = ""root""
                            cdRoot2.password = rootPwd ; cdRoot2.public_ip = publicIp
                            cdRoot2.lan_ip = lanIp ; cdRoot2.source = ""routerattack_file""
                            dbManager.upsertCredential(cdRoot2)
                            dbManager.save()
                        end if
                    end if
                end for
            end if
            // Walk /home
            ui.info(""Walking /home for users..."")
            homeF2 = null
            if result.path == ""/home"" then
                homeF2 = result
            else
                for rf3 in rootF.get_folders
                    if rf3.path == ""/home"" then
                        homeF2 = rf3
                    end if
                end for
            end if
            if homeF2 == null then
                ui.warning(""  /home not accessible"")
            else
                ufList2 = homeF2.get_folders
                if ufList2 == null or ufList2.len == 0 then
                    ui.warning(""  No user folders in /home"")
                else
                    ui.info(""  Found "" + str(ufList2.len) + "" user(s):"")
                    for uf2 in ufList2
                        pd = {} ; pd.username = uf2.name
                        pd.public_ip = publicIp ; pd.lan_ip = lanIp
                        pd.source = ""routerattack_file""
                        // Try Mail.txt for this user via folder traversal
                        subFolders2 = uf2.get_folders
                        if subFolders2 != null then
                            for sf2 in subFolders2
                                if sf2.name != ""Config"" then
                                    continue
                                end if
                                sfFiles2 = sf2.get_files
                                if sfFiles2 == null then
                                    continue
                                end if
                                for mf2 in sfFiles2
                                    if mf2.name != ""Mail.txt"" then
                                        continue
                                    end if
                                    if not mf2.has_permission(""r"") then
                                        continue
                                    end if
                                    rawMail2 = mf2.get_content
                                    if rawMail2 == null or rawMail2.len == 0 then
                                        continue
                                    end if
                                    // Mail.txt is plaintext: email@domain.com:hash
                                    for ml2 in rawMail2.split(char(10))
                                        if ml2.len == 0 then
                                            continue
                                        end if
                                        ci2 = ml2.indexOf("":"")
                                        ai2 = ml2.indexOf(""@"")
                                        if ci2 == null or ai2 == null or ai2 >= ci2 then
                                            continue
                                        end if
                                        mEmail2 = ml2[:ci2].trim
                                        mHash2  = ml2[ci2 + 1:].trim
                                        if mEmail2.len == 0 or mHash2.len == 0 then
                                            continue
                                        end if
                                        mPass2 = """"
                                        if crypto != null then
                                            mDec2 = crypto.decipher(mHash2)
                                            if mDec2 != null then
                                                mPass2 = mDec2
                                            end if
                                        end if
                                        ui.success(""  "" + uf2.name + "" | "" + mEmail2 + "" | "" + mPass2)
                                        pd.email = mEmail2
                                        cdMail2 = {} ; cdMail2.type = ""mail""
                                        cdMail2.username = mEmail2 ; cdMail2.password = mPass2
                                        cdMail2.public_ip = publicIp ; cdMail2.lan_ip = lanIp
                                        cdMail2.source = ""routerattack_file""
                                        dbManager.upsertCredential(cdMail2)
                                    end for
                                end for
                            end for
                        end if
                        if not pd.hasIndex(""email"") then
                            ui.info(""  "" + uf2.name + ""  -> social engineering target"")
                        end if
                        dbManager.upsertPerson(pd)
                    end for
                    dbManager.save()
                end if
            end if
            ui.info(""Mail.exe -> PF -> Funny Game -> send your Nest IP + port 1222"")
        end if
    end for

    // Remind about staged shiny libs
    shinyMgr2 = mediator.getExtension(""shinyLibsManager"")
    if shinyMgr2 != null and shinyMgr2.db.staged.len > 0 then
        shinyMgr2.showStagedNotification()
    end if

    ui.separator()
end function
commandManager.register(_cmd)

// ── portattack ───────────────────────────────────────────────────────────
_cmd = new Command
_cmd.name = ""portattack""
_cmd.description = ""Attack a single specific port/service. Usage: portattack <ip> <port> [lanip]""
_cmd.parameters = [StringParameter.New({""name"": ""ip"", ""required"": true}), StringParameter.New({""name"": ""port"", ""required"": true}), StringParameter.New({""name"": ""lanip"", ""required"": false, ""default"": """"})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    ui             = mediator.getExtension(""corvidUi"")
    dbManager      = mediator.getExtension(""databaseManager"")
    attackManager  = mediator.getExtension(""attackManager"")
    sessionManager = mediator.getExtension(""sessionManager"")
    intelManager   = mediator.getExtension(""intelManager"")

    targetIp  = params.ip.trim
    targetPort = params.port.val
    lanIp     = params.lanip.trim

    if not is_valid_ip(targetIp) then
        return Error.New(""Invalid IP: "" + targetIp, ""INVALID_IP"")
    end if
    if targetPort <= 0 then
        return Error.New(""Invalid port: "" + params.port, ""INVALID_PORT"")
    end if

    ui.separator()
    ui.highlight(""PORT ATTACK"")
    ui.separator()
    ui.info(""Target : "" + targetIp + "":"" + str(targetPort))
    if lanIp.len > 0 then
        ui.info(""LAN    : "" + lanIp)
    end if
    ui.print("""")

    // Look up service info from DB
    targets = dbManager.findTarget(targetIp)
    serviceName = ""unknown""
    serviceVersion = ""unknown""
    portForwarded = false
    if targets.len > 0 then
        for tgt in targets
            if not tgt.hasIndex(""ports"") then
                continue
            end if
            for pr in tgt.ports
                if pr.port == targetPort then
                    serviceName    = pr.service
                    serviceVersion = pr.version
                    portForwarded  = pr.forwarded
                end if
            end for
        end for
    end if
    ui.info(""Service: "" + serviceName + "" v"" + serviceVersion)
    if not portForwarded then
        ui.warning(""Port "" + str(targetPort) + "" not marked as forwarded in DB - attack may fail"")
    end if
    ui.print("""")

    // Get router IP
    routerIp = targetIp
    if targets.len > 0 and targets[0].hasIndex(""router_ip"") then
        if targets[0].router_ip.len > 0 then
            routerIp = targets[0].router_ip
        end if
    end if

    // Scan just this one port
    ui.info(""Scanning port "" + str(targetPort) + ""..."")
    scanLanIp = """"
    if lanIp.len > 0 then
        scanLanIp = lanIp
    end if
    results = attackManager.runScan(targetIp, targetPort, scanLanIp, routerIp)
    if results isa Error then
        return Error.New(""Scan failed on port "" + str(targetPort) + "": "" + results.message, ""SCAN_FAIL"")
    end if
    if results.len == 0 then
        ui.warning(""No exploitable vulnerabilities found on port "" + str(targetPort))
        ui.info(""Check hackshop for "" + serviceName + "" v"" + serviceVersion + "" exploits"")
        return
    end if

    // Rank results same as main attack
    ranked = []
    for r in results
        r.port = targetPort ; r.service = serviceName
        ranked.push(r)
    end for
    // Sort: root shell > user shell > guest shell > computer > file
    sortedRanked = []
    for r in ranked
        if r.rtype == ""shell"" and r.privilege == ""root"" then
            sortedRanked.push(r)
        end if
    end for
    for r in ranked
        if r.rtype == ""shell"" and r.privilege != ""root"" and r.privilege != ""guest"" and r.privilege != ""unknown"" then
            sortedRanked.push(r)
        end if
    end for
    for r in ranked
        if r.rtype == ""shell"" and r.privilege == ""guest"" then
            sortedRanked.push(r)
        end if
    end for
    for r in ranked
        if r.rtype == ""computer"" then
            sortedRanked.push(r)
        end if
    end for
    for r in ranked
        if r.rtype == ""file"" then
            sortedRanked.push(r)
        end if
    end for

    // Display candidates
    ui.highlight(""EXPLOIT CANDIDATES  ["" + serviceName + "" port "" + str(targetPort) + ""]"")
    ui.separator()
    for i in range(0, sortedRanked.len - 1)
        r = sortedRanked[i]
        rtLabel = r.rtype
        if r.rtype == ""shell"" then
            rtLabel = ""shell ("" + r.privilege + "")""
        end if
        if r.rtype == ""computer"" then
            rtLabel = ""computer ("" + r.privilege + "")""
        end if
        ui.print(""  ["" + str(i) + ""] "" + r.exploit + ""  ->  "" + rtLabel)
    end for
    ui.print("""")

    // Prompt: auto-try all or pick specific
    ui.info(""Options:"")
    ui.print(""  all        - try all in ranked order"")
    ui.print(""  0-"" + str(sortedRanked.len - 1) + ""        - try specific exploit"")
    ui.print(""  skip       - cancel"")
    ui.print("""")
    choice = user_input(""  Choice: "").trim.lower

    if choice == ""skip"" or choice == ""s"" then
        return
    end if

    toTry = []
    if choice == ""all"" then
        toTry = sortedRanked[0:]
    else
        idx = choice.val
        if idx >= 0 and idx < sortedRanked.len then
            toTry = [sortedRanked[idx]]
        else
            ui.warning(""Invalid choice"")
            return
        end if
    end if

    // Execute
    ui.separator()
    ui.highlight(""EXECUTING"")
    ui.separator()

    succeeded = false
    for r in toTry
        if succeeded then
            break
        end if
        rtLabel = r.rtype
        if r.rtype == ""shell"" then
            rtLabel = ""shell ("" + r.privilege + "")""
        end if
        ui.info(""Trying: "" + r.exploit + "" -> "" + rtLabel + ""..."")

        result = attackManager.exploit(targetIp, targetPort, scanLanIp, routerIp, null)
        if result isa Error then
            ui.warning(""  Failed: "" + result.message)
            continue
        end if

        succeeded = true

        // Check what type of result we actually got
        resultType = typeof(result)

        if resultType == ""shell"" or (result isa Shell) then
            // Proper shell session - already set as current by exploit()
            currentSession = sessionManager.currentSession
            priv = currentSession.handler.privilege()
            ui.success(""Session opened as: "" + priv + "" on "" + targetIp + "":"" + str(targetPort))
            if priv == ""root"" then
                ui.info(""Root obtained - harvesting credentials..."")
                intelManager.harvestAll(targetIp, currentSession.data.ip.local)
                ui.success(""Harvest complete"")
            else
                ui.info(""Got "" + priv + "" - run 'harvest' or 'attack' for escalation"")
            end if

        else if resultType == ""computer"" or (result isa Computer) then
            ui.success(""Got computer object on "" + targetIp)
            ui.info(""Use 'attack' for full escalation from computer object"")

        else if resultType == ""file"" or (result isa File) then
            // File/folder result - roll back to previous session, handle the file intel
            ui.success(""Got file/folder object"")
            // Revert current session to previous (file sessions aren't useful as current)
            if sessionManager.sessions.len > 1 then
                sessionManager.setCurrentSession(sessionManager.sessions[sessionManager.sessions.len - 2])
                // Remove the file session that was added
                sessionManager.sessions.remove(sessionManager.sessions.len - 1)
            end if

            // Load crypto for potential decipher
            crypto = include_lib(""/lib/crypto.so"")
            if crypto == null then
                crypto = include_lib(current_path + ""/crypto.so"")
            end if

            // Route to appropriate handler based on path
            // result is a RAW game file object - use properties not methods for name/path/is_folder
            folderPath = """"
            if result.is_folder then
                folderPath = result.path
            end if

            if folderPath == ""/lib"" or folderPath.indexOf(""/lib"") == 0 then
                ui.separator()
                ui.highlight(""LIBRARY INTEL"")
                ui.separator()
                meta = include_lib(""/lib/metaxploit.so"")
                libFiles = result.get_files
                if libFiles != null then
                    for lf in libFiles
                        if lf.name.indexOf("".so"") == null then
                            continue
                        end if
                        if meta != null then
                            loadedLib = meta.load(lf.path)
                            if loadedLib != null then
                                ui.info(""  "" + lf.name + ""  v"" + loadedLib.version)
                            else
                                ui.dim(""  "" + lf.name + ""  (service lib - not locally loadable)"")
                            end if
                        end if
                    end for
                end if
                // Walk up to root then find /etc/passwd
                rootFolder = result
                while rootFolder.path != ""/""
                    rootFolder = rootFolder.parent()
                end while
                subFolders = rootFolder.get_folders
                if subFolders != null then
                    for rf in subFolders
                        if rf.path != ""/etc"" then
                            continue
                        end if
                        etcFiles = rf.get_files
                        if etcFiles == null then
                            continue
                        end if
                        for ef in etcFiles
                            if ef.name != ""passwd"" then
                                continue
                            end if
                            if not ef.has_permission(""r"") then
                                continue
                            end if
                            if crypto != null then
                                rp = crypto.decipher(ef.get_content)
                                if rp != null then
                                    ui.success(""  Root password: "" + rp)
                                    rootCred = {}
                                    rootCred.type = ""system"" ; rootCred.username = ""root""
                                    rootCred.password = rp ; rootCred.public_ip = targetIp
                                    rootCred.lan_ip = lanIp ; rootCred.source = ""native""
                                    dbManager.upsertCredential(rootCred)
                                    dbManager.save()
                                end if
                            end if
                        end for
                    end for
                end if
                ui.info(""Use lib versions above to find local exploits in hackshop"")

            else if folderPath == ""/home"" or folderPath.indexOf(""/home"") == 0 then
                ui.separator()
                ui.highlight(""USER HARVEST"")
                ui.separator()
                userFolders = result.get_folders
                if userFolders != null then
                    for uf in userFolders
                        username = uf.name
                        ui.info(""  User: "" + username)
                        pd = {}
                        pd.username = username ; pd.public_ip = targetIp
                        pd.lan_ip = lanIp ; pd.source = ""native""
                        dbManager.upsertPerson(pd)
                    end for
                end if
                dbManager.save()

            else
                ui.info(""File result at: "" + folderPath)
                if not result.is_folder and result.has_permission(""r"") then
                    fc = result.get_content
                    if fc != null and fc.len > 0 and crypto != null then
                        dec = crypto.decipher(fc)
                        if dec != null then
                            ui.success(""  Deciphered: "" + dec)
                        end if
                    end if
                end if
            end if
        end if
    end for

    if not succeeded then
        ui.warning(""All exploits on port "" + str(targetPort) + "" failed"")
        ui.info(""Check hackshop for updated "" + serviceName + "" v"" + serviceVersion + "" exploits"")
    end if
    ui.separator()
end function
commandManager.register(_cmd)

// ── put ──────────────────────────────────────────────────────────────────
// Upload a file from pivot session to current session
_cmd = new Command
_cmd.name = ""put""
_cmd.description = ""Upload file from your server to current session target. Usage: put <localpath> <remotepath>""
_cmd.parameters = [StringParameter.New({""name"": ""localpath"", ""required"": true}), StringParameter.New({""name"": ""remotepath"", ""required"": true})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    ui             = mediator.getExtension(""corvidUi"")
    sessionManager = mediator.getExtension(""sessionManager"")

    localPath  = params.localpath.trim
    remotePath = params.remotepath.trim

    pivotSession   = sessionManager.pivotSession
    currentSession = sessionManager.currentSession

    if pivotSession == null then
        return Error.New(""No pivot session"", ""NO_PIVOT"")
    end if
    if currentSession == null then
        return Error.New(""No current session"", ""NO_SESSION"")
    end if
    if currentSession == pivotSession then
        return Error.New(""Current session IS pivot - no remote target to upload to"", ""SAME_SESSION"")
    end if

    // Verify source file exists on pivot
    srcFile = pivotSession.handler.getFile(localPath)
    if srcFile isa Error then
        return Error.New(""Source not found on server: "" + localPath, ""SRC_NOT_FOUND"")
    end if

    // Treat remotePath as destination directory directly
    remoteDir = remotePath.trim
    if remoteDir.len == 0 then
        remoteDir = ""/home/guest""
    end if

    // Verify session has a shell (FileSession does not)
    if not (currentSession.handler isa ShellSession) then
        return Error.New(""Current session is not a shell session - cannot scp"", ""NOT_SHELL"")
    end if

    destCheck = currentSession.handler.getFile(remoteDir)
    if destCheck isa Error then
        return Error.New(""Remote destination not found: "" + remoteDir, ""DEST_NOT_FOUND"")
    end if

    // Perform the scp transfer
    ui.info(""Uploading "" + localPath + "" -> "" + remoteDir + ""..."")

    pivotShell   = pivotSession.handler.shell.shell
    currentShell = currentSession.handler.shell.shell

    result = pivotShell.scp(localPath, remoteDir, currentShell)

    if typeof(result) == ""string"" and result.len > 0 then
        return Error.New(""Upload failed: "" + result, ""SCP_FAILED"")
    end if
    ui.success(""Uploaded: "" + srcFile.name() + "" -> "" + remoteDir)
end function
commandManager.register(_cmd)

// ── lannmap ──────────────────────────────────────────────────────────────
// Deploy a tiny LAN scanner to the current root session, run it there
// so get_router() resolves in the target's network context, then read
// the results back and import into the DB.
// Usage: lannmap <public_ip>
_cmd = new Command
_cmd.name = ""lannmap""
_cmd.description = ""Deploy LAN scanner to current root session and import results. Usage: lannmap <publicip>""
_cmd.parameters = [StringParameter.New({""name"": ""publicip"", ""required"": true})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    ui             = mediator.getExtension(""corvidUi"")
    sessionManager = mediator.getExtension(""sessionManager"")
    dbManager      = mediator.getExtension(""databaseManager"")
    configManager  = mediator.getExtension(""configManager"")

    publicIp = params.publicip.trim
    if not is_valid_ip(publicIp) then
        return Error.New(""Invalid public IP: "" + publicIp, ""INVALID_IP"")
    end if

    currentSession = sessionManager.currentSession
    pivotSession   = sessionManager.pivotSession

    if currentSession == pivotSession then
        return Error.New(""Must be on a remote session to use lannmap"", ""SAME_SESSION"")
    end if

    if not (currentSession.handler isa ShellSession) then
        return Error.New(""Current session must be a shell session"", ""NOT_SHELL"")
    end if

    if currentSession.handler.privilege() != ""root"" then
        return Error.New(""Root access required to deploy lannmap"", ""NOT_ROOT"")
    end if

    ui.separator()
    ui.highlight(""LAN NMAP via target context"")
    ui.separator()

    pivotHandler = pivotSession.handler

    // ── Step 1: ensure cnmap binary exists on Nest ────────────────────────
    // cnmap.src is shipped at /Corvid/tools/cnmap.src - just compile it
    cnmapBinary = pivotHandler.getFile(""/Corvid/tools/cnmap"")
    if not (cnmapBinary isa Error) then
        cnmapBinary.delete()
    end if

    ui.info(""Building cnmap scanner..."")
    cnmapSrcFile = pivotHandler.getFile(""/Corvid/tools/cnmap.src"")
    if cnmapSrcFile isa Error then
        return Error.New(""cnmap.src not found at /Corvid/tools/cnmap.src - check ZIP installation"", ""SRC_MISSING"")
    end if

    pivotShellBuild = pivotSession.handler.shell.shell
    buildResult = pivotShellBuild.build(""/Corvid/tools/cnmap.src"", ""/Corvid/tools"")
    if typeof(buildResult) == ""string"" and buildResult.len > 0 then
        return Error.New(""cnmap build failed: "" + buildResult, ""BUILD_FAILED"")
    end if

    cnmapBinary = pivotHandler.getFile(""/Corvid/tools/cnmap"")
    if cnmapBinary isa Error then
        return Error.New(""cnmap build succeeded but binary not found"", ""BINARY_NOT_FOUND"")
    end if
    ui.success(""cnmap built at /Corvid/tools/cnmap"")

    // ── Step 2: upload cnmap to target ────────────────────────────────────
    ui.info(""Uploading cnmap to target..."")
    pivotShell   = pivotSession.handler.shell.shell
    targetShell  = currentSession.handler.shell.shell
    targetHandler = currentSession.handler

    // Try upload paths in order - same pattern as rootcallback deploy
    cnmapUploadPaths = []
    cnmapUploadPaths.push(""/root"")
    tmpCheck = targetHandler.getFile(""/shiny"")
    if not (tmpCheck isa Error) then
        cnmapUploadPaths.push(""/shiny"")
    end if
    currentUser = targetHandler.user
    if currentUser.len > 0 and currentUser != ""root"" then
        cnmapUploadPaths.push(""/home/"" + currentUser)
    end if

    cnmapUploadedDir = """"
    for uploadDir in cnmapUploadPaths
        scpResult = pivotShell.scp(""/Corvid/tools/cnmap"", uploadDir, targetShell)
        if typeof(scpResult) != ""string"" or scpResult.len == 0 then
            cnmapUploadedDir = uploadDir
            ui.success(""Uploaded "" + uploadDir + ""/cnmap"")
            break
        end if
        ui.dim(""  "" + uploadDir + "" failed - trying next..."")
    end for

    if cnmapUploadedDir.len == 0 then
        return Error.New(""Upload failed on all paths"", ""UPLOAD_FAILED"")
    end if

    cnmapBinPath = cnmapUploadedDir + ""/cnmap""
    cnmapOutPath = ""/root/cnmap_out.txt""

    // ── Step 3: launch on target ──────────────────────────────────────────
    ui.info(""Running LAN scan on target..."")
    targetShell.launch(cnmapBinPath, """")

    // ── Step 4: poll for output file ──────────────────────────────────────
    outFile = null
    pollCount = 0
    pollMax   = 20
    while pollCount < pollMax
        attempt = targetHandler.getFile(cnmapOutPath)
        if not (attempt isa Error) then
            raw = attempt.content()
            if raw != null and raw.indexOf(""DONE"") != null then
                outFile = attempt
                break
            end if
        end if
        pollCount = pollCount + 1
    end while

    if outFile == null then
        return Error.New(""cnmap timed out - no output received"", ""TIMEOUT"")
    end if

    // ── Step 5: parse output and import to DB ─────────────────────────────
    raw     = outFile.content()
    lines   = raw.split(char(10))
    currentDeviceIp = """"
    imported = 0
    devices  = 0

    ui.print("""")
    ui.highlight(""LAN SCAN RESULTS  ["" + publicIp + ""]"")
    ui.separator()

    for line in lines
        line = line.trim
        if line.len == 0 then
            continue
        end if
        if line == ""DONE"" then
            continue
        end if

        if line.indexOf(""DEVICE "") == 0 then
            currentDeviceIp = line[7:]
            ui.info(""Device: "" + currentDeviceIp)
            devices = devices + 1

        else if line.indexOf(""PORT "") == 0 then
            parts = line[5:].split("" "")
            if parts.len < 5 then
                continue
            end if
            portNum  = parts[0].val
            svcName  = parts[1]
            svcVer   = parts[2]
            isFwd    = parts[3] == ""1""
            isOpen   = parts[4] == ""1""

            fwdStr  = ""0""
            openStr = ""0""
            if isFwd  then
                fwdStr  = ""1""
            end if
            if isOpen then
                openStr = ""1""
            end if
            ui.print(""  port "" + parts[0] + ""  "" + svcName + ""  "" + svcVer + ""  fwd:"" + fwdStr + ""  open:"" + openStr)

            // Upsert into DB
            if currentDeviceIp.len > 0 then
                targetData = {}
                targetData.public_ip = publicIp
                targetData.lan_ip    = currentDeviceIp
                portRecord = {}
                portRecord.port      = portNum
                portRecord.service   = svcName
                portRecord.version   = svcVer
                portRecord.forwarded = isFwd
                portRecord.exploited = false
                targetData.ports = [portRecord]
                dbManager.upsertTarget(targetData)
                imported = imported + 1
            end if
        end if
    end for

    dbManager.save()
    ui.print("""")
    ui.success(""Imported "" + str(imported) + "" port record(s) across "" + str(devices) + "" device(s)"")
    ui.separator()

    // ── Step 6: register for leave cleanup ───────────────────────────────
    configManager.set(""cnmapActive"", currentSession.data.ip.public)
    configManager.set(""cnmapDir"", cnmapUploadedDir)

end function
commandManager.register(_cmd)


// ── portfwd ──────────────────────────────────────────────────────────────
// Manage port forwarding on a router you have shell access to
_cmd = new Command
_cmd.name = ""portfwd""
_cmd.description = ""Manage port forwarding on a router. Subcommands: list, add, remove. Usage: portfwd list [routerip] | portfwd add <ext> <int> <lanip> [routerip] | portfwd remove <extport> <lanip> [routerip]""
_cmd.parameters = [StringParameter.New({""name"": ""subcommand"", ""required"": true}), StringParameter.New({""name"": ""arg1"", ""required"": false, ""default"": """"}), StringParameter.New({""name"": ""arg2"", ""required"": false, ""default"": """"}), StringParameter.New({""name"": ""arg3"", ""required"": false, ""default"": """"}), StringParameter.New({""name"": ""arg4"", ""required"": false, ""default"": """"})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    ui             = mediator.getExtension(""corvidUi"")
    sessionManager = mediator.getExtension(""sessionManager"")

    sub  = params.subcommand.trim.lower
    arg1 = params.arg1.trim
    arg2 = params.arg2.trim
    arg3 = params.arg3.trim
    arg4 = params.arg4.trim

    // Determine router IP - use arg1 for list, arg4 for add/remove (optional last arg)
    // For list: portfwd list [routerip]
    // For add:  portfwd add <extport> <intport> <lanip> [routerip]
    // For remove: portfwd remove <extport> <lanip> [routerip]
    routerIp = """"
    if sub == ""list"" then
        routerIp = arg1
    else if sub == ""add"" then
        routerIp = arg4
    else if sub == ""remove"" then
        routerIp = arg3
    end if

    // Get router object
    rawRouter = null
    if routerIp.len > 0 and is_valid_ip(routerIp) then
        rawRouter = get_router(routerIp)
    else
        rawRouter = get_router()
    end if
    if rawRouter == null then
        routerDesc = "" (local)""
        if routerIp.len > 0 then
            routerDesc = "" at "" + routerIp
        end if
        return Error.New(""Could not access router"" + routerDesc, ""NO_ROUTER"")
    end if

    if sub == ""list"" then
        ui.separator()
        ui.highlight(""PORT FORWARDING  ["" + rawRouter.public_ip + ""]"")
        ui.separator()
        usedPorts = rawRouter.used_ports
        if usedPorts == null or usedPorts.len == 0 then
            ui.info(""No port forwarding rules configured"")
        else
            ui.info(""External Port  ->  LAN IP  :  Internal Port"")
            for p in usedPorts
                extPort = p.port_number
                lanIp   = p.get_lan_ip
                status  = """"
                if p.is_closed then
                    status = ""  [closed]""
                end if
                // Get service info
                infoStr = rawRouter.port_info(extPort)
                svcStr = """"
                if infoStr != null and infoStr.len > 0 then
                    svcStr = ""  ("" + infoStr + "")""
                end if
                ui.info(""  "" + str(extPort) + ""  ->  "" + lanIp + svcStr + status)
            end for
        end if
        ui.separator()

    else if sub == ""add"" then
        if arg1.len == 0 or arg2.len == 0 or arg3.len == 0 then
            return Error.New(""Usage: portfwd add <extport> <intport> <lanip> [routerip]"", ""USAGE"")
        end if
        extPort = arg1.val
        intPort = arg2.val
        lanIp   = arg3
        if extPort <= 0 then
            return Error.New(""Invalid external port: "" + arg1, ""INVALID_PORT"")
        end if
        if intPort <= 0 then
            return Error.New(""Invalid internal port: "" + arg2, ""INVALID_PORT"")
        end if
        if not is_valid_ip(lanIp) then
            return Error.New(""Invalid LAN IP: "" + lanIp, ""INVALID_IP"")
        end if

        ui.info(""Adding port forward: "" + str(extPort) + "" -> "" + lanIp + "":"" + str(intPort) + ""..."")
        result = rawRouter.port_forward_rule(extPort, intPort, lanIp)
        if typeof(result) == ""string"" and result.len > 0 then
            return Error.New(""Failed: "" + result, ""FORWARD_FAILED"")
        end if
        ui.success(""Port forward added: external "" + str(extPort) + "" -> "" + lanIp + "":"" + str(intPort))

    else if sub == ""remove"" then
        if arg1.len == 0 or arg2.len == 0 then
            return Error.New(""Usage: portfwd remove <extport> <lanip> [routerip]"", ""USAGE"")
        end if
        extPort = arg1.val
        lanIp   = arg2
        if extPort <= 0 then
            return Error.New(""Invalid port: "" + arg1, ""INVALID_PORT"")
        end if
        if not is_valid_ip(lanIp) then
            return Error.New(""Invalid LAN IP: "" + lanIp, ""INVALID_IP"")
        end if

        ui.info(""Removing port forward: "" + str(extPort) + "" -> "" + lanIp + ""..."")
        result = rawRouter.close_port(extPort, lanIp)
        if typeof(result) == ""string"" and result.len > 0 then
            return Error.New(""Failed: "" + result, ""REMOVE_FAILED"")
        end if
        ui.success(""Port forward removed: "" + str(extPort) + "" -> "" + lanIp)

    else
        return Error.New(""Unknown subcommand: "" + sub + "". Use: list, add, remove"", ""UNKNOWN_SUB"")
    end if
end function
commandManager.register(_cmd)

// ── intel ─────────────────────────────────────────────────────────────────
// Aggregated intel view for a target IP from DB
_cmd = new Command
_cmd.name = ""intel""
_cmd.description = ""Show all stored intel for a target IP. Usage: intel <ip>""
_cmd.parameters = [StringParameter.New({""name"": ""ip"", ""required"": true})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    ui        = mediator.getExtension(""corvidUi"")
    dbManager = mediator.getExtension(""databaseManager"")

    targetIp = params.ip.trim
    if not is_valid_ip(targetIp) then
        return Error.New(""Invalid IP: "" + targetIp, ""INVALID_IP"")
    end if

    ui.separator()
    ui.highlight(""INTEL  ["" + targetIp + ""]"")
    ui.separator()

    // Find all target records for this IP
    targets = dbManager.findTarget(targetIp)
    if targets.len == 0 then
        ui.warning(""No target records found for "" + targetIp)
        ui.info(""Run: nmap "" + targetIp + "" to scan first"")
        return
    end if

    // Show each LAN record
    for tgt in targets
        lanIp = """"
        if tgt.hasIndex(""lan_ip"") then
            lanIp = tgt.lan_ip
        end if
        status = """"
        if tgt.hasIndex(""status"") then
            status = tgt.status
        end if
        priv = """"
        if tgt.hasIndex(""privilege"") then
            priv = tgt.privilege
        end if

        label = tgt.id + ""  "" + targetIp
        if lanIp.len > 0 and lanIp != ""unknown"" then
            label = label + "" / "" + lanIp
        end if
        ui.highlight(""  "" + label)

        // Status and privilege
        statusLine = ""  Status: "" + status
        if priv.len > 0 and priv != ""unknown"" then
            statusLine = statusLine + ""  |  Privilege: "" + priv
        end if
        ui.info(statusLine)

        // Ports
        if tgt.hasIndex(""ports"") and tgt.ports.len > 0 then
            ui.print("""")
            ui.info(""  PORTS:"")
            for pr in tgt.ports
                fwdStr = """"
                if pr.forwarded then
                    fwdStr = "" [fwd]""
                end if
                exStr = """"
                if pr.exploited then
                    exStr = "" [exploited]""
                end if
                ui.print(""    "" + str(pr.port) + ""  "" + pr.service + "" v"" + pr.version + fwdStr + exStr)
            end for
        end if

        // Exploit results summary
        if tgt.hasIndex(""exploit_db"") then
            totalExploits = 0
            workingExploits = 0
            for libKey in tgt.exploit_db.indexes
                for ex in tgt.exploit_db[libKey]
                    totalExploits = totalExploits + 1
                    if ex.rtype != ""Failed"" then
                        workingExploits = workingExploits + 1
                    end if
                end for
            end for
            if totalExploits > 0 then
                ui.print("""")
                ui.info(""  EXPLOITS: "" + str(workingExploits) + "" working / "" + str(totalExploits) + "" total across "" + str(tgt.exploit_db.indexes.len) + "" lib(s)"")
                // Show working ones
                for libKey in tgt.exploit_db.indexes
                    for ex in tgt.exploit_db[libKey]
                        if ex.rtype != ""Failed"" then
                            ui.success(""    "" + ex.exploit + ""  ->  "" + ex.rtype + "" ("" + ex.privilege + "")  ["" + libKey + ""]"")
                        end if
                    end for
                end for
            end if
        end if

        // Notes (cleaned)
        if tgt.hasIndex(""notes"") and tgt.notes.len > 0 then
            noteLines = tgt.notes.split(char(10))
            if noteLines.len > 0 then
                ui.print("""")
                ui.info(""  NOTES:"")
                for nl in noteLines
                    nl = nl.trim
                    if nl.len > 0 then
                        ui.dim(""    "" + nl)
                    end if
                end for
            end if
        end if

        ui.print("""")
    end for

    // Credentials for this IP
    creds = dbManager.findCredentialsByIp(targetIp)
    if creds.len > 0 then
        ui.separator()
        ui.info(""CREDENTIALS  ("" + str(creds.len) + "")"")
        for cr in creds
            typeStr = """"
            if cr.hasIndex(""type"") then
                typeStr = ""["" + cr.type + ""] ""
            end if
            srcStr = """"
            if cr.hasIndex(""source"") then
                srcStr = ""  (source: "" + cr.source + "")""
            end if
            ui.success(""  "" + typeStr + cr.username + "" / "" + cr.password + srcStr)
        end for
        ui.print("""")
    end if

    // Persons associated with this IP
    persons = dbManager.allPersons()
    ipPersons = []
    for p in persons
        if p.hasIndex(""public_ip"") and p.public_ip == targetIp then
            ipPersons.push(p)
        else if p.hasIndex(""ip"") and p.ip == targetIp then
            ipPersons.push(p)
        end if
    end for
    if ipPersons.len > 0 then
        ui.separator()
        ui.info(""PERSONS  ("" + str(ipPersons.len) + "")"")
        for p in ipPersons
            line = ""  "" + p.username
            if p.hasIndex(""email"") and p.email.len > 0 then
                line = line + ""  <"" + p.email + "">""
            end if
            if p.hasIndex(""lan_ip"") and p.lan_ip.len > 0 then
                line = line + ""  (LAN: "" + p.lan_ip + "")""
            end if
            ui.info(line)
        end for
        ui.print("""")
    end if

    ui.separator()
end function
commandManager.register(_cmd)

// ── su ────────────────────────────────────────────────────────────────────
// Escalate privileges on current session using credentials
// Uses connect_service back to same machine - no SSH dependency
_cmd = new Command
_cmd.name = ""su""
_cmd.description = ""Escalate privileges on current session. Tries DB credentials then prompts. Usage: su [user] [password]""
_cmd.parameters = [StringParameter.New({""name"": ""user"", ""required"": false, ""default"": ""root""}), StringParameter.New({""name"": ""password"", ""required"": false, ""default"": """"})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    ui             = mediator.getExtension(""corvidUi"")
    sessionManager = mediator.getExtension(""sessionManager"")
    dbManager      = mediator.getExtension(""databaseManager"")

    currentSession = sessionManager.currentSession
    if currentSession == null then
        return Error.New(""No active session"", ""NO_SESSION"")
    end if

    if not (currentSession.handler isa ShellSession) then
        return Error.New(""su requires a shell session"", ""NOT_SHELL"")
    end if

    currentPriv = currentSession.handler.privilege()
    if currentPriv == ""root"" then
        ui.info(""Already root on this session"")
        return
    end if

    targetUser = params.user.trim
    if targetUser.len == 0 then
        targetUser = ""root""
    end if
    targetPass = params.password.trim

    // Get target IP from current session
    targetIp = currentSession.data.ip.public
    if targetIp == null or targetIp.len == 0 or targetIp == ""unknown"" then
        targetIp = currentSession.data.ip.local
    end if

    ui.separator()
    ui.highlight(""PRIVILEGE ESCALATION"")
    ui.separator()
    ui.info(""Current: "" + currentPriv + "" on "" + targetIp)
    ui.info(""Target:  "" + targetUser)
    ui.print("""")

    // Build list of passwords to try: param first, then DB for this IP, then prompt
    toTry = []
    if targetPass.len > 0 then
        toTry.push({""user"": targetUser, ""pass"": targetPass, ""src"": ""argument""})
    end if

    // Check DB for credentials matching this IP and user
    creds = dbManager.findCredentialsByIp(targetIp)
    for cr in creds
        if cr.username == targetUser or cr.username == ""root"" then
            alreadyIn = false
            for t in toTry
                if t.pass == cr.password then
                    alreadyIn = true
                end if
            end for
            if not alreadyIn and cr.password.len > 0 then
                toTry.push({""user"": cr.username, ""pass"": cr.password, ""src"": ""db""})
            end if
            if cr.hasIndex(""native_pass"") and cr.native_pass.len > 0 then
                alreadyIn = false
                for t in toTry
                    if t.pass == cr.native_pass then
                        alreadyIn = true
                    end if
                end for
                if not alreadyIn then
                    toTry.push({""user"": cr.username, ""pass"": cr.native_pass, ""src"": ""db""})
                end if
            end if
        end if
    end for

    // If nothing in DB, prompt
    if toTry.len == 0 then
        manualPass = user_input(""  Password for "" + targetUser + "": "")
        if manualPass.trim.len > 0 then
            toTry.push({""user"": targetUser, ""pass"": manualPass.trim, ""src"": ""manual""})
        end if
    end if

    if toTry.len == 0 then
        return Error.New(""No credentials to try"", ""NO_CREDS"")
    end if

    // Try each credential using connect_service from the current shell
    // This uses the already-established network path so works for LAN machines too
    currentShell = currentSession.handler.shell.shell
    targetLocalIp  = currentSession.data.ip.local
    targetPublicIp = currentSession.data.ip.public

    // Find an SSH port to connect back on - check DB ports first
    sshPort = 22
    targets = dbManager.findTarget(targetIp)
    if targets.len > 0 then
        for tgt in targets
            if not tgt.hasIndex(""ports"") then
                continue
            end if
            for pr in tgt.ports
                if pr.service == ""ssh"" then
                    sshPort = pr.port
                end if
            end for
        end for
    end if
    ui.info(""Using port "" + str(sshPort) + "" for re-connection"")

    // Determine which IP to connect to:
    // If we have a local IP and it differs from public, use local (LAN machine)
    connectIp = targetPublicIp
    if targetLocalIp.len > 0 and targetLocalIp != ""unknown"" and targetLocalIp != targetPublicIp then
        connectIp = targetLocalIp
    end if

    for cred in toTry
        ui.info(""Trying "" + cred.user + "" / *** (from "" + cred.src + "")..."")
        result = currentShell.connect_service(connectIp, sshPort, cred.user, cred.pass, ""ssh"")
        if typeof(result) == ""shell"" then
            newSession = sessionManager.addSession(result, cred.user + ""@"" + connectIp + "" [su]"")
            if not (newSession isa Error) then
                sessionManager.setCurrentSession(newSession)
                newPriv = newSession.handler.privilege()
                ui.success(""Escalated to: "" + newPriv + "" on "" + connectIp)
                if cred.src != ""db"" then
                    credData = {}
                    credData.username = cred.user ; credData.password = cred.pass
                    credData.type = ""system"" ; credData.public_ip = targetPublicIp
                    credData.lan_ip = targetLocalIp ; credData.source = ""native""
                    dbManager.upsertCredential(credData) ; dbManager.save()
                    ui.info(""Credential saved to DB"")
                end if
                return
            end if
        end if
        ui.dim(""  -> failed"")
    end for

    ui.warning(""All credentials failed for "" + targetUser + "" on "" + connectIp)
    ui.info(""Tip: Run 'harvest' to collect more credentials, or try 'attack' for deep escalation"")
    ui.separator()
end function
commandManager.register(_cmd)

