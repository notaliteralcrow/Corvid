m("/Corvid/asriN/managers/session/shell-session.txt","// ============================================================
// CORVID | managers/session/shell-session
// Extends ComputerSession with shell-specific operations:
// SSH connections, file transfer, build, launch, activate.
// ============================================================

ShellSession = new ComputerSession

ShellSession.shell = null

ShellSession.connectTo = function(ip, port, user, pass, service)
    if service == null then
        service = ""ssh""
    end if
    newShell = self.shell.connectTo(ip, port, user, pass, service)
    if newShell isa Error then
        return newShell
    end if
    return ShellSession.New(newShell)
end function

ShellSession.transferFileFrom = function(srcPath, destFolder, otherSession)
    // Pull a file FROM otherSession TO this session
    srcFile = otherSession.getFile(srcPath)
    if srcFile isa Error then
        return srcFile
    end if
    destDir = self.getFile(destFolder)
    if destDir isa Error then
        return destDir
    end if
    return otherSession.shell.transferFile(srcFile.path(), destDir.path(), self.shell)
end function

ShellSession.transferFileTo = function(srcPath, destFolder, otherSession)
    // Push a file FROM this session TO otherSession
    srcFile = self.getFile(srcPath)
    if srcFile isa Error then
        return srcFile
    end if
    destDir = otherSession.getFile(destFolder)
    if destDir isa Error then
        return destDir
    end if
    return self.shell.transferFile(srcFile.path(), destDir.path(), otherSession.shell)
end function

ShellSession.launch = function(path, args)
    file = self.getFile(path)
    if file isa Error then
        return file
    end if
    return self.shell.launch(file.path(), args)
end function

ShellSession.build = function(srcPath, destPath)
    srcFile = self.getFile(srcPath)
    if srcFile isa Error then
        return srcFile
    end if
    return self.shell.build(srcFile.path(), destPath)
end function

ShellSession.activate = function()
    self.shell.activate()
end function

ShellSession.corruptLogs = function()
    // Create a fresh empty file then move it onto system.log, atomically
    // replacing the log content. This is more reliable than set_content("""")
    // or delete+recreate since the move overwrites the existing file in place.
    rawComp = self.shell.shell.host_computer
    logFile = rawComp.File(""/var/system.log"")
    if logFile == null then
        return ""Log does not exist - nothing to wipe.""
    end if
    rawComp.touch(""/var"", ""t"")
    emptyFile = rawComp.File(""/var/t"")
    if emptyFile == null then
        return Error.New(""Could not create temp file - need root access"", ""WIPE_FAILED"")
    end if
    moveResult = emptyFile.move(""/var"", ""system.log"")
    if moveResult != 1 then
        emptyFile.delete()
        return Error.New(""Could not replace system.log"", ""WIPE_FAILED"")
    end if
    return ""Log wiped.""
end function

ShellSession.type = function()
    return ""shell""
end function

ShellSession.New = function(shell)
    result         = new ShellSession
    result.shell   = shell
    computer       = shell.getComputer()
    if computer isa Error then
        return computer
    end if
    result.computer = computer
    rootFile        = computer.getFile(""/"")
    if rootFile isa Error then
        result.root    = null
        result.current = null
    else
        result.root    = climbFileToRoot(rootFile)
        result.current = rootFile
    end if
    result.user = getUserFromHandler(result)
    return result
end function
",1)
m("/Corvid/asriN/managers/session/session.txt","// ============================================================
// CORVID | managers/session/session
// Session factory  -  wraps any raw game object or facade
// in the appropriate session type.
// ============================================================

Session = {}
Session.handler = null
Session.data    = {}
Session.label   = """"

Session.New = function(object, label)
    // Already a session  -  return as-is
    if object isa Session then
        return object
    end if

    if label == null then
        label = """"
    end if

    result         = new Session
    result.data    = {}
    result.label   = label

    // Wrap raw game objects in facades first
    if typeof(object) == ""shell"" then
        wrapped = Shell.New(object)
        if wrapped isa Error then
            return wrapped
        end if
        handler = ShellSession.New(wrapped)
        if handler isa Error then
            return handler
        end if
        result.handler = handler
        result.data.ip = handler.ip()
        // Navigate to home directory
        if handler.user == ""root"" then
            handler.goTo(""/root"")
        else if handler.user != ""unknown"" then
            handler.goTo(""/home/"" + handler.user)
        end if
        return result
    end if

    if typeof(object) == ""computer"" then
        wrapped = Computer.New(object)
        if wrapped isa Error then
            return wrapped
        end if
        handler = ComputerSession.New(wrapped)
        if handler isa Error then
            return handler
        end if
        result.handler = handler
        result.data.ip = handler.ip()
        if handler.user == ""root"" then
            handler.goTo(""/root"")
        else if handler.user != ""unknown"" then
            handler.goTo(""/home/"" + handler.user)
        end if
        return result
    end if

    if typeof(object) == ""file"" then
        wrapped = File.New(object)
        if wrapped isa Error then
            return wrapped
        end if
        handler = FileSession.New(wrapped)
        if handler isa Error then
            return handler
        end if
        result.handler  = handler
        result.data.ip  = {""public"": ""unknown"", ""local"": ""unknown""}
        return result
    end if

    // Shell facade
    if object isa Shell then
        handler = ShellSession.New(object)
        if handler isa Error then
            return handler
        end if
        result.handler = handler
        result.data.ip = handler.ip()
        if handler.user == ""root"" then
            handler.goTo(""/root"")
        else if handler.user != ""unknown"" then
            handler.goTo(""/home/"" + handler.user)
        end if
        return result
    end if

    // Computer facade
    if object isa Computer then
        handler = ComputerSession.New(object)
        if handler isa Error then
            return handler
        end if
        result.handler = handler
        result.data.ip = handler.ip()
        if handler.user == ""root"" then
            handler.goTo(""/root"")
        else if handler.user != ""unknown"" then
            handler.goTo(""/home/"" + handler.user)
        end if
        return result
    end if

    // File facade
    if object isa File then
        handler = FileSession.New(object)
        if handler isa Error then
            return handler
        end if
        result.handler  = handler
        result.data.ip  = {""public"": ""unknown"", ""local"": ""unknown""}
        return result
    end if

    return Error.New(""Cannot create session from object of type: "" + typeof(object), ""TYPE_ERROR"")
end function
",1)
m("/Corvid/asriN/managers/session/session-manager.txt","// ============================================================
// CORVID | managers/session/session-manager
// Manages all sessions. Maintains the session chain for
// back navigation. Tracks current (operating) session and
// pivot (home Nest) session separately.
// ============================================================

SessionManager = {}
SessionManager.mediator      = null
SessionManager.sessions      = []
SessionManager.sessionChain  = []
SessionManager.currentSession = null
SessionManager.pivotSession   = null

SessionManager.addSession = function(object, label)
    session = Session.New(object, label)
    if session isa Error then
        return session
    end if
    self.sessions.push(session)

    if self.currentSession == null then
        self.currentSession = session
        self.sessionChain.push(session)
    end if
    if self.pivotSession == null then
        self.pivotSession = session
    end if
    return session
end function

SessionManager.setCurrentSession = function(indexOrSession)
    if typeof(indexOrSession) == ""number"" then
        if not self.sessions.hasIndex(indexOrSession) then
            return Error.New(""Session index out of range: "" + indexOrSession, ""OUT_OF_RANGE"")
        end if
        session = self.sessions[indexOrSession]
    else
        session = indexOrSession
    end if
    self.currentSession = session
    self.sessionChain.push(session)
end function

SessionManager.setPivotSession = function(indexOrSession)
    if typeof(indexOrSession) == ""number"" then
        if not self.sessions.hasIndex(indexOrSession) then
            return Error.New(""Session index out of range: "" + indexOrSession, ""OUT_OF_RANGE"")
        end if
        self.pivotSession = self.sessions[indexOrSession]
    else
        self.pivotSession = indexOrSession
    end if
end function

SessionManager.back = function()
    if self.sessionChain.len <= 1 then
        return Error.New(""Already at origin session"", ""AT_ORIGIN"")
    end if
    // Remove the session we are leaving from the sessions list too
    leaving = self.sessionChain[self.sessionChain.len - 1]
    leavingIdx = self.getSessionIndex(leaving)
    self.sessionChain.pop()
    self.currentSession = self.sessionChain[self.sessionChain.len - 1]
    // Remove from sessions list if not session 0 (Nest)
    if leavingIdx != null and leavingIdx > 0 then
        self.sessions.remove(leavingIdx)
    end if
end function

SessionManager.removeSession = function(index)
    if not self.sessions.hasIndex(index) then
        return Error.New(""Session index out of range: "" + index, ""OUT_OF_RANGE"")
    end if
    self.sessions.remove(index)
end function

SessionManager.getSessionIndex = function(session)
    for i in range(0, self.sessions.len - 1)
        if self.sessions[i] == session then
            return i
        end if
    end for
    return null
end function

SessionManager.listSessions = function()
    return self.sessions
end function

SessionManager.removeSession = function(id)
    if not self.sessions.hasIndex(id) then
        return Error.New(""No session at index: "" + str(id), ""NOT_FOUND"")
    end if
    removedSession = self.sessions[id]
    self.sessions.remove(id)
    // If we removed the current session, fall back to previous in chain
    if self.currentSession == removedSession then
        if self.sessionChain.len > 0 then
            self.currentSession = self.sessionChain[self.sessionChain.len - 1]
        else
            self.currentSession = self.pivotSession
        end if
    end if
    // Clean session from chain if present
    newChain = []
    for sc in self.sessionChain
        if sc != removedSession then
            newChain.push(sc)
        end if
    end for
    self.sessionChain = newChain
    return true
end function

SessionManager.setMediator = function(mediator)
    self.mediator = mediator
end function

SessionManager.New = function()
    result = new SessionManager
    result.sessions      = []
    result.sessionChain  = []
    result.currentSession = null
    result.pivotSession   = null
    return result
end function
",1)
m("/Corvid/asriN/managers/lib-manager.txt","// ============================================================
// CORVID | managers/lib/lib-manager
// Tracks all loaded metaxploit and crypto libraries.
// Maintains current (active) and pivot (Nest) refs for each.
// ============================================================

LIB_TYPES = {}
LIB_TYPES.METAXPLOIT = ""metaxploit""
LIB_TYPES.CRYPTO     = ""crypto""

// ---- Lib record ----

Lib = {}
Lib.lib     = null
Lib.type    = ""unknown""
Lib.data    = {}

Lib.New = function(rawLib, data)
    result      = new Lib
    result.data = {}
    result.data.ip      = {""public"": ""unknown"", ""local"": ""unknown""}
    result.data.version = ""unknown""
    result.data.path    = """"

    if not data.hasIndex(""ip"") then
        return Error.New(""Lib.New requires ip in data"", ""MISSING_PARAM"")
    end if
    result.data.ip = data.ip
    if data.hasIndex(""path"")    then
        result.data.path    = data.path
    end if
    if data.hasIndex(""version"") then
        result.data.version = data.version
    end if

    if typeof(rawLib) == ""MetaxploitLib"" then
        wrapped = Metaxploit.New(rawLib)
        if wrapped isa Error then
            return wrapped
        end if
        result.lib  = wrapped
        result.type = LIB_TYPES.METAXPLOIT
    else if typeof(rawLib) == ""cryptoLib"" then
        wrapped = Crypto.New(rawLib)
        if wrapped isa Error then
            return wrapped
        end if
        result.lib  = wrapped
        result.type = LIB_TYPES.CRYPTO
    else
        return Error.New(""Unknown library type: "" + typeof(rawLib), ""TYPE_ERROR"")
    end if

    return result
end function

// ---- LibManager ----

LibManager = {}
LibManager.mediator     = null
LibManager.libs         = []
LibManager.currentLibs  = {}
LibManager.pivotLibs    = {}

LibManager.addLib = function(rawLib, data)
    lib = Lib.New(rawLib, data)
    if lib isa Error then
        return lib
    end if

    // If metaxploit, get version from the library itself
    if lib.type == LIB_TYPES.METAXPLOIT and data.hasIndex(""path"") then
        netSession = lib.lib.metaxploit.net_use
        // Version extracted differently  -  store path for later use
        lib.data.path = data.path
    end if

    self.libs.push(lib)

    // Set as current and pivot if first of this type
    if not self.currentLibs.hasIndex(lib.type) or self.currentLibs[lib.type] == null then
        self.currentLibs[lib.type] = lib
    end if
    if not self.pivotLibs.hasIndex(lib.type) or self.pivotLibs[lib.type] == null then
        self.pivotLibs[lib.type] = lib
    end if

    return lib
end function

LibManager.getCurrentLib = function(libType)
    if not self.currentLibs.hasIndex(libType) then
        return null
    end if
    return self.currentLibs[libType]
end function

LibManager.setCurrentLib = function(lib)
    self.currentLibs[lib.type] = lib
end function

LibManager.getPivotLib = function(libType)
    if not self.pivotLibs.hasIndex(libType) then
        return null
    end if
    return self.pivotLibs[libType]
end function

LibManager.setPivotLib = function(libType, lib)
    self.pivotLibs[libType] = lib
end function

LibManager.getLibById = function(index)
    if not self.libs.hasIndex(index) then
        return Error.New(""No lib at index: "" + index, ""NOT_FOUND"")
    end if
    return self.libs[index]
end function

LibManager.allLibs = function()
    return self.libs
end function

LibManager.getMetaxploit = function()
    lib = self.getCurrentLib(LIB_TYPES.METAXPLOIT)
    if lib == null then
        return Error.New(""No metaxploit library loaded"", ""NO_LIB"")
    end if
    return lib.lib
end function

LibManager.getCrypto = function()
    lib = self.getCurrentLib(LIB_TYPES.CRYPTO)
    if lib == null then
        return Error.New(""No crypto library loaded"", ""NO_LIB"")
    end if
    return lib.lib
end function

LibManager.getPivotMetaxploit = function()
    lib = self.getPivotLib(LIB_TYPES.METAXPLOIT)
    if lib == null then
        return Error.New(""No pivot metaxploit library loaded"", ""NO_LIB"")
    end if
    return lib.lib
end function

LibManager.setMediator = function(mediator)
    self.mediator = mediator
end function

LibManager.New = function()
    result = new LibManager
    result.libs        = []
    result.currentLibs = {}
    result.pivotLibs   = {}
    return result
end function
