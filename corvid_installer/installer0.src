m("/Corvid/asriN/utils/genRandomPass.txt","// ============================================================
// CORVID | utils/genRandomPass
// Centralised random password generator.
// Used by bounces harden, verify reattack, and any other
// place that needs to generate a fresh credential.
//
// Avoids the ad-hoc per-call-site seed patterns scattered
// through the codebase. Salt parameter lets callers add
// per-target entropy (e.g. an IP) without colliding when
// adjacent calls land in the same time tick.
// ============================================================

__genPassCounter = 0

genRandomPass = function(length, salt)
    if length == null or length < 1 then
        length = 12
    end if
    if salt == null then
        salt = """"
    end if
    chars = ""abcdefghijkmnpqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ23456789""
    // Combine time, salt length, and a per-call counter so successive
    // calls within the same time tick produce different output.
    __genPassCounter = __genPassCounter + 1
    seed = floor(time * 1000) + salt.len * 17 + __genPassCounter * 31
    out = """"
    for i in range(0, length - 1)
        idx = (seed + i * 7 + salt.len * 3) % chars.len
        out = out + chars[idx]
        seed = (seed * 13 + 7) % 99999
    end for
    return out
end function
",1)
m("/Corvid/asriN/managers/command.txt","// ============================================================
// CORVID | managers/command/command
// Command and Parameter type definitions.
// Typed parameter parsing with validation before any
// command handler ever runs.
// ============================================================

// ============================================================
// PARAMETER TYPES
// ============================================================

PARAMETER_TYPES = {}
PARAMETER_TYPES.STRING  = ""string""
PARAMETER_TYPES.NUMBER  = ""number""
PARAMETER_TYPES.BOOLEAN = ""boolean""
PARAMETER_TYPES.REST    = ""rest""
PARAMETER_TYPES.FLAG    = ""flag""
PARAMETER_TYPES.OPTIONS = ""options""

// ---- StringParameter ----

StringParameter = {}
StringParameter.name     = null
StringParameter.required = false
StringParameter.default  = null
StringParameter.type     = PARAMETER_TYPES.STRING
StringParameter.handle = function(args, index)
    if not args.hasIndex(index) then
        if self.required then
            return Error.New(""Missing required parameter: "" + self.name, ""MISSING_PARAM"")
        end if
        return [self.default, index + 1]
    end if
    return [args[index], index + 1]
end function
StringParameter.New = function(options)
    p = new StringParameter
    if not options.hasIndex(""name"") then
        return Error.New(""Parameter requires a name"", ""MISSING_PARAM"")
    end if
    p.name     = options.name
    p.required = options.hasIndex(""required"") and options.required
    p.default  = null
    if options.hasIndex(""default"") then
        p.default = options.default
    end if
    return p
end function

// ---- NumberParameter ----

NumberParameter = {}
NumberParameter.name     = null
NumberParameter.required = false
NumberParameter.default  = null
NumberParameter.type     = PARAMETER_TYPES.NUMBER
NumberParameter.handle = function(args, index)
    if not args.hasIndex(index) then
        if self.required then
            return Error.New(""Missing required parameter: "" + self.name, ""MISSING_PARAM"")
        end if
        return [self.default, index + 1]
    end if
    raw = args[index]
    num = raw.val
    if typeof(num) == ""string"" then
        return Error.New(""Parameter '"" + self.name + ""' must be a number"", ""TYPE_ERROR"")
    end if
    return [num, index + 1]
end function
NumberParameter.New = function(options)
    p = new NumberParameter
    if not options.hasIndex(""name"") then
        return Error.New(""Parameter requires a name"", ""MISSING_PARAM"")
    end if
    p.name     = options.name
    p.required = options.hasIndex(""required"") and options.required
    p.default  = null
    if options.hasIndex(""default"") then
        p.default = options.default
    end if
    return p
end function

// ---- BooleanParameter ----

BooleanParameter = {}
BooleanParameter.name     = null
BooleanParameter.required = false
BooleanParameter.default  = null
BooleanParameter.type     = PARAMETER_TYPES.BOOLEAN
BooleanParameter.handle = function(args, index)
    if not args.hasIndex(index) then
        if self.required then
            return Error.New(""Missing required parameter: "" + self.name, ""MISSING_PARAM"")
        end if
        return [self.default, index + 1]
    end if
    raw = args[index]
    if raw == ""true""  then
        return [true,  index + 1]
    end if
    if raw == ""false"" then
        return [false, index + 1]
    end if
    return Error.New(""Parameter '"" + self.name + ""' must be true or false"", ""TYPE_ERROR"")
end function
BooleanParameter.New = function(options)
    p = new BooleanParameter
    if not options.hasIndex(""name"") then
        return Error.New(""Parameter requires a name"", ""MISSING_PARAM"")
    end if
    p.name     = options.name
    p.required = options.hasIndex(""required"") and options.required
    p.default  = null
    if options.hasIndex(""default"") then
        p.default = options.default
    end if
    return p
end function

// ---- FlagParameter ----
// A boolean switch  -  e.g. -R, -f, --verbose
// Returns true if the flag token is present, false otherwise.
// Does NOT advance the index if the flag is absent.

FlagParameter = {}
FlagParameter.name     = null
FlagParameter.required = false
FlagParameter.flag     = null
FlagParameter.type     = PARAMETER_TYPES.FLAG
FlagParameter.handle = function(args, index)
    if not args.hasIndex(index) then
        return [false, index]
    end if
    if args[index] == self.flag then
        return [true, index + 1]
    end if
    return [false, index]
end function
FlagParameter.New = function(options)
    p = new FlagParameter
    if not options.hasIndex(""name"") then
        return Error.New(""Parameter requires a name"", ""MISSING_PARAM"")
    end if
    if not options.hasIndex(""flag"") then
        return Error.New(""FlagParameter requires a flag value"", ""MISSING_PARAM"")
    end if
    p.name = options.name
    p.flag = options.flag
    return p
end function

// ---- OptionsParameter ----
// An enum  -  only accepts values from a predefined set.

OptionsParameter = {}
OptionsParameter.name     = null
OptionsParameter.required = false
OptionsParameter.default  = null
OptionsParameter.options  = {}
OptionsParameter.type     = PARAMETER_TYPES.OPTIONS
OptionsParameter.handle = function(args, index)
    if not args.hasIndex(index) then
        if self.required then
            return Error.New(""Missing required parameter: "" + self.name, ""MISSING_PARAM"")
        end if
        return [self.default, index + 1]
    end if
    arg = args[index]
    if not self.options.hasIndex(arg) then
        return Error.New(""Invalid option '"" + arg + ""' for "" + self.name, ""INVALID_OPTION"")
    end if
    return [self.options[arg], index + 1]
end function
OptionsParameter.New = function(options)
    p = new OptionsParameter
    if not options.hasIndex(""name"") then
        return Error.New(""Parameter requires a name"", ""MISSING_PARAM"")
    end if
    if not options.hasIndex(""options"") then
        return Error.New(""OptionsParameter requires an options map"", ""MISSING_PARAM"")
    end if
    p.name     = options.name
    p.required = options.hasIndex(""required"") and options.required
    p.options  = options.options
    p.default  = null
    if options.hasIndex(""default"") then
        p.default = options.default
    end if
    return p
end function

// ---- RestParameter ----
// Captures all remaining arguments as a single joined string.
// Always comes last in a parameter list.

RestParameter = {}
RestParameter.name     = null
RestParameter.required = false
RestParameter.default  = null
RestParameter.type     = PARAMETER_TYPES.REST
RestParameter.handle = function(args, index)
    if not args.hasIndex(index) then
        if self.required then
            return Error.New(""Missing required parameter: "" + self.name, ""MISSING_PARAM"")
        end if
        return [self.default, args.len]
    end if
    rest = args[index:]
    return [rest.join("" ""), args.len]
end function
RestParameter.New = function(options)
    p = new RestParameter
    if not options.hasIndex(""name"") then
        return Error.New(""Parameter requires a name"", ""MISSING_PARAM"")
    end if
    p.name     = options.name
    p.required = options.hasIndex(""required"") and options.required
    p.default  = null
    if options.hasIndex(""default"") then
        p.default = options.default
    end if
    return p
end function

// ============================================================
// COMMAND
// ============================================================

Command = {}
Command.name        = null
Command.description = null
Command.parameters  = []
Command.callback    = null
Command.permissions = {""object"": ""file"", ""privilege"": ""guest""}

Command.execute = function(args, mediator)
    parsed = self.parseArgs(args)
    if parsed isa Error then
        return parsed
    end if
    return self.callback(parsed, mediator)
end function

Command.parseArgs = function(args)
    params = {}
    tokens = args.split("" "")

    // Strip empty tokens
    clean = []
    for t in tokens
        if t.len > 0 then
            clean.push(t)
        end if
    end for
    tokens = clean

    index = 0
    for param in self.parameters
        result = param.handle(tokens, index)
        if result isa Error then
            return result
        end if
        params[param.name] = result[0]
        index = result[1]
    end for
    return params
end function

Command.help = function()
    line = self.name + ""  ""
    for param in self.parameters
        if param.type == PARAMETER_TYPES.FLAG then
            line = line + ""("" + param.flag + "") ""
        else if param.required then
            line = line + ""["" + param.name + ""] ""
        else
            line = line + ""("" + param.name + "") ""
        end if
    end for
    line = line + "" -  "" + self.description
    return line
end function

Command.New = function(options)
    if not options.hasIndex(""name"") then
        return Error.New(""Command requires a name"", ""MISSING_PARAM"")
    end if
    if not options.hasIndex(""callback"") then
        return Error.New(""Command requires a callback"", ""MISSING_PARAM"")
    end if
    c = new Command
    c.name        = options.name
    c.description = """"
    c.parameters  = []
    c.permissions = {""object"": ""file"", ""privilege"": ""guest""}
    if options.hasIndex(""description"") then
        c.description = options.description
    end if
    if options.hasIndex(""parameters"")  then
        c.parameters  = options.parameters
    end if
    if options.hasIndex(""permissions"") then
        c.permissions = {""object"": ""file"", ""privilege"": ""guest""} + options.permissions
    end if
    c.callback = @options.callback
    return c
end function

Command.Build = function(name, description, params, objPerm, privPerm, callback)
    c = new Command
    c.name        = name
    c.description = description
    c.parameters  = params
    c.permissions = {}
    c.permissions.object    = objPerm
    c.permissions.privilege = privPerm
    c.callback = @callback
    return c
end function
",1)
m("/Corvid/asriN/managers/command-manager.txt","// ============================================================
// CORVID | managers/command/command-manager
// Command registry, queue, history, alias resolution,
// macro dispatch, and permission checking.
// ============================================================

CommandManager = {}
CommandManager.mediator  = null
CommandManager.commands  = {}
CommandManager.aliases   = {}
CommandManager.queue     = []
CommandManager.history   = []

CommandManager.register = function(command)
    if command isa Error then
        return command
    end if
    self.commands[command.name] = command
end function

CommandManager.unregister = function(name)
    if self.commands.hasIndex(name) then
        self.commands.remove(name)
    end if
end function

CommandManager.getCommand = function(name)
    if not self.commands.hasIndex(name) or self.commands[name] == null then
        return Error.New(""Unknown command: "" + name, ""UNKNOWN_COMMAND"")
    end if
    return self.commands[name]
end function

CommandManager.execute = function(input)
    input = input.trim
    if input.len == 0 then
        return
    end if

    // Resolve alias
    parts   = input.split("" "")
    cmdName = parts[0]
    argParts = parts[1:]
    args    = argParts.join("" "")

    if self.aliases.hasIndex(cmdName) then
        aliasVal  = self.aliases[cmdName]
        aliasParts = aliasVal.split("" "")
        cmdName   = aliasParts[0]
        aliasArgParts = aliasParts[1:]
    aliasArgs = aliasArgParts.join("" "")
        if aliasArgs.len > 0 then
            args = aliasArgs + "" "" + args
        end if
    end if

    // Macro dispatch via @macroname
    if cmdName.indexOf(""@"") == 0 then
        macroManager = self.mediator.getExtension(""macroManager"")
        if macroManager != null then
            return macroManager.runMacro(cmdName[1:])
        end if
        return Error.New(""No macro manager available"", ""NO_MACRO_MANAGER"")
    end if

    command = self.getCommand(cmdName)
    if command isa Error then
        self.queue.push(command)
        return
    end if

    self.queue.push([command, args])
end function

CommandManager.run = function()
    while self.queue.len > 0
        item = self.queue.pull()
        if item isa Error then
            self.printResult(item)
            self.queue = []
            return
        end if

        // Check permissions
        permCheck = self.checkPermissions(item[0])
        if permCheck isa Error then
            self.printResult(permCheck)
            return
        end if

        // Execute
        self.history.insert(0, item)
        cmd = item[0]
    result = cmd.execute(item[1], self.mediator)
        self.printResult(result)
    end while
end function

CommandManager.checkPermissions = function(command)
    sessionManager = self.mediator.getExtension(""sessionManager"")
    if sessionManager == null then
        return
    end if
    session  = sessionManager.currentSession
    if session == null then
        return
    end if
    handler  = session.handler
    objType  = handler.type()
    priv     = handler.privilege()

    if not self.checkObject(objType, command.permissions.object) then
        return Error.New(""This command requires "" + command.permissions.object + "" access"", ""PERMISSION_DENIED"")
    end if
    if not self.checkPrivilege(priv, command.permissions.privilege) then
        return Error.New(""This command requires "" + command.permissions.privilege + "" privilege"", ""PERMISSION_DENIED"")
    end if
end function

CommandManager.checkObject = function(current, required)
    if required == null or required == ""file""     then
        return true
    end if
    if required == ""computer"" then
        return current == ""computer"" or current == ""shell""
    end if
    if required == ""shell"" then
        return current == ""shell""
    end if
    return false
end function

CommandManager.checkPrivilege = function(current, required)
    if required == null or required == ""guest""  then
        return true
    end if
    if current == ""unknown"" then
        return true
    end if
    if required == ""user""   then
        return current == ""root"" or current == ""user""
    end if
    if required == ""root""   then
        return current == ""root""
    end if
    return false
end function

CommandManager.printResult = function(result)
    if result == null then
        return
    end if
    if result isa Error then
        ui = self.mediator.getExtension(""corvidUi"")
        if ui != null then
            ui.error(result.message)
        else
            // Use basic red for error when UI system not available
            print(""<color=#FF0000>[!] "" + result.message + ""</color>"")
        end if
        return
    end if
    if typeof(result) == ""string"" then
        print(result)
    end if
end function

CommandManager.addAlias = function(alias, target)
    self.aliases[alias] = target
end function

CommandManager.removeAlias = function(alias)
    if self.aliases.hasIndex(alias) then
        self.aliases.remove(alias)
    end if
end function

CommandManager.setMediator = function(mediator)
    self.mediator = mediator
end function

CommandManager.New = function()
    result = new CommandManager
    result.commands = {}
    result.aliases  = {}
    result.queue    = []
    result.history  = []
    return result
end function
",1)
m("/Corvid/asriN/managers/session/file-session.txt","// ============================================================
// CORVID | managers/session/file-session
// Base session type. Provides virtual filesystem navigation
// relative to a root and current directory. All higher
// session types (computer, shell) extend this.
// ============================================================

FileSession = {}
FileSession.root    = null
FileSession.current = null
FileSession.user    = ""unknown""

FileSession.getFile = function(path)
    if path == null or path.len == 0 then
        return self.current
    end if

    startingPoint = self.current
    parts         = path.split(""/"")

    if startsWith(path, ""/"") then
        startingPoint = self.root
        parts = parts[1:]
    end if

    for part in parts
        if part == "".."" then
            parent = startingPoint.parent()
            if parent isa Error then
                return Error.New(""Cannot go above root"", ""AT_ROOT"")
            end if
            startingPoint = parent
        else if part == ""."" or part.len == 0 then
            continue
        else
            child = startingPoint.child(part)
            if child isa Error then
                return Error.New(""Not found: "" + path, ""NOT_FOUND"")
            end if
            startingPoint = child
        end if
    end for

    return startingPoint
end function

FileSession.goTo = function(path)
    target = self.getFile(path)
    if target isa Error then
        return target
    end if
    if target.type() == FILE_TYPES.FILE then
        return Error.New(""Cannot cd into a file"", ""TYPE_ERROR"")
    end if
    self.current = target
end function

FileSession.path = function()
    return self.current.path()
end function

FileSession.copy = function(srcPath, destPath)
    src = self.getFile(srcPath)
    if src isa Error then
        return src
    end if
    dest     = self.getFile(destPath)
    destName = src.name()
    if dest isa Error then
        destName = destPath.split(""/"").pop()
        parentPath = parent_path(destPath)
        dest = self.getFile(parentPath)
        if dest isa Error then
            return dest
        end if
    end if
    return src.copy(dest.path(), destName)
end function

FileSession.move = function(srcPath, destPath)
    src = self.getFile(srcPath)
    if src isa Error then
        return src
    end if
    dest     = self.getFile(destPath)
    destName = src.name()
    if dest isa Error or dest.type() == FILE_TYPES.FILE then
        destName = destPath.split(""/"").pop()
        parentPath = parent_path(destPath)
        dest = self.getFile(parentPath)
        if dest isa Error then
            return dest
        end if
    end if
    return src.move(dest.path(), destName)
end function

FileSession.delete = function(path)
    target = self.getFile(path)
    if target isa Error then
        return target
    end if
    // If deleting current dir, move up first
    if startsWith(self.current.path(), target.path()) then
        self.current = target.parent()
    end if
    return target.delete()
end function

FileSession.setPermissions = function(path, perms, recursive)
    if recursive == null then
        recursive = false
    end if
    target = self.getFile(path)
    if target isa Error then
        return target
    end if
    return target.setPermissions(perms, recursive)
end function

FileSession.setOwner = function(path, owner, recursive)
    if recursive == null then
        recursive = false
    end if
    target = self.getFile(path)
    if target isa Error then
        return target
    end if
    return target.setOwner(owner, recursive)
end function

FileSession.setGroup = function(path, group, recursive)
    if recursive == null then
        recursive = false
    end if
    target = self.getFile(path)
    if target isa Error then
        return target
    end if
    return target.setGroup(group, recursive)
end function

FileSession.content = function(path)
    target = self.getFile(path)
    if target isa Error then
        return target
    end if
    return target.content()
end function

FileSession.setContent = function(path, content)
    target = self.getFile(path)
    if target isa Error then
        return target
    end if
    return target.setContent(content)
end function

FileSession.appendContent = function(path, content)
    target = self.getFile(path)
    if target isa Error then
        return target
    end if
    return target.appendContent(content)
end function

FileSession.rename = function(path, newName)
    target = self.getFile(path)
    if target isa Error then
        return target
    end if
    return target.rename(newName)
end function

FileSession.name = function()
    // File sessions have no hostname - return path as identifier
    if self.current != null then
        return self.current.path()
    end if
    return ""file-session""
end function

FileSession.privilege = function()
    if self.user == ""root""  then
        return ""root""
    end if
    if self.user == ""guest"" then
        return ""guest""
    end if
    if self.user == ""unknown"" then
        return ""unknown""
    end if
    return ""user""
end function

FileSession.type = function()
    return ""file""
end function

FileSession.New = function(file)
    result = new FileSession
    result.root    = climbFileToRoot(file)
    result.current = file
    result.user    = getUserFromHandler(result)
    return result
end function
