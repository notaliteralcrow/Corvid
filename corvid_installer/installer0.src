m("/Corvid/asriN/utils/climbFileToRoot.txt","// ============================================================
// CORVID | utils/climbFileToRoot
// Starting from any File, walks parent references until
// it reaches the root node (the parent call returns Error).
// Returns the root File object.
// ============================================================

climbFileToRoot = function(file)
    if not (file isa File) then
        return Error.New(""climbFileToRoot requires a File object"", ""TYPE_ERROR"")
    end if
    current = file
    while true
        parent = current.parent()
        if parent isa Error then
            break
        end if
        current = parent
    end while
    return current
end function
",1)
m("/Corvid/asriN/utils/getUserFromHandler.txt","// ============================================================
// CORVID | utils/getUserFromHandler
// Detects the privilege level of the current session handler
// by checking file write permissions.
// Returns: ""root"" | ""user"" | ""guest"" | ""unknown""
// ============================================================

getUserFromHandler = function(handler)
    rootFile = handler.getFile(""/root"")
    if not (rootFile isa Error) and rootFile.hasPermission(""w"") then
        return ""root""
    end if

    homeFile = handler.getFile(""/home"")
    if not (homeFile isa Error) then
        for user in homeFile.children()
            if user isa Error then
                continue
            end if
            if user.name() == ""guest"" then
                continue
            end if
            if user.hasPermission(""w"") then
                return user.name()
            end if
        end for
    end if

    guestFile = handler.getFile(""/home/guest"")
    if not (guestFile isa Error) and guestFile.hasPermission(""w"") then
        return ""guest""
    end if

    return ""unknown""
end function
