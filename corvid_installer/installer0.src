m("/Corvid/asriN/managers/database/target-db.txt","// ============================================================
// CORVID | managers/database/target-db
// Target record schema and operations.
// Every machine encountered  -  whether exploited or discovered.
//
// Schema:
//   id          string    -  auto-generated e.g. ""t_001""
//   public_ip   string    -  public IP address
//   lan_ip      string    -  LAN IP address
//   router_ip   string    -  router public IP
//   hostname    string    -  machine name if known
//   org_id      string    -  linked organisation ID
//   privilege   string    -  highest privilege achieved
//   status      string    -  unknown|scanned|exploited|owned|bounce
//   ports       list      -  port records (see below)
//   exploit_db  map       -  lib_key -> list of exploit records
//   notes       string    -  freeform notes
//   ssh_default bool      -  true if SSH was open natively (not installed by us)
//
// Port record:
//   port       number
//   service    string
//   version    string
//   forwarded  bool
//   exploited  bool
//
// Exploit record:
//   address    string    -  memory address
//   exploit    string    -  overflow value
//   rtype      string    -  Shell|Computer|File|Failed
//   privilege  string    -  root|user|guest|unknown
// ============================================================

TARGET_STATUS = {}
TARGET_STATUS.UNKNOWN   = ""unknown""
TARGET_STATUS.SCANNED   = ""scanned""
TARGET_STATUS.EXPLOITED = ""exploited""
TARGET_STATUS.OWNED     = ""owned""
TARGET_STATUS.BOUNCE    = ""bounce""

TargetDb = {}
TargetDb.db = null

TargetDb.findByPublicIp = function(ip)
    // Full scan by public_ip to return ALL records for this IP
    // (ipIndex only holds one entry per IP so can't use it for multi-record networks)
    matchIp = function(record)
        return record.hasIndex(""public_ip"") and record.public_ip == ip
    end function
    return self.db.query(@matchIp)
end function

TargetDb.findByLanIp = function(ip)
    matchIp = function(record)
        return record.hasIndex(""lan_ip"") and record.lan_ip == ip
    end function
    return self.db.query(@matchIp)
end function

TargetDb.findByStatus = function(status)
    matchStatus = function(record)
        return record.hasIndex(""status"") and record.status == status
    end function
    return self.db.query(@matchStatus)
end function

TargetDb.findByOrg = function(orgId)
    matchOrg = function(record)
        return record.hasIndex(""org_id"") and record.org_id == orgId
    end function
    return self.db.query(@matchOrg)
end function

TargetDb.findBounces = function()
    return self.findByStatus(TARGET_STATUS.BOUNCE)
end function

TargetDb.getExploits = function(id, libKey)
    record = self.db.get(id)
    if record isa Error then
        return record
    end if
    if not record.hasIndex(""exploit_db"") then
        return []
    end if
    if not record.exploit_db.hasIndex(libKey) then
        return []
    end if
    return record.exploit_db[libKey]
end function

TargetDb.upsert = function(data)
    // Natural key: public_ip + lan_ip
    if not data.hasIndex(""public_ip"") then
        return Error.New(""Target record requires public_ip"", ""VALIDATION_ERROR"")
    end if

    lanIp = """"
    if data.hasIndex(""lan_ip"") then
        lanIp = data.lan_ip
    end if

    matchExisting = function(record)
        if record.public_ip != data.public_ip then
            return false
        end if
        // Only enforce lan_ip match if BOTH have a lan_ip set
        if lanIp.len > 0 and record.hasIndex(""lan_ip"") and record.lan_ip.len > 0 and record.lan_ip != lanIp then
            return false
        end if
        return true
    end function

    existing = self.db.query(@matchExisting)
    if existing.len > 0 then
        record = existing[0]
        id     = record.id
        // Merge ports  -  avoid duplicates by port number
        if data.hasIndex(""ports"") then
            for newPort in data.ports
                found = false
                if record.ports.len > 0 then
                    for i in range(0, record.ports.len - 1)
                        if record.ports[i].port == newPort.port then
                            record.ports[i] = newPort
                            found = true
                        end if
                    end for
                end if
                if not found then
                    record.ports.push(newPort)
                end if
            end for
        end if
        // Update scalar fields
        if data.hasIndex(""hostname"")  and data.hostname.len  > 0 then
            record.hostname  = data.hostname
        end if
        if data.hasIndex(""org_id"")    and data.org_id.len    > 0 then
            record.org_id    = data.org_id
        end if
        if data.hasIndex(""router_ip"") and data.router_ip.len > 0 then
            record.router_ip = data.router_ip
        end if
        if data.hasIndex(""notes"")     and data.notes.len     > 0 then
            if record.notes.len > 0 then
                record.notes = record.notes + char(10) + data.notes
            else
                record.notes = data.notes
            end if
        end if
        // Status  -  only upgrade, never downgrade
        statusOrder = [TARGET_STATUS.UNKNOWN, TARGET_STATUS.SCANNED, TARGET_STATUS.EXPLOITED, TARGET_STATUS.OWNED, TARGET_STATUS.BOUNCE]
        if data.hasIndex(""status"") then
            currentIdx = statusOrder.indexOf(record.status)
            newIdx     = statusOrder.indexOf(data.status)
            if newIdx == null then
                newIdx = 0
            end if
            if currentIdx == null then
                currentIdx = 0
            end if
            if newIdx > currentIdx then
                record.status = data.status
            end if
        end if
        // Privilege  -  only upgrade
        privOrder = [""unknown"", ""guest"", ""user"", ""root""]
        if data.hasIndex(""privilege"") then
            currentPrivIdx = privOrder.indexOf(record.privilege)
            newPrivIdx     = privOrder.indexOf(data.privilege)
            if newPrivIdx == null then
                newPrivIdx = 0
            end if
            if currentPrivIdx == null then
                currentPrivIdx = 0
            end if
            if newPrivIdx > currentPrivIdx then
                record.privilege = data.privilege
            end if
        end if
        // Exploit DB  -  merge by lib key
        if data.hasIndex(""exploit_db"") then
            if not record.hasIndex(""exploit_db"") then
                record.exploit_db = {}
            end if
            for kv in data.exploit_db
                record.exploit_db[kv.key] = kv.value
            end for
        end if
        // ssh_default  -  once true, stays true
        if data.hasIndex(""ssh_default"") and data.ssh_default then
            record.ssh_default = true
        end if
        self.db.set(id, record)
        return id
    else
        id = self.db.nextId(""t"")
        record = {}
        record.id          = id
        record.public_ip   = data.public_ip
        record.lan_ip      = """"
        record.router_ip   = """"
        record.hostname    = """"
        record.org_id      = """"
        record.privilege   = ""unknown""
        record.status      = TARGET_STATUS.UNKNOWN
        record.ports       = []
        record.exploit_db  = {}
        record.notes       = """"
        record.ssh_default = false
        if data.hasIndex(""lan_ip"")      then
            record.lan_ip      = data.lan_ip
        end if
        if data.hasIndex(""router_ip"")   then
            record.router_ip   = data.router_ip
        end if
        if data.hasIndex(""hostname"")    then
            record.hostname     = data.hostname
        end if
        if data.hasIndex(""org_id"")      then
            record.org_id      = data.org_id
        end if
        if data.hasIndex(""privilege"")   then
            record.privilege    = data.privilege
        end if
        if data.hasIndex(""status"")      then
            record.status       = data.status
        end if
        if data.hasIndex(""ports"")       then
            record.ports        = data.ports
        end if
        if data.hasIndex(""exploit_db"")  then
            record.exploit_db   = data.exploit_db
        end if
        if data.hasIndex(""notes"")       then
            record.notes        = data.notes
        end if
        if data.hasIndex(""ssh_default"") then
            record.ssh_default  = data.ssh_default
        end if
        self.db.set(id, record)
        return id
    end if
end function

TargetDb.storeExploits = function(targetId, libKey, exploits)
    // Store tested exploit results against a target by library key
    record = self.db.get(targetId)
    if record isa Error then
        return record
    end if
    if not record.hasIndex(""exploit_db"") then
        record.exploit_db = {}
    end if
    record.exploit_db[libKey] = exploits
    self.db.set(targetId, record)
end function

TargetDb.setStatus = function(targetId, status)
    record = self.db.get(targetId)
    if record isa Error then
        return record
    end if
    record.status = status
    self.db.set(targetId, record)
end function

TargetDb.addNote = function(id, note)
    record = self.db.get(id)
    if record isa Error then
        return record
    end if
    if record.notes.len > 0 then
        record.notes = record.notes + char(10) + note
    else
        record.notes = note
    end if
    self.db.set(id, record)
end function

TargetDb.get = function(id)
    return self.db.get(id)
end function

TargetDb.all = function()
    return self.db.all()
end function

TargetDb.New = function(db)
    result    = new TargetDb
    result.db = db
    return result
end function
",1)
m("/Corvid/asriN/managers/database/database-manager.txt","// ============================================================
// CORVID | managers/database/database-manager
// Unified database access layer. Instantiates and owns all
// four databases. All other managers query intelligence
// exclusively through this manager.
// ============================================================

DatabaseManager = {}
DatabaseManager.mediator    = null
DatabaseManager.personDb    = null
DatabaseManager.orgDb       = null
DatabaseManager.credDb      = null
DatabaseManager.targetDb    = null
DatabaseManager.exploitKb   = null
DatabaseManager.roostDb     = null
DatabaseManager.snifferDb   = null

DatabaseManager.init = function()
    // Ensure /Corvid/Data/ exists on the Nest
    sessionManager = self.mediator.getExtension(""sessionManager"")
    handler = sessionManager.pivotSession.handler

    corvid = handler.getFile(""/Corvid"")
    if corvid isa Error then
        result = handler.createFolder(""/Corvid"")
        if result isa Error then
            return result
        end if
    end if
    data = handler.getFile(""/Corvid/Data"")
    if data isa Error then
        result = handler.createFolder(""/Corvid/Data"")
        if result isa Error then
            return result
        end if
    end if

    // Instantiate raw databases
    personsRaw = Database.New(""persons"")
    personsRaw.setMediator(self.mediator)
    personsRaw.load()

    orgsRaw = Database.New(""orgs"")
    orgsRaw.setMediator(self.mediator)
    orgsRaw.load()

    credsRaw = Database.New(""credentials"")
    credsRaw.setMediator(self.mediator)
    credsRaw.load()

    targetsRaw = Database.New(""targets"")
    targetsRaw.setMediator(self.mediator)
    targetsRaw.load()

    // Wrap in typed layers
    self.personDb = PersonDb.New(personsRaw)
    self.orgDb    = OrgDb.New(orgsRaw)
    self.credDb   = CredentialDb.New(credsRaw)
    self.targetDb = TargetDb.New(targetsRaw)

    // Exploit knowledge base - separate file
    self.exploitKb = ExploitKbManager.New()
    self.exploitKb.setMediator(self.mediator)
    self.exploitKb.init()

    // Roost node pool - supports file chaining for large pools
    self.roostDb = RoostDb
    self.roostDb.setMediator(self.mediator)
    self.roostDb.records = self.loadChainedList(""roost"", handler)

    // Sniffer capture DB - supports file chaining for large capture sets
    self.snifferDb = SnifferDb
    self.snifferDb.setMediator(self.mediator)
    snifferRecords = self.loadChainedList(""sniffer"", handler)
    self.snifferDb.records = snifferRecords
    if snifferRecords.len > 0 then
        lastId = snifferRecords[snifferRecords.len - 1].id
        numStr = lastId[3:]
        self.snifferDb.nextId = numStr.val + 1
    end if

    // ShinyLibs DB
    self.shinyLibsDb = ShinyLibsDb
    self.shinyLibsDb.init()
    shinyData = self.loadJson(""shinylibs"", handler)
    if shinyData != null then
        self.shinyLibsDb.deserialize(shinyData)
    end if
end function

DatabaseManager.save = function()
    // Save all dirty databases
    results = []
    r1 = self.personDb.db.save()
    r2 = self.orgDb.db.save()
    r3 = self.credDb.db.save()
    r4 = self.targetDb.db.save()
    r5 = self.exploitKb.save()
    sessionManager = self.mediator.getExtension(""sessionManager"")
    handler = sessionManager.pivotSession.handler
    self.saveChainedList(""roost"", self.roostDb.records, handler)
    self.saveChainedList(""sniffer"", self.snifferDb.records, handler)
    self.saveJson(""shinylibs"", self.shinyLibsDb.serialize(), handler)
    if r1 isa Error then
        results.push(r1)
    end if
    if r2 isa Error then
        results.push(r2)
    end if
    if r3 isa Error then
        results.push(r3)
    end if
    if r4 isa Error then
        results.push(r4)
    end if
    if r5 isa Error then
        results.push(r5)
    end if
    if results.len > 0 then
        return results[0]
    end if
end function

// ---- Chained list persistence helpers ----
// Used for roost and sniffer which store flat arrays rather than keyed maps.
// Files: /Corvid/Data/<name>.json, /Corvid/Data/<name>_2.json, etc.
// Each file is a JSON object: {""records"": [...], ""continued"": ""<next_path>""}
// Always rewrites from file 1 to prevent stale records.

DatabaseManager.listChainPath = function(name, n)
    if n == 1 then
        return ""/Corvid/Data/"" + name + "".json""
    end if
    return ""/Corvid/Data/"" + name + ""_"" + str(n) + "".json""
end function

// Simple JSON file load/save for non-chained single-file databases
DatabaseManager.loadJson = function(name, handler)
    filePath = ""/Corvid/Data/"" + name + "".json""
    f = handler.getFile(filePath)
    if f isa Error then
        return null
    end if
    raw = f.content()
    if raw == null or raw.len == 0 then
        return null
    end if
    result = parse(raw)
    if result == null then
        return null
    end if
    return result
end function

DatabaseManager.saveJson = function(name, data, handler)
    filePath = ""/Corvid/Data/"" + name + "".json""
    encoded  = toJSON(data)
    f = handler.getFile(filePath)
    if f isa Error then
        result = handler.createFile(filePath)
        if result isa Error then
            return result
        end if
        f = handler.getFile(filePath)
        if f isa Error then
            return f
        end if
    end if
    f.setContent(encoded)
end function

DatabaseManager.loadChainedList = function(name, handler)
    allRecords = []
    currentN = 1
    chainDone = false
    while not chainDone
        path = self.listChainPath(name, currentN)
        file = handler.getFile(path)
        if file isa Error then
            chainDone = true
        else
            raw = file.content()
            if raw isa Error or raw.len == 0 then
                chainDone = true
            else
                parsed = parse(raw)
                if parsed == null then
                    chainDone = true
                else
                    // Support both old format (bare list) and new format (object with records key)
                    if typeof(parsed) == ""list"" then
                        for r in parsed
                            allRecords.push(r)
                        end for
                        chainDone = true
                    else if parsed.hasIndex(""records"") then
                        for r in parsed.records
                            allRecords.push(r)
                        end for
                        if parsed.hasIndex(""continued"") and parsed.continued.len > 0 then
                            currentN = currentN + 1
                        else
                            chainDone = true
                        end if
                    else
                        chainDone = true
                    end if
                end if
            end if
        end if
    end while
    return allRecords
end function

DatabaseManager.saveChainedList = function(name, records, handler)
    THRESHOLD = 140000
    // Partition records into chunks by running size estimate
    chunks = []
    currentChunk = []
    currentSize = 2  // []
    for r in records
        entryJson = toJSON(r)
        // comma + entry
        entrySize = entryJson.len + 1
        if currentSize + entrySize < THRESHOLD - 200 then
            currentChunk.push(r)
            currentSize = currentSize + entrySize
        else
            chunks.push(currentChunk)
            currentChunk = [r]
            currentSize = 2 + entryJson.len
        end if
    end for
    if currentChunk.len > 0 then
        chunks.push(currentChunk)
    end if
    if chunks.len == 0 then
        chunks.push([])
    end if

    // Write each chunk - always from file 1
    fileN = 1
    for i in range(0, chunks.len - 1)
        path = self.listChainPath(name, fileN)
        fileObj = {}
        fileObj.records = chunks[i]
        if i < chunks.len - 1 then
            fileObj.continued = self.listChainPath(name, fileN + 1)
        else
            fileObj.continued = """"
        end if
        file = handler.getFile(path)
        if file isa Error then
            handler.createFile(path)
            file = handler.getFile(path)
        end if
        if not (file isa Error) then
            file.setContent(toJSON(fileObj))
        end if
        fileN = fileN + 1
    end for

    // Delete any leftover chain files from previous larger saves
    cleanN = fileN
    cleanDone = false
    while not cleanDone
        cleanPath = self.listChainPath(name, cleanN)
        cleanFile = handler.getFile(cleanPath)
        if cleanFile isa Error then
            cleanDone = true
        else
            cleanFile.delete()
            cleanN = cleanN + 1
        end if
    end while
end function

