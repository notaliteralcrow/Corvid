m("/Corvid/asriN/libs/functional.txt","// ============================================================
// CORVID | libs/functional
// Functional programming utilities.
// map, find, some, flat, indexOf.
// ============================================================

isIterable = function(item)
    if typeof(item) == ""map"" then
        return true
    end if
    if typeof(item) == ""list"" then
        return true
    end if
    return false
end function

map = function(list, callback)
    if typeof(list) == ""map"" then
        newList = {}
    end if
    if typeof(list) == ""list"" then
        newList = []
    end if
    if not isIterable(list) then
        return Error.New(""map requires a list or map"", ""TYPE_ERROR"")
    end if
    if typeof(list) == ""map"" then
        for item in list
            k = item.key
            newList[k] = callback(item)
        end for
    end if
    if typeof(list) == ""list"" then
        for v in list
            newList.push(callback(v))
        end for
    end if
    return newList
end function

find = function(list, callback)
    if not isIterable(list) then
        return Error.New(""find requires a list or map"", ""TYPE_ERROR"")
    end if
    for v in list
        if callback(v) then
            return v
        end if
    end for
    return null
end function

some = function(list, callback)
    if not isIterable(list) then
        return Error.New(""some requires a list or map"", ""TYPE_ERROR"")
    end if
    for v in list
        if callback(v) then
            return true
        end if
    end for
    return false
end function

flat = function(list)
    if typeof(list) != ""list"" then
        return Error.New(""flat requires a list"", ""TYPE_ERROR"")
    end if
    result = []
    for item in list
        if typeof(item) == ""list"" then
            for nested in item
                result.push(nested)
            end for
        else
            result.push(item)
        end if
    end for
    return result
end function

indexOf = function(list, item)
    if typeof(list) != ""list"" then
        return Error.New(""indexOf requires a list"", ""TYPE_ERROR"")
    end if
    for i in range(0, list.len - 1)
        if list[i] == item then
            return i
        end if
    end for
    return null
end function
",1)
m("/Corvid/asriN/libs/string.txt","// ============================================================
// CORVID | libs/string
// String utility functions.
// ============================================================

startsWith = function(str, prefix)
    return str.indexOf(prefix) == 0
end function

padRight = function(str, width)
    str = str + """"
    while str.len < width
        str = str + "" ""
    end while
    return str
end function

trimLeft = function(str)
    i = 0
    while i < str.len and str[i] == "" ""
        i = i + 1
    end while
    return str[i:]
end function

trimRight = function(str)
    i = str.len - 1
    while i >= 0 and str[i] == "" ""
        i = i - 1
    end while
    return str[:i + 1]
end function

trim = function(str)
    return trimLeft(trimRight(str))
end function

",1)
m("/Corvid/asriN/libs/ssv.txt","// ============================================================
// CORVID | libs/ssv
// Space-separated value parser.
// Used for parsing show_procs and similar game output.
// ============================================================

ssvToList = function(csv)
    lineSplitter = function(line)
        return line.split("" "")
    end function
    lines = map(csv.split(char(10)), @lineSplitter)

    names = []
    firstLine = lines.pull()
    for item in firstLine
        if item.len > 0 then
            names.push(item)
        end if
    end for

    result = []
    for line in lines
        if line.len == 0 then
            continue
        end if
        row = {}
        for i in range(0, names.len - 1)
            if line.hasIndex(i) then
                row[names[i]] = line[i]
            else
                row[names[i]] = """"
            end if
        end for
        result.push(row)
    end for

    return result
end function
",1)
m("/Corvid/asriN/mediator.txt","// ============================================================
// CORVID | mediator
// ExtensionMediator  -  the central communication broker.
// All managers register here and communicate through here.
// No manager ever holds a direct reference to another.
// ============================================================

ExtensionMediator = {}
ExtensionMediator.extensions = {}
ExtensionMediator.addExtension = function(name, extension)
    self.extensions[name] = extension
    if extension != null then
        extension.setMediator(self)
    end if
end function
ExtensionMediator.getExtension = function(name)
    if not self.extensions.hasIndex(name) then
        return null
    end if
    return self.extensions[name]
end function
ExtensionMediator.removeExtension = function(name)
    self.extensions.remove(name)
end function
ExtensionMediator.New = function()
    result = new ExtensionMediator
    result.extensions = {}
    return result
end function
",1)
m("/Corvid/asriN/facades/file.txt","// ============================================================
// CORVID | facades/file
// Wraps the game File object.
// All methods return typed results  -  never raw null or strings.
// Directories are Files with type FOLDER.
// ============================================================

FILE_TYPES = {}
FILE_TYPES.FILE   = ""FILE""
FILE_TYPES.FOLDER = ""FOLDER""

File = {}
File.file = null

File.name = function()
    return self.file.name
end function

File.path = function()
    return self.file.path
end function

File.owner = function()
    return self.file.owner
end function

File.group = function()
    return self.file.group
end function

File.permissions = function()
    return self.file.permissions
end function

File.size = function()
    return self.file.size
end function

File.type = function()
    if self.file.is_folder then
        return FILE_TYPES.FOLDER
    end if
    return FILE_TYPES.FILE
end function

File.isBinary = function()
    return self.file.is_binary == 1
end function

File.hasPermission = function(permission)
    return self.file.has_permission(permission)
end function

File.content = function()
    if self.type() == FILE_TYPES.FOLDER then
        return Error.New(""Cannot read content of a folder"", ""TYPE_ERROR"")
    end if
    if self.isBinary() then
        return Error.New(""File is binary and cannot be read as text"", ""BINARY_FILE"")
    end if
    result = self.file.get_content
    if result == null then
        return Error.New(""Could not read file content"", ""READ_ERROR"")
    end if
    return result
end function

File.setContent = function(newContent)
    if self.type() == FILE_TYPES.FOLDER then
        return Error.New(""Cannot set content of a folder"", ""TYPE_ERROR"")
    end if
    result = self.file.set_content(newContent)
    if not result then
        return Error.New(""Could not write file content"", ""WRITE_ERROR"")
    end if
end function

File.appendContent = function(newContent)
    if self.type() == FILE_TYPES.FOLDER then
        return Error.New(""Cannot append content to a folder"", ""TYPE_ERROR"")
    end if
    existing = self.content()
    if existing isa Error then
        return existing
    end if
    return self.setContent(existing + newContent)
end function

File.children = function()
    if self.type() == FILE_TYPES.FILE then
        return Error.New(""Cannot get children of a file"", ""TYPE_ERROR"")
    end if
    raw = self.file.get_files() + self.file.get_folders()
    wrapChild = function(child)
        return File.New(child)
    end function
    return map(raw, @wrapChild)
end function

File.child = function(name)
    kids = self.children()
    if kids isa Error then
        return kids
    end if
    matchName = function(child)
        return child.name() == name
    end function
    result = find(kids, @matchName)
    if result == null then
        return Error.New(""Child not found: "" + name, ""NOT_FOUND"")
    end if
    return result
end function

File.hasChild = function(name)
    result = self.child(name)
    return not (result isa Error)
end function

File.parent = function()
    raw = self.file.parent
    if raw == null then
        return Error.New(""No parent  -  already at root"", ""AT_ROOT"")
    end if
    return File.New(raw)
end function

File.copy = function(destination, name)
    if name == null then
        name = self.name()
    end if
    result = self.file.copy(destination, name)
    if typeof(result) == ""string"" then
        return Error.New(result, ""COPY_ERROR"")
    end if
end function

File.move = function(destination, name)
    if name == null then
        name = self.name()
    end if
    result = self.file.move(destination, name)
    if typeof(result) == ""string"" then
        return Error.New(result, ""MOVE_ERROR"")
    end if
end function

File.rename = function(newName)
    result = self.file.rename(newName)
    if typeof(result) == ""string"" and result.len > 0 then
        return Error.New(result, ""RENAME_ERROR"")
    end if
end function

File.delete = function()
    if self.type() == FILE_TYPES.FOLDER then
        kids = self.children()
        if not (kids isa Error) then
            for child in kids
                child.delete()
            end for
        end if
    end if
    if self.path() == ""/"" then
        return
    end if
    result = self.file.delete()
    if typeof(result) == ""string"" and result.len > 0 then
        return Error.New(result, ""DELETE_ERROR"")
    end if
end function

File.setPermissions = function(perms, recursive)
    if recursive == null then
        recursive = false
    end if
    result = self.file.chmod(perms, recursive)
    if typeof(result) == ""string"" and result.len > 0 then
        return Error.New(result, ""CHMOD_ERROR"")
    end if
end function

File.setOwner = function(owner, recursive)
    if recursive == null then
        recursive = false
    end if
    result = self.file.set_owner(owner, recursive)
    if typeof(result) == ""string"" and result.len > 0 then
        return Error.New(result, ""CHOWN_ERROR"")
    end if
end function

File.setGroup = function(group, recursive)
    if recursive == null then
        recursive = false
    end if
    result = self.file.set_group(group, recursive)
    if typeof(result) == ""string"" and result.len > 0 then
        return Error.New(result, ""CHGRP_ERROR"")
    end if
end function

File.New = function(file)
    if typeof(file) != ""file"" then
        return Error.New(""Cannot create File from non-file object"", ""TYPE_ERROR"")
    end if
    result = new File
    result.file = file
    return result
end function
",1)
m("/Corvid/asriN/facades/computer.txt","// ============================================================
// CORVID | facades/computer
// Wraps the game Computer object.
// ============================================================

Computer = {}
Computer.computer = null

Computer.name = function()
    return self.computer.get_name
end function

Computer.lanIp = function()
    return self.computer.local_ip
end function

Computer.getFile = function(path)
    result = self.computer.File(path)
    if result == null then
        return Error.New(""File not found: "" + path, ""NOT_FOUND"")
    end if
    return File.New(result)
end function

Computer.touch = function(path, name)
    result = self.computer.touch(path, name)
    if typeof(result) == ""string"" then
        return Error.New(result, ""TOUCH_ERROR"")
    end if
end function

Computer.createFolder = function(path, name)
    result = self.computer.create_folder(path, name)
    if typeof(result) == ""string"" then
        return Error.New(result, ""MKDIR_ERROR"")
    end if
end function

Computer.addUser = function(user, password)
    result = self.computer.create_user(user, password)
    if typeof(result) == ""string"" then
        return Error.New(result, ""ADDUSER_ERROR"")
    end if
end function

Computer.deleteUser = function(user, removeHome)
    if removeHome == null then
        removeHome = false
    end if
    result = self.computer.delete_user(user, removeHome)
    if typeof(result) == ""string"" then
        return Error.New(result, ""DELUSER_ERROR"")
    end if
end function

Computer.changePassword = function(user, password)
    result = self.computer.change_password(user, password)
    if typeof(result) == ""string"" then
        return Error.New(result, ""PASSWD_ERROR"")
    end if
end function

Computer.showProcs = function()
    return ssvToList(self.computer.show_procs)
end function

Computer.closeProcess = function(pid)
    result = self.computer.close_program(pid.val)
    if typeof(result) == ""string"" then
        return Error.New(result, ""KILL_ERROR"")
    end if
end function

Computer.getPorts = function()
    return self.computer.get_ports
end function

Computer.isNetworkActive = function()
    return self.computer.is_network_active == 1
end function

Computer.New = function(computer)
    if typeof(computer) != ""computer"" then
        return Error.New(""Cannot create Computer from non-computer object"", ""TYPE_ERROR"")
    end if
    result = new Computer
    result.computer = computer
    return result
end function
