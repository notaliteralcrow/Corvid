s = get_shell;c = s.host_computer;existingStaging = c.File("/Corvid/asriN");if existingStaging != null then;    existingStaging.delete;    print("Cleaned up previous staging dir");end if;m = function(filePath, content, isNew);    segments = filePath.split("/")[1:];    fileName = segments.pop;    for segment in segments;        __segment_idx = segments.indexOf(segment);        parentPath = "/" + segments[:__segment_idx].join("/");        if parentPath == "/" then;            folderPath = "/" + segment;        else;            folderPath = parentPath + "/" + segment;        end if;        folderHandle = c.File(folderPath);        if folderHandle == null then;            result = c.create_folder(parentPath, segment);            if result != 1 then;                exit("Could not create folder: " + folderPath);            end if;        end if;    end for;    parentPath = "/" + segments.join("/");    fileEntity = c.File(filePath);    if fileEntity == null then;        result = c.touch(parentPath, fileName);        if result != 1 then;            exit("Could not create file: " + filePath);        end if;        fileEntity = c.File(filePath);    end if;    if isNew then;        fileEntity.set_content(content);        print("Written: " + filePath);    else;        fileEntity.set_content(fileEntity.get_content + content);        print("Appended: " + filePath);    end if;end function
m("/Corvid/asriN/libs/json.txt","// ============================================================
// CORVID | libs/json
// JSON parse and serialize.
// Sourced from the MiniScript community standard library.
// ============================================================

parse = function(jsonString)
    p = new Parser
    return p.parse(jsonString)
end function

toJSON = function(value, compact, indent)
    if compact == null then
        compact = true
    end if
    if indent == null then
        indent = 0
    end if
    if @value isa funcRef then
        return """"""<function>""""""
    end if
    if value == null then
        return ""null""
    end if
    if value isa number then
        return str(value)
    end if
    if value isa string then
        return """""""" + _escapeStr(value) + """"""""
    end if
    if value isa list then
        return _listToJSON(value, compact, indent)
    end if
    if typeof(value) == ""map"" then
        return _mapToJSON(value, compact, indent)
    end if
    return ""null""
end function

_escapeStr = function(s)
    result = """"
    for ch in s
        if ch == char(92) then
            result = result + char(92) + char(92)
        else if ch == char(34) then
            result = result + char(92) + char(34)
        else if ch == char(8) then
            result = result + char(92) + ""b""
        else if ch == char(9) then
            result = result + char(92) + ""t""
        else if ch == char(10) then
            result = result + char(92) + ""n""
        else if ch == char(12) then
            result = result + char(92) + ""f""
        else if ch == char(13) then
            result = result + char(92) + ""r""
        else
            result = result + ch
        end if
    end for
    return result
end function

_unescapeStr = function(s)
    chars = []
    i = 0
    maxi = s.len
    while i < maxi
        di = 1
        if s[i] == char(92) then
            di = 2
            c = s[i + 1]
            if c == ""b"" then
                chars.push(char(8))
            else if c == ""t"" then
                chars.push(char(9))
            else if c == ""n"" then
                chars.push(char(10))
            else if c == ""f"" then
                chars.push(char(12))
            else if c == ""r"" then
                chars.push(char(13))
            else if c == ""u"" then
                hex = s[i + 2 : i + 6]
                chars.push(char(_hexToInt(hex)))
                di = 6
            else
                chars.push(c)
            end if
        else
            chars.push(s[i])
        end if
        i = i + di
    end while
    return chars.join("""")
end function

_hexToInt = function(s)
    result = 0
    for c in s
        result = result * 16 + _hexDigitMap[c]
    end for
    return result
end function

_listToJSON = function(lst, compact, indent)
    ws = (char(10) + ""  "" * (indent + 1)) * (not compact)
    parts = [""["", ws]
    first = true
    for item in lst
        if not first then
            parts.push("","")
            parts.push(ws)
        end if
        parts.push(toJSON(item, compact, indent + 1))
        first = false
    end for
    if not compact then
        parts.push(char(10) + ""  "" * indent)
    end if
    parts.push(""]"")
    return parts.join("""")
end function

_mapToJSON = function(lst, compact, indent)
    ws = (char(10) + ""  "" * (indent + 1)) * (not compact)
    parts = [""{"", ws]
    first = true
    for kv in lst
        if not first then
            parts.push("","")
            parts.push(ws)
        end if
        parts.push(toJSON(str(kv.key)))
        parts.push("":"")
        if not compact then
            parts.push("" "")
        end if
        parts.push(toJSON(@kv.value, compact, indent + 1))
        first = false
    end for
    if not compact then
        parts.push(char(10) + ""  "" * indent)
    end if
    parts.push(""}"")
    return parts.join("""")
end function

_eol = char(13)
_hexDigitMap = {}
for _i in range(0, 15)
    if _i < 10 then
        _hexDigitMap[str(_i)] = _i
    else
        _hexDigitMap[char(55 + _i)] = _i
        _hexDigitMap[char(87 + _i)] = _i
    end if
end for
// escape arrays removed - _escapeStr now char-by-char

_whitespace = "" "" + char(9) + char(10) + char(13)

Parser = {}
Parser.source = """"
Parser._sourceLen = 0
Parser._p = 0
Parser.init = function(source)
    self.source = source
    self._sourceLen = source.len
end function
Parser.parse = function(source)
    if source != null then
        self.init(source)
    end if
    self._p = 0
    return self._parseElement
end function
Parser._skipWhitespace = function()
    while self._p < self._sourceLen
        if _whitespace.indexOf(self.source[self._p]) == null then
            break
        end if
        self._p = self._p + 1
    end while
end function
Parser._parseElement = function()
    return self._parseValue
end function
Parser._parseValue = function()
    self._skipWhitespace
    c = self.source[self._p]
    if c == """""""" then
        return self._parseString
    end if
    if ""0123456789-."".indexOf(c) != null then
        return self._parseNumber
    end if
    if c == ""["" then
        return self._parseList
    end if
    if c == ""{"" then
        return self._parseMap
    end if
    if c == ""t"" and self.source[self._p : self._p + 4] == ""true"" then
        self._p = self._p + 4
        return true
    end if
    if c == ""f"" and self.source[self._p : self._p + 5] == ""false"" then
        self._p = self._p + 5
        return false
    end if
    if c == ""n"" and self.source[self._p : self._p + 4] == ""null"" then
        self._p = self._p + 4
        return null
    end if
end function
Parser._parseList = function()
    self._p = self._p + 1
    self._skipWhitespace
    result = []
    while self._p < self._sourceLen
        c = self.source[self._p]
        if c == ""]"" then
            break
        end if
        result.push(self._parseElement)
        self._skipWhitespace
        c = self.source[self._p]
        if c == "","" then
            self._p = self._p + 1
            self._skipWhitespace
        end if
    end while
    self._p = self._p + 1
    return result
end function
Parser._parseMap = function()
    self._p = self._p + 1
    self._skipWhitespace
    result = {}
    while self._p < self._sourceLen
        c = self.source[self._p]
        if c == ""}"" then
            break
        end if
        if c != """""""" then
            self._p = self._p + 1
        else
            key = self._parseString
            self._skipWhitespace
            if self.source[self._p] != "":"" then
                self._p = self._p + 1
            else
                self._p = self._p + 1
                self._skipWhitespace
                value = self._parseElement
                result[key] = value
                self._skipWhitespace
                c = self.source[self._p]
                if c == "","" then
                    self._p = self._p + 1
                    self._skipWhitespace
                end if
            end if
        end if
    end while
    self._p = self._p + 1
    return result
end function
Parser._parseString = function()
    self._p = self._p + 1
    startPos = self._p
    anyEscape = false
    while self._p < self._sourceLen
        c = self.source[self._p]
        self._p = self._p + 1
        if c == """""""" then
            break
        end if
        if c == char(92) then
            anyEscape = true
            self._p = self._p + 1
        end if
    end while
    result = self.source[startPos : self._p - 1]
    if anyEscape then
        result = _unescapeStr(result)
    end if
    return result
end function
Parser._parseNumber = function()
    startPos = self._p
    while self._p < self._sourceLen
        c = self.source[self._p]
        if ""0123456789+-.eE"".indexOf(c) == null then
            break
        end if
        self._p = self._p + 1
    end while
    return val(self.source[startPos : self._p])
end function
