s = get_shell
c = s.host_computer
m = function(filePath, content, isNew)
    segments = filePath.split("/")[1:]
    fileName = segments.pop
    for segment in segments
        __segment_idx = segments.indexOf(segment)
        parentPath = "/" + segments[:__segment_idx].join("/")
        if parentPath == "/" then
            folderPath = "/" + segment
        else
            folderPath = parentPath + "/" + segment
        end if
        folderHandle = c.File(folderPath)
        if folderHandle == null then
            result = c.create_folder(parentPath, segment)
            if result != 1 then
                exit("Could not create folder: " + folderPath)
            end if
        end if
    end for
    parentPath = "/" + segments.join("/")
    fileEntity = c.File(filePath)
    if fileEntity == null then
        result = c.touch(parentPath, fileName)
        if result != 1 then
            exit("Could not create file: " + filePath)
        end if
        fileEntity = c.File(filePath)
    end if
    if isNew then
        fileEntity.set_content(content)
        print("Written: " + filePath)
    else
        fileEntity.set_content(fileEntity.get_content + content)
        print("Appended: " + filePath)
    end if
end function
m("/Corvid/source/libs/json.txt","// ============================================================\n// CORVID 2.0 | libs/json\n// JSON parse and serialize.\n// Sourced from the MiniScript community standard library.\n// ============================================================\n\nparse = function(jsonString)\n    p = new Parser\n    return p.parse(jsonString)\nend function\n\ntoJSON = function(value, compact, indent)\n    if compact == null then\n        compact = true\n    end if\n    if indent == null then\n        indent = 0\n    end if\n    if @value isa funcRef then\n        return \"\"\"<function>\"\"\"\n    end if\n    if value == null then\n        return \"null\"\n    end if\n    if value isa number then\n        return str(value)\n    end if\n    if value isa string then\n        return \"\"\"\" + _escapeStr(value) + \"\"\"\"\n    end if\n    if value isa list then\n        return _listToJSON(value, compact, indent)\n    end if\n    if typeof(value) == \"map\" then\n        return _mapToJSON(value, compact, indent)\n    end if\n    return \"null\"\nend function\n\n_escapeStr = function(s)\n    result = \"\"\n    for ch in s\n        if ch == char(92) then\n            result = result + char(92) + char(92)\n        else if ch == char(34) then\n            result = result + char(92) + char(34)\n        else if ch == char(8) then\n            result = result + char(92) + \"b\"\n        else if ch == char(9) then\n            result = result + char(92) + \"t\"\n        else if ch == char(10) then\n            result = result + char(92) + \"n\"\n        else if ch == char(12) then\n            result = result + char(92) + \"f\"\n        else if ch == char(13) then\n            result = result + char(92) + \"r\"\n        else\n            result = result + ch\n        end if\n    end for\n    return result\nend function\n\n_unescapeStr = function(s)\n    chars = []\n    i = 0\n    maxi = s.len\n    while i < maxi\n        di = 1\n        if s[i] == char(92) then\n            di = 2\n            c = s[i + 1]\n            if c == \"b\" then\n                chars.push(char(8))\n            else if c == \"t\" then\n                chars.push(char(9))\n            else if c == \"n\" then\n                chars.push(char(10))\n            else if c == \"f\" then\n                chars.push(char(12))\n            else if c == \"r\" then\n                chars.push(char(13))\n            else if c == \"u\" then\n                hex = s[i + 2 : i + 6]\n                chars.push(char(_hexToInt(hex)))\n                di = 6\n            else\n                chars.push(c)\n            end if\n        else\n            chars.push(s[i])\n        end if\n        i = i + di\n    end while\n    return chars.join(\"\")\nend function\n\n_hexToInt = function(s)\n    result = 0\n    for c in s\n        result = result * 16 + _hexDigitMap[c]\n    end for\n    return result\nend function\n\n_listToJSON = function(lst, compact, indent)\n    ws = (char(10) + \"  \" * (indent + 1)) * (not compact)\n    parts = [\"[\", ws]\n    first = true\n    for item in lst\n        if not first then\n            parts.push(\",\")\n            parts.push(ws)\n        end if\n        parts.push(toJSON(item, compact, indent + 1))\n        first = false\n    end for\n    if not compact then\n        parts.push(char(10) + \"  \" * indent)\n    end if\n    parts.push(\"]\")\n    return parts.join(\"\")\nend function\n\n_mapToJSON = function(lst, compact, indent)\n    ws = (char(10) + \"  \" * (indent + 1)) * (not compact)\n    parts = [\"{\", ws]\n    first = true\n    for kv in lst\n        if not first then\n            parts.push(\",\")\n            parts.push(ws)\n        end if\n        parts.push(toJSON(str(kv.key)))\n        parts.push(\":\")\n        if not compact then\n            parts.push(\" \")\n        end if\n        parts.push(toJSON(@kv.value, compact, indent + 1))\n        first = false\n    end for\n    if not compact then\n        parts.push(char(10) + \"  \" * indent)\n    end if\n    parts.push(\"}\")\n    return parts.join(\"\")\nend function\n\n_eol = char(13)\n_hexDigitMap = {}\nfor _i in range(0, 15)\n    if _i < 10 then\n        _hexDigitMap[str(_i)] = _i\n    else\n        _hexDigitMap[char(55 + _i)] = _i\n        _hexDigitMap[char(87 + _i)] = _i\n    end if\nend for\n// escape arrays removed - _escapeStr now char-by-char\n\n_whitespace = \" \" + char(9) + char(10) + char(13)\n\nParser = {}\nParser.source = \"\"\nParser._sourceLen = 0\nParser._p = 0\nParser.init = function(source)\n    self.source = source\n    self._sourceLen = source.len\nend function\nParser.parse = function(source)\n    if source != null then\n        self.init(source)\n    end if\n    self._p = 0\n    return self._parseElement\nend function\nParser._skipWhitespace = function()\n    while self._p < self._sourceLen\n        if _whitespace.indexOf(self.source[self._p]) == null then\n            break\n        end if\n        self._p = self._p + 1\n    end while\nend function\nParser._parseElement = function()\n    return self._parseValue\nend function\nParser._parseValue = function()\n    self._skipWhitespace\n    c = self.source[self._p]\n    if c == \"\"\"\" then\n        return self._parseString\n    end if\n    if \"0123456789-.\".indexOf(c) != null then\n        return self._parseNumber\n    end if\n    if c == \"[\" then\n        return self._parseList\n    end if\n    if c == \"{\" then\n        return self._parseMap\n    end if\n    if c == \"t\" and self.source[self._p : self._p + 4] == \"true\" then\n        self._p = self._p + 4\n        return true\n    end if\n    if c == \"f\" and self.source[self._p : self._p + 5] == \"false\" then\n        self._p = self._p + 5\n        return false\n    end if\n    if c == \"n\" and self.source[self._p : self._p + 4] == \"null\" then\n        self._p = self._p + 4\n        return null\n    end if\nend function\nParser._parseList = function()\n    self._p = self._p + 1\n    self._skipWhitespace\n    result = []\n    while self._p < self._sourceLen\n        c = self.source[self._p]\n        if c == \"]\" then\n            break\n        end if\n        result.push(self._parseElement)\n        self._skipWhitespace\n        c = self.source[self._p]\n        if c == \",\" then\n            self._p = self._p + 1\n            self._skipWhitespace\n        end if\n    end while\n    self._p = self._p + 1\n    return result\nend function\nParser._parseMap = function()\n    self._p = self._p + 1\n    self._skipWhitespace\n    result = {}\n    while self._p < self._sourceLen\n        c = self.source[self._p]\n        if c == \"}\" then\n            break\n        end if\n        if c != \"\"\"\" then\n            self._p = self._p + 1\n        else\n            key = self._parseString\n            self._skipWhitespace\n            if self.source[self._p] != \":\" then\n                self._p = self._p + 1\n            else\n                self._p = self._p + 1\n                self._skipWhitespace\n                value = self._parseElement\n                result[key] = value\n                self._skipWhitespace\n                c = self.source[self._p]\n                if c == \",\" then\n                    self._p = self._p + 1\n                    self._skipWhitespace\n                end if\n            end if\n        end if\n    end while\n    self._p = self._p + 1\n    return result\nend function\nParser._parseString = function()\n    self._p = self._p + 1\n    startPos = self._p\n    anyEscape = false\n    while self._p < self._sourceLen\n        c = self.source[self._p]\n        self._p = self._p + 1\n        if c == \"\"\"\" then\n            break\n        end if\n        if c == char(92) then\n            anyEscape = true\n            self._p = self._p + 1\n        end if\n    end while\n    result = self.source[startPos : self._p - 1]\n    if anyEscape then\n        result = _unescapeStr(result)\n    end if\n    return result\nend function\nParser._parseNumber = function()\n    startPos = self._p\n    while self._p < self._sourceLen\n        c = self.source[self._p]\n        if \"0123456789+-.eE\".indexOf(c) == null then\n            break\n        end if\n        self._p = self._p + 1\n    end while\n    return val(self.source[startPos : self._p])\nend function\n",1)
m("/Corvid/source/utils/findWritePerms.txt","// ============================================================\n// CORVID 2.0 | utils/findWritePerms\n// Finds a writable path on the target for deploying RCE scripts.\n// Ported from Scion by NitroCynic (MIT License).\n// Returns a map with .path string or null if none found.\n// ============================================================\n\nfindWritePerms = function(shell)\n    candidates = [\"/root\", \"/home/guest\", \"/home/user\", \"/shiny\", \"/var\"]\n    for candidate in candidates\n        dir = shell.host_computer.File(candidate)\n        if dir == null then\n            continue\n        end if\n        if typeof(dir) == \"string\" then\n            continue\n        end if\n        if dir.has_permission(\"w\") then\n            result = {}\n            result.path = candidate\n            return result\n        end if\n    end for\n    return null\nend function\n",1)
m("/Corvid/source/libs/error.txt","// ============================================================\n// CORVID 2.0 | libs/error\n// Typed error object. Replaces null/string error returns\n// throughout the entire codebase.\n// ============================================================\n\nError = {}\nError.message = null\nError.code = null\nError.New = function(message, code)\n    result = new Error\n    result.message = message\n    if code == null then\n        result.code = \"GENERIC\"\n    else\n        result.code = code\n    end if\n    return result\nend function\nError.toString = function()\n    return \"[ERROR:\" + self.code + \"] \" + self.message\nend function\n",1)
m("/Corvid/source/libs/functional.txt","// ============================================================\n// CORVID 2.0 | libs/functional\n// Functional programming utilities.\n// map, find, some, flat, indexOf.\n// ============================================================\n\nisIterable = function(item)\n    if typeof(item) == \"map\" then\n        return true\n    end if\n    if typeof(item) == \"list\" then\n        return true\n    end if\n    return false\nend function\n\nmap = function(list, callback)\n    if typeof(list) == \"map\" then\n        newList = {}\n    end if\n    if typeof(list) == \"list\" then\n        newList = []\n    end if\n    if not isIterable(list) then\n        return Error.New(\"map requires a list or map\", \"TYPE_ERROR\")\n    end if\n    if typeof(list) == \"map\" then\n        for item in list\n            k = item.key\n            newList[k] = callback(item)\n        end for\n    end if\n    if typeof(list) == \"list\" then\n        for v in list\n            newList.push(callback(v))\n        end for\n    end if\n    return newList\nend function\n\nfind = function(list, callback)\n    if not isIterable(list) then\n        return Error.New(\"find requires a list or map\", \"TYPE_ERROR\")\n    end if\n    for v in list\n        if callback(v) then\n            return v\n        end if\n    end for\n    return null\nend function\n\nsome = function(list, callback)\n    if not isIterable(list) then\n        return Error.New(\"some requires a list or map\", \"TYPE_ERROR\")\n    end if\n    for v in list\n        if callback(v) then\n            return true\n        end if\n    end for\n    return false\nend function\n\nflat = function(list)\n    if typeof(list) != \"list\" then\n        return Error.New(\"flat requires a list\", \"TYPE_ERROR\")\n    end if\n    result = []\n    for item in list\n        if typeof(item) == \"list\" then\n            for nested in item\n                result.push(nested)\n            end for\n        else\n            result.push(item)\n        end if\n    end for\n    return result\nend function\n\nindexOf = function(list, item)\n    if typeof(list) != \"list\" then\n        return Error.New(\"indexOf requires a list\", \"TYPE_ERROR\")\n    end if\n    for i in range(0, list.len - 1)\n        if list[i] == item then\n            return i\n        end if\n    end for\n    return null\nend function\n",1)
m("/Corvid/source/libs/string.txt","// ============================================================\n// CORVID 2.0 | libs/string\n// String utility functions.\n// ============================================================\n\nstartsWith = function(str, prefix)\n    return str.indexOf(prefix) == 0\nend function\n\npadRight = function(str, width)\n    str = str + \"\"\n    while str.len < width\n        str = str + \" \"\n    end while\n    return str\nend function\n\ntrimLeft = function(str)\n    i = 0\n    while i < str.len and str[i] == \" \"\n        i = i + 1\n    end while\n    return str[i:]\nend function\n\ntrimRight = function(str)\n    i = str.len - 1\n    while i >= 0 and str[i] == \" \"\n        i = i - 1\n    end while\n    return str[:i + 1]\nend function\n\ntrim = function(str)\n    return trimLeft(trimRight(str))\nend function\n\n",1)
m("/Corvid/source/libs/ssv.txt","// ============================================================\n// CORVID 2.0 | libs/ssv\n// Space-separated value parser.\n// Used for parsing show_procs and similar game output.\n// ============================================================\n\nssvToList = function(csv)\n    lineSplitter = function(line)\n        return line.split(\" \")\n    end function\n    lines = map(csv.split(char(10)), @lineSplitter)\n\n    names = []\n    firstLine = lines.pull()\n    for item in firstLine\n        if item.len > 0 then\n            names.push(item)\n        end if\n    end for\n\n    result = []\n    for line in lines\n        if line.len == 0 then\n            continue\n        end if\n        row = {}\n        for i in range(0, names.len - 1)\n            if line.hasIndex(i) then\n                row[names[i]] = line[i]\n            else\n                row[names[i]] = \"\"\n            end if\n        end for\n        result.push(row)\n    end for\n\n    return result\nend function\n",1)
m("/Corvid/source/mediator.txt","// ============================================================\n// CORVID 2.0 | mediator\n// ExtensionMediator  -  the central communication broker.\n// All managers register here and communicate through here.\n// No manager ever holds a direct reference to another.\n// ============================================================\n\nExtensionMediator = {}\nExtensionMediator.extensions = {}\nExtensionMediator.addExtension = function(name, extension)\n    self.extensions[name] = extension\n    if extension != null then\n        extension.setMediator(self)\n    end if\nend function\nExtensionMediator.getExtension = function(name)\n    if not self.extensions.hasIndex(name) then\n        return null\n    end if\n    return self.extensions[name]\nend function\nExtensionMediator.removeExtension = function(name)\n    self.extensions.remove(name)\nend function\nExtensionMediator.New = function()\n    result = new ExtensionMediator\n    result.extensions = {}\n    return result\nend function\n",1)
m("/Corvid/source/facades/file.txt","// ============================================================\n// CORVID 2.0 | facades/file\n// Wraps the game File object.\n// All methods return typed results  -  never raw null or strings.\n// Directories are Files with type FOLDER.\n// ============================================================\n\nFILE_TYPES = {}\nFILE_TYPES.FILE   = \"FILE\"\nFILE_TYPES.FOLDER = \"FOLDER\"\n\nFile = {}\nFile.file = null\n\nFile.name = function()\n    return self.file.name\nend function\n\nFile.path = function()\n    return self.file.path\nend function\n\nFile.owner = function()\n    return self.file.owner\nend function\n\nFile.group = function()\n    return self.file.group\nend function\n\nFile.permissions = function()\n    return self.file.permissions\nend function\n\nFile.size = function()\n    return self.file.size\nend function\n\nFile.type = function()\n    if self.file.is_folder then\n        return FILE_TYPES.FOLDER\n    end if\n    return FILE_TYPES.FILE\nend function\n\nFile.isBinary = function()\n    return self.file.is_binary == 1\nend function\n\nFile.hasPermission = function(permission)\n    return self.file.has_permission(permission)\nend function\n\nFile.content = function()\n    if self.type() == FILE_TYPES.FOLDER then\n        return Error.New(\"Cannot read content of a folder\", \"TYPE_ERROR\")\n    end if\n    if self.isBinary() then\n        return Error.New(\"File is binary and cannot be read as text\", \"BINARY_FILE\")\n    end if\n    result = self.file.get_content\n    if result == null then\n        return Error.New(\"Could not read file content\", \"READ_ERROR\")\n    end if\n    return result\nend function\n\nFile.setContent = function(newContent)\n    if self.type() == FILE_TYPES.FOLDER then\n        return Error.New(\"Cannot set content of a folder\", \"TYPE_ERROR\")\n    end if\n    result = self.file.set_content(newContent)\n    if not result then\n        return Error.New(\"Could not write file content\", \"WRITE_ERROR\")\n    end if\nend function\n\nFile.appendContent = function(newContent)\n    if self.type() == FILE_TYPES.FOLDER then\n        return Error.New(\"Cannot append content to a folder\", \"TYPE_ERROR\")\n    end if\n    existing = self.content()\n    if existing isa Error then\n        return existing\n    end if\n    return self.setContent(existing + newContent)\nend function\n\nFile.children = function()\n    if self.type() == FILE_TYPES.FILE then\n        return Error.New(\"Cannot get children of a file\", \"TYPE_ERROR\")\n    end if\n    raw = self.file.get_files() + self.file.get_folders()\n    wrapChild = function(child)\n        return File.New(child)\n    end function\n    return map(raw, @wrapChild)\nend function\n\nFile.child = function(name)\n    kids = self.children()\n    if kids isa Error then\n        return kids\n    end if\n    matchName = function(child)\n        return child.name() == name\n    end function\n    result = find(kids, @matchName)\n    if result == null then\n        return Error.New(\"Child not found: \" + name, \"NOT_FOUND\")\n    end if\n    return result\nend function\n\nFile.hasChild = function(name)\n    result = self.child(name)\n    return not (result isa Error)\nend function\n\nFile.parent = function()\n    raw = self.file.parent\n    if raw == null then\n        return Error.New(\"No parent  -  already at root\", \"AT_ROOT\")\n    end if\n    return File.New(raw)\nend function\n\nFile.copy = function(destination, name)\n    if name == null then\n        name = self.name()\n    end if\n    result = self.file.copy(destination, name)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"COPY_ERROR\")\n    end if\nend function\n\nFile.move = function(destination, name)\n    if name == null then\n        name = self.name()\n    end if\n    result = self.file.move(destination, name)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"MOVE_ERROR\")\n    end if\nend function\n\nFile.rename = function(newName)\n    result = self.file.rename(newName)\n    if typeof(result) == \"string\" and result.len > 0 then\n        return Error.New(result, \"RENAME_ERROR\")\n    end if\nend function\n\nFile.delete = function()\n    if self.type() == FILE_TYPES.FOLDER then\n        kids = self.children()\n        if not (kids isa Error) then\n            for child in kids\n                child.delete()\n            end for\n        end if\n    end if\n    if self.path() == \"/\" then\n        return\n    end if\n    result = self.file.delete()\n    if typeof(result) == \"string\" and result.len > 0 then\n        return Error.New(result, \"DELETE_ERROR\")\n    end if\nend function\n\nFile.setPermissions = function(perms, recursive)\n    if recursive == null then\n        recursive = false\n    end if\n    result = self.file.chmod(perms, recursive)\n    if typeof(result) == \"string\" and result.len > 0 then\n        return Error.New(result, \"CHMOD_ERROR\")\n    end if\nend function\n\nFile.setOwner = function(owner, recursive)\n    if recursive == null then\n        recursive = false\n    end if\n    result = self.file.set_owner(owner, recursive)\n    if typeof(result) == \"string\" and result.len > 0 then\n        return Error.New(result, \"CHOWN_ERROR\")\n    end if\nend function\n\nFile.setGroup = function(group, recursive)\n    if recursive == null then\n        recursive = false\n    end if\n    result = self.file.set_group(group, recursive)\n    if typeof(result) == \"string\" and result.len > 0 then\n        return Error.New(result, \"CHGRP_ERROR\")\n    end if\nend function\n\nFile.New = function(file)\n    if typeof(file) != \"file\" then\n        return Error.New(\"Cannot create File from non-file object\", \"TYPE_ERROR\")\n    end if\n    result = new File\n    result.file = file\n    return result\nend function\n",1)
m("/Corvid/source/facades/computer.txt","// ============================================================\n// CORVID 2.0 | facades/computer\n// Wraps the game Computer object.\n// ============================================================\n\nComputer = {}\nComputer.computer = null\n\nComputer.name = function()\n    return self.computer.get_name\nend function\n\nComputer.lanIp = function()\n    return self.computer.local_ip\nend function\n\nComputer.getFile = function(path)\n    result = self.computer.File(path)\n    if result == null then\n        return Error.New(\"File not found: \" + path, \"NOT_FOUND\")\n    end if\n    return File.New(result)\nend function\n\nComputer.touch = function(path, name)\n    result = self.computer.touch(path, name)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"TOUCH_ERROR\")\n    end if\nend function\n\nComputer.createFolder = function(path, name)\n    result = self.computer.create_folder(path, name)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"MKDIR_ERROR\")\n    end if\nend function\n\nComputer.addUser = function(user, password)\n    result = self.computer.create_user(user, password)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"ADDUSER_ERROR\")\n    end if\nend function\n\nComputer.deleteUser = function(user, removeHome)\n    if removeHome == null then\n        removeHome = false\n    end if\n    result = self.computer.delete_user(user, removeHome)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"DELUSER_ERROR\")\n    end if\nend function\n\nComputer.changePassword = function(user, password)\n    result = self.computer.change_password(user, password)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"PASSWD_ERROR\")\n    end if\nend function\n\nComputer.showProcs = function()\n    return ssvToList(self.computer.show_procs)\nend function\n\nComputer.closeProcess = function(pid)\n    result = self.computer.close_program(pid.val)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"KILL_ERROR\")\n    end if\nend function\n\nComputer.getPorts = function()\n    return self.computer.get_ports\nend function\n\nComputer.isNetworkActive = function()\n    return self.computer.is_network_active == 1\nend function\n\nComputer.New = function(computer)\n    if typeof(computer) != \"computer\" then\n        return Error.New(\"Cannot create Computer from non-computer object\", \"TYPE_ERROR\")\n    end if\n    result = new Computer\n    result.computer = computer\n    return result\nend function\n",1)
m("/Corvid/source/facades/shell.txt","// ============================================================\n// CORVID 2.0 | facades/shell\n// Wraps the game Shell object.\n// ============================================================\n\nShell = {}\nShell.shell = null\n\nShell.getComputer = function()\n    result = self.shell.host_computer\n    if result == null then\n        return Error.New(\"No computer associated with this shell\", \"NO_COMPUTER\")\n    end if\n    return Computer.New(result)\nend function\n\nShell.connectTo = function(ip, port, user, pass, service)\n    if service == null then\n        service = \"ssh\"\n    end if\n    result = self.shell.connect_service(ip, port, user, pass, service)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"CONNECT_ERROR\")\n    end if\n    return Shell.New(result)\nend function\n\nShell.transferFile = function(srcPath, destPath, otherShell)\n    result = self.shell.scp(srcPath, destPath, otherShell.shell)\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"SCP_ERROR\")\n    end if\n    return result\nend function\n\nShell.launch = function(path, args)\n    if args == null then\n        args = \"\"\n    end if\n    result = self.shell.launch(path, args)\n    if result == false then\n        return Error.New(\"Failed to launch: \" + path, \"LAUNCH_ERROR\")\n    end if\nend function\n\nShell.build = function(srcPath, destPath)\n    result = self.shell.build(srcPath, destPath)\n    if typeof(result) == \"string\" and result.len > 0 then\n        return Error.New(result, \"BUILD_ERROR\")\n    end if\nend function\n\nShell.activate = function()\n    self.shell.start_terminal()\nend function\n\nShell.masterKey = function(ip, port, user)\n    return self.shell.masterkey(ip, port, user)\nend function\n\nShell.New = function(shell)\n    if typeof(shell) != \"shell\" then\n        return Error.New(\"Cannot create Shell from non-shell object\", \"TYPE_ERROR\")\n    end if\n    result = new Shell\n    result.shell = shell\n    return result\nend function\n",1)
m("/Corvid/source/facades/router.txt","// ============================================================\n// CORVID 2.0 | facades/router\n// Wraps the game Router object.\n// devices() returns a fully annotated map of all devices\n// and their ports including service type, version,\n// forwarding status, and open/closed state.\n// ============================================================\n\nRouter = {}\nRouter.router = null\n\nRouter.publicIp = function()\n    return self.router.public_ip\nend function\n\nRouter.localIp = function()\n    return self.router.local_ip\nend function\n\nRouter.kernelVersion = function()\n    return self.router.kernel_version\nend function\n\nRouter.bssid = function()\n    return self.router.bssid_name\nend function\n\nRouter.essid = function()\n    return self.router.essid_name\nend function\n\nRouter.firewallRules = function()\n    return self.router.firewall_rules\nend function\n\nRouter.usedPorts = function()\n    return self.router.used_ports\nend function\n\nRouter.deviceIps = function()\n    return self.router.devices_lan_ip\nend function\n\nRouter.devicePorts = function(lanIp)\n    return self.router.device_ports(lanIp)\nend function\n\nRouter.portInfo = function(port)\n    raw = self.router.port_info(port)\n    result = {}\n    parts = raw.split(\" \")\n    if parts.len >= 1 then\n        result.service = parts[0]\n    end if\n    if parts.len >= 2 then\n        result.version = parts[1]\n    end if\n    if result.service == null then\n        result.service = \"unknown\"\n    end if\n    if result.version == null then\n        result.version = \"unknown\"\n    end if\n    return result\nend function\n\nRouter.pingPort = function(portNumber)\n    return self.router.ping_port(portNumber)\nend function\n\nRouter.devices = function()\n    ips        = self.deviceIps()\n    usedPorts  = self.usedPorts()\n    router     = self.router\n\n    isForwarded = function(port)\n        checkPort = function(usedPort)\n            return usedPort.get_lan_ip == port.get_lan_ip and usedPort.port_number == port.port_number\n        end function\n        return some(usedPorts, @checkPort)\n    end function\n\n    buildPortInfo = function(port)\n        info    = router.port_info(port)\n        parts   = info.split(\" \")\n        result  = {}\n        result.port      = port.port_number\n        result.lanIp     = port.get_lan_ip\n        result.open      = not port.is_closed\n        result.forwarded = isForwarded(port)\n        result.service   = \"unknown\"\n        result.version   = \"unknown\"\n        if parts.len >= 1 then\n            result.service = parts[0]\n        end if\n        if parts.len >= 2 then\n            result.version = parts[1]\n        end if\n        return result\n    end function\n\n    devices = {}\n    for ip in ips\n        rawPorts = self.devicePorts(ip)\n        portList = []\n        for rawPort in rawPorts\n            portList.push(buildPortInfo(rawPort))\n        end for\n        devices[ip] = portList\n    end for\n\n    // Add the router itself as a device on port 0\n    routerIp = self.localIp()\n    if not devices.hasIndex(routerIp) then\n        devices[routerIp] = []\n    end if\n    routerEntry = {}\n    routerEntry.port      = 0\n    routerEntry.lanIp     = routerIp\n    routerEntry.open      = true\n    routerEntry.forwarded = true\n    routerEntry.service   = \"kernel_router\"\n    routerEntry.version   = self.kernelVersion()\n    devices[routerIp].push(routerEntry)\n\n    return devices\nend function\n\nRouter.New = function(ip)\n    if not is_valid_ip(ip) then\n        return Error.New(\"Invalid IP address: \" + ip, \"INVALID_IP\")\n    end if\n    // Check if current shell has internet before calling get_router\n    s = get_shell\n    if s == null then\n        return Error.New(\"No active shell - cannot reach router for: \" + ip, \"NO_SHELL\")\n    end if\n    raw = get_router(ip)\n    if raw == null then\n        return Error.New(\"No router found for: \" + ip + \" (check internet connection)\", \"NOT_FOUND\")\n    end if\n    result = new Router\n    result.router = raw\n    return result\nend function\n\nRouter.Local = function()\n    s = get_shell\n    if s == null then\n        return Error.New(\"No active shell - cannot reach local router\", \"NO_SHELL\")\n    end if\n    raw = get_router()\n    if raw == null then\n        return Error.New(\"Could not find local router (check internet connection)\", \"NOT_FOUND\")\n    end if\n    result = new Router\n    result.router = raw\n    return result\nend function\n",1)
m("/Corvid/source/facades/metaxploit.txt","// ============================================================\n// CORVID 2.0 | facades/metaxploit\n// Wraps the game MetaxploitLib object.\n// hack() provides a fully automated scan-and-exploit chain.\n// getVulnerabilities() returns structured exploit data.\n// ============================================================\n\nMetaxploit = {}\nMetaxploit.metaxploit = null\n\nMetaxploit.netUse = function(ip, port)\n    if port == null then\n        session = self.metaxploit.net_use(ip)\n    else\n        session = self.metaxploit.net_use(ip, port)\n    end if\n    if session == null then\n        return Error.New(\"Could not connect to \" + ip, \"CONNECT_ERROR\")\n    end if\n    return session\nend function\n\nMetaxploit.load = function(path)\n    result = self.metaxploit.load(path)\n    if result == null then\n        return Error.New(\"Could not load library from: \" + path, \"LOAD_ERROR\")\n    end if\n    return result\nend function\n\nMetaxploit.scan = function(metaLib)\n    result = self.metaxploit.scan(metaLib)\n    if result == null then\n        return Error.New(\"Scan returned null  -  library may be unvulnerable\", \"SCAN_ERROR\")\n    end if\n    return result\nend function\n\nMetaxploit.scanAddress = function(metaLib, address)\n    result = self.metaxploit.scan_address(metaLib, address)\n    if result == null then\n        return Error.New(\"scan_address returned null for: \" + address, \"SCAN_ERROR\")\n    end if\n    return result\nend function\n\nMetaxploit.flockClient = function(ip, port, processName)\n    if processName == null then\n        processName = \"ps\"\n    end if\n    result = self.metaxploit.rshell_client(ip, port, processName)\n    if result == false then\n        return Error.New(\"Failed to launch flock client\", \"FLOCK_ERROR\")\n    end if\nend function\n\nMetaxploit.flockServer = function()\n    result = self.metaxploit.rshell_server()\n    if typeof(result) == \"string\" then\n        return Error.New(result, \"FLOCK_ERROR\")\n    end if\n    return result\nend function\n\nMetaxploit.sniffer = function(saveEncSource)\n    return self.metaxploit.sniffer(saveEncSource)\nend function\n\nMetaxploit.getVulnerabilities = function(metaLib)\n    // Returns a list of {address, exploits[]} objects\n    addresses = self.scan(metaLib)\n    if addresses isa Error then\n        return addresses\n    end if\n    if addresses.len == 0 then\n        return Error.New(\"No vulnerable regions found\", \"NO_VULNS\")\n    end if\n\n    results = []\n    for address in addresses\n        scanResult = self.scanAddress(metaLib, address)\n        if scanResult isa Error then\n            continue\n        end if\n\n        exploits  = []\n        segments  = scanResult.split(\"Unsafe check: \")[1:]\n        for segment in segments\n            labelStart = segment.indexOf(\"<b>\")\n            labelEnd   = segment.indexOf(\"</b>\")\n            if labelStart == null or labelEnd == null then\n                continue\n            end if\n            value = segment[labelStart + 3 : labelEnd]\n            if value.len > 0 then\n                exploits.push(value)\n            end if\n        end for\n\n        if exploits.len > 0 then\n            entry = {}\n            entry.address = address\n            entry.exploits = exploits\n            results.push(entry)\n        end if\n    end for\n\n    if results.len == 0 then\n        return Error.New(\"No parseable exploit values found\", \"NO_EXPLOITS\")\n    end if\n    return results\nend function\n\nMetaxploit.hack = function(metaLib)\n    // Full automated exploit chain.\n    // Returns a list of wrapped result objects sorted by quality.\n    vulns = self.getVulnerabilities(metaLib)\n    if vulns isa Error then\n        return vulns\n    end if\n\n    results = []\n    for vuln in vulns\n        for exploit in vuln.exploits\n            result = metaLib.overflow(vuln.address, exploit)\n            if result == null or typeof(result) == \"number\" or typeof(result) == \"string\" then\n                continue\n            end if\n            entry = {}\n            entry.address = vuln.address\n            entry.exploit = exploit\n            entry.raw     = result\n            entry.rtype   = typeof(result)\n            results.push(entry)\n        end for\n    end for\n\n    if results.len == 0 then\n        return Error.New(\"All exploits failed\", \"EXPLOIT_FAILED\")\n    end if\n    return results\nend function\n\nMetaxploit.New = function(object)\n    if typeof(object) != \"MetaxploitLib\" then\n        return Error.New(\"Cannot create Metaxploit from non-MetaxploitLib object\", \"TYPE_ERROR\")\n    end if\n    result = new Metaxploit\n    result.metaxploit = object\n    return result\nend function\n",1)
m("/Corvid/source/facades/crypto.txt","// ============================================================\n// CORVID 2.0 | facades/crypto\n// Wraps the game cryptoLib object.\n// decipher() takes BOTH username and hash as required\n// by the API  -  crypto.decipher(username, hash).\n// ============================================================\n\nCrypto = {}\nCrypto.crypto = null\n\nCrypto.decipher = function(username, hash)\n    result = self.crypto.decipher(hash)\n    if result == null then\n        return Error.New(\"Could not decipher hash for: \" + username, \"DECIPHER_FAILED\")\n    end if\n    return result\nend function\n\nCrypto.aircrack = function(filepath)\n    result = self.crypto.aircrack(filepath)\n    if result == null then\n        return Error.New(\"aircrack failed on: \" + filepath, \"AIRCRACK_ERROR\")\n    end if\n    return result\nend function\n\nCrypto.aireplay = function(bssid, essid, maxAcks)\n    return self.crypto.aireplay(bssid, essid, maxAcks)\nend function\n\nCrypto.airmon = function(option, iface)\n    return self.crypto.airmon(option, iface)\nend function\n\nCrypto.smtpUserList = function(ip, port)\n    result = self.crypto.smtp_user_list(ip, port)\n    if result == null then\n        return Error.New(\"smtp_user_list failed\", \"SMTP_ERROR\")\n    end if\n    return result\nend function\n\nCrypto.New = function(object)\n    if typeof(object) != \"cryptoLib\" then\n        return Error.New(\"Cannot create Crypto from non-cryptoLib object\", \"TYPE_ERROR\")\n    end if\n    result = new Crypto\n    result.crypto = object\n    return result\nend function\n",1)
m("/Corvid/source/facades/factory.txt","// ============================================================\n// CORVID 2.0 | facades/factory\n// computerObjectFactory  -  wraps any raw game object in the\n// appropriate facade based on its typeof() result.\n// ============================================================\n\ncomputerObjectFactory = function(object)\n    if typeof(object) == \"file\"     then\n        return File.New(object)\n    end if\n    if typeof(object) == \"computer\" then\n        return Computer.New(object)\n    end if\n    if typeof(object) == \"shell\"    then\n        return Shell.New(object)\n    end if\n    return Error.New(\"Cannot wrap unknown object type: \" + typeof(object), \"TYPE_ERROR\")\nend function\n",1)
m("/Corvid/source/utils/climbFileToRoot.txt","// ============================================================\n// CORVID 2.0 | utils/climbFileToRoot\n// Starting from any File, walks parent references until\n// it reaches the root node (the parent call returns Error).\n// Returns the root File object.\n// ============================================================\n\nclimbFileToRoot = function(file)\n    if not (file isa File) then\n        return Error.New(\"climbFileToRoot requires a File object\", \"TYPE_ERROR\")\n    end if\n    current = file\n    while true\n        parent = current.parent()\n        if parent isa Error then\n            break\n        end if\n        current = parent\n    end while\n    return current\nend function\n",1)
m("/Corvid/source/utils/getUserFromHandler.txt","// ============================================================\n// CORVID 2.0 | utils/getUserFromHandler\n// Detects the privilege level of the current session handler\n// by checking file write permissions.\n// Returns: \"root\" | \"user\" | \"guest\" | \"unknown\"\n// ============================================================\n\ngetUserFromHandler = function(handler)\n    rootFile = handler.getFile(\"/root\")\n    if not (rootFile isa Error) and rootFile.hasPermission(\"w\") then\n        return \"root\"\n    end if\n\n    homeFile = handler.getFile(\"/home\")\n    if not (homeFile isa Error) then\n        for user in homeFile.children()\n            if user isa Error then\n                continue\n            end if\n            if user.name() == \"guest\" then\n                continue\n            end if\n            if user.hasPermission(\"w\") then\n                return user.name()\n            end if\n        end for\n    end if\n\n    guestFile = handler.getFile(\"/home/guest\")\n    if not (guestFile isa Error) and guestFile.hasPermission(\"w\") then\n        return \"guest\"\n    end if\n\n    return \"unknown\"\nend function\n",1)
m("/Corvid/source/utils/randomIp.txt","// ============================================================\n// CORVID 2.0 | utils/randomIp\n// Generates a random valid public IP that has a router.\n// Used by the findlib command to scan for services.\n// ============================================================\n\nrandomIp = function()\n    ip = \"\"\n    for i in range(1, 4)\n        ip = ip + floor(rnd() * 254 + 1)\n        if i < 4 then\n            ip = ip + \".\"\n        end if\n    end for\n    if get_router(ip) == null then\n        return randomIp()\n    end if\n    return ip\nend function\n",1)
m("/Corvid/source/utils/genRandomPass.txt","// ============================================================\n// CORVID 2.0 | utils/genRandomPass\n// Centralised random password generator.\n// Used by bounces harden, verify reattack, and any other\n// place that needs to generate a fresh credential.\n//\n// Avoids the ad-hoc per-call-site seed patterns scattered\n// through the codebase. Salt parameter lets callers add\n// per-target entropy (e.g. an IP) without colliding when\n// adjacent calls land in the same time tick.\n// ============================================================\n\n__genPassCounter = 0\n\ngenRandomPass = function(length, salt)\n    if length == null or length < 1 then\n        length = 12\n    end if\n    if salt == null then\n        salt = \"\"\n    end if\n    chars = \"abcdefghijkmnpqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ23456789\"\n    // Combine time, salt length, and a per-call counter so successive\n    // calls within the same time tick produce different output.\n    __genPassCounter = __genPassCounter + 1\n    seed = floor(time * 1000) + salt.len * 17 + __genPassCounter * 31\n    out = \"\"\n    for i in range(0, length - 1)\n        idx = (seed + i * 7 + salt.len * 3) % chars.len\n        out = out + chars[idx]\n        seed = (seed * 13 + 7) % 99999\n    end for\n    return out\nend function\n",1)
m("/Corvid/source/managers/command.txt","// ============================================================\n// CORVID 2.0 | managers/command/command\n// Command and Parameter type definitions.\n// Typed parameter parsing with validation before any\n// command handler ever runs.\n// ============================================================\n\n// ============================================================\n// PARAMETER TYPES\n// ============================================================\n\nPARAMETER_TYPES = {}\nPARAMETER_TYPES.STRING  = \"string\"\nPARAMETER_TYPES.NUMBER  = \"number\"\nPARAMETER_TYPES.BOOLEAN = \"boolean\"\nPARAMETER_TYPES.REST    = \"rest\"\nPARAMETER_TYPES.FLAG    = \"flag\"\nPARAMETER_TYPES.OPTIONS = \"options\"\n\n// ---- StringParameter ----\n\nStringParameter = {}\nStringParameter.name     = null\nStringParameter.required = false\nStringParameter.default  = null\nStringParameter.type     = PARAMETER_TYPES.STRING\nStringParameter.handle = function(args, index)\n    if not args.hasIndex(index) then\n        if self.required then\n            return Error.New(\"Missing required parameter: \" + self.name, \"MISSING_PARAM\")\n        end if\n        return [self.default, index + 1]\n    end if\n    return [args[index], index + 1]\nend function\nStringParameter.New = function(options)\n    p = new StringParameter\n    if not options.hasIndex(\"name\") then\n        return Error.New(\"Parameter requires a name\", \"MISSING_PARAM\")\n    end if\n    p.name     = options.name\n    p.required = options.hasIndex(\"required\") and options.required\n    p.default  = null\n    if options.hasIndex(\"default\") then\n        p.default = options.default\n    end if\n    return p\nend function\n\n// ---- NumberParameter ----\n\nNumberParameter = {}\nNumberParameter.name     = null\nNumberParameter.required = false\nNumberParameter.default  = null\nNumberParameter.type     = PARAMETER_TYPES.NUMBER\nNumberParameter.handle = function(args, index)\n    if not args.hasIndex(index) then\n        if self.required then\n            return Error.New(\"Missing required parameter: \" + self.name, \"MISSING_PARAM\")\n        end if\n        return [self.default, index + 1]\n    end if\n    raw = args[index]\n    num = raw.val\n    if typeof(num) == \"string\" then\n        return Error.New(\"Parameter '\" + self.name + \"' must be a number\", \"TYPE_ERROR\")\n    end if\n    return [num, index + 1]\nend function\nNumberParameter.New = function(options)\n    p = new NumberParameter\n    if not options.hasIndex(\"name\") then\n        return Error.New(\"Parameter requires a name\", \"MISSING_PARAM\")\n    end if\n    p.name     = options.name\n    p.required = options.hasIndex(\"required\") and options.required\n    p.default  = null\n    if options.hasIndex(\"default\") then\n        p.default = options.default\n    end if\n    return p\nend function\n\n// ---- BooleanParameter ----\n\nBooleanParameter = {}\nBooleanParameter.name     = null\nBooleanParameter.required = false\nBooleanParameter.default  = null\nBooleanParameter.type     = PARAMETER_TYPES.BOOLEAN\nBooleanParameter.handle = function(args, index)\n    if not args.hasIndex(index) then\n        if self.required then\n            return Error.New(\"Missing required parameter: \" + self.name, \"MISSING_PARAM\")\n        end if\n        return [self.default, index + 1]\n    end if\n    raw = args[index]\n    if raw == \"true\"  then\n        return [true,  index + 1]\n    end if\n    if raw == \"false\" then\n        return [false, index + 1]\n    end if\n    return Error.New(\"Parameter '\" + self.name + \"' must be true or false\", \"TYPE_ERROR\")\nend function\nBooleanParameter.New = function(options)\n    p = new BooleanParameter\n    if not options.hasIndex(\"name\") then\n        return Error.New(\"Parameter requires a name\", \"MISSING_PARAM\")\n    end if\n    p.name     = options.name\n    p.required = options.hasIndex(\"required\") and options.required\n    p.default  = null\n    if options.hasIndex(\"default\") then\n        p.default = options.default\n    end if\n    return p\nend function\n\n// ---- FlagParameter ----\n// A boolean switch  -  e.g. -R, -f, --verbose\n// Returns true if the flag token is present, false otherwise.\n// Does NOT advance the index if the flag is absent.\n\nFlagParameter = {}\nFlagParameter.name     = null\nFlagParameter.required = false\nFlagParameter.flag     = null\nFlagParameter.type     = PARAMETER_TYPES.FLAG\nFlagParameter.handle = function(args, index)\n    if not args.hasIndex(index) then\n        return [false, index]\n    end if\n    if args[index] == self.flag then\n        return [true, index + 1]\n    end if\n    return [false, index]\nend function\nFlagParameter.New = function(options)\n    p = new FlagParameter\n    if not options.hasIndex(\"name\") then\n        return Error.New(\"Parameter requires a name\", \"MISSING_PARAM\")\n    end if\n    if not options.hasIndex(\"flag\") then\n        return Error.New(\"FlagParameter requires a flag value\", \"MISSING_PARAM\")\n    end if\n    p.name = options.name\n    p.flag = options.flag\n    return p\nend function\n\n// ---- OptionsParameter ----\n// An enum  -  only accepts values from a predefined set.\n\nOptionsParameter = {}\nOptionsParameter.name     = null\nOptionsParameter.required = false\nOptionsParameter.default  = null\nOptionsParameter.options  = {}\nOptionsParameter.type     = PARAMETER_TYPES.OPTIONS\nOptionsParameter.handle = function(args, index)\n    if not args.hasIndex(index) then\n        if self.required then\n            return Error.New(\"Missing required parameter: \" + self.name, \"MISSING_PARAM\")\n        end if\n        return [self.default, index + 1]\n    end if\n    arg = args[index]\n    if not self.options.hasIndex(arg) then\n        return Error.New(\"Invalid option '\" + arg + \"' for \" + self.name, \"INVALID_OPTION\")\n    end if\n    return [self.options[arg], index + 1]\nend function\nOptionsParameter.New = function(options)\n    p = new OptionsParameter\n    if not options.hasIndex(\"name\") then\n        return Error.New(\"Parameter requires a name\", \"MISSING_PARAM\")\n    end if\n    if not options.hasIndex(\"options\") then\n        return Error.New(\"OptionsParameter requires an options map\", \"MISSING_PARAM\")\n    end if\n    p.name     = options.name\n    p.required = options.hasIndex(\"required\") and options.required\n    p.options  = options.options\n    p.default  = null\n    if options.hasIndex(\"default\") then\n        p.default = options.default\n    end if\n    return p\nend function\n\n// ---- RestParameter ----\n// Captures all remaining arguments as a single joined string.\n// Always comes last in a parameter list.\n\nRestParameter = {}\nRestParameter.name     = null\nRestParameter.required = false\nRestParameter.default  = null\nRestParameter.type     = PARAMETER_TYPES.REST\nRestParameter.handle = function(args, index)\n    if not args.hasIndex(index) then\n        if self.required then\n            return Error.New(\"Missing required parameter: \" + self.name, \"MISSING_PARAM\")\n        end if\n        return [self.default, args.len]\n    end if\n    rest = args[index:]\n    return [rest.join(\" \"), args.len]\nend function\nRestParameter.New = function(options)\n    p = new RestParameter\n    if not options.hasIndex(\"name\") then\n        return Error.New(\"Parameter requires a name\", \"MISSING_PARAM\")\n    end if\n    p.name     = options.name\n    p.required = options.hasIndex(\"required\") and options.required\n    p.default  = null\n    if options.hasIndex(\"default\") then\n        p.default = options.default\n    end if\n    return p\nend function\n\n// ============================================================\n// COMMAND\n// ============================================================\n\nCommand = {}\nCommand.name        = null\nCommand.description = null\nCommand.parameters  = []\nCommand.callback    = null\nCommand.permissions = {\"object\": \"file\", \"privilege\": \"guest\"}\n\nCommand.execute = function(args, mediator)\n    parsed = self.parseArgs(args)\n    if parsed isa Error then\n        return parsed\n    end if\n    return self.callback(parsed, mediator)\nend function\n\nCommand.parseArgs = function(args)\n    params = {}\n    tokens = args.split(\" \")\n\n    // Strip empty tokens\n    clean = []\n    for t in tokens\n        if t.len > 0 then\n            clean.push(t)\n        end if\n    end for\n    tokens = clean\n\n    index = 0\n    for param in self.parameters\n        result = param.handle(tokens, index)\n        if result isa Error then\n            return result\n        end if\n        params[param.name] = result[0]\n        index = result[1]\n    end for\n    return params\nend function\n\nCommand.help = function()\n    line = self.name + \"  \"\n    for param in self.parameters\n        if param.type == PARAMETER_TYPES.FLAG then\n            line = line + \"(\" + param.flag + \") \"\n        else if param.required then\n            line = line + \"[\" + param.name + \"] \"\n        else\n            line = line + \"(\" + param.name + \") \"\n        end if\n    end for\n    line = line + \" -  \" + self.description\n    return line\nend function\n\nCommand.New = function(options)\n    if not options.hasIndex(\"name\") then\n        return Error.New(\"Command requires a name\", \"MISSING_PARAM\")\n    end if\n    if not options.hasIndex(\"callback\") then\n        return Error.New(\"Command requires a callback\", \"MISSING_PARAM\")\n    end if\n    c = new Command\n    c.name        = options.name\n    c.description = \"\"\n    c.parameters  = []\n    c.permissions = {\"object\": \"file\", \"privilege\": \"guest\"}\n    if options.hasIndex(\"description\") then\n        c.description = options.description\n    end if\n    if options.hasIndex(\"parameters\")  then\n        c.parameters  = options.parameters\n    end if\n    if options.hasIndex(\"permissions\") then\n        c.permissions = {\"object\": \"file\", \"privilege\": \"guest\"} + options.permissions\n    end if\n    c.callback = @options.callback\n    return c\nend function\n\nCommand.Build = function(name, description, params, objPerm, privPerm, callback)\n    c = new Command\n    c.name        = name\n    c.description = description\n    c.parameters  = params\n    c.permissions = {}\n    c.permissions.object    = objPerm\n    c.permissions.privilege = privPerm\n    c.callback = @callback\n    return c\nend function\n",1)
m("/Corvid/source/managers/command-manager.txt","// ============================================================\n// CORVID 2.0 | managers/command/command-manager\n// Command registry, queue, history, alias resolution,\n// macro dispatch, and permission checking.\n// ============================================================\n\nCommandManager = {}\nCommandManager.mediator  = null\nCommandManager.commands  = {}\nCommandManager.aliases   = {}\nCommandManager.queue     = []\nCommandManager.history   = []\n\nCommandManager.register = function(command)\n    if command isa Error then\n        return command\n    end if\n    self.commands[command.name] = command\nend function\n\nCommandManager.unregister = function(name)\n    if self.commands.hasIndex(name) then\n        self.commands.remove(name)\n    end if\nend function\n\nCommandManager.getCommand = function(name)\n    if not self.commands.hasIndex(name) or self.commands[name] == null then\n        return Error.New(\"Unknown command: \" + name, \"UNKNOWN_COMMAND\")\n    end if\n    return self.commands[name]\nend function\n\nCommandManager.execute = function(input)\n    input = input.trim\n    if input.len == 0 then\n        return\n    end if\n\n    // Resolve alias\n    parts   = input.split(\" \")\n    cmdName = parts[0]\n    argParts = parts[1:]\n    args    = argParts.join(\" \")\n\n    if self.aliases.hasIndex(cmdName) then\n        aliasVal  = self.aliases[cmdName]\n        aliasParts = aliasVal.split(\" \")\n        cmdName   = aliasParts[0]\n        aliasArgParts = aliasParts[1:]\n    aliasArgs = aliasArgParts.join(\" \")\n        if aliasArgs.len > 0 then\n            args = aliasArgs + \" \" + args\n        end if\n    end if\n\n    // Macro dispatch via @macroname\n    if cmdName.indexOf(\"@\") == 0 then\n        macroManager = self.mediator.getExtension(\"macroManager\")\n        if macroManager != null then\n            return macroManager.runMacro(cmdName[1:])\n        end if\n        return Error.New(\"No macro manager available\", \"NO_MACRO_MANAGER\")\n    end if\n\n    command = self.getCommand(cmdName)\n    if command isa Error then\n        self.queue.push(command)\n        return\n    end if\n\n    self.queue.push([command, args])\nend function\n\nCommandManager.run = function()\n    while self.queue.len > 0\n        item = self.queue.pull()\n        if item isa Error then\n            self.printResult(item)\n            self.queue = []\n            return\n        end if\n\n        // Check permissions\n        permCheck = self.checkPermissions(item[0])\n        if permCheck isa Error then\n            self.printResult(permCheck)\n            return\n        end if\n\n        // Execute\n        self.history.insert(0, item)\n        cmd = item[0]\n    result = cmd.execute(item[1], self.mediator)\n        self.printResult(result)\n    end while\nend function\n\nCommandManager.checkPermissions = function(command)\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    if sessionManager == null then\n        return\n    end if\n    session  = sessionManager.currentSession\n    if session == null then\n        return\n    end if\n    handler  = session.handler\n    objType  = handler.type()\n    priv     = handler.privilege()\n\n    if not self.checkObject(objType, command.permissions.object) then\n        return Error.New(\"This command requires \" + command.permissions.object + \" access\", \"PERMISSION_DENIED\")\n    end if\n    if not self.checkPrivilege(priv, command.permissions.privilege) then\n        return Error.New(\"This command requires \" + command.permissions.privilege + \" privilege\", \"PERMISSION_DENIED\")\n    end if\nend function\n\nCommandManager.checkObject = function(current, required)\n    if required == null or required == \"file\"     then\n        return true\n    end if\n    if required == \"computer\" then\n        return current == \"computer\" or current == \"shell\"\n    end if\n    if required == \"shell\" then\n        return current == \"shell\"\n    end if\n    return false\nend function\n\nCommandManager.checkPrivilege = function(current, required)\n    if required == null or required == \"guest\"  then\n        return true\n    end if\n    if current == \"unknown\" then\n        return true\n    end if\n    if required == \"user\"   then\n        return current == \"root\" or current == \"user\"\n    end if\n    if required == \"root\"   then\n        return current == \"root\"\n    end if\n    return false\nend function\n\nCommandManager.printResult = function(result)\n    if result == null then\n        return\n    end if\n    if result isa Error then\n        ui = self.mediator.getExtension(\"corvidUi\")\n        if ui != null then\n            ui.error(result.message)\n        else\n            // Use basic red for error when UI system not available\n            print(\"<color=#FF0000>[!] \" + result.message + \"</color>\")\n        end if\n        return\n    end if\n    if typeof(result) == \"string\" then\n        print(result)\n    end if\nend function\n\nCommandManager.addAlias = function(alias, target)\n    self.aliases[alias] = target\nend function\n\nCommandManager.removeAlias = function(alias)\n    if self.aliases.hasIndex(alias) then\n        self.aliases.remove(alias)\n    end if\nend function\n\nCommandManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nCommandManager.New = function()\n    result = new CommandManager\n    result.commands = {}\n    result.aliases  = {}\n    result.queue    = []\n    result.history  = []\n    return result\nend function\n",1)
m("/Corvid/source/managers/session/file-session.txt","// ============================================================\n// CORVID 2.0 | managers/session/file-session\n// Base session type. Provides virtual filesystem navigation\n// relative to a root and current directory. All higher\n// session types (computer, shell) extend this.\n// ============================================================\n\nFileSession = {}\nFileSession.root    = null\nFileSession.current = null\nFileSession.user    = \"unknown\"\n\nFileSession.getFile = function(path)\n    if path == null or path.len == 0 then\n        return self.current\n    end if\n\n    startingPoint = self.current\n    parts         = path.split(\"/\")\n\n    if startsWith(path, \"/\") then\n        startingPoint = self.root\n        parts = parts[1:]\n    end if\n\n    for part in parts\n        if part == \"..\" then\n            parent = startingPoint.parent()\n            if parent isa Error then\n                return Error.New(\"Cannot go above root\", \"AT_ROOT\")\n            end if\n            startingPoint = parent\n        else if part == \".\" or part.len == 0 then\n            continue\n        else\n            child = startingPoint.child(part)\n            if child isa Error then\n                return Error.New(\"Not found: \" + path, \"NOT_FOUND\")\n            end if\n            startingPoint = child\n        end if\n    end for\n\n    return startingPoint\nend function\n\nFileSession.goTo = function(path)\n    target = self.getFile(path)\n    if target isa Error then\n        return target\n    end if\n    if target.type() == FILE_TYPES.FILE then\n        return Error.New(\"Cannot cd into a file\", \"TYPE_ERROR\")\n    end if\n    self.current = target\nend function\n\nFileSession.path = function()\n    return self.current.path()\nend function\n\nFileSession.copy = function(srcPath, destPath)\n    src = self.getFile(srcPath)\n    if src isa Error then\n        return src\n    end if\n    dest     = self.getFile(destPath)\n    destName = src.name()\n    if dest isa Error then\n        destName = destPath.split(\"/\").pop()\n        parentPath = parent_path(destPath)\n        dest = self.getFile(parentPath)\n        if dest isa Error then\n            return dest\n        end if\n    end if\n    return src.copy(dest.path(), destName)\nend function\n\nFileSession.move = function(srcPath, destPath)\n    src = self.getFile(srcPath)\n    if src isa Error then\n        return src\n    end if\n    dest     = self.getFile(destPath)\n    destName = src.name()\n    if dest isa Error or dest.type() == FILE_TYPES.FILE then\n        destName = destPath.split(\"/\").pop()\n        parentPath = parent_path(destPath)\n        dest = self.getFile(parentPath)\n        if dest isa Error then\n            return dest\n        end if\n    end if\n    return src.move(dest.path(), destName)\nend function\n\nFileSession.delete = function(path)\n    target = self.getFile(path)\n    if target isa Error then\n        return target\n    end if\n    // If deleting current dir, move up first\n    if startsWith(self.current.path(), target.path()) then\n        self.current = target.parent()\n    end if\n    return target.delete()\nend function\n\nFileSession.setPermissions = function(path, perms, recursive)\n    if recursive == null then\n        recursive = false\n    end if\n    target = self.getFile(path)\n    if target isa Error then\n        return target\n    end if\n    return target.setPermissions(perms, recursive)\nend function\n\nFileSession.setOwner = function(path, owner, recursive)\n    if recursive == null then\n        recursive = false\n    end if\n    target = self.getFile(path)\n    if target isa Error then\n        return target\n    end if\n    return target.setOwner(owner, recursive)\nend function\n\nFileSession.setGroup = function(path, group, recursive)\n    if recursive == null then\n        recursive = false\n    end if\n    target = self.getFile(path)\n    if target isa Error then\n        return target\n    end if\n    return target.setGroup(group, recursive)\nend function\n\nFileSession.content = function(path)\n    target = self.getFile(path)\n    if target isa Error then\n        return target\n    end if\n    return target.content()\nend function\n\nFileSession.setContent = function(path, content)\n    target = self.getFile(path)\n    if target isa Error then\n        return target\n    end if\n    return target.setContent(content)\nend function\n\nFileSession.appendContent = function(path, content)\n    target = self.getFile(path)\n    if target isa Error then\n        return target\n    end if\n    return target.appendContent(content)\nend function\n\nFileSession.rename = function(path, newName)\n    target = self.getFile(path)\n    if target isa Error then\n        return target\n    end if\n    return target.rename(newName)\nend function\n\nFileSession.name = function()\n    // File sessions have no hostname - return path as identifier\n    if self.current != null then\n        return self.current.path()\n    end if\n    return \"file-session\"\nend function\n\nFileSession.privilege = function()\n    if self.user == \"root\"  then\n        return \"root\"\n    end if\n    if self.user == \"guest\" then\n        return \"guest\"\n    end if\n    if self.user == \"unknown\" then\n        return \"unknown\"\n    end if\n    return \"user\"\nend function\n\nFileSession.type = function()\n    return \"file\"\nend function\n\nFileSession.New = function(file)\n    result = new FileSession\n    result.root    = climbFileToRoot(file)\n    result.current = file\n    result.user    = getUserFromHandler(result)\n    return result\nend function\n",1)
m("/Corvid/source/managers/session/computer-session.txt","// ============================================================\n// CORVID 2.0 | managers/session/computer-session\n// Extends FileSession with computer-specific operations:\n// user management, process control, file creation.\n// ============================================================\n\nComputerSession = new FileSession\n\nComputerSession.computer = null\n\nComputerSession.ip = function()\n    result = {}\n    result.public = self.computer.computer.public_ip\n    result.local  = self.computer.lanIp()\n    return result\nend function\n\nComputerSession.name = function()\n    return self.computer.name()\nend function\n\nComputerSession.getFile = function(path)\n    if path == null or path.len == 0 then\n        return self.current\n    end if\n    // Absolute path - try computer.File() first\n    if startsWith(path, \"/\") then\n        raw = self.computer.getFile(path)\n        if not (raw isa Error) then\n            return raw\n        end if\n    end if\n    // Relative path - traverse manually\n    startingPoint = self.current\n    parts = path.split(\"/\")\n    if startsWith(path, \"/\") then\n        startingPoint = self.root\n        parts = parts[1:]\n    end if\n    for part in parts\n        if part == \"..\" then\n            parent = startingPoint.parent()\n            if parent isa Error then\n                return Error.New(\"Cannot go above root\", \"AT_ROOT\")\n            end if\n            startingPoint = parent\n        else if part == \".\" or part.len == 0 then\n            continue\n        else\n            child = startingPoint.child(part)\n            if child isa Error then\n                return Error.New(\"Not found: \" + path, \"NOT_FOUND\")\n            end if\n            startingPoint = child\n        end if\n    end for\n    return startingPoint\nend function\n\nComputerSession.createFolder = function(path)\n    parts  = path.split(\"/\")\n    name   = parts.pop()\n    parent = self.getFile(parts.join(\"/\"))\n    if parent isa Error then\n        return parent\n    end if\n    return self.computer.createFolder(parent.path(), name)\nend function\n\nComputerSession.createFile = function(path)\n    parts  = path.split(\"/\")\n    name   = parts.pop()\n    parent = self.getFile(parts.join(\"/\"))\n    if parent isa Error then\n        return parent\n    end if\n    return self.computer.touch(parent.path(), name)\nend function\n\nComputerSession.addUser = function(user, password)\n    return self.computer.addUser(user, password)\nend function\n\nComputerSession.deleteUser = function(user)\n    return self.computer.deleteUser(user)\nend function\n\nComputerSession.changePassword = function(user, password)\n    return self.computer.changePassword(user, password)\nend function\n\nComputerSession.showProcs = function()\n    return self.computer.showProcs()\nend function\n\nComputerSession.closeProcess = function(pid)\n    return self.computer.closeProcess(pid)\nend function\n\nComputerSession.getPorts = function()\n    return self.computer.getPorts()\nend function\n\nComputerSession.hasActiveUsers = function()\n    procs = self.computer.showProcs()\n    if procs isa Error then\n        return false\n    end if\n    for proc in procs\n        if proc.hasIndex(\"COMMAND\") then\n            if proc.COMMAND == \"dsession\" then\n                return true\n            end if\n        end if\n    end for\n    return false\nend function\n\nComputerSession.type = function()\n    return \"computer\"\nend function\n\nComputerSession.New = function(computer)\n    result        = new ComputerSession\n    result.computer = computer\n    rootFile      = computer.getFile(\"/\")\n    if rootFile isa Error then\n        result.root    = null\n        result.current = null\n    else\n        result.root    = climbFileToRoot(rootFile)\n        result.current = rootFile\n    end if\n    result.user = getUserFromHandler(result)\n    return result\nend function\n",1)
m("/Corvid/source/managers/session/shell-session.txt","// ============================================================\n// CORVID 2.0 | managers/session/shell-session\n// Extends ComputerSession with shell-specific operations:\n// SSH connections, file transfer, build, launch, activate.\n// ============================================================\n\nShellSession = new ComputerSession\n\nShellSession.shell = null\n\nShellSession.connectTo = function(ip, port, user, pass, service)\n    if service == null then\n        service = \"ssh\"\n    end if\n    newShell = self.shell.connectTo(ip, port, user, pass, service)\n    if newShell isa Error then\n        return newShell\n    end if\n    return ShellSession.New(newShell)\nend function\n\nShellSession.transferFileFrom = function(srcPath, destFolder, otherSession)\n    // Pull a file FROM otherSession TO this session\n    srcFile = otherSession.getFile(srcPath)\n    if srcFile isa Error then\n        return srcFile\n    end if\n    destDir = self.getFile(destFolder)\n    if destDir isa Error then\n        return destDir\n    end if\n    return otherSession.shell.transferFile(srcFile.path(), destDir.path(), self.shell)\nend function\n\nShellSession.transferFileTo = function(srcPath, destFolder, otherSession)\n    // Push a file FROM this session TO otherSession\n    srcFile = self.getFile(srcPath)\n    if srcFile isa Error then\n        return srcFile\n    end if\n    destDir = otherSession.getFile(destFolder)\n    if destDir isa Error then\n        return destDir\n    end if\n    return self.shell.transferFile(srcFile.path(), destDir.path(), otherSession.shell)\nend function\n\nShellSession.launch = function(path, args)\n    file = self.getFile(path)\n    if file isa Error then\n        return file\n    end if\n    return self.shell.launch(file.path(), args)\nend function\n\nShellSession.build = function(srcPath, destPath)\n    srcFile = self.getFile(srcPath)\n    if srcFile isa Error then\n        return srcFile\n    end if\n    return self.shell.build(srcFile.path(), destPath)\nend function\n\nShellSession.activate = function()\n    self.shell.activate()\nend function\n\nShellSession.corruptLogs = function()\n    // Create a fresh empty file then move it onto system.log, atomically\n    // replacing the log content. This is more reliable than set_content(\"\")\n    // or delete+recreate since the move overwrites the existing file in place.\n    rawComp = self.shell.shell.host_computer\n    logFile = rawComp.File(\"/var/system.log\")\n    if logFile == null then\n        return \"Log does not exist - nothing to wipe.\"\n    end if\n    rawComp.touch(\"/var\", \"t\")\n    emptyFile = rawComp.File(\"/var/t\")\n    if emptyFile == null then\n        return Error.New(\"Could not create temp file - need root access\", \"WIPE_FAILED\")\n    end if\n    moveResult = emptyFile.move(\"/var\", \"system.log\")\n    if moveResult != 1 then\n        emptyFile.delete()\n        return Error.New(\"Could not replace system.log\", \"WIPE_FAILED\")\n    end if\n    return \"Log wiped.\"\nend function\n\nShellSession.type = function()\n    return \"shell\"\nend function\n\nShellSession.New = function(shell)\n    result         = new ShellSession\n    result.shell   = shell\n    computer       = shell.getComputer()\n    if computer isa Error then\n        return computer\n    end if\n    result.computer = computer\n    rootFile        = computer.getFile(\"/\")\n    if rootFile isa Error then\n        result.root    = null\n        result.current = null\n    else\n        result.root    = climbFileToRoot(rootFile)\n        result.current = rootFile\n    end if\n    result.user = getUserFromHandler(result)\n    return result\nend function\n",1)
m("/Corvid/source/managers/session/session.txt","// ============================================================\n// CORVID 2.0 | managers/session/session\n// Session factory  -  wraps any raw game object or facade\n// in the appropriate session type.\n// ============================================================\n\nSession = {}\nSession.handler = null\nSession.data    = {}\nSession.label   = \"\"\n\nSession.New = function(object, label)\n    // Already a session  -  return as-is\n    if object isa Session then\n        return object\n    end if\n\n    if label == null then\n        label = \"\"\n    end if\n\n    result         = new Session\n    result.data    = {}\n    result.label   = label\n\n    // Wrap raw game objects in facades first\n    if typeof(object) == \"shell\" then\n        wrapped = Shell.New(object)\n        if wrapped isa Error then\n            return wrapped\n        end if\n        handler = ShellSession.New(wrapped)\n        if handler isa Error then\n            return handler\n        end if\n        result.handler = handler\n        result.data.ip = handler.ip()\n        // Navigate to home directory\n        if handler.user == \"root\" then\n            handler.goTo(\"/root\")\n        else if handler.user != \"unknown\" then\n            handler.goTo(\"/home/\" + handler.user)\n        end if\n        return result\n    end if\n\n    if typeof(object) == \"computer\" then\n        wrapped = Computer.New(object)\n        if wrapped isa Error then\n            return wrapped\n        end if\n        handler = ComputerSession.New(wrapped)\n        if handler isa Error then\n            return handler\n        end if\n        result.handler = handler\n        result.data.ip = handler.ip()\n        if handler.user == \"root\" then\n            handler.goTo(\"/root\")\n        else if handler.user != \"unknown\" then\n            handler.goTo(\"/home/\" + handler.user)\n        end if\n        return result\n    end if\n\n    if typeof(object) == \"file\" then\n        wrapped = File.New(object)\n        if wrapped isa Error then\n            return wrapped\n        end if\n        handler = FileSession.New(wrapped)\n        if handler isa Error then\n            return handler\n        end if\n        result.handler  = handler\n        result.data.ip  = {\"public\": \"unknown\", \"local\": \"unknown\"}\n        return result\n    end if\n\n    // Shell facade\n    if object isa Shell then\n        handler = ShellSession.New(object)\n        if handler isa Error then\n            return handler\n        end if\n        result.handler = handler\n        result.data.ip = handler.ip()\n        if handler.user == \"root\" then\n            handler.goTo(\"/root\")\n        else if handler.user != \"unknown\" then\n            handler.goTo(\"/home/\" + handler.user)\n        end if\n        return result\n    end if\n\n    // Computer facade\n    if object isa Computer then\n        handler = ComputerSession.New(object)\n        if handler isa Error then\n            return handler\n        end if\n        result.handler = handler\n        result.data.ip = handler.ip()\n        if handler.user == \"root\" then\n            handler.goTo(\"/root\")\n        else if handler.user != \"unknown\" then\n            handler.goTo(\"/home/\" + handler.user)\n        end if\n        return result\n    end if\n\n    // File facade\n    if object isa File then\n        handler = FileSession.New(object)\n        if handler isa Error then\n            return handler\n        end if\n        result.handler  = handler\n        result.data.ip  = {\"public\": \"unknown\", \"local\": \"unknown\"}\n        return result\n    end if\n\n    return Error.New(\"Cannot create session from object of type: \" + typeof(object), \"TYPE_ERROR\")\nend function\n",1)
m("/Corvid/source/managers/session/session-manager.txt","// ============================================================\n// CORVID 2.0 | managers/session/session-manager\n// Manages all sessions. Maintains the session chain for\n// back navigation. Tracks current (operating) session and\n// pivot (home Nest) session separately.\n// ============================================================\n\nSessionManager = {}\nSessionManager.mediator      = null\nSessionManager.sessions      = []\nSessionManager.sessionChain  = []\nSessionManager.currentSession = null\nSessionManager.pivotSession   = null\n\nSessionManager.addSession = function(object, label)\n    session = Session.New(object, label)\n    if session isa Error then\n        return session\n    end if\n    self.sessions.push(session)\n\n    if self.currentSession == null then\n        self.currentSession = session\n        self.sessionChain.push(session)\n    end if\n    if self.pivotSession == null then\n        self.pivotSession = session\n    end if\n    return session\nend function\n\nSessionManager.setCurrentSession = function(indexOrSession)\n    if typeof(indexOrSession) == \"number\" then\n        if not self.sessions.hasIndex(indexOrSession) then\n            return Error.New(\"Session index out of range: \" + indexOrSession, \"OUT_OF_RANGE\")\n        end if\n        session = self.sessions[indexOrSession]\n    else\n        session = indexOrSession\n    end if\n    self.currentSession = session\n    self.sessionChain.push(session)\nend function\n\nSessionManager.setPivotSession = function(indexOrSession)\n    if typeof(indexOrSession) == \"number\" then\n        if not self.sessions.hasIndex(indexOrSession) then\n            return Error.New(\"Session index out of range: \" + indexOrSession, \"OUT_OF_RANGE\")\n        end if\n        self.pivotSession = self.sessions[indexOrSession]\n    else\n        self.pivotSession = indexOrSession\n    end if\nend function\n\nSessionManager.back = function()\n    if self.sessionChain.len <= 1 then\n        return Error.New(\"Already at origin session\", \"AT_ORIGIN\")\n    end if\n    // Remove the session we are leaving from the sessions list too\n    leaving = self.sessionChain[self.sessionChain.len - 1]\n    leavingIdx = self.getSessionIndex(leaving)\n    self.sessionChain.pop()\n    self.currentSession = self.sessionChain[self.sessionChain.len - 1]\n    // Remove from sessions list if not session 0 (Nest)\n    if leavingIdx != null and leavingIdx > 0 then\n        self.sessions.remove(leavingIdx)\n    end if\nend function\n\nSessionManager.removeSession = function(index)\n    if not self.sessions.hasIndex(index) then\n        return Error.New(\"Session index out of range: \" + index, \"OUT_OF_RANGE\")\n    end if\n    self.sessions.remove(index)\nend function\n\nSessionManager.getSessionIndex = function(session)\n    for i in range(0, self.sessions.len - 1)\n        if self.sessions[i] == session then\n            return i\n        end if\n    end for\n    return null\nend function\n\nSessionManager.listSessions = function()\n    return self.sessions\nend function\n\nSessionManager.removeSession = function(id)\n    if not self.sessions.hasIndex(id) then\n        return Error.New(\"No session at index: \" + str(id), \"NOT_FOUND\")\n    end if\n    removedSession = self.sessions[id]\n    self.sessions.remove(id)\n    // If we removed the current session, fall back to previous in chain\n    if self.currentSession == removedSession then\n        if self.sessionChain.len > 0 then\n            self.currentSession = self.sessionChain[self.sessionChain.len - 1]\n        else\n            self.currentSession = self.pivotSession\n        end if\n    end if\n    // Clean session from chain if present\n    newChain = []\n    for sc in self.sessionChain\n        if sc != removedSession then\n            newChain.push(sc)\n        end if\n    end for\n    self.sessionChain = newChain\n    return true\nend function\n\nSessionManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nSessionManager.New = function()\n    result = new SessionManager\n    result.sessions      = []\n    result.sessionChain  = []\n    result.currentSession = null\n    result.pivotSession   = null\n    return result\nend function\n",1)
m("/Corvid/source/managers/lib-manager.txt","// ============================================================\n// CORVID 2.0 | managers/lib/lib-manager\n// Tracks all loaded metaxploit and crypto libraries.\n// Maintains current (active) and pivot (Nest) refs for each.\n// ============================================================\n\nLIB_TYPES = {}\nLIB_TYPES.METAXPLOIT = \"metaxploit\"\nLIB_TYPES.CRYPTO     = \"crypto\"\n\n// ---- Lib record ----\n\nLib = {}\nLib.lib     = null\nLib.type    = \"unknown\"\nLib.data    = {}\n\nLib.New = function(rawLib, data)\n    result      = new Lib\n    result.data = {}\n    result.data.ip      = {\"public\": \"unknown\", \"local\": \"unknown\"}\n    result.data.version = \"unknown\"\n    result.data.path    = \"\"\n\n    if not data.hasIndex(\"ip\") then\n        return Error.New(\"Lib.New requires ip in data\", \"MISSING_PARAM\")\n    end if\n    result.data.ip = data.ip\n    if data.hasIndex(\"path\")    then\n        result.data.path    = data.path\n    end if\n    if data.hasIndex(\"version\") then\n        result.data.version = data.version\n    end if\n\n    if typeof(rawLib) == \"MetaxploitLib\" then\n        wrapped = Metaxploit.New(rawLib)\n        if wrapped isa Error then\n            return wrapped\n        end if\n        result.lib  = wrapped\n        result.type = LIB_TYPES.METAXPLOIT\n    else if typeof(rawLib) == \"cryptoLib\" then\n        wrapped = Crypto.New(rawLib)\n        if wrapped isa Error then\n            return wrapped\n        end if\n        result.lib  = wrapped\n        result.type = LIB_TYPES.CRYPTO\n    else\n        return Error.New(\"Unknown library type: \" + typeof(rawLib), \"TYPE_ERROR\")\n    end if\n\n    return result\nend function\n\n// ---- LibManager ----\n\nLibManager = {}\nLibManager.mediator     = null\nLibManager.libs         = []\nLibManager.currentLibs  = {}\nLibManager.pivotLibs    = {}\n\nLibManager.addLib = function(rawLib, data)\n    lib = Lib.New(rawLib, data)\n    if lib isa Error then\n        return lib\n    end if\n\n    // If metaxploit, get version from the library itself\n    if lib.type == LIB_TYPES.METAXPLOIT and data.hasIndex(\"path\") then\n        netSession = lib.lib.metaxploit.net_use\n        // Version extracted differently  -  store path for later use\n        lib.data.path = data.path\n    end if\n\n    self.libs.push(lib)\n\n    // Set as current and pivot if first of this type\n    if not self.currentLibs.hasIndex(lib.type) or self.currentLibs[lib.type] == null then\n        self.currentLibs[lib.type] = lib\n    end if\n    if not self.pivotLibs.hasIndex(lib.type) or self.pivotLibs[lib.type] == null then\n        self.pivotLibs[lib.type] = lib\n    end if\n\n    return lib\nend function\n\nLibManager.getCurrentLib = function(libType)\n    if not self.currentLibs.hasIndex(libType) then\n        return null\n    end if\n    return self.currentLibs[libType]\nend function\n\nLibManager.setCurrentLib = function(lib)\n    self.currentLibs[lib.type] = lib\nend function\n\nLibManager.getPivotLib = function(libType)\n    if not self.pivotLibs.hasIndex(libType) then\n        return null\n    end if\n    return self.pivotLibs[libType]\nend function\n\nLibManager.setPivotLib = function(libType, lib)\n    self.pivotLibs[libType] = lib\nend function\n\nLibManager.getLibById = function(index)\n    if not self.libs.hasIndex(index) then\n        return Error.New(\"No lib at index: \" + index, \"NOT_FOUND\")\n    end if\n    return self.libs[index]\nend function\n\nLibManager.allLibs = function()\n    return self.libs\nend function\n\nLibManager.getMetaxploit = function()\n    lib = self.getCurrentLib(LIB_TYPES.METAXPLOIT)\n    if lib == null then\n        return Error.New(\"No metaxploit library loaded\", \"NO_LIB\")\n    end if\n    return lib.lib\nend function\n\nLibManager.getCrypto = function()\n    lib = self.getCurrentLib(LIB_TYPES.CRYPTO)\n    if lib == null then\n        return Error.New(\"No crypto library loaded\", \"NO_LIB\")\n    end if\n    return lib.lib\nend function\n\nLibManager.getPivotMetaxploit = function()\n    lib = self.getPivotLib(LIB_TYPES.METAXPLOIT)\n    if lib == null then\n        return Error.New(\"No pivot metaxploit library loaded\", \"NO_LIB\")\n    end if\n    return lib.lib\nend function\n\nLibManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nLibManager.New = function()\n    result = new LibManager\n    result.libs        = []\n    result.currentLibs = {}\n    result.pivotLibs   = {}\n    return result\nend function\n",1)
m("/Corvid/source/managers/metaxploit-manager.txt","// ============================================================\n// CORVID 2.0 | managers/lib/metaxploit-manager\n// Orchestrates all metaxploit operations through the\n// lib-manager. Handles the hack workflow, rshell,\n// and net_use connections.\n// ============================================================\n\nMetaxploitManager = {}\nMetaxploitManager.mediator = null\n\nMetaxploitManager.getMetaxploit = function()\n    // When platform is active, use roost node metaxploit so exploit\n    // traffic originates from the roost node rather than Nest\n    platformManager = self.mediator.getExtension(\"platformManager\")\n    if platformManager != null and platformManager.active then\n        roostMeta = platformManager.getMeta()\n        if roostMeta != null then\n            return roostMeta\n        end if\n    end if\n    libManager = self.mediator.getExtension(\"libManager\")\n    meta = libManager.getMetaxploit()\n    if meta isa Error then\n        return meta\n    end if\n    return meta\nend function\n\nMetaxploitManager.getPivotMetaxploit = function()\n    libManager = self.mediator.getExtension(\"libManager\")\n    meta = libManager.getPivotMetaxploit()\n    if meta isa Error then\n        return meta\n    end if\n    return meta\nend function\n\nMetaxploitManager.netUse = function(ip, port)\n    meta = self.getMetaxploit()\n    if meta isa Error then\n        return meta\n    end if\n    return meta.netUse(ip, port)\nend function\n\nMetaxploitManager.getTargetLib = function(ip, port)\n    // Connect and dump the target library\n    meta = self.getMetaxploit()\n    if meta isa Error then\n        return meta\n    end if\n    session = meta.netUse(ip, port)\n    if session isa Error then\n        return session\n    end if\n    lib = session.dump_lib\n    if lib == null then\n        return Error.New(\"dump_lib returned null for \" + ip + \":\" + port, \"DUMP_LIB_ERROR\")\n    end if\n    return lib\nend function\n\nMetaxploitManager.checkActiveUsers = function(ip, port)\n    meta = self.getMetaxploit()\n    if meta isa Error then\n        return false\n    end if\n    session = meta.netUse(ip, port)\n    if session isa Error then\n        return false\n    end if\n    if session.is_any_active_user == 1 then\n        if session.is_root_active_user == 1 then\n            return \"root\"\n        end if\n        return \"user\"\n    end if\n    return false\nend function\n\nMetaxploitManager.hack = function(ip, port)\n    // Full automated hack chain using pivot metaxploit\n    // 1. Get target lib via current metaxploit\n    // 2. Run hack via pivot metaxploit (where our .so lives)\n    // 3. Return structured results\n    currentMeta = self.getMetaxploit()\n    if currentMeta isa Error then\n        return currentMeta\n    end if\n    pivotMeta = self.getPivotMetaxploit()\n    if pivotMeta isa Error then\n        return pivotMeta\n    end if\n\n    session = currentMeta.netUse(ip, port)\n    if session isa Error then\n        return session\n    end if\n\n    targetLib = session.dump_lib\n    if targetLib == null then\n        return Error.New(\"Could not get target library\", \"DUMP_LIB_ERROR\")\n    end if\n\n    // Get vulnerabilities using pivot metaxploit\n    vulns = pivotMeta.getVulnerabilities(targetLib)\n    if vulns isa Error then\n        return vulns\n    end if\n\n    // Test each exploit and collect results\n    results = []\n    for vuln in vulns\n        for exploit in vuln.exploits\n            // Fresh session for each attempt\n            freshSession = currentMeta.netUse(ip, port)\n            if freshSession isa Error then\n                continue\n            end if\n            freshLib = freshSession.dump_lib\n            if freshLib == null then\n                continue\n            end if\n\n            raw = freshLib.overflow(vuln.address, exploit)\n            if raw == null or typeof(raw) == \"number\" or typeof(raw) == \"string\" then\n                entry = {}\n                entry.address   = vuln.address\n                entry.exploit   = exploit\n                entry.rtype     = \"Failed\"\n                entry.privilege = \"none\"\n                results.push(entry)\n                continue\n            end if\n\n            rtype     = typeof(raw)\n            privilege = \"unknown\"\n\n            if rtype == \"shell\" then\n                comp = raw.host_computer\n                privilege = self.detectPrivilege(comp)\n            else if rtype == \"computer\" then\n                privilege = self.detectPrivilege(raw)\n            else if rtype == \"file\" then\n                privilege = raw.path\n            end if\n\n            entry = {}\n            entry.address   = vuln.address\n            entry.exploit   = exploit\n            entry.rtype     = rtype\n            entry.privilege = privilege\n            entry.raw       = raw\n            results.push(entry)\n        end for\n    end for\n\n    if results.len == 0 then\n        return Error.New(\"No exploits could be tested\", \"NO_RESULTS\")\n    end if\n\n    return results\nend function\n\nMetaxploitManager.detectPrivilege = function(computer)\n    rootFolder = computer.File(\"/root\")\n    if rootFolder != null and rootFolder.has_permission(\"w\") then\n        return \"root\"\n    end if\n    homeFolder = computer.File(\"/home\")\n    if homeFolder != null then\n        for userFolder in homeFolder.get_folders()\n            if userFolder.name == \"guest\" then\n                continue\n            end if\n            if userFolder.has_permission(\"w\") then\n                return userFolder.name\n            end if\n        end for\n    end if\n    guestFolder = computer.File(\"/home/guest\")\n    if guestFolder != null and guestFolder.has_permission(\"w\") then\n        return \"guest\"\n    end if\n    return \"unknown\"\nend function\n\nMetaxploitManager.getBestResult = function(results)\n    // Priority: Shell root > Shell user > Computer root >\n    //           Computer user > Computer guest > File > Failed\n    for r in results\n        if r.rtype == \"shell\" and r.privilege == \"root\" then\n            return r\n        end if\n    end for\n    for r in results\n        if r.rtype == \"shell\" and r.privilege != \"unknown\" and r.privilege != \"guest\" then\n            return r\n        end if\n    end for\n    for r in results\n        if r.rtype == \"computer\" and r.privilege == \"root\" then\n            return r\n        end if\n    end for\n    for r in results\n        if r.rtype == \"computer\" and r.privilege != \"unknown\" and r.privilege != \"guest\" then\n            return r\n        end if\n    end for\n    for r in results\n        if r.rtype == \"computer\" then\n            return r\n        end if\n    end for\n    for r in results\n        if r.rtype == \"file\" then\n            return r\n        end if\n    end for\n    return null\nend function\n\nMetaxploitManager.flockList = function()\n    meta = self.getMetaxploit()\n    if meta isa Error then\n        return meta\n    end if\n    return meta.flockServer()\nend function\n\nMetaxploitManager.flockClient = function(ip, port, processName)\n    meta = self.getMetaxploit()\n    if meta isa Error then\n        return meta\n    end if\n    return meta.flockClient(ip, port, processName)\nend function\n\nMetaxploitManager.addLib = function(rawLib, data)\n    libManager = self.mediator.getExtension(\"libManager\")\n    return libManager.addLib(rawLib, data)\nend function\n\nMetaxploitManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nMetaxploitManager.New = function()\n    result = new MetaxploitManager\n    return result\nend function\n",1)
m("/Corvid/source/managers/database/database.txt","// ============================================================\n// CORVID 2.0 | managers/database/database\n// Core database engine. Backed by JSON files on the Nest.\n// Provides generic read, write, upsert, query, delete.\n// Each database is a map keyed by record id.\n//\n// CHAINING:\n//   When a file exceeds SPLIT_THRESHOLD chars on save, it is\n//   closed with a {\"__continued\": \"name_2.json\"} marker and\n//   a new file is started. On load all files in the chain are\n//   merged into one in-memory map. Writes always go to the\n//   latest file (lazy strategy - stale copies in earlier files\n//   are overwritten on next load).\n//\n// OPTIMIZATIONS:\n//   - ipIndex: map of publicIp -> id for O(1) IP lookups\n//   - idCounter: tracks highest ID number to avoid full scan\n//   - dirty flag prevents redundant saves\n// ============================================================\n\nDatabase = {}\nDatabase.mediator     = null\nDatabase.name         = null\nDatabase.records      = {}\nDatabase.ipIndex      = {}\nDatabase.idCounter    = 0\nDatabase.dirty        = false\nDatabase.chainIndex   = 1      // current file number (1 = name.json, 2 = name_2.json...)\nDatabase.SPLIT_THRESHOLD = 140000\n\nDatabase.basePath = function()\n    return \"/Corvid/Data/\" + self.name + \".json\"\nend function\n\nDatabase.chainPath = function(n)\n    if n == 1 then\n        return \"/Corvid/Data/\" + self.name + \".json\"\n    end if\n    return \"/Corvid/Data/\" + self.name + \"_\" + str(n) + \".json\"\nend function\n\nDatabase.rebuildIndex = function()\n    self.ipIndex   = {}\n    self.idCounter = 0\n    for kv in self.records\n        rec = kv.value\n        id  = kv.key\n        if rec.hasIndex(\"public_ip\") and rec.public_ip.len > 0 then\n            self.ipIndex[rec.public_ip] = id\n        end if\n        if id.len > 2 then\n            num = id[2:].val\n            if num > self.idCounter then\n                self.idCounter = num\n            end if\n        end if\n    end for\nend function\n\nDatabase.load = function()\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler = sessionManager.pivotSession.handler\n\n    self.records   = {}\n    self.ipIndex   = {}\n    self.idCounter = 0\n    self.chainIndex = 1\n\n    // Follow the chain, merging all files into records\n    currentN = 1\n    while true\n        path = self.chainPath(currentN)\n        file = handler.getFile(path)\n        if file isa Error then\n            // No file at this index - stop (chainIndex stays at last good file)\n            if currentN > 1 then\n                self.chainIndex = currentN - 1\n            end if\n            break\n        end if\n        raw = file.content()\n        if raw isa Error or raw.len == 0 then\n            if currentN > 1 then\n                self.chainIndex = currentN - 1\n            end if\n            break\n        end if\n        parsed = parse(raw)\n        if parsed == null then\n            if currentN > 1 then\n                self.chainIndex = currentN - 1\n            end if\n            break\n        end if\n\n        // Check for continuation marker\n        nextFile = \"\"\n        if parsed.hasIndex(\"__continued\") then\n            nextFile = parsed[\"__continued\"]\n            parsed.remove(\"__continued\")\n        end if\n\n        // Merge records - later files overwrite earlier ones (lazy dedup)\n        for kv in parsed\n            if kv.key != \"__continued\" then\n                self.records[kv.key] = kv.value\n            end if\n        end for\n\n        if nextFile.len > 0 then\n            // Advance to next file in chain\n            currentN = currentN + 1\n        else\n            // This is the last file in the chain\n            self.chainIndex = currentN\n            break\n        end if\n    end while\n\n    self.rebuildIndex()\nend function\n\nDatabase.save = function()\n    if not self.dirty then\n        return\n    end if\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler = sessionManager.pivotSession.handler\n\n    // Collect all record keys (excluding any __continued sentinel)\n    allKeys = []\n    for kv in self.records\n        if kv.key != \"__continued\" then\n            allKeys.push(kv.key)\n        end if\n    end for\n\n    // Partition records into chunks that each fit within SPLIT_THRESHOLD.\n    // We always rewrite from file 1 so there are never stale records in\n    // earlier chain files from a previous session's split point.\n    // Use a running size estimate to avoid O(n^2) toJSON calls.\n    chunks = []\n    currentChunk = {}\n    currentSize = 2  // opening/closing braces of {}\n    for k in allKeys\n        recJson = toJSON(self.records[k])\n        // key + colon + value + comma + quotes = key.len + recJson.len + 4\n        entrySize = k.len + recJson.len + 4\n        // Keep 200 chars of headroom for the __continued marker\n        if currentSize + entrySize < self.SPLIT_THRESHOLD - 200 then\n            currentChunk[k] = self.records[k]\n            currentSize = currentSize + entrySize\n        else\n            chunks.push(currentChunk)\n            currentChunk = {}\n            currentChunk[k] = self.records[k]\n            currentSize = 2 + entrySize\n        end if\n    end for\n    if currentChunk.len > 0 then\n        chunks.push(currentChunk)\n    end if\n\n    if chunks.len == 0 then\n        // Empty database - write empty file\n        chunks.push({})\n    end if\n\n    // Write each chunk to its chain file.\n    // All but the last get a __continued pointer to the next file.\n    fileN = 1\n    for i in range(0, chunks.len - 1)\n        chunk = chunks[i]\n        path = self.chainPath(fileN)\n        if i < chunks.len - 1 then\n            chunk[\"__continued\"] = self.chainPath(fileN + 1)\n        end if\n        file = handler.getFile(path)\n        if file isa Error then\n            result = handler.createFile(path)\n            if result isa Error then\n                return result\n            end if\n            file = handler.getFile(path)\n            if file isa Error then\n                return file\n            end if\n        end if\n        file.setContent(toJSON(chunk))\n        fileN = fileN + 1\n    end for\n\n    // Delete any chain files beyond what we just wrote (left over from\n    // a previous session that had more chunks than we need now)\n    cleanN = fileN\n    cleanDone = false\n    while not cleanDone\n        cleanPath = self.chainPath(cleanN)\n        cleanFile = handler.getFile(cleanPath)\n        if cleanFile isa Error then\n            cleanDone = true\n        else\n            cleanFile.delete()\n            cleanN = cleanN + 1\n        end if\n    end while\n\n    self.chainIndex = fileN - 1\n    self.dirty = false\nend function\n\nDatabase.get = function(id)\n    if not self.records.hasIndex(id) then\n        return Error.New(\"Record not found: \" + id, \"NOT_FOUND\")\n    end if\n    return self.records[id]\nend function\n\nDatabase.set = function(id, record)\n    if record.hasIndex(\"public_ip\") and record.public_ip.len > 0 then\n        self.ipIndex[record.public_ip] = id\n    end if\n    self.records[id] = record\n    self.dirty = true\nend function\n\nDatabase.delete = function(id)\n    if not self.records.hasIndex(id) then\n        return Error.New(\"Record not found: \" + id, \"NOT_FOUND\")\n    end if\n    rec = self.records[id]\n    if rec.hasIndex(\"public_ip\") and self.ipIndex.hasIndex(rec.public_ip) then\n        self.ipIndex.remove(rec.public_ip)\n    end if\n    self.records.remove(id)\n    self.dirty = true\nend function\n\nDatabase.all = function()\n    result = []\n    for kv in self.records\n        if kv.key != \"__continued\" then\n            result.push(kv.value)\n        end if\n    end for\n    return result\nend function\n\nDatabase.query = function(matchFn)\n    result = []\n    for kv in self.records\n        if kv.key != \"__continued\" then\n            if matchFn(kv.value) then\n                result.push(kv.value)\n            end if\n        end if\n    end for\n    return result\nend function\n\nDatabase.findByIp = function(ip)\n    if not self.ipIndex.hasIndex(ip) then\n        return null\n    end if\n    id = self.ipIndex[ip]\n    if not self.records.hasIndex(id) then\n        return null\n    end if\n    return self.records[id]\nend function\n\nDatabase.upsert = function(id, record)\n    if self.records.hasIndex(id) then\n        existing = self.records[id]\n        for kv in record\n            existing[kv.key] = kv.value\n        end for\n        self.set(id, existing)\n    else\n        record.id = id\n        self.set(id, record)\n    end if\n    self.dirty = true\nend function\n\nDatabase.nextId = function(prefix)\n    self.idCounter = self.idCounter + 1\n    next = str(self.idCounter)\n    while next.len < 3\n        next = \"0\" + next\n    end while\n    return prefix + \"_\" + next\nend function\n\nDatabase.count = function()\n    return self.records.len\nend function\n\nDatabase.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nDatabase.New = function(name)\n    result = new Database\n    result.name         = name\n    result.records      = {}\n    result.ipIndex      = {}\n    result.idCounter    = 0\n    result.dirty        = false\n    result.chainIndex   = 1\n    return result\nend function\n",1)
m("/Corvid/source/managers/database/person-db.txt","// ============================================================\n// CORVID 2.0 | managers/database/person-db\n// Person record schema and operations.\n// A person is anyone whose identity has been discovered  - \n// from whois, mail files, or social engineering.\n//\n// Schema:\n//   id        string    -  auto-generated e.g. \"p_001\"\n//   name      string    -  full name\n//   email     string    -  primary email address\n//   org_id    string    -  linked organisation ID\n//   ips       list      -  known public IPs\n//   lan_ips   list      -  known LAN IPs\n//   notes     string    -  freeform notes\n//   source    string    -  how discovered: whois | mail | manual\n// ============================================================\n\nPersonDb = {}\nPersonDb.db = null\n\nPersonDb.findByEmail = function(email)\n    matchEmail = function(record)\n        return record.hasIndex(\"email\") and record.email == email\n    end function\n    return self.db.query(@matchEmail)\nend function\n\nPersonDb.findByName = function(name)\n    matchName = function(record)\n        return record.hasIndex(\"name\") and record.name.indexOf(name) != null\n    end function\n    return self.db.query(@matchName)\nend function\n\nPersonDb.findByIp = function(ip)\n    matchIp = function(record)\n        if record.hasIndex(\"ips\") and record.ips.indexOf(ip) != null then\n            return true\n        end if\n        if record.hasIndex(\"lan_ips\") and record.lan_ips.indexOf(ip) != null then\n            return true\n        end if\n        return false\n    end function\n    return self.db.query(@matchIp)\nend function\n\nPersonDb.findByOrg = function(orgId)\n    matchOrg = function(record)\n        return record.hasIndex(\"org_id\") and record.org_id == orgId\n    end function\n    return self.db.query(@matchOrg)\nend function\n\nPersonDb.search = function(term)\n    // Broad search across name, email, notes\n    term = lower(term)\n    matchAny = function(record)\n        if record.hasIndex(\"name\")  and record.lower(name).indexOf(term)  != null then\n            return true\n        end if\n        if record.hasIndex(\"email\") and record.lower(email).indexOf(term) != null then\n            return true\n        end if\n        if record.hasIndex(\"notes\") and record.lower(notes).indexOf(term) != null then\n            return true\n        end if\n        return false\n    end function\n    return self.db.query(@matchAny)\nend function\n\nPersonDb.upsert = function(data)\n    // Upsert by email  -  email is the natural key for a person\n    if not data.hasIndex(\"email\") or data.email.len == 0 then\n        return Error.New(\"Person record requires an email address\", \"VALIDATION_ERROR\")\n    end if\n    existing = self.findByEmail(data.email)\n    if existing.len > 0 then\n        record = existing[0]\n        id     = record.id\n        // Merge IPs\n        if data.hasIndex(\"ips\") then\n            for ip in data.ips\n                if record.ips.indexOf(ip) == null then\n                    record.ips.push(ip)\n                end if\n            end for\n        end if\n        if data.hasIndex(\"lan_ips\") then\n            for ip in data.lan_ips\n                if record.lan_ips.indexOf(ip) == null then\n                    record.lan_ips.push(ip)\n                end if\n            end for\n        end if\n        // Update scalar fields if provided and non-empty\n        if data.hasIndex(\"name\")   and data.name.len   > 0 then\n            record.name   = data.name\n        end if\n        if data.hasIndex(\"org_id\") and data.org_id.len > 0 then\n            record.org_id = data.org_id\n        end if\n        if data.hasIndex(\"notes\")  and data.notes.len  > 0 then\n            record.notes  = data.notes\n        end if\n        self.db.set(id, record)\n        return id\n    else\n        id = self.db.nextId(\"p\")\n        record = {}\n        record.id      = id\n        record.name    = \"\"\n        record.email   = data.email\n        record.org_id  = \"\"\n        record.ips     = []\n        record.lan_ips = []\n        record.notes   = \"\"\n        record.source  = \"unknown\"\n        if data.hasIndex(\"name\")    then\n            record.name    = data.name\n        end if\n        if data.hasIndex(\"org_id\")  then\n            record.org_id  = data.org_id\n        end if\n        if data.hasIndex(\"ips\")     then\n            record.ips     = data.ips\n        end if\n        if data.hasIndex(\"lan_ips\") then\n            record.lan_ips = data.lan_ips\n        end if\n        if data.hasIndex(\"notes\")   then\n            record.notes   = data.notes\n        end if\n        if data.hasIndex(\"source\")  then\n            record.source  = data.source\n        end if\n        self.db.set(id, record)\n        return id\n    end if\nend function\n\nPersonDb.get = function(id)\n    return self.db.get(id)\nend function\n\nPersonDb.all = function()\n    return self.db.all()\nend function\n\nPersonDb.addNote = function(id, note)\n    record = self.db.get(id)\n    if record isa Error then\n        return record\n    end if\n    if record.notes.len > 0 then\n        record.notes = record.notes + char(10) + note\n    else\n        record.notes = note\n    end if\n    self.db.set(id, record)\nend function\n\nPersonDb.New = function(db)\n    result    = new PersonDb\n    result.db = db\n    return result\nend function\n",1)
m("/Corvid/source/managers/database/org-db.txt","// ============================================================\n// CORVID 2.0 | managers/database/org-db\n// Organisation record schema and operations.\n// An org is any company or entity whose infrastructure\n// has been touched or identified.\n//\n// Schema:\n//   id      string    -  auto-generated e.g. \"o_001\"\n//   name    string    -  company name\n//   domain  string    -  primary domain e.g. \"acme.net\"\n//   ips     list      -  known public IPs\n//   notes   string    -  freeform notes\n// ============================================================\n\nOrgDb = {}\nOrgDb.db = null\n\nOrgDb.findByDomain = function(domain)\n    matchDomain = function(record)\n        return record.hasIndex(\"domain\") and record.domain == domain\n    end function\n    return self.db.query(@matchDomain)\nend function\n\nOrgDb.findByName = function(name)\n    term = lower(name)\n    matchName = function(record)\n        return record.hasIndex(\"name\") and record.lower(name).indexOf(term) != null\n    end function\n    return self.db.query(@matchName)\nend function\n\nOrgDb.findByIp = function(ip)\n    matchIp = function(record)\n        return record.hasIndex(\"ips\") and record.ips.indexOf(ip) != null\n    end function\n    return self.db.query(@matchIp)\nend function\n\nOrgDb.search = function(term)\n    term = lower(term)\n    matchAny = function(record)\n        if record.hasIndex(\"name\")   and record.lower(name).indexOf(term)   != null then\n            return true\n        end if\n        if record.hasIndex(\"domain\") and record.lower(domain).indexOf(term) != null then\n            return true\n        end if\n        if record.hasIndex(\"notes\")  and record.lower(notes).indexOf(term)  != null then\n            return true\n        end if\n        return false\n    end function\n    return self.db.query(@matchAny)\nend function\n\nOrgDb.upsert = function(data)\n    // Upsert by domain  -  domain is the natural key for an org\n    if not data.hasIndex(\"domain\") or data.domain.len == 0 then\n        return Error.New(\"Organisation record requires a domain\", \"VALIDATION_ERROR\")\n    end if\n    existing = self.findByDomain(data.domain)\n    if existing.len > 0 then\n        record = existing[0]\n        id     = record.id\n        if data.hasIndex(\"ips\") then\n            for ip in data.ips\n                if record.ips.indexOf(ip) == null then\n                    record.ips.push(ip)\n                end if\n            end for\n        end if\n        if data.hasIndex(\"name\")  and data.name.len  > 0 then\n            record.name  = data.name\n        end if\n        if data.hasIndex(\"notes\") and data.notes.len > 0 then\n            record.notes = data.notes\n        end if\n        self.db.set(id, record)\n        return id\n    else\n        id = self.db.nextId(\"o\")\n        record = {}\n        record.id     = id\n        record.name   = \"\"\n        record.domain = data.domain\n        record.ips    = []\n        record.notes  = \"\"\n        if data.hasIndex(\"name\")  then\n            record.name  = data.name\n        end if\n        if data.hasIndex(\"ips\")   then\n            record.ips   = data.ips\n        end if\n        if data.hasIndex(\"notes\") then\n            record.notes = data.notes\n        end if\n        self.db.set(id, record)\n        return id\n    end if\nend function\n\nOrgDb.get = function(id)\n    return self.db.get(id)\nend function\n\nOrgDb.all = function()\n    return self.db.all()\nend function\n\nOrgDb.addNote = function(id, note)\n    record = self.db.get(id)\n    if record isa Error then\n        return record\n    end if\n    if record.notes.len > 0 then\n        record.notes = record.notes + char(10) + note\n    else\n        record.notes = note\n    end if\n    self.db.set(id, record)\nend function\n\nOrgDb.New = function(db)\n    result    = new OrgDb\n    result.db = db\n    return result\nend function\n",1)
m("/Corvid/source/managers/database/credential-db.txt","// ============================================================\n// CORVID 2.0 | managers/database/credential-db\n// Credential record schema and operations.\n// All credential types  -  system, mail, bank  -  unified\n// in one schema with a type field to distinguish them.\n//\n// Schema:\n//   id            string  -  auto-generated e.g. \"c_001\"\n//   type          string  -  system | mail | bank\n//   username      string  -  login name or email address\n//   password      string  -  plaintext if cracked, else \"\"\n//   native_pass   string  -  original password before Corvid changed it\n//   hash          string  -  original hash from passwd/mail\n//   bank_number   string  -  bank account number (bank type)\n//   public_ip     string  -  source machine public IP\n//   lan_ip        string  -  source machine LAN IP\n//   org_id        string  -  linked organisation ID\n//   person_id     string  -  linked person ID\n//   source        string  -  native | exploit_generated | hardened | harvest_updated | mail | bounce\n// ============================================================\n\nCRED_TYPES = {}\nCRED_TYPES.SYSTEM = \"system\"\nCRED_TYPES.MAIL   = \"mail\"\nCRED_TYPES.BANK   = \"bank\"\n\nCredentialDb = {}\nCredentialDb.db = null\n\nCredentialDb.findByUsername = function(username)\n    term = lower(username)\n    matchUser = function(record)\n        return record.hasIndex(\"username\") and lower(record.username).indexOf(term) != null\n    end function\n    return self.db.query(@matchUser)\nend function\n\nCredentialDb.findByIp = function(ip)\n    // Credentials can have multiple per IP so we still scan\n    // but skip records where neither IP field matches early\n    result = []\n    for kv in self.db.records\n        rec = kv.value\n        if rec.hasIndex(\"public_ip\") and rec.public_ip == ip then\n            result.push(rec)\n        else if rec.hasIndex(\"lan_ip\") and rec.lan_ip == ip then\n            result.push(rec)\n        end if\n    end for\n    return result\nend function\n\nCredentialDb.findByType = function(credType)\n    matchType = function(record)\n        return record.hasIndex(\"type\") and record.type == credType\n    end function\n    return self.db.query(@matchType)\nend function\n\nCredentialDb.findCracked = function()\n    matchCracked = function(record)\n        return record.hasIndex(\"password\") and record.password.len > 0\n    end function\n    return self.db.query(@matchCracked)\nend function\n\nCredentialDb.findByOrg = function(orgId)\n    matchOrg = function(record)\n        return record.hasIndex(\"org_id\") and record.org_id == orgId\n    end function\n    return self.db.query(@matchOrg)\nend function\n\nCredentialDb.search = function(term)\n    term = lower(term)\n    matchAny = function(record)\n        if record.hasIndex(\"username\") and lower(record.username).indexOf(term) != null then\n            return true\n        end if\n        if record.hasIndex(\"password\") and lower(record.password).indexOf(term) != null then\n            return true\n        end if\n        if record.hasIndex(\"public_ip\") and record.public_ip.indexOf(term) != null then\n            return true\n        end if\n        return false\n    end function\n    return self.db.query(@matchAny)\nend function\n\nCredentialDb.upsert = function(data)\n    // Natural key: username + public_ip + type\n    if not data.hasIndex(\"username\") then\n        return Error.New(\"Credential requires a username\", \"VALIDATION_ERROR\")\n    end if\n    if not data.hasIndex(\"type\") then\n        return Error.New(\"Credential requires a type (system|mail|bank)\", \"VALIDATION_ERROR\")\n    end if\n\n    pubIp = \"\"\n    if data.hasIndex(\"public_ip\") then\n        pubIp = data.public_ip\n    end if\n    credType = data.type\n    username = data.username\n\n    matchExisting = function(record)\n        if record.username != username then\n            return false\n        end if\n        if record.type     != credType then\n            return false\n        end if\n        if record.public_ip != pubIp   then\n            return false\n        end if\n        return true\n    end function\n\n    existing = self.db.query(@matchExisting)\n    if existing.len > 0 then\n        record = existing[0]\n        id     = record.id\n        incomingSource = \"\"\n        if data.hasIndex(\"source\") then\n            incomingSource = data.source\n        end if\n\n        if data.hasIndex(\"password\") and data.password.len > 0 then\n            incomingPass = data.password\n            existingPass = record.password\n\n            if incomingSource == \"exploit_generated\" or incomingSource == \"hardened\" then\n                // Preserve current password as native_pass before overwriting\n                // Only if we don't already have a native_pass saved\n                if not record.hasIndex(\"native_pass\") or record.native_pass.len == 0 then\n                    record.native_pass = existingPass\n                end if\n                record.password = incomingPass\n                record.source   = incomingSource\n\n            else if incomingSource == \"native\" or incomingSource == \"harvest\" then\n                // Re-harvest: if password differs from stored, flag as updated\n                // but don't overwrite native_pass if already set\n                if existingPass.len > 0 and incomingPass != existingPass then\n                    // Password changed since last visit - keep native, note update\n                    if not record.hasIndex(\"native_pass\") or record.native_pass.len == 0 then\n                        record.native_pass = existingPass\n                    end if\n                    record.password = incomingPass\n                    record.source   = \"harvest_updated\"\n                else if existingPass.len == 0 then\n                    record.password = incomingPass\n                    if not record.hasIndex(\"source\") or record.source.len == 0 or record.source == \"unknown\" then\n                        record.source = incomingSource\n                    end if\n                end if\n\n            else if incomingSource == \"routerattack\" or incomingSource == \"routerattack_passwd\" or incomingSource == \"routerattack_file\" then\n                // Router harvest - update password, preserving native if changed\n                if existingPass.len > 0 and incomingPass != existingPass then\n                    if not record.hasIndex(\"native_pass\") or record.native_pass.len == 0 then\n                        record.native_pass = existingPass\n                    end if\n                end if\n                record.password = incomingPass\n                record.source   = incomingSource\n\n            else\n                // Generic update - just update if not already set\n                if existingPass.len == 0 then\n                    record.password = incomingPass\n                end if\n            end if\n        end if\n\n        if data.hasIndex(\"hash\")        and data.hash.len        > 0 then\n            record.hash        = data.hash\n        end if\n        if data.hasIndex(\"bank_number\") and data.bank_number.len > 0 then\n            record.bank_number = data.bank_number\n        end if\n        if data.hasIndex(\"org_id\")      and data.org_id.len      > 0 then\n            record.org_id      = data.org_id\n        end if\n        if data.hasIndex(\"person_id\")   and data.person_id.len   > 0 then\n            record.person_id   = data.person_id\n        end if\n        if data.hasIndex(\"lan_ip\")      and data.lan_ip.len      > 0 then\n            record.lan_ip      = data.lan_ip\n        end if\n        self.db.set(id, record)\n        return id\n    else\n        id = self.db.nextId(\"c\")\n        record = {}\n        record.id          = id\n        record.type        = data.type\n        record.username    = data.username\n        record.password    = \"\"\n        record.native_pass = \"\"\n        record.hash        = \"\"\n        record.bank_number = \"\"\n        record.public_ip   = \"\"\n        record.lan_ip      = \"\"\n        record.org_id      = \"\"\n        record.person_id   = \"\"\n        record.source      = \"native\"\n        if data.hasIndex(\"password\")    then\n            record.password    = data.password\n        end if\n        if data.hasIndex(\"native_pass\") then\n            record.native_pass = data.native_pass\n        end if\n        if data.hasIndex(\"hash\")        then\n            record.hash        = data.hash\n        end if\n        if data.hasIndex(\"bank_number\") then\n            record.bank_number = data.bank_number\n        end if\n        if data.hasIndex(\"public_ip\")   then\n            record.public_ip   = data.public_ip\n        end if\n        if data.hasIndex(\"lan_ip\")      then\n            record.lan_ip      = data.lan_ip\n        end if\n        if data.hasIndex(\"org_id\")      then\n            record.org_id      = data.org_id\n        end if\n        if data.hasIndex(\"person_id\")   then\n            record.person_id   = data.person_id\n        end if\n        if data.hasIndex(\"source\")      then\n            record.source      = data.source\n        end if\n        self.db.set(id, record)\n        return id\n    end if\nend function\n\nCredentialDb.get = function(id)\n    return self.db.get(id)\nend function\n\nCredentialDb.updateRecord = function(record)\n    // Direct update of a record by id - used by migration and targeted updates\n    if not record.hasIndex(\"id\") then\n        return Error.New(\"Record missing id field\", \"NO_ID\")\n    end if\n    self.db.set(record.id, record)\n    return record.id\nend function\n\nCredentialDb.all = function()\n    return self.db.all()\nend function\n\nCredentialDb.New = function(db)\n    result    = new CredentialDb\n    result.db = db\n    return result\nend function\n",1)
m("/Corvid/source/managers/database/target-db.txt","// ============================================================\n// CORVID 2.0 | managers/database/target-db\n// Target record schema and operations.\n// Every machine encountered  -  whether exploited or discovered.\n//\n// Schema:\n//   id          string    -  auto-generated e.g. \"t_001\"\n//   public_ip   string    -  public IP address\n//   lan_ip      string    -  LAN IP address\n//   router_ip   string    -  router public IP\n//   hostname    string    -  machine name if known\n//   org_id      string    -  linked organisation ID\n//   privilege   string    -  highest privilege achieved\n//   status      string    -  unknown|scanned|exploited|owned|bounce\n//   ports       list      -  port records (see below)\n//   exploit_db  map       -  lib_key -> list of exploit records\n//   notes       string    -  freeform notes\n//   ssh_default bool      -  true if SSH was open natively (not installed by us)\n//\n// Port record:\n//   port       number\n//   service    string\n//   version    string\n//   forwarded  bool\n//   exploited  bool\n//\n// Exploit record:\n//   address    string    -  memory address\n//   exploit    string    -  overflow value\n//   rtype      string    -  Shell|Computer|File|Failed\n//   privilege  string    -  root|user|guest|unknown\n// ============================================================\n\nTARGET_STATUS = {}\nTARGET_STATUS.UNKNOWN   = \"unknown\"\nTARGET_STATUS.SCANNED   = \"scanned\"\nTARGET_STATUS.EXPLOITED = \"exploited\"\nTARGET_STATUS.OWNED     = \"owned\"\nTARGET_STATUS.BOUNCE    = \"bounce\"\n\nTargetDb = {}\nTargetDb.db = null\n\nTargetDb.findByPublicIp = function(ip)\n    // Full scan by public_ip to return ALL records for this IP\n    // (ipIndex only holds one entry per IP so can't use it for multi-record networks)\n    matchIp = function(record)\n        return record.hasIndex(\"public_ip\") and record.public_ip == ip\n    end function\n    return self.db.query(@matchIp)\nend function\n\nTargetDb.findByLanIp = function(ip)\n    matchIp = function(record)\n        return record.hasIndex(\"lan_ip\") and record.lan_ip == ip\n    end function\n    return self.db.query(@matchIp)\nend function\n\nTargetDb.findByStatus = function(status)\n    matchStatus = function(record)\n        return record.hasIndex(\"status\") and record.status == status\n    end function\n    return self.db.query(@matchStatus)\nend function\n\nTargetDb.findByOrg = function(orgId)\n    matchOrg = function(record)\n        return record.hasIndex(\"org_id\") and record.org_id == orgId\n    end function\n    return self.db.query(@matchOrg)\nend function\n\nTargetDb.findBounces = function()\n    return self.findByStatus(TARGET_STATUS.BOUNCE)\nend function\n\nTargetDb.getExploits = function(id, libKey)\n    record = self.db.get(id)\n    if record isa Error then\n        return record\n    end if\n    if not record.hasIndex(\"exploit_db\") then\n        return []\n    end if\n    if not record.exploit_db.hasIndex(libKey) then\n        return []\n    end if\n    return record.exploit_db[libKey]\nend function\n\nTargetDb.upsert = function(data)\n    // Natural key: public_ip + lan_ip\n    if not data.hasIndex(\"public_ip\") then\n        return Error.New(\"Target record requires public_ip\", \"VALIDATION_ERROR\")\n    end if\n\n    lanIp = \"\"\n    if data.hasIndex(\"lan_ip\") then\n        lanIp = data.lan_ip\n    end if\n\n    matchExisting = function(record)\n        if record.public_ip != data.public_ip then\n            return false\n        end if\n        // Only enforce lan_ip match if BOTH have a lan_ip set\n        if lanIp.len > 0 and record.hasIndex(\"lan_ip\") and record.lan_ip.len > 0 and record.lan_ip != lanIp then\n            return false\n        end if\n        return true\n    end function\n\n    existing = self.db.query(@matchExisting)\n    if existing.len > 0 then\n        record = existing[0]\n        id     = record.id\n        // Merge ports  -  avoid duplicates by port number\n        if data.hasIndex(\"ports\") then\n            for newPort in data.ports\n                found = false\n                if record.ports.len > 0 then\n                    for i in range(0, record.ports.len - 1)\n                        if record.ports[i].port == newPort.port then\n                            record.ports[i] = newPort\n                            found = true\n                        end if\n                    end for\n                end if\n                if not found then\n                    record.ports.push(newPort)\n                end if\n            end for\n        end if\n        // Update scalar fields\n        if data.hasIndex(\"hostname\")  and data.hostname.len  > 0 then\n            record.hostname  = data.hostname\n        end if\n        if data.hasIndex(\"org_id\")    and data.org_id.len    > 0 then\n            record.org_id    = data.org_id\n        end if\n        if data.hasIndex(\"router_ip\") and data.router_ip.len > 0 then\n            record.router_ip = data.router_ip\n        end if\n        if data.hasIndex(\"notes\")     and data.notes.len     > 0 then\n            if record.notes.len > 0 then\n                record.notes = record.notes + char(10) + data.notes\n            else\n                record.notes = data.notes\n            end if\n        end if\n        // Status  -  only upgrade, never downgrade\n        statusOrder = [TARGET_STATUS.UNKNOWN, TARGET_STATUS.SCANNED, TARGET_STATUS.EXPLOITED, TARGET_STATUS.OWNED, TARGET_STATUS.BOUNCE]\n        if data.hasIndex(\"status\") then\n            currentIdx = statusOrder.indexOf(record.status)\n            newIdx     = statusOrder.indexOf(data.status)\n            if newIdx == null then\n                newIdx = 0\n            end if\n            if currentIdx == null then\n                currentIdx = 0\n            end if\n            if newIdx > currentIdx then\n                record.status = data.status\n            end if\n        end if\n        // Privilege  -  only upgrade\n        privOrder = [\"unknown\", \"guest\", \"user\", \"root\"]\n        if data.hasIndex(\"privilege\") then\n            currentPrivIdx = privOrder.indexOf(record.privilege)\n            newPrivIdx     = privOrder.indexOf(data.privilege)\n            if newPrivIdx == null then\n                newPrivIdx = 0\n            end if\n            if currentPrivIdx == null then\n                currentPrivIdx = 0\n            end if\n            if newPrivIdx > currentPrivIdx then\n                record.privilege = data.privilege\n            end if\n        end if\n        // Exploit DB  -  merge by lib key\n        if data.hasIndex(\"exploit_db\") then\n            if not record.hasIndex(\"exploit_db\") then\n                record.exploit_db = {}\n            end if\n            for kv in data.exploit_db\n                record.exploit_db[kv.key] = kv.value\n            end for\n        end if\n        // ssh_default  -  once true, stays true\n        if data.hasIndex(\"ssh_default\") and data.ssh_default then\n            record.ssh_default = true\n        end if\n        self.db.set(id, record)\n        return id\n    else\n        id = self.db.nextId(\"t\")\n        record = {}\n        record.id          = id\n        record.public_ip   = data.public_ip\n        record.lan_ip      = \"\"\n        record.router_ip   = \"\"\n        record.hostname    = \"\"\n        record.org_id      = \"\"\n        record.privilege   = \"unknown\"\n        record.status      = TARGET_STATUS.UNKNOWN\n        record.ports       = []\n        record.exploit_db  = {}\n        record.notes       = \"\"\n        record.ssh_default = false\n        if data.hasIndex(\"lan_ip\")      then\n            record.lan_ip      = data.lan_ip\n        end if\n        if data.hasIndex(\"router_ip\")   then\n            record.router_ip   = data.router_ip\n        end if\n        if data.hasIndex(\"hostname\")    then\n            record.hostname     = data.hostname\n        end if\n        if data.hasIndex(\"org_id\")      then\n            record.org_id      = data.org_id\n        end if\n        if data.hasIndex(\"privilege\")   then\n            record.privilege    = data.privilege\n        end if\n        if data.hasIndex(\"status\")      then\n            record.status       = data.status\n        end if\n        if data.hasIndex(\"ports\")       then\n            record.ports        = data.ports\n        end if\n        if data.hasIndex(\"exploit_db\")  then\n            record.exploit_db   = data.exploit_db\n        end if\n        if data.hasIndex(\"notes\")       then\n            record.notes        = data.notes\n        end if\n        if data.hasIndex(\"ssh_default\") then\n            record.ssh_default  = data.ssh_default\n        end if\n        self.db.set(id, record)\n        return id\n    end if\nend function\n\nTargetDb.storeExploits = function(targetId, libKey, exploits)\n    // Store tested exploit results against a target by library key\n    record = self.db.get(targetId)\n    if record isa Error then\n        return record\n    end if\n    if not record.hasIndex(\"exploit_db\") then\n        record.exploit_db = {}\n    end if\n    record.exploit_db[libKey] = exploits\n    self.db.set(targetId, record)\nend function\n\nTargetDb.setStatus = function(targetId, status)\n    record = self.db.get(targetId)\n    if record isa Error then\n        return record\n    end if\n    record.status = status\n    self.db.set(targetId, record)\nend function\n\nTargetDb.addNote = function(id, note)\n    record = self.db.get(id)\n    if record isa Error then\n        return record\n    end if\n    if record.notes.len > 0 then\n        record.notes = record.notes + char(10) + note\n    else\n        record.notes = note\n    end if\n    self.db.set(id, record)\nend function\n\nTargetDb.get = function(id)\n    return self.db.get(id)\nend function\n\nTargetDb.all = function()\n    return self.db.all()\nend function\n\nTargetDb.New = function(db)\n    result    = new TargetDb\n    result.db = db\n    return result\nend function\n",1)
m("/Corvid/source/managers/database/database-manager.txt","// ============================================================\n// CORVID 2.0 | managers/database/database-manager\n// Unified database access layer. Instantiates and owns all\n// four databases. All other managers query intelligence\n// exclusively through this manager.\n// ============================================================\n\nDatabaseManager = {}\nDatabaseManager.mediator    = null\nDatabaseManager.personDb    = null\nDatabaseManager.orgDb       = null\nDatabaseManager.credDb      = null\nDatabaseManager.targetDb    = null\nDatabaseManager.exploitKb   = null\nDatabaseManager.roostDb     = null\nDatabaseManager.snifferDb   = null\n\nDatabaseManager.init = function()\n    // Ensure /Corvid/Data/ exists on the Nest\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler = sessionManager.pivotSession.handler\n\n    corvid = handler.getFile(\"/Corvid\")\n    if corvid isa Error then\n        result = handler.createFolder(\"/Corvid\")\n        if result isa Error then\n            return result\n        end if\n    end if\n    data = handler.getFile(\"/Corvid/Data\")\n    if data isa Error then\n        result = handler.createFolder(\"/Corvid/Data\")\n        if result isa Error then\n            return result\n        end if\n    end if\n\n    // Instantiate raw databases\n    personsRaw = Database.New(\"persons\")\n    personsRaw.setMediator(self.mediator)\n    personsRaw.load()\n\n    orgsRaw = Database.New(\"orgs\")\n    orgsRaw.setMediator(self.mediator)\n    orgsRaw.load()\n\n    credsRaw = Database.New(\"credentials\")\n    credsRaw.setMediator(self.mediator)\n    credsRaw.load()\n\n    targetsRaw = Database.New(\"targets\")\n    targetsRaw.setMediator(self.mediator)\n    targetsRaw.load()\n\n    // Wrap in typed layers\n    self.personDb = PersonDb.New(personsRaw)\n    self.orgDb    = OrgDb.New(orgsRaw)\n    self.credDb   = CredentialDb.New(credsRaw)\n    self.targetDb = TargetDb.New(targetsRaw)\n\n    // Exploit knowledge base - separate file\n    self.exploitKb = ExploitKbManager.New()\n    self.exploitKb.setMediator(self.mediator)\n    self.exploitKb.init()\n\n    // Roost node pool - supports file chaining for large pools\n    self.roostDb = RoostDb\n    self.roostDb.setMediator(self.mediator)\n    self.roostDb.records = self.loadChainedList(\"roost\", handler)\n\n    // Sniffer capture DB - supports file chaining for large capture sets\n    self.snifferDb = SnifferDb\n    self.snifferDb.setMediator(self.mediator)\n    snifferRecords = self.loadChainedList(\"sniffer\", handler)\n    self.snifferDb.records = snifferRecords\n    if snifferRecords.len > 0 then\n        lastId = snifferRecords[snifferRecords.len - 1].id\n        numStr = lastId[3:]\n        self.snifferDb.nextId = numStr.val + 1\n    end if\n\n    // ShinyLibs DB\n    self.shinyLibsDb = ShinyLibsDb\n    self.shinyLibsDb.init()\n    shinyData = self.loadJson(\"shinylibs\", handler)\n    if shinyData != null then\n        self.shinyLibsDb.deserialize(shinyData)\n    end if\nend function\n\nDatabaseManager.save = function()\n    // Save all dirty databases\n    results = []\n    r1 = self.personDb.db.save()\n    r2 = self.orgDb.db.save()\n    r3 = self.credDb.db.save()\n    r4 = self.targetDb.db.save()\n    r5 = self.exploitKb.save()\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler = sessionManager.pivotSession.handler\n    self.saveChainedList(\"roost\", self.roostDb.records, handler)\n    self.saveChainedList(\"sniffer\", self.snifferDb.records, handler)\n    self.saveJson(\"shinylibs\", self.shinyLibsDb.serialize(), handler)\n    if r1 isa Error then\n        results.push(r1)\n    end if\n    if r2 isa Error then\n        results.push(r2)\n    end if\n    if r3 isa Error then\n        results.push(r3)\n    end if\n    if r4 isa Error then\n        results.push(r4)\n    end if\n    if r5 isa Error then\n        results.push(r5)\n    end if\n    if results.len > 0 then\n        return results[0]\n    end if\nend function\n\n// ---- Chained list persistence helpers ----\n// Used for roost and sniffer which store flat arrays rather than keyed maps.\n// Files: /Corvid/Data/<name>.json, /Corvid/Data/<name>_2.json, etc.\n// Each file is a JSON object: {\"records\": [...], \"continued\": \"<next_path>\"}\n// Always rewrites from file 1 to prevent stale records.\n\nDatabaseManager.listChainPath = function(name, n)\n    if n == 1 then\n        return \"/Corvid/Data/\" + name + \".json\"\n    end if\n    return \"/Corvid/Data/\" + name + \"_\" + str(n) + \".json\"\nend function\n\n// Simple JSON file load/save for non-chained single-file databases\nDatabaseManager.loadJson = function(name, handler)\n    filePath = \"/Corvid/Data/\" + name + \".json\"\n    f = handler.getFile(filePath)\n    if f isa Error then\n        return null\n    end if\n    raw = f.content()\n    if raw == null or raw.len == 0 then\n        return null\n    end if\n    result = parse(raw)\n    if result == null then\n        return null\n    end if\n    return result\nend function\n\nDatabaseManager.saveJson = function(name, data, handler)\n    filePath = \"/Corvid/Data/\" + name + \".json\"\n    encoded  = toJSON(data)\n    f = handler.getFile(filePath)\n    if f isa Error then\n        result = handler.createFile(filePath)\n        if result isa Error then\n            return result\n        end if\n        f = handler.getFile(filePath)\n        if f isa Error then\n            return f\n        end if\n    end if\n    f.setContent(encoded)\nend function\n\nDatabaseManager.loadChainedList = function(name, handler)\n    allRecords = []\n    currentN = 1\n    chainDone = false\n    while not chainDone\n        path = self.listChainPath(name, currentN)\n        file = handler.getFile(path)\n        if file isa Error then\n            chainDone = true\n        else\n            raw = file.content()\n            if raw isa Error or raw.len == 0 then\n                chainDone = true\n            else\n                parsed = parse(raw)\n                if parsed == null then\n                    chainDone = true\n                else\n                    // Support both old format (bare list) and new format (object with records key)\n                    if typeof(parsed) == \"list\" then\n                        for r in parsed\n                            allRecords.push(r)\n                        end for\n                        chainDone = true\n                    else if parsed.hasIndex(\"records\") then\n                        for r in parsed.records\n                            allRecords.push(r)\n                        end for\n                        if parsed.hasIndex(\"continued\") and parsed.continued.len > 0 then\n                            currentN = currentN + 1\n                        else\n                            chainDone = true\n                        end if\n                    else\n                        chainDone = true\n                    end if\n                end if\n            end if\n        end if\n    end while\n    return allRecords\nend function\n\nDatabaseManager.saveChainedList = function(name, records, handler)\n    THRESHOLD = 140000\n    // Partition records into chunks by running size estimate\n    chunks = []\n    currentChunk = []\n    currentSize = 2  // []\n    for r in records\n        entryJson = toJSON(r)\n        // comma + entry\n        entrySize = entryJson.len + 1\n        if currentSize + entrySize < THRESHOLD - 200 then\n            currentChunk.push(r)\n            currentSize = currentSize + entrySize\n        else\n            chunks.push(currentChunk)\n            currentChunk = [r]\n            currentSize = 2 + entryJson.len\n        end if\n    end for\n    if currentChunk.len > 0 then\n        chunks.push(currentChunk)\n    end if\n    if chunks.len == 0 then\n        chunks.push([])\n    end if\n\n    // Write each chunk - always from file 1\n    fileN = 1\n    for i in range(0, chunks.len - 1)\n        path = self.listChainPath(name, fileN)\n        fileObj = {}\n        fileObj.records = chunks[i]\n        if i < chunks.len - 1 then\n            fileObj.continued = self.listChainPath(name, fileN + 1)\n        else\n            fileObj.continued = \"\"\n        end if\n        file = handler.getFile(path)\n        if file isa Error then\n            handler.createFile(path)\n            file = handler.getFile(path)\n        end if\n        if not (file isa Error) then\n            file.setContent(toJSON(fileObj))\n        end if\n        fileN = fileN + 1\n    end for\n\n    // Delete any leftover chain files from previous larger saves\n    cleanN = fileN\n    cleanDone = false\n    while not cleanDone\n        cleanPath = self.listChainPath(name, cleanN)\n        cleanFile = handler.getFile(cleanPath)\n        if cleanFile isa Error then\n            cleanDone = true\n        else\n            cleanFile.delete()\n            cleanN = cleanN + 1\n        end if\n    end while\nend function\n\n// ---- Person operations ----\n\nDatabaseManager.upsertPerson = function(data)\n    return self.personDb.upsert(data)\nend function\n\nDatabaseManager.findPerson = function(term)\n    return self.personDb.search(term)\nend function\n\nDatabaseManager.findPersonByEmail = function(email)\n    return self.personDb.findByEmail(email)\nend function\n\nDatabaseManager.findPersonByIp = function(ip)\n    return self.personDb.findByIp(ip)\nend function\n\nDatabaseManager.allPersons = function()\n    return self.personDb.all()\nend function\n\nDatabaseManager.getPerson = function(id)\n    return self.personDb.get(id)\nend function\n\n// ---- Organisation operations ----\n\nDatabaseManager.upsertOrg = function(data)\n    return self.orgDb.upsert(data)\nend function\n\nDatabaseManager.findOrg = function(term)\n    return self.orgDb.search(term)\nend function\n\nDatabaseManager.findOrgByDomain = function(domain)\n    return self.orgDb.findByDomain(domain)\nend function\n\nDatabaseManager.findOrgByIp = function(ip)\n    return self.orgDb.findByIp(ip)\nend function\n\nDatabaseManager.allOrgs = function()\n    return self.orgDb.all()\nend function\n\nDatabaseManager.getOrg = function(id)\n    return self.orgDb.get(id)\nend function\n\n// ---- Credential operations ----\n\nDatabaseManager.upsertCredential = function(data)\n    return self.credDb.upsert(data)\nend function\n\nDatabaseManager.getExploitKb = function()\n    return self.exploitKb\nend function\n\nDatabaseManager.kbLookup = function(libName, libVersion)\n    return self.exploitKb.lookup(libName, libVersion)\nend function\n\nDatabaseManager.kbRecord = function(libName, libVersion, address, exploit, outcome, constraints, rtype, resultPath, privilege, blockedBy)\n    return self.exploitKb.record(libName, libVersion, address, exploit, outcome, constraints, rtype, resultPath, privilege, blockedBy)\nend function\n\nDatabaseManager.kbGetBest = function(libName, libVersion)\n    return self.exploitKb.getBestExploit(libName, libVersion)\nend function\n\nDatabaseManager.kbStats = function()\n    return self.exploitKb.stats()\nend function\n\nDatabaseManager.updateCredentialRecord = function(record)\n    return self.credDb.updateRecord(record)\nend function\n\nDatabaseManager.findCredentials = function(term)\n    return self.credDb.search(term)\nend function\n\nDatabaseManager.findCredentialsByIp = function(ip)\n    return self.credDb.findByIp(ip)\nend function\n\nDatabaseManager.findCredentialsByType = function(credType)\n    return self.credDb.findByType(credType)\nend function\n\nDatabaseManager.findCrackedCredentials = function()\n    return self.credDb.findCracked()\nend function\n\nDatabaseManager.allCredentials = function()\n    return self.credDb.all()\nend function\n\n// Helper: Find root system credentials for SSH access\nDatabaseManager.findRootSshCredentials = function(ip)\n    creds = self.findCredentialsByIp(ip)\n    result = {\"password\": \"\", \"native_pass\": \"\"}\n    for cred in creds\n        if cred.type == CRED_TYPES.SYSTEM and cred.username == \"root\" then\n            if cred.password.len > 0 then\n                result.password = cred.password\n            end if\n            if cred.hasIndex(\"native_pass\") and cred.native_pass.len > 0 then\n                result.native_pass = cred.native_pass\n            end if\n        end if\n    end for\n    return result\nend function\n\n// Helper: Extract all unique root passwords (current + native) for escalation\nDatabaseManager.extractRootPasswords = function(ip)\n    creds = self.findCredentialsByIp(ip)\n    passwords = []\n    for cred in creds\n        if cred.type == CRED_TYPES.SYSTEM and cred.username == \"root\" then\n            if cred.password.len > 0 and passwords.indexOf(cred.password) == null then\n                passwords.push(cred.password)\n            end if\n            if cred.hasIndex(\"native_pass\") and cred.native_pass.len > 0 then\n                if passwords.indexOf(cred.native_pass) == null then\n                    passwords.push(cred.native_pass)\n                end if\n            end if\n        end if\n    end for\n    return passwords\nend function\n\n// Helper: Find specific user credentials by IP and username\nDatabaseManager.findUserCredentials = function(ip, username)\n    creds = self.findCredentialsByIp(ip)\n    result = []\n    for cred in creds\n        if cred.username == username then\n            result.push(cred)\n        end if\n    end for\n    return result\nend function\n\n// Helper: Find any system credential (prefers root, falls back to any system user)\nDatabaseManager.findAnySystemCredentials = function(ip)\n    creds = self.findCredentialsByIp(ip)\n    result = {\"username\": \"\", \"password\": \"\"}\n    \n    // Pass 1: prefer root\n    for cred in creds\n        if cred.username == \"root\" and cred.password.len > 0 then\n            result.username = \"root\"\n            result.password = cred.password\n            return result\n        end if\n        if cred.username == \"root\" and cred.hasIndex(\"native_pass\") and cred.native_pass.len > 0 then\n            if result.password.len == 0 then\n                result.username = \"root\"\n                result.password = cred.native_pass\n            end if\n        end if\n    end for\n    \n    // Pass 2: fall back to any system credential\n    if result.password.len == 0 then\n        for cred in creds\n            cType = \"\"\n            if cred.hasIndex(\"type\") then\n                cType = cred.type\n            end if\n            if cType != \"system\" then\n                continue\n            end if\n            if cred.password.len > 0 then\n                result.username = cred.username\n                result.password = cred.password\n                break\n            end if\n            if cred.hasIndex(\"native_pass\") and cred.native_pass.len > 0 then\n                result.username = cred.username\n                result.password = cred.native_pass\n                break\n            end if\n        end for\n    end if\n    \n    return result\nend function\n\n// ---- Target operations ----\n\nDatabaseManager.upsertTarget = function(data)\n    return self.targetDb.upsert(data)\nend function\n\nDatabaseManager.findTarget = function(ip)\n    results = self.targetDb.findByPublicIp(ip)\n    if results.len == 0 then\n        results = self.targetDb.findByLanIp(ip)\n    end if\n    return results\nend function\n\nDatabaseManager.findTargetsByStatus = function(status)\n    return self.targetDb.findByStatus(status)\nend function\n\nDatabaseManager.findBounces = function()\n    return self.targetDb.findBounces()\nend function\n\nDatabaseManager.allTargets = function()\n    return self.targetDb.all()\nend function\n\nDatabaseManager.getTarget = function(id)\n    return self.targetDb.get(id)\nend function\n\nDatabaseManager.storeExploits = function(targetId, libKey, exploits)\n    return self.targetDb.storeExploits(targetId, libKey, exploits)\nend function\n\nDatabaseManager.getExploits = function(targetId, libKey)\n    return self.targetDb.getExploits(targetId, libKey)\nend function\n\nDatabaseManager.setTargetStatus = function(targetId, status)\n    return self.targetDb.setStatus(targetId, status)\nend function\n\n// ---- Linking operations ----\n\nDatabaseManager.linkPersonToOrg = function(personId, orgId)\n    record = self.personDb.get(personId)\n    if record isa Error then\n        return record\n    end if\n    record.org_id = orgId\n    self.personDb.db.set(personId, record)\nend function\n\nDatabaseManager.linkCredentialToPerson = function(credId, personId)\n    record = self.credDb.get(credId)\n    if record isa Error then\n        return record\n    end if\n    record.person_id = personId\n    self.credDb.db.set(credId, record)\nend function\n\nDatabaseManager.addNote = function(collection, id, note)\n    if collection == \"person\" then\n        return self.personDb.addNote(id, note)\n    end if\n    if collection == \"org\"    then\n        return self.orgDb.addNote(id, note)\n    end if\n    if collection == \"target\" then\n        return self.targetDb.addNote(id, note)\n    end if\n    return Error.New(\"Unknown collection: \" + collection, \"UNKNOWN_COLLECTION\")\nend function\n\n// ---- Sniffer operations ----\n\nDatabaseManager.addSnifferCapture = function(raw, capturedFrom)\n    return self.snifferDb.add(raw, capturedFrom)\nend function\n\nDatabaseManager.getSnifferCapture = function(id)\n    return self.snifferDb.find(id)\nend function\n\nDatabaseManager.allSnifferCaptures = function()\n    return self.snifferDb.records\nend function\n\nDatabaseManager.removeSnifferCapture = function(id)\n    return self.snifferDb.remove(id)\nend function\n\n// ---- Stats ----\n\nDatabaseManager.stats = function()\n    result = {}\n    result.persons     = self.personDb.db.count()\n    result.orgs        = self.orgDb.db.count()\n    result.credentials = self.credDb.db.count()\n    result.targets     = self.targetDb.db.count()\n    result.sniffer     = self.snifferDb.records.len\n    return result\nend function\n\nDatabaseManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nDatabaseManager.New = function()\n    result = new DatabaseManager\n    result.personDb = null\n    result.orgDb    = null\n    result.credDb   = null\n    result.targetDb = null\n    return result\nend function\n",1)
