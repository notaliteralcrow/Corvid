// ---- Linking operations ----

DatabaseManager.linkPersonToOrg = function(personId, orgId)
    record = self.personDb.get(personId)
    if record isa Error then
        return record
    end if
    record.org_id = orgId
    self.personDb.db.set(personId, record)
end function

DatabaseManager.linkCredentialToPerson = function(credId, personId)
    record = self.credDb.get(credId)
    if record isa Error then
        return record
    end if
    record.person_id = personId
    self.credDb.db.set(credId, record)
end function

DatabaseManager.addNote = function(collection, id, note)
    if collection == ""person"" then
        return self.personDb.addNote(id, note)
    end if
    if collection == ""org""    then
        return self.orgDb.addNote(id, note)
    end if
    if collection == ""target"" then
        return self.targetDb.addNote(id, note)
    end if
    return Error.New(""Unknown collection: "" + collection, ""UNKNOWN_COLLECTION"")
end function

// ---- Sniffer operations ----

DatabaseManager.addSnifferCapture = function(raw, capturedFrom)
    return self.snifferDb.add(raw, capturedFrom)
end function

DatabaseManager.getSnifferCapture = function(id)
    return self.snifferDb.find(id)
end function

DatabaseManager.allSnifferCaptures = function()
    return self.snifferDb.records
end function

DatabaseManager.removeSnifferCapture = function(id)
    return self.snifferDb.remove(id)
end function

// ---- Stats ----

DatabaseManager.stats = function()
    result = {}
    result.persons     = self.personDb.db.count()
    result.orgs        = self.orgDb.db.count()
    result.credentials = self.credDb.db.count()
    result.targets     = self.targetDb.db.count()
    result.sniffer     = self.snifferDb.records.len
    return result
end function

DatabaseManager.setMediator = function(mediator)
    self.mediator = mediator
end function

DatabaseManager.New = function()
    result = new DatabaseManager
    result.personDb = null
    result.orgDb    = null
    result.credDb   = null
    result.targetDb = null
    return result
end function
