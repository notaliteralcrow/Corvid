m("/Corvid/asriN/managers/database/database.txt","// ============================================================
// CORVID | managers/database/database
// Core database engine. Backed by JSON files on the Nest.
// Provides generic read, write, upsert, query, delete.
// Each database is a map keyed by record id.
//
// CHAINING:
//   When a file exceeds SPLIT_THRESHOLD chars on save, it is
//   closed with a {""__continued"": ""name_2.json""} marker and
//   a new file is started. On load all files in the chain are
//   merged into one in-memory map. Writes always go to the
//   latest file (lazy strategy - stale copies in earlier files
//   are overwritten on next load).
//
// OPTIMIZATIONS:
//   - ipIndex: map of publicIp -> id for O(1) IP lookups
//   - idCounter: tracks highest ID number to avoid full scan
//   - dirty flag prevents redundant saves
// ============================================================

Database = {}
Database.mediator     = null
Database.name         = null
Database.records      = {}
Database.ipIndex      = {}
Database.idCounter    = 0
Database.dirty        = false
Database.chainIndex   = 1      // current file number (1 = name.json, 2 = name_2.json...)
Database.SPLIT_THRESHOLD = 140000

Database.basePath = function()
    return ""/Corvid/Data/"" + self.name + "".json""
end function

Database.chainPath = function(n)
    if n == 1 then
        return ""/Corvid/Data/"" + self.name + "".json""
    end if
    return ""/Corvid/Data/"" + self.name + ""_"" + str(n) + "".json""
end function

Database.rebuildIndex = function()
    self.ipIndex   = {}
    self.idCounter = 0
    for kv in self.records
        rec = kv.value
        id  = kv.key
        if rec.hasIndex(""public_ip"") and rec.public_ip.len > 0 then
            self.ipIndex[rec.public_ip] = id
        end if
        if id.len > 2 then
            num = id[2:].val
            if num > self.idCounter then
                self.idCounter = num
            end if
        end if
    end for
end function

Database.load = function()
    sessionManager = self.mediator.getExtension(""sessionManager"")
    handler = sessionManager.pivotSession.handler

    self.records   = {}
    self.ipIndex   = {}
    self.idCounter = 0
    self.chainIndex = 1

    // Follow the chain, merging all files into records
    currentN = 1
    while true
        path = self.chainPath(currentN)
        file = handler.getFile(path)
        if file isa Error then
            // No file at this index - stop (chainIndex stays at last good file)
            if currentN > 1 then
                self.chainIndex = currentN - 1
            end if
            break
        end if
        raw = file.content()
        if raw isa Error or raw.len == 0 then
            if currentN > 1 then
                self.chainIndex = currentN - 1
            end if
            break
        end if
        parsed = parse(raw)
        if parsed == null then
            if currentN > 1 then
                self.chainIndex = currentN - 1
            end if
            break
        end if

        // Check for continuation marker
        nextFile = """"
        if parsed.hasIndex(""__continued"") then
            nextFile = parsed[""__continued""]
            parsed.remove(""__continued"")
        end if

        // Merge records - later files overwrite earlier ones (lazy dedup)
        for kv in parsed
            if kv.key != ""__continued"" then
                self.records[kv.key] = kv.value
            end if
        end for

        if nextFile.len > 0 then
            // Advance to next file in chain
            currentN = currentN + 1
        else
            // This is the last file in the chain
            self.chainIndex = currentN
            break
        end if
    end while

    self.rebuildIndex()
end function

Database.save = function()
    if not self.dirty then
        return
    end if
    sessionManager = self.mediator.getExtension(""sessionManager"")
    handler = sessionManager.pivotSession.handler

    // Collect all record keys (excluding any __continued sentinel)
    allKeys = []
    for kv in self.records
        if kv.key != ""__continued"" then
            allKeys.push(kv.key)
        end if
    end for

    // Partition records into chunks that each fit within SPLIT_THRESHOLD.
    // We always rewrite from file 1 so there are never stale records in
    // earlier chain files from a previous session's split point.
    // Use a running size estimate to avoid O(n^2) toJSON calls.
    chunks = []
    currentChunk = {}
    currentSize = 2  // opening/closing braces of {}
    for k in allKeys
        recJson = toJSON(self.records[k])
        // key + colon + value + comma + quotes = key.len + recJson.len + 4
        entrySize = k.len + recJson.len + 4
        // Keep 200 chars of headroom for the __continued marker
        if currentSize + entrySize < self.SPLIT_THRESHOLD - 200 then
            currentChunk[k] = self.records[k]
            currentSize = currentSize + entrySize
        else
            chunks.push(currentChunk)
            currentChunk = {}
            currentChunk[k] = self.records[k]
            currentSize = 2 + entrySize
        end if
    end for
    if currentChunk.len > 0 then
        chunks.push(currentChunk)
    end if

    if chunks.len == 0 then
        // Empty database - write empty file
        chunks.push({})
    end if

    // Write each chunk to its chain file.
    // All but the last get a __continued pointer to the next file.
    fileN = 1
    for i in range(0, chunks.len - 1)
        chunk = chunks[i]
        path = self.chainPath(fileN)
        if i < chunks.len - 1 then
            chunk[""__continued""] = self.chainPath(fileN + 1)
        end if
        file = handler.getFile(path)
        if file isa Error then
            result = handler.createFile(path)
            if result isa Error then
                return result
            end if
            file = handler.getFile(path)
            if file isa Error then
                return file
            end if
        end if
        file.setContent(toJSON(chunk))
        fileN = fileN + 1
    end for

    // Delete any chain files beyond what we just wrote (left over from
    // a previous session that had more chunks than we need now)
    cleanN = fileN
    cleanDone = false
    while not cleanDone
        cleanPath = self.chainPath(cleanN)
        cleanFile = handler.getFile(cleanPath)
        if cleanFile isa Error then
            cleanDone = true
        else
            cleanFile.delete()
            cleanN = cleanN + 1
        end if
    end while

    self.chainIndex = fileN - 1
    self.dirty = false
end function

Database.get = function(id)
    if not self.records.hasIndex(id) then
        return Error.New(""Record not found: "" + id, ""NOT_FOUND"")
    end if
    return self.records[id]
end function

Database.set = function(id, record)
    if record.hasIndex(""public_ip"") and record.public_ip.len > 0 then
        self.ipIndex[record.public_ip] = id
    end if
    self.records[id] = record
    self.dirty = true
end function

Database.delete = function(id)
    if not self.records.hasIndex(id) then
        return Error.New(""Record not found: "" + id, ""NOT_FOUND"")
    end if
    rec = self.records[id]
    if rec.hasIndex(""public_ip"") and self.ipIndex.hasIndex(rec.public_ip) then
        self.ipIndex.remove(rec.public_ip)
    end if
    self.records.remove(id)
    self.dirty = true
end function

Database.all = function()
    result = []
    for kv in self.records
        if kv.key != ""__continued"" then
            result.push(kv.value)
        end if
    end for
    return result
end function

Database.query = function(matchFn)
    result = []
    for kv in self.records
        if kv.key != ""__continued"" then
            if matchFn(kv.value) then
                result.push(kv.value)
            end if
        end if
    end for
    return result
end function

Database.findByIp = function(ip)
    if not self.ipIndex.hasIndex(ip) then
        return null
    end if
    id = self.ipIndex[ip]
    if not self.records.hasIndex(id) then
        return null
    end if
    return self.records[id]
end function

Database.upsert = function(id, record)
    if self.records.hasIndex(id) then
        existing = self.records[id]
        for kv in record
            existing[kv.key] = kv.value
        end for
        self.set(id, existing)
    else
        record.id = id
        self.set(id, record)
    end if
    self.dirty = true
end function

Database.nextId = function(prefix)
    self.idCounter = self.idCounter + 1
    next = str(self.idCounter)
    while next.len < 3
        next = ""0"" + next
    end while
    return prefix + ""_"" + next
end function

Database.count = function()
    return self.records.len
end function

Database.setMediator = function(mediator)
    self.mediator = mediator
end function

Database.New = function(name)
    result = new Database
    result.name         = name
    result.records      = {}
    result.ipIndex      = {}
    result.idCounter    = 0
    result.dirty        = false
    result.chainIndex   = 1
    return result
end function
",1)
m("/Corvid/asriN/managers/database/person-db.txt","// ============================================================
// CORVID | managers/database/person-db
// Person record schema and operations.
// A person is anyone whose identity has been discovered  - 
// from whois, mail files, or social engineering.
//
// Schema:
//   id        string    -  auto-generated e.g. ""p_001""
//   name      string    -  full name
//   email     string    -  primary email address
//   org_id    string    -  linked organisation ID
//   ips       list      -  known public IPs
//   lan_ips   list      -  known LAN IPs
//   notes     string    -  freeform notes
//   source    string    -  how discovered: whois | mail | manual
// ============================================================

PersonDb = {}
PersonDb.db = null

PersonDb.findByEmail = function(email)
    matchEmail = function(record)
        return record.hasIndex(""email"") and record.email == email
    end function
    return self.db.query(@matchEmail)
end function

PersonDb.findByName = function(name)
    matchName = function(record)
        return record.hasIndex(""name"") and record.name.indexOf(name) != null
    end function
    return self.db.query(@matchName)
end function

PersonDb.findByIp = function(ip)
    matchIp = function(record)
        if record.hasIndex(""ips"") and record.ips.indexOf(ip) != null then
            return true
        end if
        if record.hasIndex(""lan_ips"") and record.lan_ips.indexOf(ip) != null then
            return true
        end if
        return false
    end function
    return self.db.query(@matchIp)
end function

PersonDb.findByOrg = function(orgId)
    matchOrg = function(record)
        return record.hasIndex(""org_id"") and record.org_id == orgId
    end function
    return self.db.query(@matchOrg)
end function

PersonDb.search = function(term)
    // Broad search across name, email, notes
    term = lower(term)
    matchAny = function(record)
        if record.hasIndex(""name"")  and record.lower(name).indexOf(term)  != null then
            return true
        end if
        if record.hasIndex(""email"") and record.lower(email).indexOf(term) != null then
            return true
        end if
        if record.hasIndex(""notes"") and record.lower(notes).indexOf(term) != null then
            return true
        end if
        return false
    end function
    return self.db.query(@matchAny)
end function

PersonDb.upsert = function(data)
    // Upsert by email  -  email is the natural key for a person
    if not data.hasIndex(""email"") or data.email.len == 0 then
        return Error.New(""Person record requires an email address"", ""VALIDATION_ERROR"")
    end if
    existing = self.findByEmail(data.email)
    if existing.len > 0 then
        record = existing[0]
        id     = record.id
        // Merge IPs
        if data.hasIndex(""ips"") then
            for ip in data.ips
                if record.ips.indexOf(ip) == null then
                    record.ips.push(ip)
                end if
            end for
        end if
        if data.hasIndex(""lan_ips"") then
            for ip in data.lan_ips
                if record.lan_ips.indexOf(ip) == null then
                    record.lan_ips.push(ip)
                end if
            end for
        end if
        // Update scalar fields if provided and non-empty
        if data.hasIndex(""name"")   and data.name.len   > 0 then
            record.name   = data.name
        end if
        if data.hasIndex(""org_id"") and data.org_id.len > 0 then
            record.org_id = data.org_id
        end if
        if data.hasIndex(""notes"")  and data.notes.len  > 0 then
            record.notes  = data.notes
        end if
        self.db.set(id, record)
        return id
    else
        id = self.db.nextId(""p"")
        record = {}
        record.id      = id
        record.name    = """"
        record.email   = data.email
        record.org_id  = """"
        record.ips     = []
        record.lan_ips = []
        record.notes   = """"
        record.source  = ""unknown""
        if data.hasIndex(""name"")    then
            record.name    = data.name
        end if
        if data.hasIndex(""org_id"")  then
            record.org_id  = data.org_id
        end if
        if data.hasIndex(""ips"")     then
            record.ips     = data.ips
        end if
        if data.hasIndex(""lan_ips"") then
            record.lan_ips = data.lan_ips
        end if
        if data.hasIndex(""notes"")   then
            record.notes   = data.notes
        end if
        if data.hasIndex(""source"")  then
            record.source  = data.source
        end if
        self.db.set(id, record)
        return id
    end if
end function

PersonDb.get = function(id)
    return self.db.get(id)
end function

PersonDb.all = function()
    return self.db.all()
end function

PersonDb.addNote = function(id, note)
    record = self.db.get(id)
    if record isa Error then
        return record
    end if
    if record.notes.len > 0 then
        record.notes = record.notes + char(10) + note
    else
        record.notes = note
    end if
    self.db.set(id, record)
end function

PersonDb.New = function(db)
    result    = new PersonDb
    result.db = db
    return result
end function
",1)
m("/Corvid/asriN/managers/database/org-db.txt","// ============================================================
// CORVID | managers/database/org-db
// Organisation record schema and operations.
// An org is any company or entity whose infrastructure
// has been touched or identified.
//
// Schema:
//   id      string    -  auto-generated e.g. ""o_001""
//   name    string    -  company name
//   domain  string    -  primary domain e.g. ""acme.net""
//   ips     list      -  known public IPs
//   notes   string    -  freeform notes
// ============================================================

OrgDb = {}
OrgDb.db = null

OrgDb.findByDomain = function(domain)
    matchDomain = function(record)
        return record.hasIndex(""domain"") and record.domain == domain
    end function
    return self.db.query(@matchDomain)
end function

OrgDb.findByName = function(name)
    term = lower(name)
    matchName = function(record)
        return record.hasIndex(""name"") and record.lower(name).indexOf(term) != null
    end function
    return self.db.query(@matchName)
end function

OrgDb.findByIp = function(ip)
    matchIp = function(record)
        return record.hasIndex(""ips"") and record.ips.indexOf(ip) != null
    end function
    return self.db.query(@matchIp)
end function

OrgDb.search = function(term)
    term = lower(term)
    matchAny = function(record)
        if record.hasIndex(""name"")   and record.lower(name).indexOf(term)   != null then
            return true
        end if
        if record.hasIndex(""domain"") and record.lower(domain).indexOf(term) != null then
            return true
        end if
        if record.hasIndex(""notes"")  and record.lower(notes).indexOf(term)  != null then
            return true
        end if
        return false
    end function
    return self.db.query(@matchAny)
end function

OrgDb.upsert = function(data)
    // Upsert by domain  -  domain is the natural key for an org
    if not data.hasIndex(""domain"") or data.domain.len == 0 then
        return Error.New(""Organisation record requires a domain"", ""VALIDATION_ERROR"")
    end if
    existing = self.findByDomain(data.domain)
    if existing.len > 0 then
        record = existing[0]
        id     = record.id
        if data.hasIndex(""ips"") then
            for ip in data.ips
                if record.ips.indexOf(ip) == null then
                    record.ips.push(ip)
                end if
            end for
        end if
        if data.hasIndex(""name"")  and data.name.len  > 0 then
            record.name  = data.name
        end if
        if data.hasIndex(""notes"") and data.notes.len > 0 then
            record.notes = data.notes
        end if
        self.db.set(id, record)
        return id
    else
        id = self.db.nextId(""o"")
        record = {}
        record.id     = id
        record.name   = """"
        record.domain = data.domain
        record.ips    = []
        record.notes  = """"
        if data.hasIndex(""name"")  then
            record.name  = data.name
        end if
        if data.hasIndex(""ips"")   then
            record.ips   = data.ips
        end if
        if data.hasIndex(""notes"") then
            record.notes = data.notes
        end if
        self.db.set(id, record)
        return id
    end if
end function

OrgDb.get = function(id)
    return self.db.get(id)
end function

OrgDb.all = function()
    return self.db.all()
end function

OrgDb.addNote = function(id, note)
    record = self.db.get(id)
    if record isa Error then
        return record
    end if
    if record.notes.len > 0 then
        record.notes = record.notes + char(10) + note
    else
        record.notes = note
    end if
    self.db.set(id, record)
end function

OrgDb.New = function(db)
    result    = new OrgDb
    result.db = db
    return result
end function
",1)
m("/Corvid/asriN/managers/database/credential-db.txt","// ============================================================
// CORVID | managers/database/credential-db
// Credential record schema and operations.
// All credential types  -  system, mail, bank  -  unified
// in one schema with a type field to distinguish them.
//
// Schema:
//   id            string  -  auto-generated e.g. ""c_001""
//   type          string  -  system | mail | bank
//   username      string  -  login name or email address
//   password      string  -  plaintext if cracked, else """"
//   native_pass   string  -  original password before Corvid changed it
//   hash          string  -  original hash from passwd/mail
//   bank_number   string  -  bank account number (bank type)
//   public_ip     string  -  source machine public IP
//   lan_ip        string  -  source machine LAN IP
//   org_id        string  -  linked organisation ID
//   person_id     string  -  linked person ID
//   source        string  -  native | exploit_generated | hardened | harvest_updated | mail | bounce
// ============================================================

CRED_TYPES = {}
CRED_TYPES.SYSTEM = ""system""
CRED_TYPES.MAIL   = ""mail""
CRED_TYPES.BANK   = ""bank""

CredentialDb = {}
CredentialDb.db = null

CredentialDb.findByUsername = function(username)
    term = lower(username)
    matchUser = function(record)
        return record.hasIndex(""username"") and lower(record.username).indexOf(term) != null
    end function
    return self.db.query(@matchUser)
end function

CredentialDb.findByIp = function(ip)
    // Credentials can have multiple per IP so we still scan
    // but skip records where neither IP field matches early
    result = []
    for kv in self.db.records
        rec = kv.value
        if rec.hasIndex(""public_ip"") and rec.public_ip == ip then
            result.push(rec)
        else if rec.hasIndex(""lan_ip"") and rec.lan_ip == ip then
            result.push(rec)
        end if
    end for
    return result
end function

CredentialDb.findByType = function(credType)
    matchType = function(record)
        return record.hasIndex(""type"") and record.type == credType
    end function
    return self.db.query(@matchType)
end function

CredentialDb.findCracked = function()
    matchCracked = function(record)
        return record.hasIndex(""password"") and record.password.len > 0
    end function
    return self.db.query(@matchCracked)
end function

CredentialDb.findByOrg = function(orgId)
    matchOrg = function(record)
        return record.hasIndex(""org_id"") and record.org_id == orgId
    end function
    return self.db.query(@matchOrg)
end function

CredentialDb.search = function(term)
    term = lower(term)
    matchAny = function(record)
        if record.hasIndex(""username"") and lower(record.username).indexOf(term) != null then
            return true
        end if
        if record.hasIndex(""password"") and lower(record.password).indexOf(term) != null then
            return true
        end if
        if record.hasIndex(""public_ip"") and record.public_ip.indexOf(term) != null then
            return true
        end if
        return false
    end function
    return self.db.query(@matchAny)
end function

CredentialDb.upsert = function(data)
    // Natural key: username + public_ip + type
    if not data.hasIndex(""username"") then
        return Error.New(""Credential requires a username"", ""VALIDATION_ERROR"")
    end if
    if not data.hasIndex(""type"") then
        return Error.New(""Credential requires a type (system|mail|bank)"", ""VALIDATION_ERROR"")
    end if

    pubIp = """"
    if data.hasIndex(""public_ip"") then
        pubIp = data.public_ip
    end if
    credType = data.type
    username = data.username

    matchExisting = function(record)
        if record.username != username then
            return false
        end if
        if record.type     != credType then
            return false
        end if
        if record.public_ip != pubIp   then
            return false
        end if
        return true
    end function

    existing = self.db.query(@matchExisting)
    if existing.len > 0 then
        record = existing[0]
        id     = record.id
        incomingSource = """"
        if data.hasIndex(""source"") then
            incomingSource = data.source
        end if

        if data.hasIndex(""password"") and data.password.len > 0 then
            incomingPass = data.password
            existingPass = record.password

            if incomingSource == ""exploit_generated"" or incomingSource == ""hardened"" then
                // Preserve current password as native_pass before overwriting
                // Only if we don't already have a native_pass saved
                if not record.hasIndex(""native_pass"") or record.native_pass.len == 0 then
                    record.native_pass = existingPass
                end if
                record.password = incomingPass
                record.source   = incomingSource

            else if incomingSource == ""native"" or incomingSource == ""harvest"" then
                // Re-harvest: if password differs from stored, flag as updated
                // but don't overwrite native_pass if already set
                if existingPass.len > 0 and incomingPass != existingPass then
                    // Password changed since last visit - keep native, note update
                    if not record.hasIndex(""native_pass"") or record.native_pass.len == 0 then
                        record.native_pass = existingPass
                    end if
                    record.password = incomingPass
                    record.source   = ""harvest_updated""
                else if existingPass.len == 0 then
                    record.password = incomingPass
                    if not record.hasIndex(""source"") or record.source.len == 0 or record.source == ""unknown"" then
                        record.source = incomingSource
                    end if
                end if

            else if incomingSource == ""routerattack"" or incomingSource == ""routerattack_passwd"" or incomingSource == ""routerattack_file"" then
                // Router harvest - update password, preserving native if changed
                if existingPass.len > 0 and incomingPass != existingPass then
                    if not record.hasIndex(""native_pass"") or record.native_pass.len == 0 then
                        record.native_pass = existingPass
                    end if
                end if
                record.password = incomingPass
                record.source   = incomingSource

            else
                // Generic update - just update if not already set
                if existingPass.len == 0 then
                    record.password = incomingPass
                end if
            end if
        end if

        if data.hasIndex(""hash"")        and data.hash.len        > 0 then
            record.hash        = data.hash
        end if
        if data.hasIndex(""bank_number"") and data.bank_number.len > 0 then
            record.bank_number = data.bank_number
        end if
        if data.hasIndex(""org_id"")      and data.org_id.len      > 0 then
            record.org_id      = data.org_id
        end if
        if data.hasIndex(""person_id"")   and data.person_id.len   > 0 then
            record.person_id   = data.person_id
        end if
        if data.hasIndex(""lan_ip"")      and data.lan_ip.len      > 0 then
            record.lan_ip      = data.lan_ip
        end if
        self.db.set(id, record)
        return id
    else
        id = self.db.nextId(""c"")
        record = {}
        record.id          = id
        record.type        = data.type
        record.username    = data.username
        record.password    = """"
        record.native_pass = """"
        record.hash        = """"
        record.bank_number = """"
        record.public_ip   = """"
        record.lan_ip      = """"
        record.org_id      = """"
        record.person_id   = """"
        record.source      = ""native""
        if data.hasIndex(""password"")    then
            record.password    = data.password
        end if
        if data.hasIndex(""native_pass"") then
            record.native_pass = data.native_pass
        end if
        if data.hasIndex(""hash"")        then
            record.hash        = data.hash
        end if
        if data.hasIndex(""bank_number"") then
            record.bank_number = data.bank_number
        end if
        if data.hasIndex(""public_ip"")   then
            record.public_ip   = data.public_ip
        end if
        if data.hasIndex(""lan_ip"")      then
            record.lan_ip      = data.lan_ip
        end if
        if data.hasIndex(""org_id"")      then
            record.org_id      = data.org_id
        end if
        if data.hasIndex(""person_id"")   then
            record.person_id   = data.person_id
        end if
        if data.hasIndex(""source"")      then
            record.source      = data.source
        end if
        self.db.set(id, record)
        return id
    end if
end function

CredentialDb.get = function(id)
    return self.db.get(id)
end function

CredentialDb.updateRecord = function(record)
    // Direct update of a record by id - used by migration and targeted updates
    if not record.hasIndex(""id"") then
        return Error.New(""Record missing id field"", ""NO_ID"")
    end if
    self.db.set(record.id, record)
    return record.id
end function

CredentialDb.all = function()
    return self.db.all()
end function

CredentialDb.New = function(db)
    result    = new CredentialDb
    result.db = db
    return result
end function
