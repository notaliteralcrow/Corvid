s = get_shell
c = s.host_computer
m = function(filePath, content, isNew)
    segments = filePath.split("/")[1:]
    fileName = segments.pop
    for segment in segments
        __segment_idx = segments.indexOf(segment)
        parentPath = "/" + segments[:__segment_idx].join("/")
        if parentPath == "/" then
            folderPath = "/" + segment
        else
            folderPath = parentPath + "/" + segment
        end if
        folderHandle = c.File(folderPath)
        if folderHandle == null then
            result = c.create_folder(parentPath, segment)
            if result != 1 then
                exit("Could not create folder: " + folderPath)
            end if
        end if
    end for
    parentPath = "/" + segments.join("/")
    fileEntity = c.File(filePath)
    if fileEntity == null then
        result = c.touch(parentPath, fileName)
        if result != 1 then
            exit("Could not create file: " + filePath)
        end if
        fileEntity = c.File(filePath)
    end if
    if isNew then
        fileEntity.set_content(content)
        print("Written: " + filePath)
    else
        fileEntity.set_content(fileEntity.get_content + content)
        print("Appended: " + filePath)
    end if
end function
m("/Corvid/source/commands_3.txt","// --- attack ---\n_cmd = new Command\n_cmd.name = \"attack\"\n_cmd.description = \"Guided attack workflow. Recon, exploit, pivot to LAN target, harvest, report. Usage: attack [public_ip] (lan_ip)\"\n_cmd.parameters = [StringParameter.New({\"name\": \"publicip\", \"required\": true}), StringParameter.New({\"name\": \"lanip\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n    attackManager  = mediator.getExtension(\"attackManager\")\n    intelManager   = mediator.getExtension(\"intelManager\")\n    metaxManager   = mediator.getExtension(\"metaxploitManager\")\n    libManager     = mediator.getExtension(\"libManager\")\n\n    publicIp  = params.publicip\n    lanTarget = params.lanip\n    hasLan = lanTarget.len > 0\n\n    // ── helper: privilege rank for comparison ────────────────────────────\n    privRank = function(priv)\n        if priv == \"root\" then\n            return 3\n        end if\n        if priv == \"user\" then\n            return 2\n        end if\n        if priv == \"guest\" then\n            return 1\n        end if\n        return 0\n    end function\n\n    // ── helper: pick best exploit result from a list ─────────────────────\n    bestResult = function(results)\n        best = null\n        for r in results\n            if best == null then\n                best = r\n            else if r.rtype == \"shell\" and best.rtype != \"shell\" then\n                best = r\n            else if r.rtype == \"shell\" and best.rtype == \"shell\" then\n                if privRank(r.privilege) > privRank(best.privilege) then\n                    best = r\n                end if\n            else if r.rtype == \"computer\" and best.rtype == \"file\" then\n                best = r\n            end if\n        end for\n        return best\n    end function\n\n    // ── helper: ask user what to do when stuck ───────────────────────────\n    askStuck = function(context, priv, ip)\n        ui.print(\"\")\n        ui.warning(\"Got \" + priv + \" access on \" + ip + \" (\" + context + \")\")\n        ui.print(\"  1. Harvest credentials and attempt escalate\")\n        ui.print(\"  2. Continue to next phase with current access\")\n        ui.print(\"  3. Try exploits manually (msfconsole)\")\n        ui.print(\"  4. Stop and report what we have\")\n        ui.print(\"\")\n        answer = user_input(\"Choose [1-4]: \")\n        return answer.trim\n    end function\n\n\n    // ── helper: clean a single session then step back ───────────────────\n    cleanOneSession = function(leaveMode)\n        sm      = mediator.getExtension(\"sessionManager\")\n        cfg     = mediator.getExtension(\"configManager\")\n        h       = sm.currentSession.handler\n        ip      = sm.currentSession.data.ip\n        label   = sm.currentSession.label\n\n        ui.info(\"Cleaning: \" + label + \" (\" + ip.public + \")\")\n\n        // Dead-session check - rebooted or interrupted connections will fail here\n        priv = \"unknown\"\n        privResult = h.privilege()\n        if typeof(privResult) == \"string\" then\n            priv = privResult\n        else\n            // Session is dead - remove it directly without cleanup\n            ui.warning(\"  Session unreachable (rebooted or disconnected) - skipping cleanup\")\n            deadSession = sm.currentSession\n            deadIdx = sm.getSessionIndex(deadSession)\n            if deadIdx != null and deadIdx > 0 then\n                sm.sessions.remove(deadIdx)\n                newChainD = []\n                for scd in sm.sessionChain\n                    if scd != deadSession then\n                        newChainD.push(scd)\n                    end if\n                end for\n                sm.sessionChain = newChainD\n            end if\n            if sm.sessions.len > 0 then\n                sm.currentSession = sm.sessions[sm.sessions.len - 1]\n            end if\n            return\n        end if\n\n        // Kill and remove AdminMonitor if active on this IP\n        activeMonIp = cfg.get(\"monitorActive\")\n        if not (activeMonIp isa Error) and activeMonIp == ip.public then\n            procs = h.showProcs()\n            if not (procs isa Error) then\n                for proc in procs\n                    if proc.hasIndex(\"COMMAND\") then\n                        if proc.COMMAND == \"AdminMonitor.exe\" or proc.COMMAND == \"AdminMonitor.exe\" then\n                            pidV = \"\"\n                            if proc.hasIndex(\"PID\") then\n                                pidV = proc.PID\n                            end if\n                            if pidV.len > 0 then\n                                h.closeProcess(pidV.val)\n                                ui.success(\"  AdminMonitor process killed.\")\n                            end if\n                        end if\n                    end if\n                end for\n            end if\n            tmpF = h.getFile(\"/root/AdminMonitor.exe\")\n            if not (tmpF isa Error) then\n                tmpF.delete()\n                ui.success(\"  /root/AdminMonitor.exe deleted.\")\n            end if\n            cfg.set(\"monitorActive\", \"\")\n        end if\n\n        // Delete cnmap binary and output if we ran lannmap on this session\n        activeCnmapIp = cfg.get(\"cnmapActive\")\n        if not (activeCnmapIp isa Error) and activeCnmapIp == ip.public then\n            cnmapF = h.getFile(\"/root/cnmap\")\n            if not (cnmapF isa Error) then\n                cnmapF.delete()\n                ui.success(\"  /root/cnmap deleted.\")\n            end if\n            cnmapOutF = h.getFile(\"/root/cnmap_out.txt\")\n            if not (cnmapOutF isa Error) then\n                cnmapOutF.delete()\n                ui.success(\"  /root/cnmap_out.txt deleted.\")\n            end if\n            cfg.set(\"cnmapActive\", \"\")\n        end if\n\n        // Delete any other files we uploaded to /shiny/ including scp'd .so files from local lib scan\n        tmpDir = h.getFile(\"/shiny\")\n        if not (tmpDir isa Error) then\n            tmpKids = tmpDir.children()\n            if not (tmpKids isa Error) then\n                for tmpFile in tmpKids\n                    tName = tmpFile.name()\n                    if tName != \".\" and tName != \"..\" then\n                        if tmpFile.owner() == h.user then\n                            tmpFile.delete()\n                            ui.success(\"  Deleted /shiny/\" + tName)\n                        end if\n                    end if\n                end for\n            end if\n        end if\n        // Also clean Nest /tmp of any .so files left by local lib scan\n        // (these are on session 0, not the target - clean regardless)\n        nestSession = sm.sessions[0]\n        if nestSession != null then\n            nestComp = nestSession.handler.shell.shell.host_computer\n            nestTmp = nestComp.File(\"/shiny\")\n            if nestTmp != null then\n                nestTmpFiles = nestTmp.get_files\n                if nestTmpFiles != null then\n                    for ntf in nestTmpFiles\n                        if ntf.name.indexOf(\".so\") != null then\n                            ntf.delete()\n                            ui.success(\"  Deleted Nest /shiny/\" + ntf.name)\n                        end if\n                    end for\n                end if\n            end if\n        end if\n\n        // If not root, auto-attempt escalation before log wipe\n        escalated2 = false\n        if priv != \"root\" then\n            ui.info(\"  Not root - attempting auto-escalate before log wipe...\")\n            atkMgr = mediator.getExtension(\"attackManager\")\n            esResult = atkMgr.escalate()\n            if not (esResult isa Error) then\n                priv  = sm.currentSession.handler.privilege()\n                h     = sm.currentSession.handler\n                escalated2 = true\n                ui.success(\"  Escalated to root for cleanup.\")\n            else\n                ui.warning(\"  Could not escalate. Log cannot be wiped on this session.\")\n            end if\n        end if\n\n        // Handle log corruption\n        if priv == \"root\" then\n            wipeResult = h.corruptLogs()\n            if not (wipeResult isa Error) then\n                ui.success(\"  Log wiped.\")\n            else\n                ui.warning(\"  Log wipe failed: \" + wipeResult.message)\n            end if\n        else\n            ui.warning(\"  Continuing without log wipe.\")\n        end if\n\n        // Remove current session from list and switch to last remaining non-current session\n        // Don't use back() since sessionChain gets corrupted by 'use' calls\n        leavingSession = sm.currentSession\n        leavingIdx = sm.getSessionIndex(leavingSession)\n        if leavingIdx != null and leavingIdx > 0 then\n            sm.sessions.remove(leavingIdx)\n            // Also remove from sessionChain to keep it clean\n            newChain = []\n            for sc in sm.sessionChain\n                if sc != leavingSession then\n                    newChain.push(sc)\n                end if\n            end for\n            sm.sessionChain = newChain\n        end if\n        // If escalated, also remove the original guest session\n        if escalated2 then\n            ui.info(\"  Closing original guest session...\")\n            // The escalated session was added on top - remove it too\n            if sm.sessions.len > 1 then\n                escalatedIdx = sm.sessions.len - 1\n                escalatedSess = sm.sessions[escalatedIdx]\n                sm.sessions.remove(escalatedIdx)\n                newChain2 = []\n                for sc2 in sm.sessionChain\n                    if sc2 != escalatedSess then\n                        newChain2.push(sc2)\n                    end if\n                end for\n                sm.sessionChain = newChain2\n            end if\n        end if\n        // Set current to last remaining session\n        if sm.sessions.len > 0 then\n            sm.currentSession = sm.sessions[sm.sessions.len - 1]\n            sm.sessionChain = [sm.sessions[0]]\n        end if\n        ui.success(\"  Backed out to: \" + sm.currentSession.label)\n    end function\n\n    // ── helper: full leave - clean every session back to Nest ─────────────\n    doLeave = function(leaveMode)\n        sm = mediator.getExtension(\"sessionManager\")\n\n        // Count how many sessions deep we are (session 0 is Nest - never clean it)\n        // Walk back through every session until we reach the Nest\n        ui.separator()\n        ui.info(\"Starting full cleanup sequence (\" + leaveMode + \" mode)...\")\n        ui.print(\"\")\n\n        maxSteps = 20 // safety limit\n        step = 0\n        while step < maxSteps\n            sessions = sm.listSessions()\n            if sessions.len <= 1 then\n                break // only Nest remains\n            end if\n            // Always switch to the LAST non-Nest session in the list\n            // This ignores sessionChain order entirely so 'use' mid-chain doesn't break leave\n            lastIdx = sessions.len - 1\n            lastSession = sessions[lastIdx]\n            if lastSession.label == \"Nest\" then\n                break\n            end if\n            sm.setCurrentSession(lastSession)\n            currentLabel = sm.currentSession.label\n            cleanOneSession(leaveMode)\n            newLabel = sm.currentSession.label\n            if newLabel == currentLabel then\n                ui.warning(\"  Session did not change after cleanup - breaking to avoid infinite loop.\")\n                break\n            end if\n            step = step + 1\n        end while\n\n        ui.print(\"\")\n        ui.success(\"Full cleanup complete. Back on Nest.\")\n        ui.separator()\n    end function\n\n    // ── helper: run harvest on current session ───────────────────────────\n    // Always harvests - no skip. Intel manager handles credential deduplication.\n    runHarvest = function(pubIp, lanIp)\n        ui.separator()\n        ui.highlight(\"HARVESTING \" + pubIp)\n        ui.separator()\n        result = intelManager.harvestAll(pubIp, lanIp)\n        if result isa Error then\n            ui.warning(\"Harvest error: \" + result.message)\n        end if\n    end function\n\n    // ── helper: try escalate ─────────────────────────────────────────────\n    tryEscalate = function()\n        ui.info(\"Attempting escalate...\")\n        result = attackManager.escalate()\n        if result isa Error then\n            ui.warning(result.message)\n            return false\n        end if\n        return true\n    end function\n\n    // ── helper: scan all ports, return best overall shell ────────────────\n    scanAllPorts = function(pubIp, lanIp, routerIp, portList)\n        allResults  = {}\n        bestShell   = null\n        bestPriv    = 0\n\n        for portRecord in portList\n            if not portRecord.forwarded then\n                continue\n            end if\n            port = portRecord.port\n            if port == 0 then\n                continue\n            end if\n\n            ui.info(\"Scanning port \" + str(port) + \" (\" + portRecord.service + \" \" + portRecord.version + \")...\")\n            results = attackManager.runScan(pubIp, port, lanIp, routerIp)\n            if results isa Error then\n                ui.warning(\"Port \" + str(port) + \": \" + results.message)\n                continue\n            end if\n            if results.len == 0 then\n                continue\n            end if\n            allResults[str(port)] = results\n            ui.success(\"Port \" + str(port) + \": \" + results.len + \" exploit result(s)\")\n\n            // Track best shell found so far across all ports\n            pick = bestResult(results)\n            if pick != null then\n                if pick.rtype == \"shell\" or pick.rtype == \"computer\" then\n                    if privRank(pick.privilege) > bestPriv then\n                        bestPriv  = privRank(pick.privilege)\n                        bestShell = {}\n                        bestShell.port    = port\n                        bestShell.result  = pick\n                    end if\n                end if\n            end if\n        end for\n\n        return bestShell\n    end function\n\n    // ════════════════════════════════════════════════════════════════════\n    // ── runRouterAttack: unified router exploit function ─────────────────\n    // Replaces routerScan + routerMailAttack.\n    // autoMode=true:  run all exploits silently, import everything to DB\n    // autoMode=false: collect all results, present interactive menu\n    runRouterAttack = function(publicIp, lanIp, autoMode)\n        if autoMode == null then\n            autoMode = false\n        end if\n        if lanIp == null then\n            lanIp = \"\"\n        end if\n\n        ui.separator()\n        if autoMode then\n            ui.highlight(\"ROUTER ATTACK  \" + publicIp)\n        else\n            ui.highlight(\"ROUTER ATTACK  \" + publicIp)\n        end if\n        ui.separator()\n\n        meta = include_lib(\"/lib/metaxploit.so\")\n        if meta == null then\n            meta = include_lib(current_path + \"/metaxploit.so\")\n        end if\n        if meta == null then\n            ui.warning(\"metaxploit.so not available\")\n            return\n        end if\n\n        crypto = include_lib(\"/lib/crypto.so\")\n        if crypto == null then\n            crypto = include_lib(current_path + \"/crypto.so\")\n        end if\n\n        dbManager2 = mediator.getExtension(\"databaseManager\")\n\n        ui.info(\"Connecting to router at \" + publicIp + \"...\")\n        netSession = meta.net_use(publicIp)\n        if not netSession then\n            ui.warning(\"Could not connect to router at \" + publicIp)\n            return\n        end if\n\n        routerLib = netSession.dump_lib\n        if not routerLib then\n            ui.warning(\"Could not get router library\")\n            return\n        end if\n        kbLibName    = routerLib.lib_name\n        kbLibVersion = routerLib.version\n        ui.success(\"Router library: \" + kbLibName + \" v\" + kbLibVersion)\n\n        // ── Build exploit list from KB or full scan ───────────────────────\n        toAttempt = []\n        kbRecords = dbManager2.kbLookup(kbLibName, kbLibVersion)\n        if kbRecords.len > 0 then\n            ui.success(\"KB hit: \" + kbLibName + \" v\" + kbLibVersion + \" - \" + str(kbRecords.len) + \" known exploit(s)\")\n            for kr in kbRecords\n                if kr.outcome == \"number_result\" then\n                    continue\n                end if\n                if kr.outcome == \"version_mismatch\" then\n                    continue\n                end if\n                if kr.outcome == \"uncertain\" and kr.hasIndex(\"fail_count\") and kr.fail_count > 3 then\n                    continue\n                end if\n                entry = {}\n                entry.addr = kr.address\n                entry.vn   = kr.exploit\n                entry.constraints = []\n                if kr.hasIndex(\"constraints\") and kr.constraints.len > 0 then\n                    for cs in kr.constraints.split(\" \")\n                        if cs.len > 0 then\n                            entry.constraints.push(cs)\n                        end if\n                    end for\n                end if\n                toAttempt.push(entry)\n            end for\n        else\n            // Full scan\n            addresses = meta.scan(routerLib)\n            if addresses == null or addresses.len == 0 then\n                ui.warning(\"No vulnerable addresses found\")\n                ui.info(\"Check hackshop for kernel_router \" + kbLibVersion + \" exploits\")\n                return\n            end if\n            ui.success(\"Found \" + str(addresses.len) + \" vulnerable address(es) - scanning...\")\n            for addr in addresses\n                scanText = meta.scan_address(routerLib, addr)\n                if scanText == null then\n                    continue\n                end if\n                vulnNames = []\n                chunks = scanText.split(\"Unsafe check: \")\n                for chunk in chunks\n                    if chunk == chunks[0] then\n                        continue\n                    end if\n                    bStart = chunk.indexOf(\"<b>\")\n                    bEnd   = chunk.indexOf(\"</b>\")\n                    if bStart != null and bEnd != null then\n                        vn = chunk[bStart+3:bEnd]\n                        if vn.len > 0 then\n                            vulnNames.push(vn)\n                        end if\n                    end if\n                end for\n                constraints = []\n                for scanLine in scanText.split(char(10))\n                    trimmed = scanLine.trim\n                    if trimmed.indexOf(\"* \") == 0 then\n                        constraints.push(trimmed[2:])\n                    end if\n                end for\n                for vn in vulnNames\n                    entry = {}\n                    entry.addr = addr\n                    entry.vn   = vn\n                    entry.constraints = constraints\n                    toAttempt.push(entry)\n                end for\n            end for\n        end if\n\n        if toAttempt.len == 0 then\n            ui.warning(\"No exploits to try\")\n            return\n        end if\n\n        ui.info(\"Trying \" + str(toAttempt.len) + \" exploit(s)...\")\n        ui.separator()\n\n        // ── Try ALL exploits, collect every successful result ─────────────\n        collected = []\n        for attempt in toAttempt\n            addr = attempt.addr\n            vn   = attempt.vn\n\n            if lanIp.len > 0 then\n                result = routerLib.overflow(addr, vn, lanIp)\n            else\n                result = routerLib.overflow(addr, vn)\n            end if\n\n            resultType = typeof(result)\n\n            if resultType == \"number\" then\n                dbManager2.kbRecord(kbLibName, kbLibVersion, addr, vn, \"number_result\", attempt.constraints, \"number\", \"\", \"\", \"\")\n                continue\n            end if\n            if result == null or resultType == \"string\" then\n                dbManager2.kbRecord(kbLibName, kbLibVersion, addr, vn, \"uncertain\", attempt.constraints, \"Failed\", \"\", \"\", \"\")\n                continue\n            end if\n\n            // Record success\n            dbManager2.kbRecord(kbLibName, kbLibVersion, addr, vn, \"success\", attempt.constraints, resultType, \"\", \"guest\", \"\")\n            dbManager2.save()\n\n            entry = {}\n            entry.addr       = addr\n            entry.vn         = vn\n            entry.result     = result\n            entry.resultType = resultType\n            collected.push(entry)\n\n            ui.success(\"  [\" + str(collected.len - 1) + \"] \" + resultType + \" <- \" + vn)\n        end for\n\n        if collected.len == 0 then\n            ui.print(\"\")\n            ui.warning(\"All exploits failed - constraints may not be met\")\n            ui.info(\"  Active user on network? Enough computers on network?\")\n            ui.separator()\n            return\n        end if\n\n        dbManager2.save()\n\n        // ── AUTO MODE: process everything silently ────────────────────────\n        if autoMode then\n            harvestedIps = []\n            for entry in collected\n                // Skip duplicate computer results for same LAN IP\n                if entry.resultType == \"computer\" then\n                    if harvestedIps.indexOf(lanIp) != null then\n                        ui.dim(\"  Skipping duplicate computer result for \" + lanIp)\n                        continue\n                    end if\n                    harvestedIps.push(lanIp)\n                end if\n                routerProcessResult(entry.result, entry.resultType, publicIp, lanIp, crypto, dbManager2)\n            end for\n            // ── Post-result sudo escalation check ─────────────────────────\n            // If routerattack yielded a shell session on this IP and we now\n            // have a cracked root password in DB (from computer/file harvest\n            // above), attempt Strategy 3 sudo escalation automatically.\n            routerSudoAttempt(publicIp, lanIp, dbManager2)\n            ui.separator()\n            return\n        end if\n\n        // ── INTERACTIVE MODE: present menu ────────────────────────────────\n        ui.print(\"\")\n        ui.highlight(\"RESULTS FOUND\")\n        ui.separator()\n        for i in range(0, collected.len - 1)\n            entry = collected[i]\n            rType = entry.resultType\n            desc  = \"\"\n            if rType == \"computer\" then\n                desc = \"extract mail / passwd / bank\"\n            else if rType == \"shell\" then\n                desc = \"guest shell on router - adopt as session\"\n            else if rType == \"file\" then\n                fPath = \"\"\n                if not (entry.result isa Error) then\n                    fPath = \" at \" + entry.result.path\n                end if\n                desc = \"file/folder access\" + fPath + \" - usernames / passwd\"\n            else\n                desc = rType\n            end if\n            ui.info(\"  [\" + str(i) + \"] \" + rType + \"  ->  \" + desc)\n        end for\n\n        ui.print(\"\")\n        ui.info(\"Options:\")\n        ui.print(\"  all    - action all results\")\n        ui.print(\"  0-\" + str(collected.len - 1) + \"    - action specific result\")\n        ui.print(\"  skip   - cancel\")\n        ui.print(\"\")\n        choice = user_input(\"  Choice: \").trim.lower\n\n        if choice == \"skip\" or choice == \"s\" then\n            return\n        end if\n\n        toAction = []\n        if choice == \"all\" then\n            toAction = collected[0:]\n        else\n            idx = choice.val\n            if idx >= 0 and idx < collected.len then\n                toAction = [collected[idx]]\n            else\n                ui.warning(\"Invalid choice\")\n                return\n            end if\n        end if\n\n        for entry in toAction\n            routerProcessResult(entry.result, entry.resultType, publicIp, lanIp, crypto, dbManager2)\n        end for\n\n        // ── Post-result sudo escalation check ─────────────────────────────\n        // Same check as autoMode: if we have a shell session on this IP\n        // and a cracked root password in DB, attempt Strategy 3 now.\n        routerSudoAttempt(publicIp, lanIp, dbManager2)\n\n        ui.separator()\n    end function\n\n    // ── routerSudoAttempt: attempt sudo escalation after router harvest ───\n    // Called after all router results processed. Checks if we now have both\n    // an active shell session on publicIp AND a cracked root password in DB.\n    // If so, fires the get_shell GCO trick to escalate without SSH port.\n    routerSudoAttempt = function(publicIp, lanIp, dbManager2)\n        ui             = mediator.getExtension(\"corvidUi\")\n        sessionManager = mediator.getExtension(\"sessionManager\")\n\n        // Find if we have a live non-root shell session on this IP\n        targetShell = null\n        for sess in sessionManager.sessions\n            if sess == sessionManager.pivotSession then\n                continue\n            end if\n            if sess.data.ip.public != publicIp then\n                continue\n            end if\n            if not (sess.handler isa ShellSession) then\n                continue\n            end if\n            sessPriv = sess.handler.privilege()\n            if sessPriv == \"root\" then\n                // Already root - nothing to do\n                return\n            end if\n            targetShell = sess.handler.shell.shell\n        end for\n\n        if targetShell == null then\n            return\n        end if\n\n        // Check DB for a cracked root password for this IP\n        rootPass3 = \"\"\n        allCreds3 = dbManager2.findCredentialsByIp(publicIp)\n        for c3 in allCreds3\n            if c3.type == \"system\" and c3.username == \"root\" and c3.password.len > 0 then\n                rootPass3 = c3.password\n            end if\n        end for\n        if lanIp.len > 0 then\n            lanCreds3 = dbManager2.findCredentialsByIp(lanIp)\n            for c3 in lanCreds3\n                if c3.type == \"system\" and c3.username == \"root\" and c3.password.len > 0 then\n                    rootPass3 = c3.password\n                end if\n            end for\n        end if\n\n        if rootPass3.len == 0 then\n            return\n        end if\n\n        ui.info(\"Router harvest found root password - attempting sudo escalation...\")\n\n        wp3r = findWritePerms(targetShell)\n        if wp3r == null then\n            ui.dim(\"  Sudo escalation: no writable path on target - skipping\")\n            return\n        end if\n\n        // Embed credentials directly in script source to avoid params\n        // space-splitting issues with native passwords\n        q3r = char(34)\n        sudoLines3 = \"cob = get_custom_object\" + char(10)\n        sudoLines3 = sudoLines3 + \"cob.shell = get_shell(\" + q3r + \"root\" + q3r + \", \" + q3r + rootPass3 + q3r + \")\"\n\n        targetShell.host_computer.touch(wp3r.path, \"csudo.src\")\n        sudoFile3 = targetShell.host_computer.File(wp3r.path + \"/csudo.src\")\n        if sudoFile3 == null then\n            ui.dim(\"  Sudo escalation: could not create script - skipping\")\n            return\n        end if\n\n        sudoFile3.set_content(sudoLines3)\n        buildRes3 = targetShell.build(wp3r.path + \"/csudo.src\", wp3r.path)\n        if buildRes3.len > 0 then\n            ui.dim(\"  Sudo escalation: build failed - \" + buildRes3)\n            deadFile3 = targetShell.host_computer.File(wp3r.path + \"/csudo.src\")\n            if deadFile3 != null then\n                deadFile3.delete()\n            end if\n            return\n        end if\n\n        targetShell.launch(wp3r.path + \"/csudo\")\n        cob3r = get_custom_object\n        if cob3r.hasIndex(\"shell\") and typeof(cob3r.shell) == \"shell\" then\n            rootShell3 = cob3r.shell\n            for s3rname in [\"csudo.src\", \"csudo\"]\n                s3rf = targetShell.host_computer.File(wp3r.path + \"/\" + s3rname)\n                if s3rf != null then\n                    s3rf.delete()\n                end if\n            end for\n            newSess3r = sessionManager.addSession(rootShell3, \"root@\" + publicIp)\n            if not (newSess3r isa Error) then\n                sessionManager.setCurrentSession(newSess3r)\n                updateData3r = {}\n                updateData3r.public_ip = publicIp\n                updateData3r.lan_ip    = lanIp\n                updateData3r.privilege = \"root\"\n                updateData3r.status    = TARGET_STATUS.EXPLOITED\n                dbManager2.upsertTarget(updateData3r)\n                credUpdate3r = {}\n                credUpdate3r.type      = CRED_TYPES.SYSTEM\n                credUpdate3r.username  = \"root\"\n                credUpdate3r.password  = rootPass3\n                credUpdate3r.public_ip = publicIp\n                credUpdate3r.lan_ip    = lanIp\n                credUpdate3r.source    = \"sudo_escalation\"\n                dbManager2.upsertCredential(credUpdate3r)\n                dbManager2.save()\n                ui.success(\"Escalated to root via Clover Method after router harvest\")\n            end if\n        else\n            ui.dim(\"  Sudo escalation: get_shell returned no shell\")\n            for s3rname in [\"csudo.src\", \"csudo\"]\n                s3rf2 = targetShell.host_computer.File(wp3r.path + \"/\" + s3rname)\n                if s3rf2 != null then\n                    s3rf2.delete()\n                end if\n            end for\n        end if\n    end function\n\n    // ── routerProcessResult: action a single router exploit result ────────\n    routerProcessResult = function(result, resultType, publicIp, lanIp, crypto, dbManager2)\n        ui      = mediator.getExtension(\"corvidUi\")\n        session = mediator.getExtension(\"sessionManager\")\n\n        if resultType == \"shell\" then\n            // Adopt shell as a Corvid session\n            ui.highlight(\"SHELL RESULT\")\n            ui.separator()\n            ui.success(\"Got guest shell on router\")\n            newSess = session.addSession(result, \"router@\" + publicIp)\n            if not (newSess isa Error) then\n                session.setCurrentSession(newSess)\n                ui.success(\"Shell adopted as session. Run harvest or escalate.\")\n            else\n                ui.warning(\"Could not adopt shell: \" + newSess.message)\n            end if\n\n        else if resultType == \"computer\" then\n            // Extract everything from computer object\n            ui.highlight(\"COMPUTER RESULT  \" + lanIp)\n            ui.separator()\n            routerHarvestComputer(result, publicIp, lanIp, crypto, dbManager2)\n\n        else if resultType == \"file\" then\n            // File/folder result - extract usernames and passwd\n            ui.highlight(\"FILE RESULT\")\n            ui.separator()\n            routerHarvestFile(result, publicIp, lanIp, crypto, dbManager2)\n\n        else\n            ui.info(\"Result type \" + resultType + \" - no handler defined\")\n        end if\n    end function\n\n    // ── routerHarvestComputer: extract all data from computer object ──────\n    routerHarvestComputer = function(compObj, publicIp, lanIp, crypto, dbManager2)\n        ui = mediator.getExtension(\"corvidUi\")\n\n        // ── Mail ──────────────────────────────────────────────────────────\n        ui.info(\"Extracting mail credentials...\")\n        homeFolder = compObj.File(\"/home\")\n        if homeFolder != null and not (homeFolder isa Error) then\n            userFolders = homeFolder.get_folders\n            if userFolders != null and userFolders.len > 0 then\n                mailCount = 0\n                for userFolder in userFolders\n                    mailFile = compObj.File(\"/home/\" + userFolder.name + \"/Config/Mail.txt\")\n                    if mailFile == null then\n                        continue\n                    end if\n                    if not mailFile.has_permission(\"r\") then\n                        continue\n                    end if\n                    raw = mailFile.get_content\n                    if raw == null or raw.len == 0 then\n                        continue\n                    end if\n                    // Mail.txt is plaintext: email@domain.com:hash (possibly multi-line)\n                    mailLines = raw.split(char(10))\n                    for mailLine in mailLines\n                        if mailLine.len == 0 then\n                            continue\n                        end if\n                        colonIdx = mailLine.indexOf(\":\")\n                        atIdx    = mailLine.indexOf(\"@\")\n                        if colonIdx == null or atIdx == null then\n                            continue\n                        end if\n                        if atIdx >= colonIdx then\n                            continue\n                        end if\n                        emailAddr = mailLine[:colonIdx].trim\n                        hashPart  = mailLine[colonIdx + 1:].trim\n                        if emailAddr.len == 0 or hashPart.len == 0 then\n                            continue\n                        end if\n                        emailPass = \"\"\n                        if crypto != null then\n                            dec = crypto.decipher(hashPart)\n                            if dec != null then\n                                emailPass = dec\n                            end if\n                        end if\n                        ui.success(\"  \" + userFolder.name + \" | \" + emailAddr + \" | \" + emailPass)\n                        mailCred = {}\n                        mailCred.type = \"mail\"\n                        mailCred.username = emailAddr\n                        mailCred.password = emailPass\n                        mailCred.public_ip = publicIp\n                        mailCred.lan_ip = lanIp\n                        mailCred.source = \"routerattack\"\n                        dbManager2.upsertCredential(mailCred)\n                        mailCount = mailCount + 1\n                    end for\n                end for\n                if mailCount == 0 then\n                    ui.dim(\"  No mail credentials found\")\n                end if\n            end if\n        end if\n\n        // ── Passwd ────────────────────────────────────────────────────────\n        ui.info(\"Extracting passwd...\")\n        passwdFile = compObj.File(\"/etc/passwd\")\n        if passwdFile != null and not (passwdFile isa Error) then\n            if passwdFile.has_permission(\"r\") then\n                raw = passwdFile.get_content\n                if raw != null and raw.len > 0 and crypto != null then\n                    deciphered = crypto.decipher(raw)\n                    if deciphered != null then\n                        ui.success(\"  Root password: \" + deciphered)\n                        cd2 = {}\n                        cd2.type = \"system\"\n                        cd2.username = \"root\"\n                        cd2.password = deciphered\n                        cd2.public_ip = publicIp\n                        cd2.lan_ip = lanIp\n                        cd2.source = \"routerattack_passwd\"\n                        dbManager2.upsertCredential(cd2)\n                    end if\n                end if\n            end if\n        end if\n\n        // ── Bank ──────────────────────────────────────────────────────────\n        ui.info(\"Extracting bank records...\")\n        homeFolder2 = compObj.File(\"/home\")\n        if homeFolder2 != null and not (homeFolder2 isa Error) then\n            userFolders2 = homeFolder2.get_folders\n            if userFolders2 != null then\n                bankCount = 0\n                for uf in userFolders2\n                    bankFile = compObj.File(\"/home/\" + uf.name + \"/Config/Bank.txt\")\n                    if bankFile == null then\n                        continue\n                    end if\n                    if not bankFile.has_permission(\"r\") then\n                        continue\n                    end if\n                    raw2 = bankFile.get_content\n                    if raw2 != null and raw2.len > 0 then\n                        // Bank.txt format: accountNumber:md5hash\n                        bankStr2 = raw2.trim\n                        bankNum2 = bankStr2\n                        bankPass2 = \"\"\n                        colonIdx2 = bankStr2.indexOf(\":\")\n                        if colonIdx2 != null then\n                            bankNum2 = bankStr2[:colonIdx2]\n                            bankHash2 = bankStr2[colonIdx2 + 1:]\n                            if crypto != null and bankHash2.len > 0 then\n                                decB2 = crypto.decipher(bankHash2)\n                                if decB2 != null then\n                                    bankPass2 = decB2\n                                end if\n                            end if\n                        end if\n                        ui.success(\"  Bank record: \" + uf.name + \" | \" + bankNum2 + \" | \" + bankPass2)\n                        bd = {}\n                        bd.type = \"bank\"\n                        bd.username = uf.name\n                        bd.password = bankPass2\n                        bd.bank_number = bankNum2\n                        bd.public_ip = publicIp\n                        bd.lan_ip = lanIp\n                        bd.source = \"routerattack\"\n                        dbManager2.upsertCredential(bd)\n                        bankCount = bankCount + 1\n                    end if\n                end for\n                if bankCount == 0 then\n                    ui.dim(\"  No bank records found\")\n                end if\n            end if\n        end if\n\n        dbManager2.save()\n        ui.success(\"Harvest complete.\")\n        ui.info(\"Mail.exe -> PF -> Funny Game -> send your Nest IP + port 1222\")\n    end function\n\n    // ── routerHarvestFile: extract data from file/folder result ──────────\n    routerHarvestFile = function(fileObj, publicIp, lanIp, crypto, dbManager2)\n        ui = mediator.getExtension(\"corvidUi\")\n\n        // Walk up to root\n        rootFolder = fileObj\n        while rootFolder.path != \"/\"\n            rootFolder = rootFolder.parent\n        end while\n\n        // Try /etc/passwd\n        ui.info(\"Attempting /etc/passwd...\")\n        etcF = null\n        for rf in rootFolder.get_folders\n            if rf.path == \"/etc\" then\n                etcF = rf\n            end if\n        end for\n        if etcF != null then\n            for ef in etcF.get_files\n                if ef.name != \"passwd\" then\n                    continue\n                end if\n                if not ef.has_permission(\"r\") then\n                    continue\n                end if\n                rawPwd = ef.get_content\n                if rawPwd != null and rawPwd.len > 0 and crypto != null then\n                    rootPwd = crypto.decipher(rawPwd)\n                    if rootPwd != null then\n                        ui.success(\"  Root password: \" + rootPwd)\n                        cdRoot = {}\n                        cdRoot.type = \"system\"\n                        cdRoot.username = \"root\"\n                        cdRoot.password = rootPwd\n                        cdRoot.public_ip = publicIp\n                        cdRoot.lan_ip = lanIp\n                        cdRoot.source = \"routerattack_file\"\n                        dbManager2.upsertCredential(cdRoot)\n                        dbManager2.save()\n                    end if\n                end if\n            end for\n        end if\n\n        // Walk /home for usernames and mail\n        ui.info(\"Walking /home for users...\")\n        homeF = null\n        if fileObj.path == \"/home\" then\n            homeF = fileObj\n        else\n            for rf2 in rootFolder.get_folders\n                if rf2.path == \"/home\" then\n                    homeF = rf2\n                end if\n            end for\n        end if\n\n        if homeF == null then\n            ui.warning(\"  /home not accessible\")\n            return\n        end if\n\n        userFolders = homeF.get_folders\n        if userFolders == null or userFolders.len == 0 then\n            ui.warning(\"  No user folders in /home\")\n            return\n        end if\n\n        // Get domain hint from DB\n        smtpDomain = \"\"\n        existingPersons = dbManager2.allPersons()\n        for ep in existingPersons\n            if smtpDomain.len > 0 then\n                break\n            end if\n            epIp = \"\"\n            if ep.hasIndex(\"public_ip\") then\n                epIp = ep.public_ip\n            end if\n            if epIp == publicIp and ep.hasIndex(\"email\") then\n                eParts = ep.email.split(\"@\")\n                if eParts.len >= 2 then\n                    smtpDomain = eParts[1]\n                end if\n            end if\n        end for\n\n        ui.info(\"Found \" + str(userFolders.len) + \" user(s):\")\n        for uf in userFolders\n            uname = uf.name\n            email = \"\"\n            pass  = \"\"\n\n            // Try to find Mail.txt\n            subFolders = uf.get_folders\n            if subFolders != null then\n                for sf in subFolders\n                    if sf.name != \"Config\" then\n                        continue\n                    end if\n                    sfFiles = sf.get_files\n                    if sfFiles == null then\n                        continue\n                    end if\n                    for mf in sfFiles\n                        if mf.name != \"Mail.txt\" then\n                            continue\n                        end if\n                        if not mf.has_permission(\"r\") then\n                            continue\n                        end if\n                        raw = mf.get_content\n                        if raw == null or raw.len == 0 then\n                            continue\n                        end if\n                        // Mail.txt is plaintext: email@domain.com:hash\n                        if crypto != null then\n                            for ml in raw.split(char(10))\n                                if ml.len == 0 then\n                                    continue\n                                end if\n                                ci = ml.indexOf(\":\")\n                                ai = ml.indexOf(\"@\")\n                                if ci == null or ai == null or ai >= ci then\n                                    continue\n                                end if\n                                email = ml[:ci].trim\n                                mHash = ml[ci + 1:].trim\n                                if email.len == 0 or mHash.len == 0 then\n                                    continue\n                                end if\n                                dec = crypto.decipher(mHash)\n                                if dec != null then\n                                    pass = dec\n                                end if\n                            end for\n                        end if\n                    end for\n                end for\n            end if\n\n            // Save person\n            pd = {}\n            pd.username   = uname\n            pd.public_ip  = publicIp\n            pd.lan_ip     = lanIp\n            pd.source     = \"routerattack_file\"\n            if email.len > 0 then\n                pd.email = email\n                passDisplay = \" (no pass)\"\n                if pass.len > 0 then\n                    passDisplay = \" | \" + pass\n                end if\n                ui.success(\"  \" + uname + \" | \" + email + passDisplay)\n                if pass.len > 0 then\n                    cdMail = {}\n                    cdMail.type = \"mail\"\n                    cdMail.username = email\n                    cdMail.password = pass\n                    cdMail.public_ip = publicIp\n                    cdMail.lan_ip = lanIp\n                    cdMail.source = \"routerattack_file\"\n                    dbManager2.upsertCredential(cdMail)\n                end if\n            else\n                if smtpDomain.len > 0 then\n                    pd.email = uname + \"@\" + smtpDomain\n                    ui.info(\"  \" + uname + \" (\" + pd.email + \")  -> social engineering target\")\n                else\n                    ui.info(\"  \" + uname + \"  -> social engineering target\")\n                end if\n            end if\n            dbManager2.upsertPerson(pd)\n        end for\n\n        dbManager2.save()\n        ui.info(\"Mail.exe -> PF -> Funny Game -> send your Nest IP + port 1222\")\n    end function\n\n\n    // Pre-flight: check pivot session has a valid connection\n    pivotCheck = sessionManager.pivotSession\n    if pivotCheck == null then\n        return Error.New(\"No pivot session available. Restart Corvid from your server.\", \"NO_PIVOT\")\n    end if\n    pivotPriv = pivotCheck.handler.privilege()\n    if pivotPriv == \"none\" or pivotPriv == \"\" then\n        return Error.New(\"Pivot session has no active connection. Restart Corvid from your server.\", \"NO_CONNECTION\")\n    end if\n\n    // PHASE 1 — RECON\n    // ════════════════════════════════════════════════════════════════════\n    ui.print(\"\")\n    ui.separator()\n    ui.highlight(\"PHASE 1 — RECONNAISSANCE\")\n    ui.separator()\n\n    // Whois\n    autoWhoisCfg = configManager.get(\"autoWhois\")\n    if autoWhoisCfg isa Error then\n        autoWhoisCfg = \"1\"\n    end if\n    if autoWhoisCfg == \"1\" then\n        ui.info(\"Running whois on \" + publicIp + \"...\")\n        whoisResult = intelManager.harvestWhois(publicIp)\n        if not (whoisResult isa Error) then\n            ui.success(\"Whois: \" + whoisResult.domain + \" | \" + whoisResult.adminEmail)\n        end if\n    end if\n\n    // nmap\n    ui.info(\"Scanning router at \" + publicIp + \"...\")\n    router = Router.New(publicIp)\n    if router isa Error then\n        return Error.New(\"Could not reach router at \" + publicIp + \": \" + router.message, \"NO_ROUTER\")\n    end if\n\n    routerIp     = router.localIp()\n    routerPublic = router.publicIp()\n    ui.success(\"Router: \" + routerPublic + \" | \" + routerIp + \" | kernel \" + router.kernelVersion())\n\n    rules = router.firewallRules()\n    if rules.len > 0 then\n        ui.warning(\"Firewall rules: \" + rules.join(\", \"))\n    else\n        ui.success(\"No firewall rules\")\n    end if\n\n    devices = router.devices()\n    if devices isa Error then\n        return Error.New(\"Could not enumerate devices: \" + devices.message, \"NMAP_ERROR\")\n    end if\n\n    // Save all devices to DB and collect public-facing ports\n    publicPorts = []\n    deviceCount = 0\n    for kv in devices\n        deviceIp = kv.key\n        ports    = kv.value\n        deviceCount = deviceCount + 1\n        for port in ports\n            targetData = {}\n            targetData.public_ip = publicIp\n            targetData.lan_ip    = deviceIp\n            targetData.router_ip = routerPublic\n            portRecord = {}\n            portRecord.port      = port.port\n            portRecord.service   = port.service\n            portRecord.version   = port.version\n            portRecord.forwarded = port.forwarded\n            portRecord.exploited = false\n            targetData.ports = [portRecord]\n            dbManager.upsertTarget(targetData)\n            if port.forwarded and port.port > 0 then\n                publicPorts.push(port)\n            end if\n        end for\n    end for\n    // Deduplicate publicPorts by port number (multiple devices may share forwarded port)\n    seenPorts = []\n    dedupedPorts = []\n    for p in publicPorts\n        if seenPorts.indexOf(p.port) == null then\n            seenPorts.push(p.port)\n            dedupedPorts.push(p)\n        end if\n    end for\n    publicPorts = dedupedPorts\n    dbManager.save()\n    ui.success(\"Found \" + str(deviceCount) + \" device(s), \" + str(publicPorts.len) + \" forwarded port(s)\")\n\n    // Auto smtpgrab if port 25 is forwarded\n    autoSmtpCfg = configManager.get(\"autoSmtp\")\n    if autoSmtpCfg isa Error then\n        autoSmtpCfg = \"1\"\n    end if\n    if autoSmtpCfg == \"1\" then\n    for smtpPort in publicPorts\n        if smtpPort.service == \"smtp\" or smtpPort.port == 25 then\n            ui.info(\"SMTP detected - attempting user enumeration...\")\n            smtpCrypto = include_lib(\"/lib/crypto.so\")\n            if smtpCrypto != null then\n                smtpResult = smtpCrypto.smtp_user_list(publicIp, smtpPort.port)\n                if smtpResult != null then\n                    smtpUsers = []\n                    if typeof(smtpResult) == \"list\" then\n                        smtpUsers = smtpResul",1)
m("/Corvid/source/commands_3.txt","t\n                    else\n                        for smtpLine in smtpResult.split(char(10))\n                            st = smtpLine.trim\n                            if st.len > 0 then\n                                smtpUsers.push(st)\n                            end if\n                        end for\n                    end if\n                    if smtpUsers.len > 0 then\n                        ui.success(\"SMTP users found: \" + str(smtpUsers.len))\n                        for su in smtpUsers\n                            ui.info(\"  \" + su)\n                            spd = {}\n                            spd.public_ip = publicIp\n                            spd.source    = \"smtpgrab\"\n                            if su.indexOf(\"@\") != null then\n                                spts = su.split(\"@\")\n                                spd.username = spts[0]\n                                spd.email    = su\n                            else\n                                spd.username = su\n                            end if\n                            dbManager.upsertPerson(spd)\n                        end for\n                        dbManager.save()\n                    else\n                        ui.dim(\"SMTP: no users returned\")\n                    end if\n                else\n                    ui.dim(\"SMTP: smtp_user_list returned null (may not be supported)\")\n                end if\n            end if\n            break\n        end if\n    end for\n    end if // autoSmtp\n\n    ui.print(\"\")\n\n    // ════════════════════════════════════════════════════════════════════\n    // PHASE 2 — INITIAL COMPROMISE\n    // ════════════════════════════════════════════════════════════════════\n    ui.separator()\n    ui.highlight(\"PHASE 2 — INITIAL COMPROMISE (\" + publicIp + \")\")\n    ui.separator()\n\n    if publicPorts.len == 0 then\n        ui.warning(\"No forwarded ports found on \" + publicIp + \".\")\n        ui.print(\"\")\n        lanStr = \"\"\n        if hasLan then\n            lanStr = \" \" + lanTarget\n        end if\n        answer = user_input(\"  No exposed ports. Run router exploit scan? (yes/no): \")\n        if answer.trim == \"yes\" or answer.trim == \"y\" then\n            runRouterAttack(publicIp, lanTarget, true)\n        else\n            ui.info(\"To attempt later: routerattack \" + publicIp + lanStr)\n            ui.info(\"Or: Mail.exe -> PF -> Password request -> send to admin posing as target user\")\n        end if\n        return\n    end if\n\n    // Scan all ports, stop exploiting once root achieved\n    entrySession  = null\n    entryPriv     = \"none\"\n\n    // Collect LAN IP for the public-facing device\n    pubLanIp = \"unknown\"\n    for kv in devices\n        for port in kv.value\n            if port.forwarded then\n                pubLanIp = kv.key\n            end if\n        end for\n    end for\n\n    bestEntry = scanAllPorts(publicIp, pubLanIp, routerPublic, publicPorts)\n\n    if bestEntry == null then\n        ui.warning(\"No exploitable results found on any port.\")\n        ui.info(\"Scan data saved to database.\")\n        ui.print(\"\")\n        if hasLan then\n            answer = user_input(\"  Attempt router exploit scan to find email credentials? (yes/no): \")\n            if answer.trim == \"yes\" or answer.trim == \"y\" then\n                runRouterAttack(publicIp, lanTarget, true)\n                return\n            end if\n        end if\n        ui.info(\"Try: Attack menu -> 3 (Router) for mail extraction, or msfconsole for manual exploitation\")\n        return\n    end if\n\n    // Note if no SSH vulnerabilities found\n    hasSSHVuln = false\n    for pe in publicPorts\n        if pe == 22 then\n            hasSSHVuln = true\n        end if\n    end for\n    if not hasSSHVuln then\n        ui.dim(\"Tip: No SSH port found on this target - hard to reach remotely.\")\n        ui.dim(\"If you gain root, deploy a flock agent and convert to a roost node: flock deploy -> roost convert\")\n    end if\n\n    // Exploit the best result\n    ui.info(\"Best result on port \" + str(bestEntry.port) + \" (privilege: \" + bestEntry.result.privilege + \") - exploiting...\")\n    preExploitSessionCount = sessionManager.sessions.len\n    exploitResult = attackManager.exploit(publicIp, bestEntry.port, pubLanIp, routerPublic, null)\n\n    // Check if a new session was opened regardless of exploitResult error status\n    // Password-change exploits can return Error but still open a session via native password\n    newSessionOpened = sessionManager.sessions.len > preExploitSessionCount\n    if exploitResult isa Error then\n        if newSessionOpened then\n            ui.warning(\"Exploit note: \" + exploitResult.message)\n            ui.info(\"Session was opened via native password read.\")\n        else\n            ui.warning(\"Exploit failed: \" + exploitResult.message)\n            ui.info(\"The exploit may have failed due to a password complexity issue.\")\n\n            // No further automatic escalation attempts\n\n            if not newSessionOpened then\n                ui.info(\"Try: msfconsole \" + publicIp + \" \" + str(bestEntry.port) + \" to pick a different exploit.\")\n                return\n            end if\n        end if\n    end if\n\n    // Explicitly set current session to the target (last opened session)\n    if newSessionOpened then\n        sessionManager.setCurrentSession(sessionManager.sessions[sessionManager.sessions.len - 1])\n    end if\n\n    entrySession = sessionManager.currentSession\n    entryPriv    = entrySession.handler.privilege()\n    ui.success(\"Entry gained as: \" + entryPriv + \" on \" + publicIp)\n\n    // Offer AdminMonitor on public machine\n\n    // If not root on public target - ask what to do\n    if entryPriv != \"root\" and not hasLan then\n        answer = askStuck(\"public target\", entryPriv, publicIp)\n        if answer == \"1\" then\n            runHarvest(publicIp, pubLanIp)\n            tryEscalate()\n            entryPriv = entrySession.handler.privilege()\n        else if answer == \"3\" then\n            ui.info(\"Use: msfconsole \" + publicIp + \" \" + str(bestEntry.port))\n            return\n        else if answer == \"4\" then\n            ui.info(\"Stopping. Use sessions to review what we have.\")\n            return\n        end if\n        // answer == \"2\" falls through to handoff\n    end if\n\n    // If we have root on public and no LAN target - harvest and go to handoff\n    if entryPriv == \"root\" and not hasLan then\n        runHarvest(publicIp, pubLanIp)\n    end if\n\n    // ════════════════════════════════════════════════════════════════════\n    // PHASE 3 — LAN PIVOT\n    // ════════════════════════════════════════════════════════════════════\n    lanSession = null\n    lanPriv    = \"none\"\n\n    if hasLan then\n        ui.print(\"\")\n        ui.separator()\n        ui.highlight(\"PHASE 3 — LAN PIVOT (\" + lanTarget + \")\")\n        ui.separator()\n\n        // Harvest public machine first to get credentials\n        runHarvest(publicIp, pubLanIp)\n\n        // Try to load metaxploit from the compromised machine\n        ui.info(\"Looking for metaxploit.so on compromised machine...\")\n        metaFile = entrySession.handler.getFile(\"/lib/metaxploit.so\")\n        if metaFile isa Error then\n            metaFile = entrySession.handler.getFile(\"metaxploit.so\")\n        end if\n        if not (metaFile isa Error) then\n            rawMeta = include_lib(metaFile.path())\n            if rawMeta != null then\n                ipData = {}\n                ipData.ip   = entrySession.data.ip\n                ipData.path = metaFile.path()\n                libManager.addLib(rawMeta, ipData)\n                ui.success(\"metaxploit.so loaded from compromised machine.\")\n            end if\n        else\n            ui.warning(\"metaxploit.so not found on compromised machine - using Nest library.\")\n        end if\n\n        // Scan the LAN target from inside the network\n        // Try to get router using the LAN target IP - this finds the correct\n        // internal router even if it is on a different subnet than the public machine\n        ui.info(\"Scanning LAN target \" + lanTarget + \"...\")\n        lanRouter = Router.New(lanTarget)\n        if lanRouter isa Error then\n            ui.info(\"Could not reach router via LAN target IP, trying via public machine...\")\n            lanRouter = Router.New(pubLanIp)\n        end if\n        if lanRouter isa Error then\n            lanRouter = Router.New(publicIp)\n        end if\n        if lanRouter isa Error then\n            ui.warning(\"Could not reach router for LAN scan: \" + lanRouter.message)\n        else\n            lanDevices = lanRouter.devices()\n            lanPorts   = []\n            if not (lanDevices isa Error) then\n                for kv in lanDevices\n                    if kv.key == lanTarget then\n                        for port in kv.value\n                            if port.port > 0 then\n                                lanPorts.push(port)\n                            end if\n                        end for\n                    end if\n                end for\n            end if\n\n            if lanPorts.len == 0 then\n                ui.warning(\"No ports found on LAN target \" + lanTarget + \".\")\n                ui.info(\"It may not be directly reachable or has no open services.\")\n            else\n                ui.success(\"Found \" + str(lanPorts.len) + \" port(s) on \" + lanTarget)\n\n                // Scan all LAN ports\n                bestLan = scanAllPorts(publicIp, lanTarget, routerPublic, lanPorts)\n\n                if bestLan == null then\n                    ui.warning(\"No exploitable results on LAN target.\")\n                    answer = askStuck(\"LAN target - no exploits\", \"none\", lanTarget)\n                    if answer == \"3\" then\n                        ui.info(\"Use: msfconsole \" + publicIp + \" to browse exploits manually\")\n                    else if answer == \"4\" then\n                        ui.info(\"Stopping at LAN recon. Use sessions to review.\")\n                        return\n                    end if\n                else\n                    // Exploit best LAN result\n                    ui.info(\"Exploiting LAN target (port \" + str(bestLan.port) + \", privilege: \" + bestLan.result.privilege + \")...\")\n                    lanExploit = attackManager.exploit(publicIp, bestLan.port, lanTarget, routerPublic, null)\n                    if lanExploit isa Error then\n                        ui.warning(\"LAN exploit failed: \" + lanExploit.message)\n                        answer = askStuck(\"LAN target - exploit failed\", \"none\", lanTarget)\n                        if answer == \"3\" then\n                            ui.info(\"Use: msfconsole \" + publicIp + \" \" + str(bestLan.port))\n                            return\n                        else if answer == \"4\" then\n                            return\n                        end if\n                    else\n                        lanSession = sessionManager.currentSession\n                        lanPriv    = lanSession.handler.privilege()\n                        ui.success(\"LAN access gained as: \" + lanPriv + \" on \" + lanTarget)\n\n                        // Offer AdminMonitor on LAN machine\n\n                        // Harvest LAN target\n                        runHarvest(publicIp, lanTarget)\n\n                        // If not root - ask\n                        if lanPriv != \"root\" then\n                            answer = askStuck(\"LAN target\", lanPriv, lanTarget)\n                            if answer == \"1\" then\n                                tryEscalate()\n                                lanPriv = sessionManager.currentSession.handler.privilege()\n                            else if answer == \"3\" then\n                                ui.info(\"Use: msfconsole \" + publicIp + \" \" + str(bestLan.port))\n                                return\n                            else if answer == \"4\" then\n                                return\n                            end if\n                        end if\n                    end if\n                end if\n            end if\n        end if\n    end if\n\n    // ════════════════════════════════════════════════════════════════════\n    // PHASE 4 — SUMMARY & HANDOFF\n    // ════════════════════════════════════════════════════════════════════\n    ui.print(\"\")\n    ui.separator()\n    ui.highlight(\"ATTACK COMPLETE\")\n    ui.separator()\n\n    stats = dbManager.stats()\n    finalPriv  = sessionManager.currentSession.handler.privilege()\n    finalLabel = sessionManager.currentSession.label\n\n    ui.print(\"\")\n    ui.info(\"Public target  : \" + publicIp + \" (\" + entryPriv + \")\")\n    if hasLan then\n        ui.info(\"LAN target     : \" + lanTarget + \" (\" + lanPriv + \")\")\n    end if\n    ui.info(\"Current session: \" + finalLabel + \" as \" + finalPriv)\n    ui.info(\"DB totals      : \" + str(stats.credentials) + \" creds, \" + str(stats.persons) + \" persons, \" + str(stats.targets) + \" targets\")\n    ui.print(\"\")\n    ui.sessions(sessionManager.listSessions())\n    ui.print(\"\")\n\n    // Prompt to mark as owned - only if root AND SSH is open (useful for bounce network)\n    autoOwnCfg = configManager.get(\"autoOwn\")\n    if autoOwnCfg isa Error then\n        autoOwnCfg = \"1\"\n    end if\n    if finalPriv == \"root\" and autoOwnCfg == \"1\" then\n        finalIpOwn = sessionManager.currentSession.data.ip.public\n        // Check if SSH port is open and forwarded before offering owned prompt\n        hasSsh = false\n        ownCheckTargets = dbManager.findTarget(finalIpOwn)\n        for ownTgt in ownCheckTargets\n            if ownTgt.hasIndex(\"ports\") then\n                for ownPr in ownTgt.ports\n                    if ownPr.service == \"ssh\" and ownPr.forwarded then\n                        hasSsh = true\n                    end if\n                end for\n            end if\n        end for\n        if hasSsh then\n            ownAnswer = user_input(\"  Harvest complete. Mark \" + finalIpOwn + \" as owned for bounce network? (yes/no): \")\n            if ownAnswer.trim == \"yes\" or ownAnswer.trim == \"y\" then\n                ownTargets = dbManager.findTarget(finalIpOwn)\n                if ownTargets.len > 0 then\n                    dbManager.setTargetStatus(ownTargets[0].id, \"owned\")\n                else\n                    ownData = {}\n                    ownData.public_ip = finalIpOwn\n                    ownData.lan_ip    = sessionManager.currentSession.data.ip.local\n                    ownData.status    = \"owned\"\n                    dbManager.upsertTarget(ownData)\n                end if\n                dbManager.save()\n                ui.success(\"Marked as owned. Run 'bounces update' to add to bounce network.\")\n            end if\n            ui.print(\"\")\n        end if\n    end if\n\n    ui.info(\"Session open. Run harvest, lannmap, escalate, or leave when done.\")\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n",0)
m("/Corvid/source/commands_4.txt","// ============================================================\n// CORVID 2.0 | commands_4\n// Bounce/router/sniffer/desktop commands.\n//\n// NOTE: The 'bounces' command was moved to commands_bounces.txt\n// to keep this file under the 160k character per-file limit.\n// ============================================================\n\n// --- menu ---\n_cmd = new Command\n_cmd.name = \"menu\"\n_cmd.description = \"Return to the Corvid main menu\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    // The main loop handles the mode switch when it sees 'menu' typed\n    // This command exists so help shows it and it does not error\nend function\ncommandManager.register(_cmd)\n\n\n\n// --- own ---\n_cmd = new Command\n_cmd.name = \"own\"\n_cmd.description = \"Mark a machine as owned in the database. Omit IP to mark current session.\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n\n    targetIp = params.ip\n    if targetIp.len == 0 then\n        targetIp = sessionManager.currentSession.data.ip.public\n    end if\n\n    targets = dbManager.findTarget(targetIp)\n    if targets.len == 0 then\n        // Create a minimal target record\n        targetData = {}\n        targetData.public_ip = targetIp\n        targetData.lan_ip    = sessionManager.currentSession.data.ip.local\n        targetData.status    = \"owned\"\n        dbManager.upsertTarget(targetData)\n        ui.success(\"Target \" + targetIp + \" marked as owned and added to database.\")\n    else\n        dbManager.setTargetStatus(targets[0].id, \"owned\")\n        ui.success(\"Target \" + targetIp + \" marked as owned.\")\n    end if\n    dbManager.save()\nend function\ncommandManager.register(_cmd)\n\n\n// ── routerattack ──────────────────────────────────────────────────────────\n// Unified router attack: scans ALL exploits, collects every result type\n// (shell, computer, file), then presents an interactive menu to action them.\n// Replaces routermail - handles mail, passwd, bank, shells and file results.\n_cmd = new Command\n_cmd.name = \"routerattack\"\n_cmd.description = \"Scan and exploit a router - extracts mail, passwd, bank, shells. Usage: routerattack <publicIp> [lanIp]\"\n_cmd.parameters = [StringParameter.New({\"name\": \"publicIp\", \"required\": true, \"default\": \"\"}), StringParameter.New({\"name\": \"lanIp\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    commandManager = mediator.getExtension(\"commandManager\")\n\n    publicIp = params.publicIp.trim\n    lanIp    = params.lanIp.trim\n\n    if not is_valid_ip(publicIp) then\n        return Error.New(\"Invalid public IP: \" + publicIp, \"INVALID_IP\")\n    end if\n\n    // runRouterAttack is defined inside the attack command callback scope\n    // We call it via the attack command's internal execution\n    // Since runRouterAttack is a closure inside the attack command,\n    // we need to invoke it through a dedicated route.\n    // Use commandManager to trigger the internal router attack function\n    // by passing through the attack infrastructure.\n\n    // Load metaxploit and crypto directly here\n    meta = include_lib(\"/lib/metaxploit.so\")\n    if meta == null then\n        return Error.New(\"metaxploit.so not found in /lib\", \"NO_META\")\n    end if\n    crypto = include_lib(\"/lib/crypto.so\")\n    dbManager = mediator.getExtension(\"databaseManager\")\n\n    ui.separator()\n    ui.highlight(\"ROUTER ATTACK  \" + publicIp)\n    ui.separator()\n\n    ui.info(\"Connecting to router at \" + publicIp + \"...\")\n    netSession = meta.net_use(publicIp)\n    if not netSession then\n        return Error.New(\"Could not connect to router at \" + publicIp, \"CONNECT_FAIL\")\n    end if\n\n    routerLib = netSession.dump_lib\n    if not routerLib then\n        return Error.New(\"Could not dump router library\", \"DUMP_FAIL\")\n    end if\n    kbLibName    = routerLib.lib_name\n    kbLibVersion = routerLib.version\n    ui.success(\"Router library: \" + kbLibName + \" v\" + kbLibVersion)\n\n    // ── Build exploit list ────────────────────────────────────────────────\n    toAttempt = []\n    kbRecords = dbManager.kbLookup(kbLibName, kbLibVersion)\n    if kbRecords.len > 0 then\n        ui.success(\"KB hit: \" + kbLibName + \" v\" + kbLibVersion + \" - \" + str(kbRecords.len) + \" known exploit(s)\")\n        for kr in kbRecords\n            if kr.outcome == \"number_result\" or kr.outcome == \"version_mismatch\" then\n                continue\n            end if\n            if kr.outcome == \"uncertain\" and kr.hasIndex(\"fail_count\") and kr.fail_count > 3 then\n                continue\n            end if\n            entry = {} ; entry.addr = kr.address ; entry.vn = kr.exploit\n            entry.constraints = []\n            if kr.hasIndex(\"constraints\") and kr.constraints.len > 0 then\n                for cs in kr.constraints.split(\" \")\n                    if cs.len > 0 then\n                        entry.constraints.push(cs)\n                    end if\n                end for\n            end if\n            toAttempt.push(entry)\n        end for\n    else\n        addresses = meta.scan(routerLib)\n        if addresses == null or addresses.len == 0 then\n            ui.warning(\"No vulnerable addresses found\")\n            ui.info(\"Check hackshop for kernel_router \" + kbLibVersion + \" exploits\")\n            return\n        end if\n        ui.success(\"Found \" + str(addresses.len) + \" address(es) - scanning...\")\n        for addr in addresses\n            scanText = meta.scan_address(routerLib, addr)\n            if scanText == null then\n                continue\n            end if\n            vulnNames = []\n            chunks = scanText.split(\"Unsafe check: \")\n            for chunk in chunks\n                if chunk == chunks[0] then\n                    continue\n                end if\n                bStart = chunk.indexOf(\"<b>\")\n                bEnd   = chunk.indexOf(\"</b>\")\n                if bStart != null and bEnd != null then\n                    vn = chunk[bStart+3:bEnd]\n                    if vn.len > 0 then\n                        vulnNames.push(vn)\n                    end if\n                end if\n            end for\n            constraints = []\n            for scanLine in scanText.split(char(10))\n                t = scanLine.trim\n                if t.indexOf(\"* \") == 0 then\n                    constraints.push(t[2:])\n                end if\n            end for\n            for vn in vulnNames\n                e2 = {} ; e2.addr = addr ; e2.vn = vn ; e2.constraints = constraints\n                toAttempt.push(e2)\n            end for\n        end for\n    end if\n\n    if toAttempt.len == 0 then\n        ui.warning(\"No exploits to try\")\n        return\n    end if\n\n    ui.info(\"Trying \" + str(toAttempt.len) + \" exploit(s) - collecting all results...\")\n    ui.separator()\n\n    // ── Run ALL exploits, collect every success ───────────────────────────\n    collected = []\n    for attempt in toAttempt\n        addr = attempt.addr\n        vn   = attempt.vn\n        if lanIp.len > 0 then\n            result = routerLib.overflow(addr, vn, lanIp)\n        else\n            result = routerLib.overflow(addr, vn)\n        end if\n        resultType = typeof(result)\n        if resultType == \"number\" then\n            dbManager.kbRecord(kbLibName, kbLibVersion, addr, vn, \"number_result\", attempt.constraints, \"number\", \"\", \"\", \"\")\n            continue\n        end if\n        if result == null or resultType == \"string\" then\n            dbManager.kbRecord(kbLibName, kbLibVersion, addr, vn, \"uncertain\", attempt.constraints, \"Failed\", \"\", \"\", \"\")\n            continue\n        end if\n        dbManager.kbRecord(kbLibName, kbLibVersion, addr, vn, \"success\", attempt.constraints, resultType, \"\", \"guest\", \"\")\n        dbManager.save()\n        entry = {} ; entry.addr = addr ; entry.vn = vn\n        entry.result = result ; entry.resultType = resultType\n        collected.push(entry)\n        ui.success(\"  [\" + str(collected.len - 1) + \"] \" + resultType + \"  <-  \" + vn)\n    end for\n\n    if collected.len == 0 then\n        ui.print(\"\")\n        ui.warning(\"All exploits failed - constraints may not be met\")\n        ui.info(\"Active user on network? Enough computers on network?\")\n        ui.separator()\n        return\n    end if\n\n    // ── Present results menu ──────────────────────────────────────────────\n    ui.print(\"\")\n    ui.highlight(\"RESULTS FOUND\")\n    ui.separator()\n    for i in range(0, collected.len - 1)\n        entry = collected[i]\n        rType = entry.resultType\n        if rType == \"computer\" then\n            desc = \"extract mail / passwd / bank\"\n        else if rType == \"shell\" then\n            desc = \"guest shell on router - adopt as session\"\n        else if rType == \"file\" then\n            fPath = entry.result.path\n            desc = \"file/folder at \" + fPath + \" - usernames / passwd\"\n        else\n            desc = rType\n        end if\n        ui.info(\"  [\" + str(i) + \"]  \" + rType + \"  ->  \" + desc)\n    end for\n\n    ui.print(\"\")\n    ui.info(\"Options:\")\n    ui.print(\"  all   - action all results\")\n    ui.print(\"  0-\" + str(collected.len - 1) + \"   - action specific result\")\n    ui.print(\"  skip  - cancel\")\n    ui.print(\"\")\n    choice = user_input(\"  Choice: \").trim.lower\n\n    if choice == \"skip\" or choice == \"s\" then\n        return\n    end if\n\n    toAction = []\n    if choice == \"all\" then\n        toAction = collected[0:]\n    else\n        idx = choice.val\n        if idx >= 0 and idx < collected.len then\n            toAction = [collected[idx]]\n        else\n            ui.warning(\"Invalid choice\")\n            return\n        end if\n    end if\n\n    // ── Action chosen results ─────────────────────────────────────────────\n    harvestedIps4 = []\n    shellAdopted = false\n    for entry in toAction\n        rType  = entry.resultType\n        result = entry.result\n\n        // Skip duplicate computer results for same LAN IP\n        if rType == \"computer\" then\n            if harvestedIps4.indexOf(lanIp) != null then\n                ui.dim(\"  Skipping duplicate computer result for \" + lanIp)\n                continue\n            end if\n            harvestedIps4.push(lanIp)\n        end if\n\n        // Skip duplicate shell results - one session is enough\n        if rType == \"shell\" then\n            if shellAdopted then\n                ui.dim(\"  Skipping duplicate shell result (session already adopted)\")\n                continue\n            end if\n        end if\n\n        if rType == \"shell\" then\n            ui.highlight(\"SHELL RESULT\")\n            ui.separator()\n            newSess = sessionManager.addSession(result, \"router@\" + publicIp)\n            if not (newSess isa Error) then\n                sessionManager.setCurrentSession(newSess)\n                shellAdopted = true\n                ui.success(\"Shell adopted as Corvid session.\")\n                ui.info(\"Run: harvest  escalate  or  leave when done\")\n                // Check for shiny libs on router session\n                shinyMgr = mediator.getExtension(\"shinyLibsManager\")\n                if shinyMgr != null then\n                    libMgr = mediator.getExtension(\"libManager\")\n                    meta   = libMgr.getMetaxploit()\n                    if meta != null and not (meta isa Error) then\n                        found = shinyMgr.scanSession(newSess.handler, meta)\n                        if found.len > 0 then\n                            shinyMgr.showStagedNotification()\n                        end if\n                    end if\n                end if\n            else\n                ui.warning(\"Could not adopt shell: \" + newSess.message)\n            end if\n\n        else if rType == \"computer\" then\n            ui.highlight(\"COMPUTER RESULT  \" + lanIp)\n            ui.separator()\n            // Extract mail\n            ui.info(\"Extracting mail credentials...\")\n            homeFolder = result.File(\"/home\")\n            if homeFolder != null and not (homeFolder isa Error) then\n                ufList = homeFolder.get_folders\n                if ufList != null then\n                    mailSaved = 0\n                    for uf in ufList\n                        mf = result.File(\"/home/\" + uf.name + \"/Config/Mail.txt\")\n                        if mf == null then\n                            continue\n                        end if\n                        if not mf.has_permission(\"r\") then\n                            continue\n                        end if\n                        raw = mf.get_content\n                        if raw == null or raw.len == 0 then\n                            continue\n                        end if\n                        // Mail.txt is plaintext: email@domain.com:hash\n                        mailLines = raw.split(char(10))\n                        for mailLine in mailLines\n                            if mailLine.len == 0 then\n                                continue\n                            end if\n                            colonIdx = mailLine.indexOf(\":\")\n                            atIdx    = mailLine.indexOf(\"@\")\n                            if colonIdx == null or atIdx == null then\n                                continue\n                            end if\n                            if atIdx >= colonIdx then\n                                continue\n                            end if\n                            eAddr    = mailLine[:colonIdx].trim\n                            eHash    = mailLine[colonIdx + 1:].trim\n                            if eAddr.len == 0 or eHash.len == 0 then\n                                continue\n                            end if\n                            ePass = \"\"\n                            if crypto != null then\n                                eDec = crypto.decipher(eHash)\n                                if eDec != null then\n                                    ePass = eDec\n                                end if\n                            end if\n                            ui.success(\"  \" + uf.name + \" | \" + eAddr + \" | \" + ePass)\n                            mailCred2 = {} ; mailCred2.type = \"mail\" ; mailCred2.username = eAddr\n                            mailCred2.password = ePass ; mailCred2.public_ip = publicIp\n                            mailCred2.lan_ip = lanIp ; mailCred2.source = \"routerattack\"\n                            dbManager.upsertCredential(mailCred2)\n                            mailSaved = mailSaved + 1\n                        end for\n                    end for\n                    if mailSaved == 0 then\n                        ui.dim(\"  No mail credentials found\")\n                    end if\n                end if\n            end if\n            // Extract passwd\n            ui.info(\"Extracting passwd...\")\n            pf = result.File(\"/etc/passwd\")\n            if pf != null and not (pf isa Error) and pf.has_permission(\"r\") then\n                rawP = pf.get_content\n                if rawP != null and rawP.len > 0 and crypto != null then\n                    dec2 = crypto.decipher(rawP)\n                    if dec2 != null then\n                        ui.success(\"  Root password: \" + dec2)\n                        cdR = {} ; cdR.type = \"system\" ; cdR.username = \"root\"\n                        cdR.password = dec2 ; cdR.public_ip = publicIp\n                        cdR.lan_ip = lanIp ; cdR.source = \"routerattack_passwd\"\n                        dbManager.upsertCredential(cdR)\n                    end if\n                end if\n            end if\n            // Extract bank\n            ui.info(\"Extracting bank records...\")\n            homeFolder3 = result.File(\"/home\")\n            if homeFolder3 != null and not (homeFolder3 isa Error) then\n                ufList3 = homeFolder3.get_folders\n                if ufList3 != null then\n                    bankSaved = 0\n                    for uf3 in ufList3\n                        bf = result.File(\"/home/\" + uf3.name + \"/Config/Bank.txt\")\n                        if bf == null then\n                            continue\n                        end if\n                        if not bf.has_permission(\"r\") then\n                            continue\n                        end if\n                        rawB = bf.get_content\n                        if rawB != null and rawB.len > 0 then\n                            // Bank.txt format: accountNumber:md5hash\n                            // Split to get account number and hash separately\n                            bankStr = rawB.trim\n                            bankNum = bankStr\n                            bankPass = \"\"\n                            colonIdx = bankStr.indexOf(\":\")\n                            if colonIdx != null then\n                                bankNum = bankStr[:colonIdx]\n                                bankHash = bankStr[colonIdx + 1:]\n                                if crypto != null and bankHash.len > 0 then\n                                    decB = crypto.decipher(bankHash)\n                                    if decB != null then\n                                        bankPass = decB\n                                    end if\n                                end if\n                            end if\n                            ui.success(\"  Bank: \" + uf3.name + \" | \" + bankNum + \" | \" + bankPass)\n                            bd = {} ; bd.type = \"bank\" ; bd.username = uf3.name\n                            bd.password = bankPass ; bd.bank_number = bankNum\n                            bd.public_ip = publicIp\n                            bd.lan_ip = lanIp ; bd.source = \"routerattack\"\n                            dbManager.upsertCredential(bd)\n                            bankSaved = bankSaved + 1\n                        end if\n                    end for\n                    if bankSaved == 0 then\n                        ui.dim(\"  No bank records found\")\n                    end if\n                end if\n            end if\n            dbManager.save()\n            ui.success(\"Harvest complete.\")\n            ui.info(\"Mail.exe -> PF -> Funny Game -> send your Nest IP + port 1222\")\n\n        else if rType == \"file\" then\n            ui.highlight(\"FILE RESULT  \" + result.path)\n            ui.separator()\n            // Walk up to root\n            rootF = result\n            while rootF.path != \"/\"\n                rootF = rootF.parent\n            end while\n            // Try passwd\n            ui.info(\"Attempting /etc/passwd...\")\n            etcF = null\n            for rf in rootF.get_folders\n                if rf.path == \"/etc\" then\n                    etcF = rf\n                end if\n            end for\n            if etcF != null then\n                for ef in etcF.get_files\n                    if ef.name != \"passwd\" then\n                        continue\n                    end if\n                    if not ef.has_permission(\"r\") then\n                        continue\n                    end if\n                    rawPwd = ef.get_content\n                    if rawPwd != null and rawPwd.len > 0 and crypto != null then\n                        rootPwd = crypto.decipher(rawPwd)\n                        if rootPwd != null then\n                            ui.success(\"  Root password: \" + rootPwd)\n                            cdRoot2 = {} ; cdRoot2.type = \"system\" ; cdRoot2.username = \"root\"\n                            cdRoot2.password = rootPwd ; cdRoot2.public_ip = publicIp\n                            cdRoot2.lan_ip = lanIp ; cdRoot2.source = \"routerattack_file\"\n                            dbManager.upsertCredential(cdRoot2)\n                            dbManager.save()\n                        end if\n                    end if\n                end for\n            end if\n            // Walk /home\n            ui.info(\"Walking /home for users...\")\n            homeF2 = null\n            if result.path == \"/home\" then\n                homeF2 = result\n            else\n                for rf3 in rootF.get_folders\n                    if rf3.path == \"/home\" then\n                        homeF2 = rf3\n                    end if\n                end for\n            end if\n            if homeF2 == null then\n                ui.warning(\"  /home not accessible\")\n            else\n                ufList2 = homeF2.get_folders\n                if ufList2 == null or ufList2.len == 0 then\n                    ui.warning(\"  No user folders in /home\")\n                else\n                    ui.info(\"  Found \" + str(ufList2.len) + \" user(s):\")\n                    for uf2 in ufList2\n                        pd = {} ; pd.username = uf2.name\n                        pd.public_ip = publicIp ; pd.lan_ip = lanIp\n                        pd.source = \"routerattack_file\"\n                        // Try Mail.txt for this user via folder traversal\n                        subFolders2 = uf2.get_folders\n                        if subFolders2 != null then\n                            for sf2 in subFolders2\n                                if sf2.name != \"Config\" then\n                                    continue\n                                end if\n                                sfFiles2 = sf2.get_files\n                                if sfFiles2 == null then\n                                    continue\n                                end if\n                                for mf2 in sfFiles2\n                                    if mf2.name != \"Mail.txt\" then\n                                        continue\n                                    end if\n                                    if not mf2.has_permission(\"r\") then\n                                        continue\n                                    end if\n                                    rawMail2 = mf2.get_content\n                                    if rawMail2 == null or rawMail2.len == 0 then\n                                        continue\n                                    end if\n                                    // Mail.txt is plaintext: email@domain.com:hash\n                                    for ml2 in rawMail2.split(char(10))\n                                        if ml2.len == 0 then\n                                            continue\n                                        end if\n                                        ci2 = ml2.indexOf(\":\")\n                                        ai2 = ml2.indexOf(\"@\")\n                                        if ci2 == null or ai2 == null or ai2 >= ci2 then\n                                            continue\n                                        end if\n                                        mEmail2 = ml2[:ci2].trim\n                                        mHash2  = ml2[ci2 + 1:].trim\n                                        if mEmail2.len == 0 or mHash2.len == 0 then\n                                            continue\n                                        end if\n                                        mPass2 = \"\"\n                                        if crypto != null then\n                                            mDec2 = crypto.decipher(mHash2)\n                                            if mDec2 != null then\n                                                mPass2 = mDec2\n                                            end if\n                                        end if\n                                        ui.success(\"  \" + uf2.name + \" | \" + mEmail2 + \" | \" + mPass2)\n                                        pd.email = mEmail2\n                                        cdMail2 = {} ; cdMail2.type = \"mail\"\n                                        cdMail2.username = mEmail2 ; cdMail2.password = mPass2\n                                        cdMail2.public_ip = publicIp ; cdMail2.lan_ip = lanIp\n                                        cdMail2.source = \"routerattack_file\"\n                                        dbManager.upsertCredential(cdMail2)\n                                    end for\n                                end for\n                            end for\n                        end if\n                        if not pd.hasIndex(\"email\") then\n                            ui.info(\"  \" + uf2.name + \"  -> social engineering target\")\n                        end if\n                        dbManager.upsertPerson(pd)\n                    end for\n                    dbManager.save()\n                end if\n            end if\n            ui.info(\"Mail.exe -> PF -> Funny Game -> send your Nest IP + port 1222\")\n        end if\n    end for\n\n    // Remind about staged shiny libs\n    shinyMgr2 = mediator.getExtension(\"shinyLibsManager\")\n    if shinyMgr2 != null and shinyMgr2.db.staged.len > 0 then\n        shinyMgr2.showStagedNotification()\n    end if\n\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// ── portattack ───────────────────────────────────────────────────────────\n_cmd = new Command\n_cmd.name = \"portattack\"\n_cmd.description = \"Attack a single specific port/service. Usage: portattack <ip> <port> [lanip]\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\", \"required\": true}), StringParameter.New({\"name\": \"port\", \"required\": true}), StringParameter.New({\"name\": \"lanip\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n    attackManager  = mediator.getExtension(\"attackManager\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    intelManager   = mediator.getExtension(\"intelManager\")\n\n    targetIp  = params.ip.trim\n    targetPort = params.port.val\n    lanIp     = params.lanip.trim\n\n    if not is_valid_ip(targetIp) then\n        return Error.New(\"Invalid IP: \" + targetIp, \"INVALID_IP\")\n    end if\n    if targetPort <= 0 then\n        return Error.New(\"Invalid port: \" + params.port, \"INVALID_PORT\")\n    end if\n\n    ui.separator()\n    ui.highlight(\"PORT ATTACK\")\n    ui.separator()\n    ui.info(\"Target : \" + targetIp + \":\" + str(targetPort))\n    if lanIp.len > 0 then\n        ui.info(\"LAN    : \" + lanIp)\n    end if\n    ui.print(\"\")\n\n    // Look up service info from DB\n    targets = dbManager.findTarget(targetIp)\n    serviceName = \"unknown\"\n    serviceVersion = \"unknown\"\n    portForwarded = false\n    if targets.len > 0 then\n        for tgt in targets\n            if not tgt.hasIndex(\"ports\") then\n                continue\n            end if\n            for pr in tgt.ports\n                if pr.port == targetPort then\n                    serviceName    = pr.service\n                    serviceVersion = pr.version\n                    portForwarded  = pr.forwarded\n                end if\n            end for\n        end for\n    end if\n    ui.info(\"Service: \" + serviceName + \" v\" + serviceVersion)\n    if not portForwarded then\n        ui.warning(\"Port \" + str(targetPort) + \" not marked as forwarded in DB - attack may fail\")\n    end if\n    ui.print(\"\")\n\n    // Get router IP\n    routerIp = targetIp\n    if targets.len > 0 and targets[0].hasIndex(\"router_ip\") then\n        if targets[0].router_ip.len > 0 then\n            routerIp = targets[0].router_ip\n        end if\n    end if\n\n    // Scan just this one port\n    ui.info(\"Scanning port \" + str(targetPort) + \"...\")\n    scanLanIp = \"\"\n    if lanIp.len > 0 then\n        scanLanIp = lanIp\n    end if\n    results = attackManager.runScan(targetIp, targetPort, scanLanIp, routerIp)\n    if results isa Error then\n        return Error.New(\"Scan failed on port \" + str(targetPort) + \": \" + results.message, \"SCAN_FAIL\")\n    end if\n    if results.len == 0 then\n        ui.warning(\"No exploitable vulnerabilities found on port \" + str(targetPort))\n        ui.info(\"Check hackshop for \" + serviceName + \" v\" + serviceVersion + \" exploits\")\n        return\n    end if\n\n    // Rank results same as main attack\n    ranked = []\n    for r in results\n        r.port = targetPort ; r.service = serviceName\n        ranked.push(r)\n    end for\n    // Sort: root shell > user shell > guest shell > computer > file\n    sortedRanked = []\n    for r in ranked\n        if r.rtype == \"shell\" and r.privilege == \"root\" then\n            sortedRanked.push(r)\n        end if\n    end for\n    for r in ranked\n        if r.rtype == \"shell\" and r.privilege != \"root\" and r.privilege != \"guest\" and r.privilege != \"unknown\" then\n            sortedRanked.push(r)\n        end if\n    end for\n    for r in ranked\n        if r.rtype == \"shell\" and r.privilege == \"guest\" then\n            sortedRanked.push(r)\n        end if\n    end for\n    for r in ranked\n        if r.rtype == \"computer\" then\n            sortedRanked.push(r)\n        end if\n    end for\n    for r in ranked\n        if r.rtype == \"file\" then\n            sortedRanked.push(r)\n        end if\n    end for\n\n    // Display candidates\n    ui.highlight(\"EXPLOIT CANDIDATES  [\" + serviceName + \" port \" + str(targetPort) + \"]\")\n    ui.separator()\n    for i in range(0, sortedRanked.len - 1)\n        r = sortedRanked[i]\n        rtLabel = r.rtype\n        if r.rtype == \"shell\" then\n            rtLabel = \"shell (\" + r.privilege + \")\"\n        end if\n        if r.rtype == \"computer\" then\n            rtLabel = \"computer (\" + r.privilege + \")\"\n        end if\n        ui.print(\"  [\" + str(i) + \"] \" + r.exploit + \"  ->  \" + rtLabel)\n    end for\n    ui.print(\"\")\n\n    // Prompt: auto-try all or pick specific\n    ui.info(\"Options:\")\n    ui.print(\"  all        - try all in ranked order\")\n    ui.print(\"  0-\" + str(sortedRanked.len - 1) + \"        - try specific exploit\")\n    ui.print(\"  skip       - cancel\")\n    ui.print(\"\")\n    choice = user_input(\"  Choice: \").trim.lower\n\n    if choice == \"skip\" or choice == \"s\" then\n        return\n    end if\n\n    toTry = []\n    if choice == \"all\" then\n        toTry = sortedRanked[0:]\n    else\n        idx = choice.val\n        if idx >= 0 and idx < sortedRanked.len then\n            toTry = [sortedRanked[idx]]\n        else\n            ui.warning(\"Invalid choice\")\n            return\n        end if\n    end if\n\n    // Execute\n    ui.separator()\n    ui.highlight(\"EXECUTING\")\n    ui.separator()\n\n    succeeded = false\n    for r in toTry\n        if succeeded then\n            break\n        end if\n        rtLabel = r.rtype\n        if r.rtype == \"shell\" then\n            rtLabel = \"shell (\" + r.privilege + \")\"\n        end if\n        ui.info(\"Trying: \" + r.exploit + \" -> \" + rtLabel + \"...\")\n\n        result = attackManager.exploit(targetIp, targetPort, scanLanIp, routerIp, null)\n        if result isa Error then\n            ui.warning(\"  Failed: \" + result.message)\n            continue\n        end if\n\n        succeeded = true\n\n        // Check what type of result we actually got\n        resultType = typeof(result)\n\n        if resultType == \"shell\" or (result isa Shell) then\n            // Proper shell session - already set as current by exploit()\n            currentSession = sessionManager.currentSession\n            priv = currentSession.handler.privilege()\n            ui.success(\"Session opened as: \" + priv + \" on \" + targetIp + \":\" + str(targetPort))\n            if priv == \"root\" then\n                ui.info(\"Root obtained - harvesting credentials...\")\n                intelManager.harvestAll(targetIp, currentSession.data.ip.local)\n                ui.success(\"Harvest complete\")\n            else\n                ui.info(\"Got \" + priv + \" - run 'harvest' or 'attack' for escalation\")\n            end if\n\n        else if resultType == \"computer\" or (result isa Computer) then\n            ui.success(\"Got computer object on \" + targetIp)\n            ui.info(\"Use 'attack' for full escalation from computer object\")\n\n        else if resultType == \"file\" or (result isa File) then\n            // File/folder result - roll back to previous session, handle the file intel\n            ui.success(\"Got file/folder object\")\n            // Revert current session to previous (file sessions aren't useful as current)\n            if sessionManager.sessions.len > 1 then\n                sessionManager.setCurrentSession(sessionManager.sessions[sessionManager.sessions.len - 2])\n                // Remove the file session that was added\n                sessionManager.sessions.remove(sessionManager.sessions.len - 1)\n            end if\n\n            // Load crypto for potential decipher\n            crypto = include_lib(\"/lib/crypto.so\")\n            if crypto == null then\n                crypto = include_lib(current_path + \"/crypto.so\")\n            end if\n\n            // Route to appropriate handler based on path\n            // result is a RAW game file object - use properties not methods for name/path/is_folder\n            folderPath = \"\"\n            if result.is_folder then\n                folderPath = result.path\n            end if\n\n            if folderPath == \"/lib\" or folderPath.indexOf(\"/lib\") == 0 then\n                ui.separator()\n                ui.highlight(\"LIBRARY INTEL\")\n                ui.separator()\n                meta = include_lib(\"/lib/metaxploit.so\")\n                libFiles = result.get_files\n                if libFiles != null then\n                    for lf in libFiles\n                        if lf.name.indexOf(\".so\") == null then\n                            continue\n                        end if\n                        if meta != null then\n                            loadedLib = meta.load(lf.path)\n                            if loadedLib != null then\n                                ui.info(\"  \" + lf.name + \"  v\" + loadedLib.version)\n                            else\n                                ui.dim(\"  \" + lf.name + \"  (service lib - not locally loadable)\")\n                            end if\n                        end if\n                    end for\n                end if\n                // Walk up to root then find /etc/passwd\n                rootFolder = result\n                while rootFolder.path != \"/\"\n                    rootFolder = rootFolder.parent()\n                end while\n                subFolders = rootFolder.get_folders\n                if subFolders != null then\n                    for rf in subFolders\n                        if rf.path != \"/etc\" then\n                            continue\n                        end if\n                        etcFiles = rf.get_files\n                        if etcFiles == null then\n                            continue\n                        end if\n                        for ef in etcFiles\n                            if ef.name != \"passwd\" then\n                                continue\n                            end if\n                            if not ef.has_permission(\"r\") then\n                                continue\n                            end if\n                            if crypto != null then\n                                rp = crypto.decipher(ef.get_content)\n                                if rp != null then\n                                    ui.success(\"  Root password: \" + rp)\n                                    rootCred = {}\n                                    rootCred.type = \"system\" ; rootCred.username = \"root\"\n                                    rootCred.password = rp ; rootCred.public_ip = targetIp\n                                    rootCred.lan_ip = lanIp ; rootCred.source = \"native\"\n                                    dbManager.upsertCredential(rootCred)\n                                    dbManager.save()\n                                end if\n                            end if\n                        end for\n                    end for\n                end if\n                ui.info(\"Use lib versions above to find local exploits in hackshop\")\n\n            else if folderPath == \"/home\" or folderPath.indexOf(\"/home\") == 0 then\n                ui.separator()\n                ui.highlight(\"USER HARVEST\")\n                ui.separator()\n                userFolders = result.get_folders\n                if userFolders != null then\n                    for uf in userFolders\n                        username = uf.name\n                        ui.info(\"  User: \" + username)\n                        pd = {}\n                        pd.username = username ; pd.public_ip = targetIp\n                        pd.lan_ip = lanIp ; pd.source = \"native\"\n                        dbManager.upsertPerson(pd)\n                    end for\n                end if\n                dbManager.save()\n\n            else\n                ui.info(\"File result at: \" + folderPath)\n                if not result.is_folder and result.has_permission(\"r\") then\n                    fc = result.get_content\n                    if fc != null and fc.len > 0 and crypto != null then\n                        dec = crypto.decipher(fc)\n                        if dec != null then\n                            ui.success(\"  Deciphered: \" + dec)\n                        end if\n                    end if\n                end if\n            end if\n        end if\n    end for\n\n    if not succeeded then\n        ui.warning(\"All exploits on port \" + str(targetPort) + \" failed\")\n        ui.info(\"Check hackshop for updated \" + serviceName + \" v\" + serviceVersion + \" exploits\")\n    end if\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// ── put ──────────────────────────────────────────────────────────────────\n// Upload a file from pivot session to current session\n_cmd = new Command\n_cmd.name = \"put\"\n_cmd.description = \"Upload file from your server to current session target. Usage: put <localpath> <remotepath>\"\n_cmd.parameters = [StringParameter.New({\"name\": \"localpath\", \"required\": true}), StringParameter.New({\"name\": \"remotepath\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n\n    localPath  = params.localpath.trim\n    remotePath = params.remotepath.trim\n\n    pivotSession   = sessionManager.pivotSession\n    currentSession = sessionManager.currentSession\n\n    if pivotSession == null then\n        return Error.New(\"No pivot session\", \"NO_PIVOT\")\n    end if\n    if currentSession == null then\n        return Error.New(\"No current session\", \"NO_SESSION\")\n    end if\n    if currentSession == pivotSession then\n        return Error.New(\"Current session IS pivot - no remote target to upload to\", \"SAME_SESSION\")\n    end if\n\n    // Verify source file exists on pivot\n    srcFile = pivotSession.handler.getFile(localPath)\n    if srcFile isa Error then\n        return Error.New(\"Source not found on server: \" + localPath, \"SRC_NOT_FOUND\")\n    end if\n\n    // Treat remotePath as destination directory directly\n    remoteDir = remotePath.trim\n    if remoteDir.len == 0 then\n        remoteDir = \"/home/guest\"\n    end if\n\n    // Verify session has a shell (FileSession does not)\n    if not (currentSession.handler isa ShellSession) then\n        return Error.New(\"Current session is not a shell session - cannot scp\", \"NOT_SHELL\")\n    end if\n\n    destCheck = currentSession.handler.getFile(remoteDir)\n    if destCheck isa Error then\n        return Error.New(\"Remote destination not found: \" + remoteDir, \"DEST_NOT_FOUND\")\n    end if\n\n    // Perform the scp transfer\n    ui.info(\"Uploading \" + localPath + \" -> \" + remoteDir + \"...\")\n\n    pivotShell   = pivotSession.handler.shell.shell\n    currentShell = currentSession.handler.shell.shell\n\n    result = pivotShell.scp(localPath, remoteDir, currentShell)\n\n    if typeof(result) == \"string\" and result.len > 0 then\n        return Error.New(\"Upload failed: \" + result, \"SCP_FAILED\")\n    end if\n    ui.success(\"Uploaded: \" + srcFile.name() + \" -> \" + remoteDir)\nend function\ncommandManager.register(_cmd)\n\n// ── lannmap ──────────────────────────────────────────────────────────────\n// Deploy a tiny LAN scanner to the current root session, run it there\n// so get_router() resolves in the target's network context, then read\n// the results back and import into the DB.\n// Usage: lannmap <public_ip>\n_cmd = new Command\n_cmd.name = \"lannmap\"\n_cmd.description = \"Deploy LAN scanner to current root session and import results. Usage: lannmap <publicip>\"\n_cmd.parameters = [StringParameter.New({\"name\": \"publicip\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n    configManager  = mediator.getExtension(\"configManager\")\n\n    publicIp = params.publicip.trim\n    if not is_valid_ip(publicIp) then\n        return Error.New(\"Invalid public IP: \" + publicIp, \"INVALID_IP\")\n    end if\n\n    currentSession = sessionManager.currentSession\n    pivotSession   = sessionManager.pivotSession\n\n    if currentSession == pivotSession then\n        return Error.New(\"Must be on a remote session to use lannmap\", \"SAME_SESSION\")\n    end if\n\n    if not (currentSession.handler isa ShellSession) then\n        return Error.New(\"Current session must be a shell session\", \"NOT_SHELL\")\n    end if\n\n    if currentSession.handler.privilege() != \"root\" then\n        return Error.New(\"Root access required to deploy lannmap\", \"NOT_ROOT\")\n    end if\n\n    ui.separator()\n    ui.highlight(\"LAN NMAP via target context\")\n    ui.separator()\n\n    pivotHandler = pivotSession.handler\n\n    // ── Step 1: ensure cnmap binary exists on Nest ────────────────────────\n    // cnmap.src is shipped at /Corvid/tools/cnmap.src - just compile it\n    cnmapBinary = pivotHandler.getFile(\"/Corvid/tools/cnmap\")\n    if not (cnmapBinary isa Error) then\n        cnmapBinary.delete()\n    end if\n\n    ui.info(\"Building cnmap scanner...\")\n    cnmapSrcFile = pivotHandler.getFile(\"/Corvid/tools/cnmap.src\")\n    if cnmapSrcFile isa Error then\n        return Error.New(\"cnmap.src not found at /Corvid/tools/cnmap.src - check ZIP installation\", \"SRC_MISSING\")\n    end if\n\n    pivotShellBuild = pivotSession.handler.shell.shell\n    buildResult = pivotShellBuild.build(\"/Corvid/tools/cnmap.src\", \"/Corvid/tools\")\n    if typeof(buildResult) == \"string\" and buildResult.len > 0 then\n        return Error.New(\"cnmap build failed: \" + buildResult, \"BUILD_FAILED\")\n    end if\n\n    cnmapBinary = pivotHandler.getFile(\"/Corvid/tools/cnmap\")\n    if cnmapBinary isa Error then\n        return Error.New(\"cnmap build succeeded but binary not found\", \"BINARY_NOT_FOUND\")\n    end if\n    ui.success(\"cnmap built at /Corvid/tools/cnmap\")\n\n    // ── Step 2: upload cnmap to target ────────────────────────────────────\n    ui.info(\"Uploading cnmap to target...\")\n    pivotShell   = pivotSession.handler.shell.shell\n    targetShell  = currentSession.handler.shell.shell\n    targetHandler = currentSession.handler\n\n    // Try upload paths in order - same pattern as rootcallback deploy\n    cnmapUploadPaths = []\n    cnmapUploadPaths.push(\"/root\")\n    tmpCheck = targetHandler.getFile(\"/shiny\")\n    if not (tmpCheck isa Error) then\n        cnmapUploadPaths.push(\"/shiny\")\n    end if\n    currentUser = targetHandler.user\n    if currentUser.len > 0 and currentUser != \"root\" then\n        cnmapUploadPaths.push(\"/home/\" + currentUser)\n    end if\n\n    cnmapUploadedDir = \"\"\n    for uploadDir in cnmapUploadPaths\n        scpResult = pivotShell.scp(\"/Corvid/tools/cnmap\", uploadDir, targetShell)\n        if typeof(scpResult) != \"string\" or scpResult.len == 0 then\n            cnmapUploadedDir = uploadDir\n            ui.success(\"Uploaded \" + uploadDir + \"/cnmap\")\n            break\n        end if\n        ui.dim(\"  \" + uploadDir + \" failed - trying next...\")\n    end for\n\n    if cnmapUploadedDir.len == 0 then\n        return Error.New(\"Upload failed on all paths\", \"UPLOAD_FAILED\")\n    end if\n\n    cnmapBinPath = cnmapUploadedDir + \"/cnmap\"\n    cnmapOutPath = \"/root/cnmap_out.txt\"\n\n    // ── Step 3: launch on target ──────────────────────────────────────────\n    ui.info(\"Running LAN scan on target...\")\n    targetShell.launch(cnmapBinPath, \"\")\n\n    // ── Step 4: poll for output file ──────────────────────────────────────\n    outFile = null\n    pollCount = 0\n    pollMax   = 20\n    while pollCount < pollMax\n        attempt = targetHandler.getFile(cnmapOutPath)\n        if not (attempt isa Error) then\n            raw = attempt.content()\n            if raw != null and raw.indexOf(\"DONE\") != null then\n                outFile = attempt\n                break\n            end if\n        end if\n        pollCount = pollCount + 1\n    end while\n\n    if outFile == null then\n        return Error.New(\"cnmap timed out - no output received\", \"TIMEOUT\")\n    end if\n\n    // ── Step 5: parse output and import to DB ─────────────────────────────\n    raw     = outFile.content()\n    lines   = raw.split(char(10))\n    currentDeviceIp = \"\"\n    imported = 0\n    devices  = 0\n\n    ui.print(\"\")\n    ui.highlight(\"LAN SCAN RESULTS  [\" + publicIp + \"]\")\n    ui.separator()\n\n    for line in lines\n        line = line.trim\n        if line.len == 0 then\n            continue\n        end if\n        if line == \"DONE\" then\n            continue\n        end if\n\n        if line.indexOf(\"DEVICE \") == 0 then\n            currentDeviceIp = line[7:]\n            ui.info(\"Device: \" + currentDeviceIp)\n            devices = devices + 1\n\n        else if line.indexOf(\"PORT \") == 0 then\n            parts = line[5:].split(\" \")\n            if parts.len < 5 then\n                continue\n            end if\n            portNum  = parts[0].val\n            svcName  = parts[1]\n            svcVer   = parts[2]\n            isFwd    = parts[3] == \"1\"\n            isOpen   = parts[4] == \"1\"\n\n            fwdStr  = \"0\"\n            openStr = \"0\"\n            if isFwd  then\n                fwdStr  = \"1\"\n            end if\n            if isOpen then\n                openStr = \"1\"\n            end if\n            ui.print(\"  port \" + parts[0] + \"  \" + svcName + \"  \" + svcVer + \"  fwd:\" + fwdStr + \"  open:\" + openStr)\n\n            // Upsert into DB\n            if currentDeviceIp.len > 0 then\n                targetData = {}\n                targetData.public_ip = publicIp\n                targetData.lan_ip    = currentDeviceIp\n                portRecord = {}\n                portRecord.port      = portNum\n                portRecord.service   = svcName\n                portRecord.version   = svcVer\n                portRecord.forwarded = isFwd\n                portRecord.exploited = false\n                targetData.ports = [portRecord]\n                dbManager.upsertTarget(targetData)\n                imported = imported + 1\n            end if\n        end if\n    end for\n\n    dbManager.save()\n    ui.print(\"\")\n    ui.success(\"Imported \" + str(imported) + \" port record(s) across \" + str(devices) + \" device(s)\")\n    ui.separator()\n\n    // ── Step 6: register for leave cleanup ───────────────────────────────\n    configManager.set(\"cnmapActive\", currentSession.data.ip.public)\n    configManager.set(\"cnmapDir\", cnmapUploadedDir)\n\nend function\ncommandManager.register(_cmd)\n\n\n// ── portfwd ──────────────────────────────────────────────────────────────\n// Manage port forwarding on a router you have shell access to\n_cmd = new Command\n_cmd.name = \"portfwd\"\n_cmd.description = \"Manage port forwarding on a router. Subcommands: list, add, remove. Usage: portfwd list [routerip] | portfwd add <ext> <int> <lanip> [routerip] | portfwd remove <extport> <lanip> [routerip]\"\n_cmd.parameters = [StringParameter.New({\"name\": \"subcommand\", \"required\": true}), StringParameter.New({\"name\": \"arg1\", \"required\": false, \"default\": \"\"}), StringParameter.New({\"name\": \"arg2\", \"required\"",1)
