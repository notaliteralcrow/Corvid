_cmd.parameters = [StringParameter.New({""name"": ""ip"",   ""required"": true}),StringParameter.New({""name"": ""port"", ""required"": true}),StringParameter.New({""name"": ""lanip"",    ""required"": false, ""default"": ""unknown""}),StringParameter.New({""name"": ""routerip"", ""required"": false, ""default"": ""unknown""}),StringParameter.New({""name"": ""index"",    ""required"": false, ""default"": """"})]
_cmd.permissions = {}
