CorvidUi.New = function()
    if CorvidUi.singleton != null then
        return CorvidUi.singleton
    end if
    instance = new CorvidUi
    CorvidUi.singleton = instance
    return instance
end function

CorvidUi.showSettingsMenu = function(configManager)
    theme = self.mediator.getExtension(""themeManager"")
    self.separator()
    print(theme.highlight(""  CORVID SETTINGS""))
    self.separator()

    // Read current values
    autoShiny  = configManager.get(""autoShiny"")
    autoWhois  = configManager.get(""autoWhois"")
    autoSmtp   = configManager.get(""autoSmtp"")
    autoOwn    = configManager.get(""autoOwn"")
    kbFallback = configManager.get(""kbFallback"")
    if autoShiny isa Error then
        autoShiny = ""1""
    end if
    if autoWhois isa Error then
        autoWhois = ""1""
    end if
    if autoSmtp isa Error then
        autoSmtp = ""1""
    end if
    if autoOwn isa Error then
        autoOwn = ""1""
    end if
    if kbFallback isa Error then
        kbFallback = ""1""
    end if

    onStr  = theme.success(""ON "")
    offStr = theme.warning(""OFF"")

    self.separator()
    print(theme.highlight(""  AUTOMATION TOGGLES""))
    self.separator()

    s1 = onStr
    if autoShiny != ""1"" then
        s1 = offStr
    end if
    s2 = onStr
    if autoWhois != ""1"" then
        s2 = offStr
    end if
    s3 = onStr
    if autoSmtp != ""1"" then
        s3 = offStr
    end if
    s4 = onStr
    if autoOwn != ""1"" then
        s4 = offStr
    end if
    s5 = onStr
    if kbFallback != ""1"" then
        s5 = offStr
    end if

    print(""  [1]  "" + s1 + ""  "" + theme.text(""autoShiny  "") + theme.secondary(""score libs during port scan + baseline Nest scan on first run""))
    print(""  [2]  "" + s2 + ""  "" + theme.text(""autoWhois  "") + theme.secondary(""whois lookup during guided attack Phase 1""))
    print(""  [3]  "" + s3 + ""  "" + theme.text(""autoSmtp   "") + theme.secondary(""SMTP user enumeration when smtp port detected during attack""))
    print(""  [4]  "" + s4 + ""  "" + theme.text(""autoOwn    "") + theme.secondary(""prompt to mark target as owned at end of attack""))
    print(""  [5]  "" + s5 + ""  "" + theme.text(""kbFallback "") + theme.secondary(""run full port scan when no KB hits found""))
    self.separator()
    print(theme.highlight(""  OTHER""))
    self.separator()
    print(""  [6]  "" + theme.text(""Aliases     "") + theme.secondary(""view and manage command shortcuts""))
    print(""  [7]  "" + theme.text(""Theme       "") + theme.secondary(""customise colours  (theme <slot> <hex>)""))
    self.separator()
    print(theme.secondary(""  Select a toggle to flip it, 6-7 for other settings, 0 to go back.""))
    print()
end function
",1)
m("/Corvid/asriN/commands_1.txt","// ============================================================
// CORVID | commands
// All command registrations. Called once from main after
// all managers are wired to the mediator.
// ============================================================

registerAllCommands = function(mediator, commandManager)

// ============================================================
// NAVIGATION
// ============================================================

// --- ls ---
_cmd = new Command
_cmd.name = ""ls""
_cmd.description = ""List files in current or given directory""
_cmd.parameters = [StringParameter.New({""name"": ""path"", ""required"": false, ""default"": "".""})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        ui             = mediator.getExtension(""corvidUi"")
        sessionManager = mediator.getExtension(""sessionManager"")
        handler        = sessionManager.currentSession.handler
        file           = handler.getFile(params.path)
        if file isa Error then
            return file
        end if
        kids = file.children()
        if kids isa Error then
            return kids
        end if
        ui.ls(kids)
    end function
commandManager.register(_cmd)

// --- cd ---
_cmd = new Command
_cmd.name = ""cd""
_cmd.description = ""Change directory""
_cmd.parameters = [StringParameter.New({""name"": ""path"", ""required"": true})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        sessionManager = mediator.getExtension(""sessionManager"")
        handler        = sessionManager.currentSession.handler
        return handler.goTo(params.path)
    end function
commandManager.register(_cmd)

// --- pwd ---
_cmd = new Command
_cmd.name = ""pwd""
_cmd.description = ""Print working directory""
_cmd.parameters = []
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        sessionManager = mediator.getExtension(""sessionManager"")
        return sessionManager.currentSession.handler.path()
    end function
commandManager.register(_cmd)

// --- back ---
_cmd = new Command
_cmd.name = ""back""
_cmd.description = ""Return to previous session""
_cmd.parameters = []
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        sessionManager = mediator.getExtension(""sessionManager"")
        ui             = mediator.getExtension(""corvidUi"")
        result = sessionManager.back()
        if result isa Error then
            return result
        end if
        ui.info(""Returned to: "" + sessionManager.currentSession.label)
    end function
commandManager.register(_cmd)

// ============================================================
// FILE OPERATIONS
// ============================================================

// --- cat ---
_cmd = new Command
_cmd.name = ""cat""
_cmd.description = ""Print file contents""
_cmd.parameters = [StringParameter.New({""name"": ""path"", ""required"": true})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        sessionManager = mediator.getExtension(""sessionManager"")
        handler        = sessionManager.currentSession.handler
        file           = handler.getFile(params.path)
        if file isa Error then
            return file
        end if
        return file.content()
    end function
commandManager.register(_cmd)

// --- write ---
_cmd = new Command
_cmd.name = ""write""
_cmd.description = ""Write content to a file. Use > to overwrite, >> to append""
_cmd.parameters = [StringParameter.New({""name"": ""path"",    ""required"": true}),OptionsParameter.New({""name"": ""mode"", ""required"": true, ""options"": {"">"": "">"", "">>"": "">>""}}),RestParameter.New({""name"": ""content"", ""required"": false, ""default"": """"})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        sessionManager = mediator.getExtension(""sessionManager"")
        handler        = sessionManager.currentSession.handler
        file           = handler.getFile(params.path)
        if file isa Error then
            return file
        end if
        if params.mode == "">"" then
            return file.setContent(params.content)
        end if
        return file.appendContent(params.content)
    end function
commandManager.register(_cmd)

// --- rm ---
_cmd = new Command
_cmd.name = ""rm""
_cmd.description = ""Delete a file or directory""
_cmd.parameters = [StringParameter.New({""name"": ""path"", ""required"": true})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        sessionManager = mediator.getExtension(""sessionManager"")
        ui             = mediator.getExtension(""corvidUi"")
        handler        = sessionManager.currentSession.handler
        result         = handler.delete(params.path)
        if result isa Error then
            return result
        end if
        ui.success(""Deleted: "" + params.path)
    end function
commandManager.register(_cmd)

// --- mkdir ---
_cmd = new Command
_cmd.name = ""mkdir""
_cmd.description = ""Create a directory""
_cmd.parameters = [StringParameter.New({""name"": ""path"", ""required"": true})]
_cmd.permissions = {}
_cmd.permissions.object = ""computer""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        sessionManager = mediator.getExtension(""sessionManager"")
        ui             = mediator.getExtension(""corvidUi"")
        handler        = sessionManager.currentSession.handler
        result         = handler.createFolder(params.path)
        if result isa Error then
            return result
        end if
        ui.success(""Created: "" + params.path)
    end function
commandManager.register(_cmd)

// --- touch ---
_cmd = new Command
_cmd.name = ""touch""
_cmd.description = ""Create an empty file""
_cmd.parameters = [StringParameter.New({""name"": ""path"", ""required"": true})]
_cmd.permissions = {}
_cmd.permissions.object = ""computer""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        sessionManager = mediator.getExtension(""sessionManager"")
