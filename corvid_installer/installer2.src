// --- hack ---
_cmd = new Command
_cmd.name = ""hack""
_cmd.description = ""Scan and immediately exploit best result on target IP:port""
_cmd.parameters = [StringParameter.New({""name"": ""ip"",   ""required"": true}),StringParameter.New({""name"": ""port"", ""required"": true}),StringParameter.New({""name"": ""lanip"",    ""required"": false, ""default"": ""unknown""}),StringParameter.New({""name"": ""routerip"", ""required"": false, ""default"": ""unknown""})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        ui            = mediator.getExtension(""corvidUi"")
        attackManager = mediator.getExtension(""attackManager"")

        // Auto-whois if enabled
        configManager = mediator.getExtension(""configManager"")
        autoWhois     = configManager.get(""autoWhois"")
        if not (autoWhois isa Error) and autoWhois then
            intelManager = mediator.getExtension(""intelManager"")
            intelManager.harvestWhois(params.ip)
        end if

        ui.info(""Scanning "" + params.ip + "":"" + str(params.port.val) + ""..."")
        scanResults = attackManager.runScan(params.ip, params.port.val, params.lanip, params.routerip)
        if scanResults isa Error then
            return scanResults
        end if
        ui.exploitResults(scanResults)

        ui.info(""Exploiting best result..."")
        result = attackManager.exploit(params.ip, params.port.val, params.lanip, params.routerip, null)
        if result isa Error then
            return result
        end if
    end function
commandManager.register(_cmd)

