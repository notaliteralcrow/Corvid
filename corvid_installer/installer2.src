\\ndrizzt\\nmadness\\nenergy\\nkinky\\n314159\\nsophia\\nstefan\\nslick\\nrocker\\n55555555\\n\"s16 = \"freeman\\nfrench\\nmongoose\\nspeed\\ndddddd\\nhong\\nhenry\\nhungry\\nyang\\ncatdog\\ncheng\\nghost\\ngogogo\\nrandy\\ntottenha\\ncurious\\nbutterfl\\nmission\\njanuary\\nsinger\\nsherman\\nshark\\ntechno\\nlancer\\nlalala\\nautumn\\nchichi\\norion\\ntrixie\\nclifford\\ndelta\\nbobbob\\nbomber\\nholden\\nkang\\nkiss\\n1968\\nspunky\\nliquid\\nmary\\nbeagle\\ngranny\\nnetwork\\nbond\\nkkkkkk\\nmillie\\n1973\\nbiggie\\nbeetle\\nteacher\\nsusan\\ntoronto\\nanakin\\ngenius\\ndream\\ndang\\nbush\"samples_str = s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10 + s11 + s12 + s13 + s14 + s15 + s16\" + char(10) + \"samples = samples_str.split(\"\\n\")\n\n// ChainSaw - A Grey Hack script for cracking passwords using Markov chains\n// by NitroCynic\n// License: MIT - https://github.com/jwfraustro/chainsaw/blob/main/LICENSE\n\nversion = \"1.0.0\"in_script = false\" + char(10) + \"if get_custom_object.hasIndex(\"in_script\") then\n	in_script = get_custom_object.in_script\nend if\n\nnl = char(10)\nlogo_str = \"   _____ _           _        _____\" + nl\nlogo_str = logo_str + \"  / ____| |         (_)      / ______| \" + nl\nlogo_str = logo_str + \" | |    | |__   __ _ _ _ __ | (___   __ ___      __\" + nl\nlogo_str = logo_str + \" | |    | '_ \\ / _` | | '_ \\ \\___ \\ / _` \\ \\ /\\ / /\" + nl\nlogo_str = logo_str + \" | |____| | | | (_| | | | | |____) | (_| |\\ V  V /\" + nl\nlogo_str = logo_str + \"  \\_____| |_|\\__,_|_|_| |_|_____/ \\__,_| \\_/\\_/\" + nl\nlogo_str = logo_str + \"ChainSaw - by NitroCynic - The Markov Chain Password Cracker v\" + version + \"\\n\"logo_str = logo_str + \"Source at: https://github.com/jwfraustro/chainsaw/ \\n\" //no-format\n\nalpha = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\"alpha = alpha + alpha.lower\" + char(10) + \"testing = false\" + char(10) + \"testing_pass = \"Dessnap\"unit_test = false // Set to true to run unit tests\" + char(10) + \"list.unique = function\" + char(10) + \"	// Remove duplicates from an array\" + char(10) + \"	unique_array = []\" + char(10) + \"	for item in self\" + char(10) + \"		if unique_array.indexOf(item) == null then\" + char(10) + \"			unique_array.push(item)\" + char(10) + \"		end if\" + char(10) + \"	end for\" + char(10) + \"	return unique_array\" + char(10) + \"end function\" + char(10) + \"ChainSaw = {}\" + char(10) + \"// Target parameters\" + char(10) + \"ChainSaw.user = \"root\"ChainSaw.ip = \"\"ChainSaw.port = 22\" + char(10) + \"ChainSaw.password = \"\"ChainSaw.shell = null\" + char(10) + \"// Markov chain parameters\" + char(10) + \"ChainSaw.origin_shell = null\" + char(10) + \"ChainSaw.samples = samples\" + char(10) + \"ChainSaw.pregens = pregens\" + char(10) + \"ChainSaw.chains = {}\" + char(10) + \"ChainSaw.trigram_frequencies = {}\" + char(10) + \"ChainSaw.optimize_chains = false // potential optimzation by sorting trigrams by frequency\" + char(10) + \"ChainSaw.min_length = 3\" + char(10) + \"ChainSaw.max_length = 9\" + char(10) + \"ChainSaw.order = 3\" + char(10) + \"// Misc. parameters\" + char(10) + \"ChainSaw.LogLevel = \"INFO\"ChainSaw.version = version\" + char(10) + \"// Internal parameters & defaults\" + char(10) + \"ChainSaw.attempts = 0\" + char(10) + \"ChainSaw._logLevels = {\" + char(10) + \"	\"DEBUG\": 0,\n	\"INFO\": 1,\n	\"WARN\": 2,\n	\"ERROR\": 3,\n}\n\nChainSaw.Log = function(level, message)\n\n	// Log messages to the console\n	if ChainSaw._logLevels[level] >= ChainSaw._logLevels[ChainSaw.LogLevel] then\n		out_str = \"[ChainSaw] [\" + level + \"] \" + message\n		if level == \"ERROR\" then\n			print(\"<color=red>\" + out_str + \"</color>\")\n		else if level == \"WARN\" then\n			print(\"<color=yellow>\" + out_str + \"</color>\")\n		else\n			print(out_str)\n		end if\n	end if\nend function\n\nChainSaw.init = function // Initialize ChainSaw\n\n	ChainSaw.load_samples\n	ChainSaw.load_pregens\n	ChainSaw.load_chains\n	if ChainSaw.optimize_chains then\n		ChainSaw.Log(\"DEBUG\", \"Optimizing chains by frequency...\")\n		ChainSaw.sort_chains_by_frequency\n	end if\n\nend function\n\nChainSaw.load_chains = function // Build the Markov chains from the given samples\n	ChainSaw.Log(\"DEBUG\", \"Building Markov chains...\")\n	// Create chains\n	for text in ChainSaw.samples\n		for i in range(0, text.len - ChainSaw.order - 1)\n			sub_text = text[i : i + ChainSaw.order]\n\n			if not ChainSaw.chains.hasIndex(sub_text) then\n				ChainSaw.chains[sub_text] = []\n			end if\n\n			next_char = text[i + ChainSaw.order]\n\n			// Nexchars are made unique here for cracking purposes,\n			// but for generating passwords, they should have duplicates\n			// for frequency probability.\n			if ChainSaw.chains[sub_text].indexOf(next_char) == null then\n				ChainSaw.chains[sub_text].push(next_char)\n			end if\n\n		end for\n	end for\n	ChainSaw.Log(\"DEBUG\", ChainSaw.chains.len + \" chains created.\")\nend function\n\nChainSaw.load_samples = function // Build the Markov samples from the given text\n\n	ChainSaw.Log(\"DEBUG\", \"Building samples...\")\n	ChainSaw.Log(\"DEBUG\", \"Using \" + ChainSaw.samples.len + \" password samples.\")\n	samples = ChainSaw.samples\n\n	// Clear the samples\n	ChainSaw.samples = []\n\n	// Initialize samples, excluding any that are too short for the given order\n	for text in samples\n		if text.len >= ChainSaw.order + 1 then\n			ChainSaw.samples.push(text.upper)\n		else\n			ChainSaw.Log(\"WARN\", \"Sample '\" + text + \"' is too short for given order \" + ChainSaw.order + \".\")\n		end if\n	end for\n\n	ChainSaw.Log(\"DEBUG\", ChainSaw.samples.len + \" samples loaded.\")\nend function\n\nChainSaw.calculate_trigram_frequencies = function()\n    // Calculate how often each trigram appears in samples\n    ChainSaw.Log(\"DEBUG\", \"Calculating trigram frequencies...\")\n\n    frequencies = {}\n\n    for sample in ChainSaw.samples\n        for i in range(0, sample.len - ChainSaw.order - 1)\n            trigram = sample[i : i + ChainSaw.order]\n\n            if not frequencies.hasIndex(trigram) then\n                frequencies[trigram] = 0\n            end if\n\n            frequencies[trigram] = frequencies[trigram] + 1\n        end for\n    end for\n\n    ChainSaw.trigram_frequencies = frequencies\n    ChainSaw.Log(\"DEBUG\", \"Calculated frequencies for \" + frequencies.len + \" trigrams\")\nend function\n\nChainSaw.sort_chains_by_frequency = function()\n    // Sort chain indexes by frequency (most common first)\n    ChainSaw.Log(\"DEBUG\", \"Sorting chains by frequency...\")\n\n    if ChainSaw.trigram_frequencies == null then\n        ChainSaw.calculate_trigram_frequencies\n    end if\n\n    // Create sortable array\n    sortable = []\n    for trigram in ChainSaw.chains.indexes\n        freq = 0\n        if ChainSaw.trigram_frequencies.hasIndex(trigram) then\n            freq = ChainSaw.trigram_frequencies[trigram]\n        end if\n\n        sortable.push({\"trigram\": trigram, \"frequency\": freq})\n    end for\n\n    // Sort by frequency (descending)\n    sortable = ChainSaw.sort_by_frequency(sortable)\n\n    // Replace chain indexes with sorted version\n    sorted_indexes = []\n    for item in sortable\n        sorted_indexes.push(item.trigram)\n    end for\n\n    ChainSaw.chains.indexes = sorted_indexes\n    ChainSaw.Log(\"DEBUG\", \"Chains sorted by frequency\")\nend function\n\nChainSaw.sort_by_frequency = function(arr)\n    // Bubble sort by frequency (descending)\n    n = arr.len\n    for i in range(0, n - 2)\n        for j in range(0, n - i - 2)\n            if arr[j].frequency < arr[j + 1].frequency then\n                temp = arr[j]\n                arr[j] = arr[j + 1]\n                arr[j + 1] = temp\n            end if\n        end for\n    end for\n    return arr\nend function\n\nChainSaw.load_pregens = function // Load the pregenerated passwords\n\n	ChainSaw.Log(\"DEBUG\", \"Loading pregenerated passwords...\")\n	ChainSaw.Log(\"DEBUG\", \"Using \" + ChainSaw.pregens.len + \" pregenerated passwords.\")\n	pregens = ChainSaw.pregens\n\n	// Clear the pregens\n	ChainSaw.pregens = []\n\n	// Initialize pregens, excluding any that are too short for the minimum password length\n	for text in pregens\n		if text.len >= ChainSaw.min_length and text.len <= ChainSaw.max_length then\n			ChainSaw.pregens.push(text)\n		else\n			ChainSaw.Log(\"WARN\", \"Pregenerated password '\" + text + \"' not within min/max length boundaries: \" + ChainSaw.min_length + \" - \" + ChainSaw.max_length + \".\")\n		end if\n	end for\n\nend function\n\n\nChainSaw.connect = function(password) // Connect to the specified service, or the local shell\n\n	if testing then\n		// If testing, use the test password\n		if password == testing_pass then\n			return \"shell\"		end if\" + char(10) + \"		return null\" + char(10) + \"	end if\" + char(10) + \"	// Connect to the service, either the local shell or a remote service\" + char(10) + \"	if ChainSaw.ip != \"\" and ChainSaw.port != null then\n		originShell = null\n		if ChainSaw.hasIndex(\"origin_shell\") and ChainSaw.origin_shell != null then\n			originShell = ChainSaw.origin_shell\n		else\n			originShell = get_shell\n		end if\n		return originShell.connect_service(\n			ChainSaw.ip,\n			ChainSaw.port,\n			ChainSaw.user,\n			password)\n	else\n		return get_shell(ChainSaw.user, password)\n	end if\n\n	return null\nend function\n\nChainSaw.next_name = function // Generate a random name using the Markov chains\n\n	text = \"\"	num = floor(805)\" + char(10) + \"	desired_len = ChainSaw.samples[num].len\" + char(10) + \"	start_idx = floor(rnd * (desired_len - ChainSaw.order))\" + char(10) + \"	text = ChainSaw.samples[num][start_idx : start_idx + ChainSaw.order]\" + char(10) + \"	while text.len < desired_len\" + char(10) + \"		start_idx = text.len - ChainSaw.order\" + char(10) + \"		sub_text = text[start_idx : start_idx + ChainSaw.order]\" + char(10) + \"		if ChainSaw.get_letter(sub_text) == \"?\" then\n			break\n		end if\n\n		text = \"\" + text + ChainSaw.get_letter(sub_text)\n\n	end while\n\n	text = text.lower\n\n	print(\"Generated password: \" + text)\n\n	return text\n\nend function\n\nChainSaw.get_letter = function(token)\n	// Get the next letter in the chain for the given token\n	if not ChainSaw.chains.hasIndex(token) then\n		return \"?\"	end if\" + char(10) + \"	next_chars = ChainSaw.chains[token]\" + char(10) + \"	num = floor(rnd * next_chars.len)\" + char(10) + \"	return next_chars[num]\" + char(10) + \"end function\" + char(10) + \"ChainSaw.recurse = function(token, max_length) // Recursively generate passwords using the Markov chains\" + char(10) + \"	// Recursivly generate passwords\" + char(10) + \"	password = token.lower\" + char(10) + \"	result = ChainSaw.connect(password)\" + char(10) + \"	ChainSaw.attempts = ChainSaw.attempts + 1 + 0 // prevent autoformat\" + char(10) + \"	if typeof(result) == \"shell\" then\n		print(\"<b>[ChainSaw] Password found: \" + password + \"</b>\")\n		ChainSaw.set_password(password)\n		return result\n	else\n		upper_first_char = password[0].upper + password[1 : password.len]\n		result = ChainSaw.connect(upper_first_char)\n		ChainSaw.attempts = ChainSaw.attempts + 1 + 0 // prevent autoformat\n		if typeof(result) == \"shell\" then\n			print(\"<b>[ChainSaw] Password found: \" + upper_first_char + \"</b>\")\n			ChainSaw.set_password(upper_first_char)\n			return result\n		end if\n	end if\n\n	if token.len >= max_length then\n		return null\n	end if\n\n	// get the index of the last token in the password\n	start_idx = token.len - ChainSaw.order\n	sub_text = token[start_idx : start_idx + ChainSaw.order]\n\n	// get the unique transitions for the last token\n	// and generate a new password using the last token and the next letter\n	if not ChainSaw.chains.hasIndex(sub_text) then\n		return null\n	end if\n\n	next_chars = ChainSaw.chains[sub_text]\n	for next_char in next_chars\n		new_password = token + next_char\n		result = ChainSaw.recurse(new_password, max_length)\n\n		if typeof(result) == \"shell\" then\n			return result\n		end if\n	end for\nend function\n\nChainSaw.PregenAttack = function // Use pregenerated passwords to crack the password\n\n	ChainSaw.Log(\"INFO\", \"Attacking with pregenerated passwords...\")\n	for password in ChainSaw.pregens\n		result = ChainSaw.connect(password)\n		ChainSaw.attempts = ChainSaw.attempts + 1 + 0 // prevent autoformat\n		if typeof(result) == \"shell\" then\n			print(\"<b>[ChainSaw] Password found: \" + password + \"</b>\")\n			ChainSaw.set_password(password)\n			return result\n		else\n			upper_first_char = password[0].upper + password[1 : password.len]\n			result = ChainSaw.connect(upper_first_char)\n			ChainSaw.attempts = ChainSaw.attempts + 1 + 0 // prevent autoformat\n			if typeof(result) == \"shell\" then\n				print(\"<b>[ChainSaw] Password found: \" + upper_first_char + \"</b>\")\n				ChainSaw.set_password(upper_first_char)\n				return result\n			end if\n		end if\n	end for\n\n	return null\nend function\n\nChainSaw.crack = function(show_logo = true) // Determine an unknown password using the markov chains\n\n	if show_logo then\n		ChainSaw.Log(\"INFO\", logo_str)\n\n		ChainSaw.Log(\"INFO\", \"VROOM!....\")\n	end if\n	start_time = time\n\n	// Try the pregenerated passwords first\n	result = ChainSaw.PregenAttack\n	if typeof(result) == \"shell\" then\n		ChainSaw.set_result(result)\n		ChainSaw.Log(\"DEBUG\", \"Evaluated \" + ChainSaw.attempts + \" passwords.\")\n		ChainSaw.Log(\"DEBUG\", \"Execution time: \" + (time - start_time) + \" seconds\")\n		return result\n	end if\n\n	ChainSaw.Log(\"INFO\", \"No pregenerated passwords found.\")\n	ChainSaw.Log(\"INFO\", \"Attacking with markov chains...\")\n	if ChainSaw.chains.len == 0 then\n		ChainSaw.Log(\"INFO\", \"No Markov chain data available (samples not loaded).\")\n		return null\n	end if\n	for i in range(0, ChainSaw.chains.indexes.len - 1)\n		token = ChainSaw.chains.indexes[i]\n		result = ChainSaw.recurse(token, ChainSaw.max_length)\n		if typeof(result) == \"shell\" then\n			ChainSaw.set_result(result)\n			ChainSaw.Log(\"DEBUG\", \"Evaluated \" + ChainSaw.attempts + \" passwords.\")\n			ChainSaw.Log(\"DEBUG\", \"Execution time: \" + (time - start_time) + \" seconds\")\n			return result\n		end if\n\n	end for\n\nend function\n\n// CLI runner removed - Corvid uses ChainSaw via direct method calls only\n",1)
