// --- creds ---
_cmd = new Command
_cmd.name = ""creds""
_cmd.description = ""List credentials for current session. Use 'creds all' to show all, or filter by type/term.""
_cmd.parameters = [StringParameter.New({""name"": ""term"", ""required"": false, ""default"": """"}),OptionsParameter.New({""name"": ""type"", ""required"": false, ""default"": """",""options"": {""system"": ""system"", ""mail"": ""mail"", ""bank"": ""bank"", ""all"": """"}})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
    ui             = mediator.getExtension(""corvidUi"")
    dbManager      = mediator.getExtension(""databaseManager"")
    sessionManager = mediator.getExtension(""sessionManager"")

    showAll = params.term.trim.lower == ""all"" or params.type.trim.lower == ""all""

    if showAll then
        // creds all - show everything
        if params.type.len > 0 and params.type != ""all"" then
            results = dbManager.findCredentialsByType(params.type)
        else if params.term.len > 0 and params.term != ""all"" then
            results = dbManager.findCredentials(params.term)
        else
            results = dbManager.allCredentials()
        end if
        ui.info(""All credentials ("" + str(results.len) + "" total):"")
    else
        // Default: filter to current session PUBLIC IP only
        // Deliberately exclude LAN IP - LAN subnets are shared across many machines
        // and would cause creds from other sessions to bleed in
        sessionIp = sessionManager.currentSession.data.ip.public
        if params.type.len > 0 then
            allOfType = dbManager.findCredentialsByType(params.type)
            results = []
            for cr in allOfType
                crIp = """"
                if cr.hasIndex(""public_ip"") then
                    crIp = cr.public_ip
                end if
                if crIp == sessionIp then
                    results.push(cr)
                end if
            end for
        else if params.term.len > 0 then
            results = dbManager.findCredentials(params.term)
        else
            results = dbManager.findCredentialsByIp(sessionIp)
        end if
        ui.info(""Credentials for "" + sessionIp + "" (use 'creds all' for full DB):"")
    end if

    if results.len == 0 then
        ui.warning(""No credentials found"")
        return
    end if
    ui.credentials(results)
end function
commandManager.register(_cmd)

