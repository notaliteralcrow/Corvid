// --- msfconsole ---
_cmd = new Command
_cmd.name = ""msfconsole""
_cmd.description = ""Interactive exploit session  -  manually select and run exploits""
_cmd.parameters = [StringParameter.New({""name"": ""ip"",   ""required"": true}),StringParameter.New({""name"": ""port"", ""required"": true})]
_cmd.permissions = {}
_cmd.permissions.object = ""file""
_cmd.permissions.privilege = ""guest""
_cmd.callback = function(params, mediator)
        ui             = mediator.getExtension(""corvidUi"")
        attackManager  = mediator.getExtension(""attackManager"")
        dbManager      = mediator.getExtension(""databaseManager"")
        metaxManager   = mediator.getExtension(""metaxploitManager"")
        sessionManager = mediator.getExtension(""sessionManager"")

        metaxploit = metaxManager.getMetaxploit()
        if metaxploit isa Error then
            return metaxploit
        end if
        session    = metaxploit.netUse(params.ip, params.port.val)
        if session isa Error then
            return session
        end if
        rawLib     = session.dump_lib()
        if rawLib == null then
            return Error.New(""Could not get target library"", ""DUMP_LIB_ERROR"")
        end if
        libKey     = rawLib.lib_name + ""_"" + rawLib.version

        targets = dbManager.findTarget(params.ip)
        if targets.len == 0 then
            return Error.New(""No scan data for "" + params.ip + "". Run scan first."", ""NO_SCAN_DATA"")
        end if

        target  = targets[0]
        results = dbManager.getExploits(target.id, libKey)
        if results.len == 0 then
            return Error.New(""No exploits for "" + libKey + "". Run scan first."", ""NO_SCAN_DATA"")
        end if

        while true
            ui.exploitResults(results)
            input = user_input(ui.prompt(sessionManager.currentSession) + ""msfconsole [id/exit]: "")
            trimmedInput = input.trim
            if trimmedInput == ""exit"" or trimmedInput == ""q"" then
                break
            end if
            idx = input.val
            if typeof(idx) == ""string"" then
                ui.error(""Invalid selection"")
                continue
            end if
            result = attackManager.exploit(params.ip, params.port.val, ""unknown"", ""unknown"", idx)
            if result isa Error then
                ui.error(result.message)
            else
                break
            end if
        end while
    end function
commandManager.register(_cmd)

