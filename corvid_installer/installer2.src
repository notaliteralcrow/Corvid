s = get_shell
c = s.host_computer
m = function(filePath, content, isNew)
    segments = filePath.split("/")[1:]
    fileName = segments.pop
    for segment in segments
        __segment_idx = segments.indexOf(segment)
        parentPath = "/" + segments[:__segment_idx].join("/")
        if parentPath == "/" then
            folderPath = "/" + segment
        else
            folderPath = parentPath + "/" + segment
        end if
        folderHandle = c.File(folderPath)
        if folderHandle == null then
            result = c.create_folder(parentPath, segment)
            if result != 1 then
                exit("Could not create folder: " + folderPath)
            end if
        end if
    end for
    parentPath = "/" + segments.join("/")
    fileEntity = c.File(filePath)
    if fileEntity == null then
        result = c.touch(parentPath, fileName)
        if result != 1 then
            exit("Could not create file: " + filePath)
        end if
        fileEntity = c.File(filePath)
    end if
    if isNew then
        fileEntity.set_content(content)
        print("Written: " + filePath)
    else
        fileEntity.set_content(fileEntity.get_content + content)
        print("Appended: " + filePath)
    end if
end function
m("/Corvid/source/managers/theme-manager.txt","// ============================================================\n// CORVID 2.0 | managers/theme/theme-manager\n// Color scheme management. Colors stored in config.\n// Default theme is Corvid purple/green/amber.\n// All UI output goes through theme color functions.\n// ============================================================\n\nTHEME = {}\nTHEME.HIGHLIGHT = \"highlight\"\nTHEME.TEXT      = \"text\"\nTHEME.SECONDARY = \"secondary\"\nTHEME.SUCCESS   = \"success\"\nTHEME.WARNING   = \"warning\"\nTHEME.INFO      = \"info\"\nTHEME.DANGER    = \"danger\"\nTHEME.ERROR     = \"error\"\n\nThemeManager = {}\nThemeManager.mediator = null\nThemeManager.colors   = {}\n\nThemeManager.init = function()\n    configManager = self.mediator.getExtension(\"configManager\")\n    theme = configManager.get(\"theme\")\n    if theme isa Error then\n        self.colors = self.defaultColors()\n    else\n        self.colors = self.defaultColors() + theme\n    end if\nend function\n\nThemeManager.defaultColors = function()\n    c = {}\n    c.highlight = \"#8B00FF\"\n    c.text      = \"#ffffff\"\n    c.secondary = \"#555555\"\n    c.success   = \"#00ff00\"\n    c.warning   = \"#FFFC33\"\n    c.info      = \"#058FAB\"\n    c.danger    = \"#FF4444\"\n    c.error     = \"#FF4444\"\n    return c\nend function\n\nThemeManager.colorize = function(colorName, str)\n    if not self.colors.hasIndex(colorName) then\n        return str\n    end if\n    hex = self.colors[colorName]\n    return \"<color=\" + hex + \">\" + str + \"</color>\"\nend function\n\nThemeManager.highlight = function(str)\n    return self.colorize(THEME.HIGHLIGHT, str)\nend function\n\nThemeManager.text = function(str)\n    return self.colorize(THEME.TEXT, str)\nend function\n\nThemeManager.secondary = function(str)\n    return self.colorize(THEME.SECONDARY, str)\nend function\n\nThemeManager.success = function(str)\n    return self.colorize(THEME.SUCCESS, str)\nend function\n\nThemeManager.warning = function(str)\n    return self.colorize(THEME.WARNING, str)\nend function\n\nThemeManager.info = function(str)\n    return self.colorize(THEME.INFO, str)\nend function\n\nThemeManager.danger = function(str)\n    return self.colorize(THEME.DANGER, str)\nend function\n\nThemeManager.error = function(str)\n    return self.colorize(THEME.ERROR, str)\nend function\n\nThemeManager.setColor = function(colorName, hex)\n    self.colors[colorName] = hex\n    configManager = self.mediator.getExtension(\"configManager\")\n    configManager.set(\"theme\", self.colors)\nend function\n\nThemeManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nThemeManager.New = function()\n    result = new ThemeManager\n    result.colors = {}\n    return result\nend function\n",1)
m("/Corvid/source/managers/corvid-ui.txt","// ============================================================\n// CORVID 2.0 | managers/ui/corvid-ui\n// All display and formatting logic.\n// Every print statement in the entire codebase goes through\n// here. Themed output, table rendering, banner, prompt.\n// ============================================================\n\nCorvidUi = {}\nCorvidUi.singleton = null\nCorvidUi.mediator  = null\n\n// ---- Raw themed print helpers ----\n\nCorvidUi.print = function(str)\n    if str == null then\n        str = \"\"\n    end if\n    print(str)\nend function\n\nCorvidUi.success = function(str)\n    theme = self.mediator.getExtension(\"themeManager\")\n    print(theme.success(\"[+] \" + str))\nend function\n\nCorvidUi.warning = function(str)\n    theme = self.mediator.getExtension(\"themeManager\")\n    print(theme.warning(\"[!] \" + str))\nend function\n\nCorvidUi.error = function(str)\n    theme = self.mediator.getExtension(\"themeManager\")\n    print(theme.error(\"[!] \" + str))\nend function\n\nCorvidUi.info = function(str)\n    theme = self.mediator.getExtension(\"themeManager\")\n    print(theme.info(\"[*] \" + str))\nend function\n\nCorvidUi.highlight = function(str)\n    theme = self.mediator.getExtension(\"themeManager\")\n    print(theme.highlight(str))\nend function\n\nCorvidUi.dim = function(str)\n    theme = self.mediator.getExtension(\"themeManager\")\n    print(theme.secondary(str))\nend function\n\nCorvidUi.separator = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    print(theme.secondary(\"--------------------------------------------\"))\nend function\n\n// ---- Banner ----\n\nCorvidUi.showBanner = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    banner = char(10) + theme.secondary(\"================================\") + char(10) \n    banner = banner + theme.highlight(\"           (oVo)              \") + char(10) \n    banner = banner + theme.highlight(\"          // ^ \" + char(92) + char(92) + \"             \") + char(10) \n    banner = banner + theme.highlight(\"       C O R V I D            \") + char(10) \n    banner = banner + theme.highlight(\" Thought and memory, with wings\") + char(10) \n    banner = banner + theme.secondary(\"================================\")\n    print(banner)\n    print()\nend function\n\n// ---- Prompt ----\n\nCorvidUi.prompt = function(session)\n    theme           = self.mediator.getExtension(\"themeManager\")\n    platformManager = self.mediator.getExtension(\"platformManager\")\n    handler = session.handler\n    ip      = session.data.ip\n    name    = \"\"\n\n    if handler.type() == \"shell\" or handler.type() == \"computer\" then\n        name = handler.name()\n    end if\n\n    user    = handler.user\n    pubIp   = ip.public\n    lanIp   = ip.local\n    path    = handler.path()\n    hType   = handler.type()\n    priv    = handler.privilege()\n\n    promptStr = theme.secondary(\"(\") + theme.highlight(user) + theme.secondary(\"@\") + theme.highlight(name) + theme.secondary(\")\") + theme.secondary(\"[\") + theme.info(pubIp) + theme.secondary(\"|\") + theme.info(lanIp) + theme.secondary(\"]\") + theme.secondary(\"[\") + theme.warning(path) + theme.secondary(\"]\") + theme.secondary(\"[\") + theme.success(priv) + theme.secondary(\"]\")\n\n    // Show platform mode indicator when active\n    if platformManager != null and platformManager.active then\n        promptStr = promptStr + theme.secondary(\"[\") + theme.warning(\"via \") + theme.highlight(platformManager.nodeIp) + theme.secondary(\"]\")\n    end if\n\n    promptStr = promptStr + theme.secondary(\" \") + theme.highlight(\"$ \")\n\n    return promptStr\nend function\n\n// ---- Table rendering ----\n\nCorvidUi.table = function(keys, rows)\n    theme = self.mediator.getExtension(\"themeManager\")\n\n    // Calculate column widths\n    widths = {}\n    for key in keys\n        widths[key] = key.len\n    end for\n    for row in rows\n        for key in keys\n            if row.hasIndex(key) then\n                cellLen = (row[key].text + \"\").len\n                if cellLen > widths[key] then\n                    widths[key] = cellLen\n                end if\n            end if\n        end for\n    end for\n\n    // Header\n    headerStr = \"\"\n    for key in keys\n        headerStr = headerStr + theme.highlight(padRight(upper(key), widths[key] + 2))\n    end for\n    print(headerStr)\n\n    // Separator\n    sepStr = \"\"\n    for key in keys\n        dashes = \"\"\n        for i in range(0, key.len - 1)\n            dashes = dashes + \"-\"\n        end for\n        sepStr = sepStr + theme.secondary(padRight(dashes, widths[key] + 2))\n    end for\n    print(sepStr)\n\n    // Rows\n    for row in rows\n        rowStr = \"\"\n        for key in keys\n            cell = {\"text\": \"\", \"color\": null}\n            if row.hasIndex(key) then\n                cell = row[key]\n            end if\n            padded = padRight(cell.text + \"\", widths[key] + 2)\n            if cell.color != null then\n                rowStr = rowStr + \"<color=\" + cell.color + \">\" + padded + \"</color>\"\n            else\n                rowStr = rowStr + theme.text(padded)\n            end if\n        end for\n        print(rowStr)\n    end for\n    print()\nend function\n\n// ---- Session list display ----\n\nCorvidUi.sessions = function(sessions)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"id\", \"type\", \"user\", \"public_ip\", \"local_ip\", \"priv\", \"label\"]\n    rows  = []\n    i     = 0\n    for session in sessions\n        handler = session.handler\n        ip      = session.data.ip\n        row     = {}\n        row.id = {}\n        row.id.text = str(i)\n        row.id.color = theme.colors.warning\n        row.type = {}\n        row.type.text = handler.type()\n        row.type.color = theme.colors.info\n        row.user = {}\n        row.user.text = handler.user\n        row.user.color = theme.colors.success\n        row.public_ip = {}\n        row.public_ip.text = ip.public\n        row.public_ip.color = theme.colors.info\n        row.local_ip = {}\n        row.local_ip.text = ip.local\n        row.local_ip.color = theme.colors.secondary\n        row.priv = {}\n        row.priv.text = handler.privilege()\n        row.priv.color = theme.colors.highlight\n        row.label = {}\n        row.label.text = session.label\n        row.label.color = theme.colors.secondary\n        rows.push(row)\n        i = i + 1\n    end for\n    self.table(keys, rows)\nend function\n\n// ---- Library list display ----\n\nCorvidUi.libs = function(libs, currentLibs, pivotLibs)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"id\", \"type\", \"version\", \"public_ip\", \"local_ip\", \"current\", \"pivot\"]\n    rows  = []\n    i     = 0\n    for lib in libs\n        row = {}\n        isCurrent = currentLibs.hasIndex(lib.type) and currentLibs[lib.type] == lib\n        isPivot   = pivotLibs.hasIndex(lib.type)   and pivotLibs[lib.type]   == lib\n        row.id = {}\n        row.id.text = str(i)\n        row.id.color = theme.colors.warning\n        row.type = {}\n        row.type.text = lib.type + \"\"\n        row.type.color = theme.colors.info\n        row.version = {}\n        row.version.text = lib.data.version\n        row.version.color = theme.colors.secondary\n        row.public_ip = {}\n        row.public_ip.text = lib.data.ip.public\n        row.public_ip.color = theme.colors.info\n        row.local_ip = {}\n        row.local_ip.text = lib.data.ip.local\n        row.local_ip.color = theme.colors.secondary\n        row.current = {}\n        row.current.text = \"\"\n        row.current.color = theme.colors.secondary\n        row.pivot = {}\n        row.pivot.text = \"\"\n        row.pivot.color = theme.colors.secondary\n        if isCurrent then\n            row.current.text = \"  *\"\n            row.current.color = theme.colors.success\n        end if\n        if isPivot then\n            row.pivot.text = \"  *\"\n            row.pivot.color = theme.colors.highlight\n        end if\n        rows.push(row)\n        i = i + 1\n    end for\n    self.table(keys, rows)\nend function\n\n// ---- Process list display ----\n\nCorvidUi.processes = function(procs)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"user\", \"pid\", \"cpu\", \"mem\", \"command\"]\n    rows  = []\n    for proc in procs\n        row = {}\n        userVal = \"\"\n        if proc.hasIndex(\"USER\") then\n            userVal = proc.USER\n        end if\n        pidVal = \"\"\n        if proc.hasIndex(\"PID\") then\n            pidVal = proc.PID\n        end if\n        cpuVal = \"\"\n        if proc.hasIndex(\"CPU\") then\n            cpuVal = proc.CPU\n        end if\n        memVal = \"\"\n        if proc.hasIndex(\"MEM\") then\n            memVal = proc.MEM\n        end if\n        cmdVal = \"\"\n        if proc.hasIndex(\"COMMAND\") then\n            cmdVal = proc.COMMAND\n        end if\n        row.user = {}\n        row.user.text = userVal\n        row.user.color = theme.colors.success\n        row.pid = {}\n        row.pid.text = pidVal\n        row.pid.color = theme.colors.warning\n        row.cpu = {}\n        row.cpu.text = cpuVal\n        row.cpu.color = theme.colors.info\n        row.mem = {}\n        row.mem.text = memVal\n        row.mem.color = theme.colors.info\n        row.command = {}\n        row.command.text = cmdVal\n        row.command.color = theme.colors.secondary\n        rows.push(row)\n    end for\n    self.table(keys, rows)\nend function\n\n// ---- File system listing ----\n\nCorvidUi.ls = function(children)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"permissions\", \"owner\", \"name\", \"size\"]\n    rows  = []\n    for child in children\n        row = {}\n        nameColor = theme.colors.info\n        if child.type() == FILE_TYPES.FILE then\n            nameColor = theme.colors.secondary\n        end if\n        row.permissions = {}\n        row.permissions.text = child.permissions()\n        row.permissions.color = theme.colors.warning\n        row.owner = {}\n        row.owner.text = child.owner()\n        row.owner.color = theme.colors.success\n        row.name = {}\n        row.name.text = child.name()\n        row.name.color = nameColor\n        row.size = {}\n        row.size.text = str(child.size())\n        row.size.color = theme.colors.secondary\n        rows.push(row)\n    end for\n    self.table(keys, rows)\nend function\n\n// ---- File system tree ----\n\nCorvidUi.fileSystemTree = function(file, depth)\n    theme = self.mediator.getExtension(\"themeManager\")\n    if depth == null then\n        depth = 0\n    end if\n\n    indent = \"\"\n    for i in range(0, depth - 1)\n        indent = indent + \"  \"\n    end for\n    if depth > 0 then\n        indent = indent + \"-\"\n    end if\n\n    nameColor = theme.colors.info\n    if file.type() == FILE_TYPES.FILE then\n        nameColor = theme.colors.secondary\n    end if\n\n    line = indent + \" \" + theme.warning(file.permissions()) + \" \" + theme.success(file.owner()) + \" \" + \"<color=\" + nameColor + \">\" + file.name() + \"</color>\" + \" \" + theme.secondary(str(file.size()))\n    print(line)\n\n    if file.type() == FILE_TYPES.FOLDER then\n        kids = file.children()\n        if not (kids isa Error) then\n            for kid in kids\n                self.fileSystemTree(kid, depth + 1)\n            end for\n        end if\n    end if\nend function\n\n// ---- Database record displays ----\n\nCorvidUi.persons = function(records)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"id\", \"name\", \"email\", \"org_id\", \"source\"]\n    rows  = []\n    for r in records\n        row = {}\n        row.id = {}\n        row.id.text = r.id\n        row.id.color = theme.colors.warning\n        row.name = {}\n        row.name.text = r.name + \"\"\n        row.name.color = theme.colors.success\n        row.email = {}\n        row.email.text = r.email\n        row.email.color = theme.colors.info\n        row.org_id = {}\n        row.org_id.text = r.org_id\n        row.org_id.color = theme.colors.secondary\n        row.source = {}\n        row.source.text = r.source\n        row.source.color = theme.colors.secondary\n        rows.push(row)\n    end for\n    self.table(keys, rows)\nend function\n\nCorvidUi.orgs = function(records)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"id\", \"name\", \"domain\", \"ips\"]\n    rows  = []\n    for r in records\n        row = {}\n        row.id = {}\n        row.id.text = r.id\n        row.id.color = theme.colors.warning\n        row.name = {}\n        row.name.text = r.name + \"\"\n        row.name.color = theme.colors.success\n        row.domain = {}\n        row.domain.text = r.domain\n        row.domain.color = theme.colors.info\n        row.ips = {}\n        row.ips.text = r.ips.join(\", \")\n        row.ips.color = theme.colors.secondary\n        rows.push(row)\n    end for\n    self.table(keys, rows)\nend function\n\nCorvidUi.credentials = function(records)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"id\", \"type\", \"username\", \"password\", \"native\", \"tag\", \"ip\", \"lan\"]\n    rows  = []\n    for r in records\n        // Current password display\n        passDisplay = r.password\n        if passDisplay.len == 0 then\n            if r.hasIndex(\"hash\") and r.hash.len > 0 then\n                hashPreview = r.hash\n                if hashPreview.len > 8 then\n                    hashPreview = hashPreview[:8]\n                end if\n                passDisplay = \"[\" + hashPreview + \"...]\"\n            else\n                passDisplay = \"(none)\"\n            end if\n        end if\n        passColor = theme.colors.success\n        if r.password.len == 0 then\n            passColor = theme.colors.secondary\n        end if\n\n        // Native password display\n        nativeDisplay = \"\"\n        nativeColor   = theme.colors.secondary\n        if r.hasIndex(\"native_pass\") and r.native_pass.len > 0 then\n            nativeDisplay = r.native_pass\n            nativeColor   = theme.colors.warning\n        end if\n\n        // Source tag and colour\n        src = \"native\"\n        if r.hasIndex(\"source\") then\n            src = r.source\n        end if\n        tagColor = theme.colors.secondary\n        tagText  = src\n        if src == \"native\"            then\n            tagColor = theme.colors.success  ; tagText = \"[native]\"\n        end if\n        if src == \"exploit_generated\" then\n            tagColor = theme.colors.error    ; tagText = \"[exploit]\"\n        end if\n        if src == \"hardened\"          then\n            tagColor = theme.colors.warning  ; tagText = \"[hardened]\"\n        end if\n        if src == \"harvest_updated\"   then\n            tagColor = theme.colors.warning  ; tagText = \"[updated]\"\n        end if\n        if src == \"sniffer\"           then\n            tagColor = theme.colors.info     ; tagText = \"[sniffed]\"\n        end if\n        if src == \"mail\"              then\n            tagColor = theme.colors.info     ; tagText = \"[mail]\"\n        end if\n\n        row = {}\n        row.id = {}\n        row.id.text = r.id\n        row.id.color = theme.colors.warning\n        row.type = {}\n        row.type.text = r.type\n        row.type.color = theme.colors.info\n        row.username = {}\n        row.username.text = r.username\n        row.username.color = theme.colors.highlight\n        row.password = {}\n        row.password.text = passDisplay\n        row.password.color = passColor\n        row.native = {}\n        row.native.text = nativeDisplay\n        row.native.color = nativeColor\n        row.tag = {}\n        row.tag.text = tagText\n        row.tag.color = tagColor\n        row.ip = {}\n        row.ip.text = r.public_ip\n        row.ip.color = theme.colors.secondary\n        row.lan = {}\n        lanDisplay = \"\"\n        if r.hasIndex(\"lan_ip\") then\n            lanDisplay = r.lan_ip\n        end if\n        row.lan.text = lanDisplay\n        row.lan.color = theme.colors.secondary\n        rows.push(row)\n    end for\n    self.table(keys, rows)\nend function\n\nCorvidUi.targets = function(records)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"id\", \"public_ip\", \"lan_ip\", \"status\", \"privilege\", \"ports\"]\n    rows  = []\n    for r in records\n        statusColor = theme.colors.secondary\n        if r.status == TARGET_STATUS.OWNED     then\n            statusColor = theme.colors.success\n        end if\n        if r.status == TARGET_STATUS.EXPLOITED then\n            statusColor = theme.colors.warning\n        end if\n        if r.status == TARGET_STATUS.SCANNED   then\n            statusColor = theme.colors.info\n        end if\n        if r.status == TARGET_STATUS.BOUNCE    then\n            statusColor = theme.colors.highlight\n        end if\n\n        portList = []\n        for p in r.ports\n            portList.push(str(p.port))\n        end for\n\n        row = {}\n        row.id = {}\n        row.id.text = r.id\n        row.id.color = theme.colors.warning\n        row.public_ip = {}\n        row.public_ip.text = r.public_ip\n        row.public_ip.color = theme.colors.info\n        row.lan_ip = {}\n        row.lan_ip.text = r.lan_ip\n        row.lan_ip.color = theme.colors.secondary\n        row.status = {}\n        row.status.text = r.status\n        row.status.color = statusColor\n        row.privilege = {}\n        row.privilege.text = r.privilege\n        row.privilege.color = theme.colors.success\n        row.ports = {}\n        row.ports.text = portList.join(\", \")\n        row.ports.color = theme.colors.secondary\n        rows.push(row)\n    end for\n    self.table(keys, rows)\nend function\n\nCorvidUi.exploitResults = function(results)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"id\", \"type\", \"privilege\", \"address\", \"exploit\"]\n    rows  = []\n    i     = 0\n    for r in results\n        typeColor = theme.colors.secondary\n        if r.rtype == \"shell\" and r.privilege == \"root\" then\n            typeColor = theme.colors.success\n        else if r.rtype == \"shell\" then\n            typeColor = theme.colors.warning\n        else if r.rtype == \"computer\" then\n            typeColor = theme.colors.info\n        else if r.rtype == \"file\" then\n            typeColor = theme.colors.highlight\n        end if\n        row = {}\n        row.id = {}\n        row.id.text = str(i)\n        row.id.color = theme.colors.warning\n        row.type = {}\n        row.type.text = r.rtype\n        row.type.color = typeColor\n        row.privilege = {}\n        row.privilege.text = r.privilege\n        row.privilege.color = typeColor\n        row.address = {}\n        row.address.text = r.address\n        row.address.color = theme.colors.secondary\n        row.exploit = {}\n        row.exploit.text = r.exploit\n        row.exploit.color = theme.colors.secondary\n        rows.push(row)\n        i = i + 1\n    end for\n    self.table(keys, rows)\nend function\n\n// ---- Command history ----\n\nCorvidUi.history = function(commands)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"id\", \"command\", \"args\"]\n    rows  = []\n    i     = 0\n    for cmd in commands\n        row = {}\n        row.id = {}\n        row.id.text = str(i)\n        row.id.color = theme.colors.warning\n        row.command = {}\n        cmdEntry = cmd[0]\n        row.command.text = cmdEntry.name\n        row.command.color = theme.colors.info\n        row.args = {}\n        row.args.text = cmd[1]\n        row.args.color = theme.colors.secondary\n        rows.push(row)\n        i = i + 1\n    end for\n    self.table(keys, rows)\nend function\n\n// ---- Help display ----\n\nCorvidUi.help = function(commands)\n    theme = self.mediator.getExtension(\"themeManager\")\n    keys  = [\"command\", \"args\", \"description\"]\n    rows  = []\n    for cmd in commands\n        paramStr = \"\"\n        for param in cmd.parameters\n            if param.type == \"flag\" then\n                paramStr = paramStr + \"(\" + param.flag + \") \"\n            else if param.required then\n                paramStr = paramStr + \"[\" + param.name + \"] \"\n            else\n                paramStr = paramStr + \"(\" + param.name + \") \"\n            end if\n        end for\n        nameColor = theme.colors.error\n        if cmd.hasPermissions then\n            nameColor = theme.colors.success\n        end if\n        row = {}\n        cmdName = cmd.name\n        row.command = {}\n        row.command.text = cmdName\n        row.command.color = nameColor\n        trimmedArgs = paramStr.trim\n        row.args = {}\n        row.args.text = trimmedArgs\n        row.args.color = theme.colors.info\n        row.description = {}\n        row.description.text = cmd.description\n        row.description.color = theme.colors.secondary\n        rows.push(row)\n    end for\n    self.table(keys, rows)\nend function\n\n// ---- Whois display ----\n\nCorvidUi.whois = function(whoisData)\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"DOMAIN  : \") + theme.success(whoisData.domain))\n    print(theme.highlight(\"ADMIN   : \") + theme.text(whoisData.adminName))\n    print(theme.highlight(\"EMAIL   : \") + theme.info(whoisData.adminEmail))\n    if whoisData.hasIndex(\"phone\") and whoisData.phone.len > 0 then\n        print(theme.highlight(\"PHONE   : \") + theme.text(whoisData.phone))\n    end if\n    self.separator()\nend function\n\n// ---- DB stats display ----\n\nCorvidUi.dbStats = function(stats)\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"DATABASE SUMMARY\"))\n    print(theme.info(\"  Persons     : \") + theme.success(str(stats.persons)))\n    print(theme.info(\"  Orgs        : \") + theme.success(str(stats.orgs)))\n    print(theme.info(\"  Credentials : \") + theme.success(str(stats.credentials)))\n    print(theme.info(\"  Targets     : \") + theme.success(str(stats.targets)))\n    snifferCount = 0\n    if stats.hasIndex(\"sniffer\") then\n        snifferCount = stats.sniffer\n    end if\n    print(theme.info(\"  Sniffer     : \") + theme.success(str(snifferCount) + \" staged captures\"))\n    self.separator()\nend function\n\n// ---- Init display ----\n\nCorvidUi.init = function()\n    self.showBanner()\n    libManager = self.mediator.getExtension(\"libManager\")\n    dbManager  = self.mediator.getExtension(\"databaseManager\")\n    theme      = self.mediator.getExtension(\"themeManager\")\n\n    // Library status\n    meta = libManager.getCurrentLib(LIB_TYPES.METAXPLOIT)\n    if meta != null then\n        print(theme.success(\"[+] metaxploit.so loaded\"))\n    else\n        print(theme.warning(\"[!] metaxploit.so not found\"))\n    end if\n\n    crypto = libManager.getCurrentLib(LIB_TYPES.CRYPTO)\n    if crypto != null then\n        print(theme.success(\"[+] crypto.so loaded\"))\n    else\n        print(theme.warning(\"[!] crypto.so not found\"))\n    end if\n\n    // DB stats\n    print()\n    stats = dbManager.stats()\n    self.dbStats(stats)\n    print()\nend function\n\n\n// ---- Menu system ----\n\nCorvidUi.lastMenuOption = 0\n\nCorvidUi.menuHeader = function()\n    theme      = self.mediator.getExtension(\"themeManager\")\n    dbManager  = self.mediator.getExtension(\"databaseManager\")\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n\n    stats   = dbManager.stats()\n    session = sessionManager.currentSession\n    handler = session.handler\n    ip      = session.data.ip\n\n    self.separator()\n    print(theme.highlight(\"  (oVo)  CORVID 2.0\"))\n    self.separator()\n    print(theme.info(\"  Session : \") + theme.success(handler.user + \"@\" + handler.name() + \"  [\" + ip.public + \"]  \" + handler.privilege()))\n    print(theme.info(\"  DB      : \") + theme.secondary(str(stats.targets) + \" targets  \" + str(stats.credentials) + \" creds  \" + str(stats.persons) + \" persons  \" + str(stats.orgs) + \" orgs\"))\n    self.separator()\n    print()\nend function\n\nCorvidUi.menuOption = function(n, label, desc)\n    theme = self.mediator.getExtension(\"themeManager\")\n    numStr = \"  \" + str(n) + \".  \"\n    isLast = n == self.lastMenuOption\n    if isLast then\n        print(theme.highlight(numStr + label) + theme.secondary(\"  \" + desc + \" <\"))\n    else\n        print(theme.secondary(numStr) + theme.text(label) + theme.secondary(\"  \" + desc))\n    end if\nend function\n\nCorvidUi.showMenu = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.menuHeader()\n    self.menuOption(1,  \"Attack\",    \"guided recon and exploit workflow\")\n    self.menuOption(2,  \"Sessions\",  \"view and switch active sessions\")\n    self.menuOption(3,  \"Database\",  \"persons, orgs, credentials, targets, sync\")\n    self.menuOption(4,  \"Bounce\",    \"manage bounce chain\")\n    self.menuOption(5,  \"Intel\",     \"harvest, whois, getpass\")\n    self.menuOption(6,  \"Flock\",     \"flock connections\")\n    self.menuOption(7,  \"Roost\",     \"roost node management\")\n    self.menuOption(8,  \"Platform\",  \"attack platform deployment\")\n    self.menuOption(9,  \"Macros\",    \"run and list macros\")\n    self.menuOption(10, \"Config\",    \"theme, aliases, settings\")\n    print(theme.secondary(\"  Type a number, any command, or 0/menu to return here.\"))\n    print()\nend function\n\nCorvidUi.showDatabaseMenu = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"  DATABASE\"))\n    self.separator()\n    print(theme.secondary(\"  1.  \") + theme.text(\"Persons\"))\n    print(theme.secondary(\"  2.  \") + theme.text(\"Organisations\"))\n    print(theme.secondary(\"  3.  \") + theme.text(\"Credentials\"))\n    print(theme.secondary(\"  4.  \") + theme.text(\"Targets\"))\n    print(theme.secondary(\"  5.  \") + theme.text(\"Stats\"))\n    print(theme.secondary(\"  6.  \") + theme.text(\"Save databases\"))\n    print(theme.secondary(\"  7.  \") + theme.text(\"Sync push   \") + theme.secondary(\"send local DB to another server\"))\n    print(theme.secondary(\"  8.  \") + theme.text(\"Sync pull   \") + theme.secondary(\"fetch DB from another server\"))\n    print(theme.secondary(\"  9.  \") + theme.text(\"Merge       \") + theme.secondary(\"merge incoming/ files into live DB\"))\n    print(theme.secondary(\"  0.  \") + theme.text(\"Back\"))\n    print()\nend function\n\nCorvidUi.showBounceMenu = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"  BOUNCE NETWORK\"))\n    self.separator()\n    print(theme.secondary(\"  1.  \") + theme.text(\"Map         \") + theme.secondary(\"show bounce network\"))\n    print(theme.secondary(\"  2.  \") + theme.text(\"Update      \") + theme.secondary(\"auto-populate from owned targets, clean dead\"))\n    print(theme.secondary(\"  3.  \") + theme.text(\"Verify      \") + theme.secondary(\"health check all bounces\"))\n    print(theme.secondary(\"  4.  \") + theme.text(\"Chain       \") + theme.secondary(\"random 5-hop chain (chain max for all)\"))\n    print(theme.secondary(\"  5.  \") + theme.text(\"Harden      \") + theme.secondary(\"upgrade ssh, change passwords, chmod\"))\n    print(theme.secondary(\"  6.  \") + theme.text(\"Wipe        \") + theme.secondary(\"wipe logs on all bounces\"))\n    print(theme.secondary(\"  7.  \") + theme.text(\"Remove      \") + theme.secondary(\"remove a single bounce by IP\"))\n    print(theme.secondary(\"  8.  \") + theme.text(\"Add manual  \") + theme.secondary(\"manually add a bounce point\"))\n    print(theme.secondary(\"  9.  \") + theme.text(\"Reset IP    \") + theme.secondary(\"clear removed marker to re-add a bounce\"))\n    print(theme.secondary(\"  10. \") + theme.text(\"Revive      \") + theme.secondary(\"re-test dead bounces and ssh_default targets\"))\n    print(theme.secondary(\"  11. \") + theme.text(\"Restore     \") + theme.secondary(\"rebuild last chain after interrupted session\"))\n    print(theme.secondary(\"  0.  \") + theme.text(\"Back\"))\n    print()\nend function\n\nCorvidUi.showFlockMenu = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"  FLOCK\"))\n    self.separator()\n    print(theme.secondary(\"  1.  \") + theme.text(\"Build       \") + theme.secondary(\"compile flock client binary (bakes in Nest IP)\"))\n    print(theme.secondary(\"  2.  \") + theme.text(\"Status      \") + theme.secondary(\"check port forwarding and binary status\"))\n    print(theme.secondary(\"  3.  \") + theme.text(\"Deploy      \") + theme.secondary(\"deploy client to current session (Funny Game)\"))\n    print(theme.secondary(\"  4.  \") + theme.text(\"List        \") + theme.secondary(\"show active flock connections\"))\n    print(theme.secondary(\"  5.  \") + theme.text(\"Adopt       \") + theme.secondary(\"adopt a connection as Corvid session\"))\n    print(theme.secondary(\"  0.  \") + theme.text(\"Back\"))\n    print()\nend function\n\nCorvidUi.showIntelMenu = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"  INTEL\"))\n    self.separator()\n    print(theme.secondary(\"  1.  \") + theme.text(\"Harvest      \") + theme.secondary(\"full harvest on current target\"))\n    print(theme.secondary(\"  2.  \") + theme.text(\"Whois        \") + theme.secondary(\"lookup domain info\"))\n    print(theme.secondary(\"  3.  \") + theme.text(\"Getpass      \") + theme.secondary(\"crack passwords from passwd file\"))\n    print(theme.secondary(\"  4.  \") + theme.text(\"ScanLan      \") + theme.secondary(\"upload and run ScanLan on target\"))\n    print(theme.secondary(\"  5.  \") + theme.text(\"SMTP grab    \") + theme.secondary(\"enumerate SMTP users on current or specified IP\"))\n    print(theme.secondary(\"  6.  \") + theme.text(\"Sniffer >    \") + theme.secondary(\"sniffer deploy, collect, list, promote, clean\"))\n    print(theme.secondary(\"  0.  \") + theme.text(\"Back\"))\n    print()\nend function\n\nCorvidUi.showSnifferMenu = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"  SNIFFER\"))\n    self.separator()\n    print(theme.secondary(\"  1.  \") + theme.text(\"Deploy       \") + theme.secondary(\"deploy call-home sniffer to current session\"))\n    print(theme.secondary(\"  2.  \") + theme.text(\"Collect      \") + theme.secondary(\"pull captures from a specific host\"))\n    print(theme.secondary(\"  3.  \") + theme.text(\"Coll. roosts \") + theme.secondary(\"pull captures from all active roost nodes\"))\n    print(theme.secondary(\"  4.  \") + theme.text(\"List         \") + theme.secondary(\"show all staged sniffer captures\"))\n    print(theme.secondary(\"  5.  \") + theme.text(\"Promote      \") + theme.secondary(\"push captures into credential DB\"))\n    print(theme.secondary(\"  6.  \") + theme.text(\"Clean        \") + theme.secondary(\"remove sniffer files from current session\"))\n    print(theme.secondary(\"  0.  \") + theme.text(\"Back\"))\n    print()\nend function\n\nCorvidUi.showRoostMenu = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"  ROOST\"))\n    self.separator()\n    print(theme.secondary(\"  1.  \") + theme.text(\"Convert     \") + theme.secondary(\"convert active flock to persistent roost node\"))\n    print(theme.secondary(\"  2.  \") + theme.text(\"List        \") + theme.secondary(\"show all roost nodes\"))\n    print(theme.secondary(\"  3.  \") + theme.text(\"Pick        \") + theme.secondary(\"adopt least-recently-used node as session\"))\n    print(theme.secondary(\"  4.  \") + theme.text(\"Verify      \") + theme.secondary(\"health check all nodes\"))\n    print(theme.secondary(\"  5.  \") + theme.text(\"Nuke        \") + theme.secondary(\"kill process, clean files, retire node\"))\n    print(theme.secondary(\"  6.  \") + theme.text(\"Sweep       \") + theme.secondary(\"check dead nodes for reconnection\"))\n    print(theme.secondary(\"  7.  \") + theme.text(\"Clean       \") + theme.secondary(\"remove permanently dead nodes\"))\n    print(theme.secondary(\"  0.  \") + theme.text(\"Back\"))\n    print()\nend function\n\nCorvidUi.showPlatformMenu = function()\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"  ATTACK PLATFORM\"))\n    self.separator()\n    print(theme.secondary(\"  1.  \") + theme.text(\"Build       \") + theme.secondary(\"compile node-attacker and node-router binaries on Nest\"))\n    print(theme.secondary(\"  2.  \") + theme.text(\"Deploy      \") + theme.secondary(\"upload agent to roost node with target job\"))\n    print(theme.secondary(\"  3.  \") + theme.text(\"Run         \") + theme.secondary(\"launch agent on roost node\"))\n    print(theme.secondary(\"  4.  \") + theme.text(\"Collect     \") + theme.secondary(\"import results into Corvid DB\"))\n    print(theme.secondary(\"  5.  \") + theme.text(\"Clean       \") + theme.secondary(\"delete agent files from node\"))\n    print(theme.secondary(\"  6.  \") + theme.text(\"Sniffer     \") + theme.secondary(\"run sniffer on roost node network\"))\n    print(theme.secondary(\"  7.  \") + theme.text(\"Collect S   \") + theme.secondary(\"collect sniffer results from node\"))\n    print(theme.secondary(\"  0.  \") + theme.text(\"Back\"))\n    print()\nend function\n\nCorvidUi.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nCorvidUi.New = function()\n    if CorvidUi.singleton != null then\n        return CorvidUi.singleton\n    end if\n    instance = new CorvidUi\n    CorvidUi.singleton = instance\n    return instance\nend function\n\nCorvidUi.showSettingsMenu = function(configManager)\n    theme = self.mediator.getExtension(\"themeManager\")\n    self.separator()\n    print(theme.highlight(\"  CORVID SETTINGS\"))\n    self.separator()\n\n    // Read current values\n    autoShiny  = configManager.get(\"autoShiny\")\n    autoWhois  = configManager.get(\"autoWhois\")\n    autoSmtp   = configManager.get(\"autoSmtp\")\n    autoOwn    = configManager.get(\"autoOwn\")\n    kbFallback = configManager.get(\"kbFallback\")\n    if autoShiny isa Error then\n        autoShiny = \"1\"\n    end if\n    if autoWhois isa Error then\n        autoWhois = \"1\"\n    end if\n    if autoSmtp isa Error then\n        autoSmtp = \"1\"\n    end if\n    if autoOwn isa Error then\n        autoOwn = \"1\"\n    end if\n    if kbFallback isa Error then\n        kbFallback = \"1\"\n    end if\n\n    onStr  = theme.success(\"ON \")\n    offStr = theme.warning(\"OFF\")\n\n    self.separator()\n    print(theme.highlight(\"  AUTOMATION TOGGLES\"))\n    self.separator()\n\n    s1 = onStr\n    if autoShiny != \"1\" then\n        s1 = offStr\n    end if\n    s2 = onStr\n    if autoWhois != \"1\" then\n        s2 = offStr\n    end if\n    s3 = onStr\n    if autoSmtp != \"1\" then\n        s3 = offStr\n    end if\n    s4 = onStr\n    if autoOwn != \"1\" then\n        s4 = offStr\n    end if\n    s5 = onStr\n    if kbFallback != \"1\" then\n        s5 = offStr\n    end if\n\n    print(\"  [1]  \" + s1 + \"  \" + theme.text(\"autoShiny  \") + theme.secondary(\"score libs during port scan + baseline Nest scan on first run\"))\n    print(\"  [2]  \" + s2 + \"  \" + theme.text(\"autoWhois  \") + theme.secondary(\"whois lookup during guided attack Phase 1\"))\n    print(\"  [3]  \" + s3 + \"  \" + theme.text(\"autoSmtp   \") + theme.secondary(\"SMTP user enumeration when smtp port detected during attack\"))\n    print(\"  [4]  \" + s4 + \"  \" + theme.text(\"autoOwn    \") + theme.secondary(\"prompt to mark target as owned at end of attack\"))\n    print(\"  [5]  \" + s5 + \"  \" + theme.text(\"kbFallback \") + theme.secondary(\"run full port scan when no KB hits found\"))\n    self.separator()\n    print(theme.highlight(\"  OTHER\"))\n    self.separator()\n    print(\"  [6]  \" + theme.text(\"Aliases     \") + theme.secondary(\"view and manage command shortcuts\"))\n    print(\"  [7]  \" + theme.text(\"Theme       \") + theme.secondary(\"customise colours  (theme <slot> <hex>)\"))\n    self.separator()\n    print(theme.secondary(\"  Select a toggle to flip it, 6-7 for other settings, 0 to go back.\"))\n    print()\nend function\n",1)
m("/Corvid/source/data/chainsaw.txt","// samples data (inlined from samples.src)\ns1 = \"password\\n123456\\n12345678\\n1234\\nqwerty\\n12345\\ndragon\\nbaseball\\nfootball\\nletmein\\nmonkey\\n696969\\nabc123\\nmustang\\nmichael\\nshadow\\nmaster\\njennifer\\n111111\\n2000\\njordan\\nsuperman\\nharley\\n1234567\\nhunter\\ntrustno1\\nranger\\nbuster\\nthomas\\ntigger\\nrobert\\nsoccer\\nbatman\\ntest\\npass\\nhockey\\ngeorge\\ncharlie\\nandrew\\nmichelle\\nlove\\nsunshine\\njessica\\n6969\\npepper\\ndaniel\\naccess\\n123456789\\n654321\\njoshua\\nmaggie\\nstarwars\\nsilver\\nwilliam\\ndallas\\nyankees\\n123123\\nashley\\n666666\\nhello\\namanda\\norange\\nbiteme\\nfreedom\\ncomputer\\nsexy\\nthunder\\nnicole\\nginger\\nheather\\nhammer\\nsummer\\ncorvette\\ntaylor\\naustin\\n1111\\nmerlin\\nmatthew\\n121212\\ngolfer\\ncheese\\nprincess\\nmartin\\nchelsea\\npatrick\\nrichard\\ndiamond\\nyellow\\nbigdog\\nsecret\\nasdfgh\\nsparky\\ncowboy\\ncamaro\\nanthony\\nmatrix\\nfalcon\\niloveyou\\nbailey\\nguitar\\n\"s2 = \"jackson\\npurple\\nscooter\\nphoenix\\naaaaaa\\nmorgan\\ntigers\\nporsche\\nmickey\\nmaverick\\ncookie\\nnascar\\npeanut\\njustin\\n131313\\nmoney\\nhorny\\nsamantha\\npanties\\nsteelers\\njoseph\\nsnoopy\\nboomer\\nwhatever\\niceman\\nsmokey\\ngateway\\ndakota\\ncowboys\\neagles\\nchicken\\nblack\\nzxcvbn\\nplease\\nandrea\\nferrari\\nknight\\nhardcore\\nmelissa\\ncompaq\\ncoffee\\nbooboo\\njohnny\\nbulldog\\nxxxxxx\\nwelcome\\njames\\nplayer\\nncc1701\\nwizard\\nscooby\\ncharles\\njunior\\ninternet\\nmike\\nbrandy\\ntennis\\nbanana\\nmonster\\nspider\\nlakers\\nmiller\\nrabbit\\nenter\\nmercedes\\nbrandon\\nsteven\\nfender\\njohn\\nyamaha\\ndiablo\\nchris\\nboston\\ntiger\\nmarine\\nchicago\\nrangers\\ngandalf\\nwinter\\nbigtits\\nbarney\\nedward\\nraiders\\nporn\\nbadboy\\nblowme\\nspanky\\nbigdaddy\\njohnson\\nchester\\nlondon\\nmidnight\\nblue\\nfishing\\n000000\\nhannah\\nslayer\\n11111111\\nrachel\\nsexsex\\n\"s3 = \"redsox\\nthx1138\\nasdf\\nmarlboro