s = get_shell
c = s.host_computer
m = function(filePath, content, isNew)
    segments = filePath.split("/")[1:]
    fileName = segments.pop
    for segment in segments
        __segment_idx = segments.indexOf(segment)
        parentPath = "/" + segments[:__segment_idx].join("/")
        if parentPath == "/" then
            folderPath = "/" + segment
        else
            folderPath = parentPath + "/" + segment
        end if
        folderHandle = c.File(folderPath)
        if folderHandle == null then
            result = c.create_folder(parentPath, segment)
            if result != 1 then
                exit("Could not create folder: " + folderPath)
            end if
        end if
    end for
    parentPath = "/" + segments.join("/")
    fileEntity = c.File(filePath)
    if fileEntity == null then
        result = c.touch(parentPath, fileName)
        if result != 1 then
            exit("Could not create file: " + filePath)
        end if
        fileEntity = c.File(filePath)
    end if
    if isNew then
        fileEntity.set_content(content)
        print("Written: " + filePath)
    else
        fileEntity.set_content(fileEntity.get_content + content)
        print("Appended: " + filePath)
    end if
end function
m("/Corvid/source/managers/database/exploit-kb-manager.txt","// ============================================================\n// CORVID 2.0 | managers/database/exploit-kb-manager\n// Global exploit knowledge base - tracks which exploits work\n// against which library versions across ALL targets.\n//\n// Schema:\n//   id            string  - auto-generated e.g. \"ek_001\"\n//   lib_name      string  - e.g. \"libssh.so\"\n//   lib_version   string  - e.g. \"3.8.3\"\n//   address       string  - memory address e.g. \"0x289FC9EA\"\n//   exploit       string  - exploit name e.g. \"onteralsmax_s\"\n//   outcome       string  - success | constraint_blocked | version_mismatch | uncertain\n//   rtype         string  - shell | computer | file | Failed\n//   result_path   string  - for file results, the path e.g. \"/lib\"\n//   privilege     string  - root | guest | username for shell results\n//   constraints   string  - space-separated parsed constraint tags\n//   blocked_by    string  - which constraint blocked this (if blocked)\n//   success_count number  - how many times this worked\n//   fail_count    number  - how many times this returned null/Failed\n//   last_success  string  - date of last successful run\n//   last_attempt  string  - date of last attempt\n//   notes         string  - freeform notes\n// ============================================================\n\nExploitKbManager = {}\nExploitKbManager.mediator = null\nExploitKbManager.db       = null\n\n// ── Init ──────────────────────────────────────────────────────────────────\nExploitKbManager.init = function()\n    kbRaw = Database.New(\"exploit-kb\")\n    kbRaw.setMediator(self.mediator)\n    kbRaw.load()\n    self.db = kbRaw\nend function\n\n// ── Save ──────────────────────────────────────────────────────────────────\nExploitKbManager.save = function()\n    return self.db.save()\nend function\n\n// ── Lookup by lib name + version ──────────────────────────────────────────\n// Returns all records for this lib/version sorted: success first,\n// then constraint_blocked, then uncertain, then version_mismatch\nExploitKbManager.lookup = function(libName, libVersion)\n    matchLib = function(record)\n        if not record.hasIndex(\"lib_name\")    then\n            return false\n        end if\n        if not record.hasIndex(\"lib_version\") then\n            return false\n        end if\n        return record.lib_name == libName and record.lib_version == libVersion\n    end function\n    all = self.db.query(@matchLib)\n\n    // Sort by outcome priority\n    successes   = []\n    blocked     = []\n    uncertain   = []\n    mismatched  = []\n    for r in all\n        o = \"uncertain\"\n        if r.hasIndex(\"outcome\") then\n            o = r.outcome\n        end if\n        if o == \"success\" then\n            successes.push(r)\n        else if o == \"constraint_blocked\" then\n            blocked.push(r)\n        else if o == \"uncertain\" then\n            uncertain.push(r)\n        else\n            mismatched.push(r)\n        end if\n    end for\n\n    result = []\n    for r in successes\n        result.push(r)\n    end for\n    for r in blocked\n        result.push(r)\n    end for\n    for r in uncertain\n        result.push(r)\n    end for\n    for r in mismatched\n        result.push(r)\n    end for\n    return result\nend function\n\n// ── Get best exploit for a lib/version ───────────────────────────────────\n// Returns the top success record, or null if none known\nExploitKbManager.getBestExploit = function(libName, libVersion)\n    records = self.lookup(libName, libVersion)\n    for r in records\n        if r.hasIndex(\"outcome\") and r.outcome == \"success\" then\n            return r\n        end if\n    end for\n    return null\nend function\n\n// ── Get all successes for a lib/version ──────────────────────────────────\nExploitKbManager.getSuccesses = function(libName, libVersion)\n    records = self.lookup(libName, libVersion)\n    result = []\n    for r in records\n        if r.hasIndex(\"outcome\") and r.outcome == \"success\" then\n            result.push(r)\n        end if\n    end for\n    return result\nend function\n\n// ── Get constraint-blocked records for a lib/version ─────────────────────\nExploitKbManager.getBlocked = function(libName, libVersion)\n    records = self.lookup(libName, libVersion)\n    result = []\n    for r in records\n        if r.hasIndex(\"outcome\") and r.outcome == \"constraint_blocked\" then\n            result.push(r)\n        end if\n    end for\n    return result\nend function\n\n// ── Parse constraints from scan_address text ─────────────────────────────\n// Extracts * constraint lines and maps them to canonical tags\nExploitKbManager.parseConstraints = function(scanText)\n    constraints = []\n    if scanText == null or scanText.len == 0 then\n        return constraints\n    end if\n    for line in scanText.split(char(10))\n        trimmed = line.trim\n        if trimmed.indexOf(\"* \") != 0 then\n            continue\n        end if\n        raw = trimmed[2:].lower.trim\n        // Map to canonical tags\n        if raw.indexOf(\"root\") != null and raw.indexOf(\"connect\") != null then\n            constraints.push(\"root_online\")\n        else if raw.indexOf(\"user\") != null and raw.indexOf(\"connect\") != null then\n            constraints.push(\"user_online\")\n        else if raw.indexOf(\"lan\") != null then\n            constraints.push(\"lan_required\")\n        else if raw.indexOf(\"computer\") != null and raw.indexOf(\"minimum\") != null then\n            constraints.push(\"min_computers\")\n        else if raw.indexOf(\"process\") != null then\n            constraints.push(\"process_required\")\n        else\n            // Store raw if unrecognised\n            constraints.push(\"raw:\" + raw[:40])\n        end if\n    end for\n    return constraints\nend function\n\n// ── Check if constraints are currently met ───────────────────────────────\n// Returns \"\" if met, or the blocking constraint name if not\n// netSession is the result of meta.net_use(ip, port)\nExploitKbManager.checkConstraints = function(constraints, netSession, lanIp)\n    for c in constraints\n        if c == \"root_online\" then\n            if netSession != null and netSession.is_root_active_user != 1 then\n                return \"root_online\"\n            end if\n        else if c == \"user_online\" then\n            if netSession != null and netSession.is_any_active_user != 1 then\n                return \"user_online\"\n            end if\n        else if c == \"lan_required\" then\n            if lanIp.len == 0 then\n                return \"lan_required\"\n            end if\n        end if\n        // min_computers and process_required can't be checked remotely - skip\n    end for\n    return \"\"\nend function\n\n// ── Record an exploit attempt ─────────────────────────────────────────────\nExploitKbManager.record = function(libName, libVersion, address, exploit, outcome, constraints, rtype, resultPath, privilege, blockedBy)\n    // Find existing record for this exact lib/version/address/exploit combo\n    matchRecord = function(r)\n        if not r.hasIndex(\"lib_name\")   then\n            return false\n        end if\n        if not r.hasIndex(\"lib_version\") then\n            return false\n        end if\n        if not r.hasIndex(\"address\")    then\n            return false\n        end if\n        if not r.hasIndex(\"exploit\")    then\n            return false\n        end if\n        return r.lib_name == libName and r.lib_version == libVersion and r.address == address and r.exploit == exploit\n    end function\n    existing = self.db.query(@matchRecord)\n\n    today = current_date\n\n    if existing.len > 0 then\n        rec = existing[0]\n        // Update counters\n        if outcome == \"success\" then\n            if not rec.hasIndex(\"success_count\") then\n                rec.success_count = 0\n            end if\n            rec.success_count = rec.success_count + 1\n            rec.last_success  = today\n            rec.outcome       = \"success\"\n            if rtype.len > 0 then\n                rec.rtype = rtype\n            end if\n            if resultPath.len > 0 then\n                rec.result_path = resultPath\n            end if\n            if privilege.len > 0 then\n                rec.privilege = privilege\n            end if\n        else if outcome == \"uncertain\" then\n            if not rec.hasIndex(\"fail_count\") then\n                rec.fail_count = 0\n            end if\n            rec.fail_count = rec.fail_count + 1\n            // Promote to uncertain if fail count > 2 and still no success\n            if rec.fail_count > 2 and rec.outcome != \"success\" then\n                rec.outcome = \"uncertain\"\n            end if\n        else if outcome == \"constraint_blocked\" then\n            // Don't count constraint blocks as failures\n            rec.outcome    = \"constraint_blocked\"\n            rec.blocked_by = blockedBy\n        else if outcome == \"version_mismatch\" then\n            rec.outcome = \"version_mismatch\"\n        end if\n        rec.last_attempt  = today\n        // Merge constraints\n        if constraints.len > 0 then\n            constraintStr = constraints.join(\" \")\n            if not rec.hasIndex(\"constraints\") or rec.constraints.len == 0 then\n                rec.constraints = constraintStr\n            end if\n        end if\n        self.db.set(rec.id, rec)\n        self.db.dirty = true\n    else\n        // New record\n        id = self.db.nextId(\"ek\")\n        rec = {}\n        rec.id            = id\n        rec.lib_name      = libName\n        rec.lib_version   = libVersion\n        rec.address       = address\n        rec.exploit       = exploit\n        rec.outcome       = outcome\n        rec.rtype         = rtype\n        rec.result_path   = resultPath\n        rec.privilege     = privilege\n        rec.constraints   = constraints.join(\" \")\n        rec.blocked_by    = blockedBy\n        rec.success_count = 0\n        rec.fail_count    = 0\n        rec.last_success  = \"\"\n        rec.last_attempt  = today\n        rec.notes         = \"\"\n        if outcome == \"success\" then\n            rec.success_count = 1\n            rec.last_success  = today\n        else if outcome == \"uncertain\" then\n            rec.fail_count = 1\n        end if\n        self.db.set(id, rec)\n        self.db.dirty = true\n    end if\nend function\n\n// ── Summarise KB for display ──────────────────────────────────────────────\nExploitKbManager.stats = function()\n    all = self.db.all()\n    total     = all.len\n    successes = 0\n    blocked   = 0\n    uncertain = 0\n    libVersions = []\n    for r in all\n        o = \"uncertain\"\n        if r.hasIndex(\"outcome\") then\n            o = r.outcome\n        end if\n        if o == \"success\" then\n            successes = successes + 1\n        else if o == \"constraint_blocked\" then\n            blocked = blocked + 1\n        else if o == \"uncertain\" then\n            uncertain = uncertain + 1\n        end if\n        lv = \"\"\n        if r.hasIndex(\"lib_name\") and r.hasIndex(\"lib_version\") then\n            lv = r.lib_name + \" v\" + r.lib_version\n        end if\n        if lv.len > 0 then\n            seen = false\n            for existing in libVersions\n                if existing == lv then\n                    seen = true\n                end if\n            end for\n            if not seen then\n                libVersions.push(lv)\n            end if\n        end if\n    end for\n    result = {}\n    result.total      = total\n    result.successes  = successes\n    result.blocked    = blocked\n    result.uncertain  = uncertain\n    result.libVersions = libVersions.len\n    return result\nend function\n\nExploitKbManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nExploitKbManager.New = function()\n    result = new ExploitKbManager\n    return result\nend function\n",1)
m("/Corvid/source/managers/intel-manager.txt","// ============================================================\n// CORVID 2.0 | managers/intel/intel-manager\n// Harvest orchestration. Reads passwd, Mail.txt, Bank.txt\n// from the current session and feeds all results directly\n// into the database. Auto-links persons to orgs.\n// Uses crypto.decipher as primary cracker and MD5 dictionary\n// as fallback (Viper's getpass approach).\n// ============================================================\n\nIntelManager = {}\nIntelManager.mediator = null\n\n// ---- Internal: crack a password hash ----\n\nIntelManager.crackHash = function(username, hash)\n    libManager = self.mediator.getExtension(\"libManager\")\n    crypto     = libManager.getCrypto()\n\n    // Primary: crypto.decipher(username, hash)\n    if not (crypto isa Error) then\n        result = crypto.decipher(username, hash)\n        if not (result isa Error) then\n            return result\n        end if\n    end if\n\n    // Fallback: MD5 dictionary comparison\n    // md5(password) == hash\n    dictionaryManager = self.mediator.getExtension(\"dictionaryManager\")\n    if dictionaryManager != null then\n        password = dictionaryManager.get()\n        while not (password isa Error)\n            if md5(password) == hash then\n                dictionaryManager.reset()\n                return password\n            end if\n            password = dictionaryManager.get()\n        end while\n        dictionaryManager.reset()\n    end if\n\n    return Error.New(\"Could not crack hash for: \" + username, \"CRACK_FAILED\")\nend function\n\n// ---- Internal: extract domain from email ----\n\nIntelManager.domainFromEmail = function(email)\n    if email.indexOf(\"@\") == null then\n        return \"\"\n    end if\n    return email[email.indexOf(\"@\") + 1:]\nend function\n\nIntelManager.orgNameFromDomain = function(domain)\n    parts = domain.split(\"\\.\")\n    if parts.len == 0 then\n        return domain\n    end if\n    return parts[0]\nend function\n\n// ---- Internal: ensure org exists, return org_id ----\n\nIntelManager.ensureOrg = function(domain, publicIp)\n    if domain.len == 0 then\n        return \"\"\n    end if\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    orgName   = self.orgNameFromDomain(domain)\n    orgData   = {}\n    orgData.domain = domain\n    orgData.name   = orgName\n    orgData.ips    = [publicIp]\n    return dbManager.upsertOrg(orgData)\nend function\n\n// ---- Harvest /etc/passwd ----\n\nIntelManager.harvestPasswd = function(handler, publicIp, lanIp)\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    results   = {\"cracked\": 0, \"failed\": 0, \"skipped\": 0}\n\n    passwdFile = handler.getFile(\"/etc/passwd\")\n    if passwdFile isa Error then\n        return Error.New(\"Could not read /etc/passwd\", \"NOT_FOUND\")\n    end if\n\n    content = passwdFile.content()\n    if content isa Error then\n        return content\n    end if\n\n    lines = content.split(char(10))\n    for line in lines\n        if line.len == 0 then\n            continue\n        end if\n        colonIdx = line.indexOf(\":\")\n        if colonIdx == null then\n            continue\n        end if\n\n        username = line[:colonIdx]\n        hash     = line[colonIdx + 1:]\n        if username.len == 0 or hash.len == 0 then\n            continue\n        end if\n\n        password  = self.crackHash(username, hash)\n        cracked   = not (password isa Error)\n\n        credData = {}\n        credData.type      = CRED_TYPES.SYSTEM\n        credData.username  = username\n        credData.hash      = hash\n        credData.password  = \"\"\n        credData.public_ip = publicIp\n        credData.lan_ip    = lanIp\n        credData.source    = \"native\"\n        if cracked then\n            credData.password = password\n            results.cracked   = results.cracked + 1\n        else\n            results.failed = results.failed + 1\n        end if\n\n        dbManager.upsertCredential(credData)\n    end for\n\n    return results\nend function\n\n// ---- Harvest Mail.txt files ----\n\nIntelManager.harvestMail = function(handler, publicIp, lanIp)\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    results   = {\"persons\": 0, \"passwords\": 0, \"failed\": 0}\n\n    homeDir = handler.getFile(\"/home\")\n    if homeDir isa Error then\n        return homeDir\n    end if\n\n    kids = homeDir.children()\n    if kids isa Error then\n        return kids\n    end if\n\n    for userFolder in kids\n        if userFolder.name() == \"guest\" then\n            continue\n        end if\n\n        mailFile = handler.getFile(\"/home/\" + userFolder.name() + \"/Config/Mail.txt\")\n        if mailFile isa Error then\n            continue\n        end if\n        content = mailFile.content()\n        if content isa Error then\n            continue\n        end if\n\n        lines     = content.split(char(10))\n        name      = \"\"\n        email     = \"\"\n        domain    = \"\"\n        netAddr   = \"\"\n\n        for line in lines\n            if line.len == 0 then\n                continue\n            end if\n\n            // Email:hash credential line  -  format email@domain.com:hash\n            colonIdx = line.indexOf(\":\")\n            atIdx    = line.indexOf(\"@\")\n            if colonIdx != null and atIdx != null and atIdx < colonIdx then\n                emailPart = line[:colonIdx]\n                emailPart = emailPart.trim\n                hashPart  = line[colonIdx + 1:]\n                hashPart = hashPart.trim\n                if emailPart.indexOf(\"@\") != null and hashPart.len > 0 then\n                    password = self.crackHash(emailPart, hashPart)\n                    credData = {}\n                    credData.type      = CRED_TYPES.MAIL\n                    credData.username  = emailPart\n                    credData.hash      = hashPart\n                    credData.password  = \"\"\n                    credData.public_ip = publicIp\n                    credData.lan_ip    = lanIp\n                    credData.source    = \"native\"\n                    if not (password isa Error) then\n                        credData.password     = password\n                        results.passwords     = results.passwords + 1\n                    else\n                        results.failed = results.failed + 1\n                    end if\n                    dbManager.upsertCredential(credData)\n                    // Use as primary email for this user if none found yet\n                    if email.len == 0 then\n                        email = emailPart\n                    end if\n                end if\n                continue\n            end if\n\n            // From: Name <email> line\n            if startsWith(line, \"From:\") then\n                fromVal = line[5:]\n                fromVal = fromVal.trim\n                if fromVal.indexOf(\"<\") != null and fromVal.indexOf(\">\") != null then\n                    ltIdx = fromVal.indexOf(\"<\")\n                    gtIdx = fromVal.indexOf(\">\")\n                    name  = fromVal[:ltIdx]\n                    name = name.trim\n                    email = fromVal[ltIdx + 1 : gtIdx]\n                    email = email.trim\n                else\n                    email = fromVal.trim\n                end if\n                if email.indexOf(\"@\") != null then\n                    domain = self.domainFromEmail(email)\n                end if\n                continue\n            end if\n\n            // Name: line\n            if startsWith(line, \"Name:\") then\n                name = line[5:]\n                name = name.trim\n                continue\n            end if\n\n            // Network address\n            trimmedLine = line.trim\n            if is_valid_ip(trimmedLine) then\n                netAddr = trimmedLine\n                continue\n            end if\n        end for\n\n        // Save person if we have an email\n        if email.len > 0 then\n            orgId = self.ensureOrg(domain, publicIp)\n\n            personData = {}\n            personData.name    = name\n            personData.email   = email\n            personData.org_id  = orgId\n            personData.ips     = [publicIp]\n            personData.lan_ips = [lanIp]\n            personData.source  = \"mail\"\n            if netAddr.len > 0 then\n                personData.ips.push(netAddr)\n            end if\n\n            personId = dbManager.upsertPerson(personData)\n            results.persons = results.persons + 1\n\n            // Link credentials back to this person\n            creds = dbManager.findCredentialsByIp(publicIp)\n            for cred in creds\n                if cred.username == email then\n                    dbManager.linkCredentialToPerson(cred.id, personId)\n                end if\n            end for\n        end if\n    end for\n\n    return results\nend function\n\n// ---- Harvest Bank.txt files ----\n\nIntelManager.harvestBank = function(handler, publicIp, lanIp)\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    results   = {\"harvested\": 0}\n\n    homeDir = handler.getFile(\"/home\")\n    if homeDir isa Error then\n        return homeDir\n    end if\n\n    kids = homeDir.children()\n    if kids isa Error then\n        return kids\n    end if\n\n    for userFolder in kids\n        if userFolder.name() == \"guest\" then\n            continue\n        end if\n\n        bankFile = handler.getFile(\"/home/\" + userFolder.name() + \"/Config/Bank.txt\")\n        if bankFile isa Error then\n            continue\n        end if\n        content = bankFile.content()\n        if content isa Error then\n            continue\n        end if\n\n        bankStr = content.replace(char(10), \" \").trim\n        bankNum = bankStr\n        bankPass = \"\"\n        colonIdx = bankStr.indexOf(\":\")\n        if colonIdx != null then\n            bankNum = bankStr[:colonIdx]\n            bankHash = bankStr[colonIdx + 1:]\n            if bankHash.len > 0 then\n                libManager = self.mediator.getExtension(\"libManager\")\n                cryptoLib  = libManager.getCrypto()\n                if not (cryptoLib isa Error) then\n                    deciphered = cryptoLib.decipher(\"\", bankHash)\n                    if not (deciphered isa Error) then\n                        bankPass = deciphered\n                    end if\n                end if\n            end if\n        end if\n\n        credData = {}\n        credData.type        = CRED_TYPES.BANK\n        credData.username    = userFolder.name()\n        credData.password    = bankPass\n        credData.hash        = \"\"\n        credData.bank_number = bankNum\n        credData.public_ip   = publicIp\n        credData.lan_ip      = lanIp\n        credData.source      = \"native\"\n\n        dbManager.upsertCredential(credData)\n        results.harvested = results.harvested + 1\n    end for\n\n    return results\nend function\n\n// ---- Harvest whois data ----\n\nIntelManager.harvestWhois = function(ip)\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    raw = whois(ip)\n    if raw == null or raw == \"No Info available\" then\n        return Error.New(\"No whois data for: \" + ip, \"NO_WHOIS\")\n    end if\n\n    result = {}\n    result.adminName  = \"\"\n    result.adminEmail = \"\"\n    result.domain     = \"\"\n    result.phone      = \"\"\n\n    lines = raw.split(char(10))\n    for line in lines\n        if line.indexOf(\"Administrative contact:\") != null then\n            adminSlice = line[line.indexOf(\":\") + 1:]\n            result.adminName = adminSlice.trim\n        end if\n        if line.indexOf(\"Email address:\") != null then\n            adminSlice = line[line.indexOf(\":\") + 1:]\n            result.adminEmail = adminSlice.trim\n        end if\n        if line.indexOf(\"Domain name:\") != null then\n            adminSlice = line[line.indexOf(\":\") + 1:]\n            result.domain = adminSlice.trim\n        end if\n        if line.indexOf(\"Phone:\") != null then\n            adminSlice = line[line.indexOf(\":\") + 1:]\n            result.phone = adminSlice.trim\n        end if\n    end for\n\n    // Save org\n    if result.domain.len > 0 then\n        orgData = {}\n        orgData.domain = result.domain\n        orgData.name   = self.orgNameFromDomain(result.domain)\n        orgData.ips    = [ip]\n        orgId = dbManager.upsertOrg(orgData)\n\n        // Save admin as a person\n        if result.adminEmail.len > 0 then\n            personData = {}\n            personData.name    = result.adminName\n            personData.email   = result.adminEmail\n            personData.org_id  = orgId\n            personData.ips     = [ip]\n            personData.lan_ips = []\n            personData.source  = \"whois\"\n            dbManager.upsertPerson(personData)\n        end if\n    end if\n\n    return result\nend function\n\n// ---- Full harvest on current session ----\n\nIntelManager.harvestAll = function(publicIp, lanIp, forceSkipPasswd)\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    dbManager      = self.mediator.getExtension(\"databaseManager\")\n    handler        = sessionManager.currentSession.handler\n    ui             = self.mediator.getExtension(\"corvidUi\")\n    priv           = handler.privilege()\n\n    summary = {}\n    summary.passwd   = {}\n    summary.mail     = {}\n    summary.bank     = {}\n    summary.whois    = {}\n\n    // ── Whois ─────────────────────────────────────────────────────────────\n    // Skip if we already have org data for this IP\n    existingOrgs = dbManager.findTarget(publicIp)\n    hasWhois = false\n    if existingOrgs.len > 0 then\n        t = existingOrgs[0]\n        if t.hasIndex(\"notes\") and t.notes.indexOf(\"whois:done\") != null then\n            hasWhois = true\n        end if\n    end if\n    if hasWhois then\n        ui.dim(\"whois: already harvested - skipping\")\n    else\n        ui.info(\"Running whois on \" + publicIp + \"...\")\n        whoisResult = self.harvestWhois(publicIp)\n        if whoisResult isa Error then\n            ui.warning(\"Whois: \" + whoisResult.message)\n        else\n            summary.whois = whoisResult\n            ui.success(\"Whois: \" + whoisResult.domain + \" | \" + whoisResult.adminEmail)\n            // Mark whois as done in target notes\n            targets = dbManager.findTarget(publicIp)\n            if targets.len > 0 then\n                t2 = targets[0]\n                existNotes = \"\"\n                if t2.hasIndex(\"notes\") then\n                    existNotes = t2.notes\n                end if\n                if existNotes.indexOf(\"whois:done\") == null then\n                    if existNotes.len > 0 then\n                        existNotes = existNotes + \" \"\n                    end if\n                    t2.notes = existNotes + \"whois:done\"\n                    dbManager.upsertTarget(t2)\n                end if\n            end if\n        end if\n    end if\n\n    // ── /etc/passwd ───────────────────────────────────────────────────────\n    // Check what we already have vs what privilege can give us now\n    // KEY: use LAN IP as primary key when available - different LAN machines\n    // share the same public IP so checking by public IP causes false skips\n    checkIp = publicIp\n    if lanIp.len > 0 and lanIp != \"unknown\" and lanIp != publicIp then\n        checkIp = lanIp\n    end if\n    existingCreds = dbManager.findCredentialsByIp(checkIp)\n    hasRootHash   = false\n    allUsersCracked = true\n    crackedCount  = 0\n    for ec in existingCreds\n        if ec.type == \"system\" and ec.username == \"root\" and ec.password.len > 0 then\n            hasRootHash = true\n        end if\n        if ec.type == \"system\" and ec.password.len == 0 then\n            allUsersCracked = false\n        end if\n        if ec.type == \"system\" and ec.password.len > 0 then\n            crackedCount = crackedCount + 1\n        end if\n    end for\n\n    skipPasswd = false\n    if forceSkipPasswd then\n        skipPasswd = true\n        ui.dim(\"passwd: skipping (handled by escalation strategy)\")\n    else if priv == \"root\" and hasRootHash and allUsersCracked then\n        skipPasswd = true\n        ui.dim(\"passwd: all hashes already cracked - skipping\")\n    else if priv != \"root\" and crackedCount > 0 then\n        skipPasswd = true\n        ui.dim(\"passwd: \" + str(crackedCount) + \" creds in DB, need root for complete harvest - skipping\")\n    end if\n\n    if not skipPasswd then\n        ui.info(\"Harvesting /etc/passwd...\")\n        passwdResult = self.harvestPasswd(handler, publicIp, lanIp)\n        if passwdResult isa Error then\n            ui.warning(\"passwd: \" + passwdResult.message)\n        else\n            summary.passwd = passwdResult\n            ui.success(\"passwd: \" + passwdResult.cracked + \" cracked, \" + passwdResult.failed + \" failed\")\n        end if\n    end if\n\n    // ── Mail files ────────────────────────────────────────────────────────\n    // Always check by public IP - LAN IPs like 192.168.0.2 are shared across\n    // many unrelated machines and cause false positive skips\n    mailCreds = 0\n    mailCredsForIp = dbManager.findCredentialsByIp(publicIp)\n    for ec in mailCredsForIp\n        if ec.type == \"mail\" then\n            ecSource = \"\"\n            if ec.hasIndex(\"source\") then\n                ecSource = ec.source\n            end if\n            if ecSource != \"routerattack\" and ecSource != \"routerattack_file\" then\n                mailCreds = mailCreds + 1\n            end if\n        end if\n    end for\n\n    if mailCreds > 0 then\n        ui.dim(\"mail: \" + str(mailCreds) + \" mail creds in DB - skipping\")\n    else\n        ui.info(\"Harvesting mail files...\")\n        mailResult = self.harvestMail(handler, publicIp, lanIp)\n        if mailResult isa Error then\n            ui.warning(\"mail: \" + mailResult.message)\n        else\n            summary.mail = mailResult\n            ui.success(\"mail: \" + mailResult.persons + \" persons, \" + mailResult.passwords + \" passwords\")\n        end if\n    end if\n\n    // ── Bank files ────────────────────────────────────────────────────────\n    // Always check by public IP for same reason as mail\n    bankCreds = 0\n    for ec in mailCredsForIp\n        if ec.type == \"bank\" then\n            ecSource = \"\"\n            if ec.hasIndex(\"source\") then\n                ecSource = ec.source\n            end if\n            if ecSource != \"routerattack\" and ecSource != \"routerattack_file\" then\n                bankCreds = bankCreds + 1\n            end if\n        end if\n    end for\n\n    if bankCreds > 0 then\n        ui.dim(\"bank: \" + str(bankCreds) + \" records in DB - skipping\")\n    else\n        ui.info(\"Harvesting bank files...\")\n        bankResult = self.harvestBank(handler, publicIp, lanIp)\n        if bankResult isa Error then\n            ui.warning(\"bank: \" + bankResult.message)\n        else\n            summary.bank = bankResult\n            ui.success(\"bank: \" + bankResult.harvested + \" records\")\n        end if\n    end if\n\n    // Save\n    dbManager.save()\n    ui.success(\"Database saved.\")\n\n    return summary\nend function\n\n// ---- Check bounce candidacy ----\n\nIntelManager.checkBounceCandidate = function(publicIp, lanIp)\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler        = sessionManager.currentSession.handler\n\n    // Check for SSH port\n    ports = handler.getPorts()\n    if ports isa Error then\n        return false\n    end if\n    hasSsh = false\n    for port in ports\n        if port.port_number == 22 then\n            hasSsh = true\n        end if\n    end for\n    if not hasSsh then\n        return false\n    end if\n\n    // Check for cracked root password in database\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    creds = dbManager.findCredentialsByIp(publicIp)\n    for cred in creds\n        if cred.type == CRED_TYPES.SYSTEM and cred.username == \"root\" and cred.password.len > 0 then\n            return cred.password\n        end if\n    end for\n\n    return false\nend function\n\nIntelManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nIntelManager.New = function()\n    result = new IntelManager\n    return result\nend function\n",1)
m("/Corvid/source/managers/attack-manager.txt","// CORVID 2.0 | managers/attack/attack-manager\n// Orchestrates the full attack workflow.\n// Checks database for existing exploit data before scanning.\n// Stores results back to database after testing.\n// Feeds target records into the database automatically.\n// ============================================================\n\nAttackManager = {}\nAttackManager.mediator = null\n\nAttackManager.buildLibKey = function(lib)\n    // lib here is a raw MetaLib from dump_lib()\n    return lib.lib_name + \"_\" + lib.version\nend function\n\nAttackManager.getOrCreateTarget = function(publicIp, lanIp, routerIp)\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    existing  = dbManager.findTarget(publicIp)\n    if existing.len > 0 then\n        return existing[0]\n    end if\n\n    targetData = {}\n    targetData.public_ip = publicIp\n    targetData.lan_ip    = lanIp\n    targetData.router_ip = routerIp\n    targetData.status    = TARGET_STATUS.UNKNOWN\n    id = dbManager.upsertTarget(targetData)\n    return dbManager.getTarget(id)\nend function\n\nAttackManager.runScan = function(publicIp, port, lanIp, routerIp)\n    // Perform a scan cycle, storing results to DB.\n    // Checks exploit KB first to skip scanning known lib/versions.\n    ui           = self.mediator.getExtension(\"corvidUi\")\n    dbManager    = self.mediator.getExtension(\"databaseManager\")\n    metaxManager = self.mediator.getExtension(\"metaxploitManager\")\n\n    target = self.getOrCreateTarget(publicIp, lanIp, routerIp)\n\n    metaxploit = metaxManager.getMetaxploit()\n    if metaxploit isa Error then\n        return metaxploit\n    end if\n\n    session = metaxploit.netUse(publicIp, port)\n    if session isa Error then\n        return session\n    end if\n\n    rawLib = session.dump_lib()\n    if rawLib == null then\n        return Error.New(\"Could not get target library\", \"DUMP_LIB_ERROR\")\n    end if\n\n    libName    = rawLib.lib_name\n    libVersion = rawLib.version\n    libKey     = self.buildLibKey(rawLib)\n\n    // ── Check exploit KB first ────────────────────────────────────────────\n    kbResults = dbManager.kbLookup(libName, libVersion)\n    if kbResults.len > 0 then\n        // Build storable list from KB records - prioritise successes\n        fromKb = []\n        for kr in kbResults\n            if kr.outcome == \"success\" then\n                entry = {}\n                entry.address   = kr.address\n                entry.exploit   = kr.exploit\n                entry.rtype     = kr.rtype\n                entry.privilege = kr.privilege\n                fromKb.push(entry)\n            end if\n        end for\n        // Also include constraint_blocked - conditions may have changed\n        for kr in kbResults\n            if kr.outcome == \"constraint_blocked\" then\n                entry = {}\n                entry.address   = kr.address\n                entry.exploit   = kr.exploit\n                entry.rtype     = kr.rtype\n                entry.privilege = kr.privilege\n                fromKb.push(entry)\n            end if\n        end for\n        if fromKb.len > 0 then\n            ui.success(\"KB hit: \" + libName + \" v\" + libVersion + \" - \" + str(fromKb.len) + \" known exploit(s) - skipping scan\")\n            // Store to per-target DB too so deep escalation can find them\n            existing = dbManager.getExploits(target.id, libKey)\n            if existing.len == 0 then\n                dbManager.storeExploits(target.id, libKey, fromKb)\n            end if\n            return fromKb\n        end if\n        ui.dim(\"KB: \" + libName + \" v\" + libVersion + \" known but no successes yet - running full scan\")\n    end if\n\n    // ── Check per-target cache ────────────────────────────────────────────\n    existing = dbManager.getExploits(target.id, libKey)\n    if existing.len > 0 then\n        ui.info(\"Existing exploit data found for \" + libKey + \"  -  \" + existing.len + \" record(s)\")\n        return existing\n    end if\n\n    // ── Full scan (respect kbFallback toggle) ─────────────────────────────\n    kbFallbackCfg = \"1\"\n    cfgMgrScan = self.mediator.getExtension(\"configManager\")\n    if cfgMgrScan != null then\n        kbFbVal = cfgMgrScan.get(\"kbFallback\")\n        if not (kbFbVal isa Error) then\n            kbFallbackCfg = kbFbVal\n        end if\n    end if\n    if kbFallbackCfg != \"1\" then\n        ui.dim(\"  kbFallback OFF — skipping full scan for unknown lib\")\n        return []\n    end if\n    ui.info(\"Scanning \" + publicIp + \":\" + str(port) + \" (\" + libKey + \")...\")\n    results = metaxManager.hack(publicIp, port)\n    if results isa Error then\n        return results\n    end if\n\n    ui.success(\"Found \" + str(results.len) + \" result(s).\")\n\n    // Feed raw scan texts into shinylibs while we have the lib loaded\n    shinyMgr = self.mediator.getExtension(\"shinyLibsManager\")\n    if shinyMgr != null then\n        configMgr = self.mediator.getExtension(\"configManager\")\n        autoShiny = configMgr.get(\"autoShiny\")\n        if autoShiny isa Error then\n            autoShiny = \"1\"\n        end if\n        if autoShiny == \"1\" then\n            metaFacade = metaxManager.getMetaxploit()\n            if not (metaFacade isa Error) then\n                exploitTexts = []\n                addrs = metaFacade.scan(rawLib)\n                if addrs != null then\n                    for addr in addrs\n                        txt = metaFacade.scanAddress(rawLib, addr)\n                        if txt != null and not (txt isa Error) then\n                            exploitTexts.push(txt)\n                        end if\n                    end for\n                end if\n                if exploitTexts.len > 0 then\n                    shinyType = shinyMgr.db.stage(libName, libVersion, exploitTexts, \"\")\n                    if shinyType != null then\n                        ui.dim(\"  [shiny] \" + libName + \" v\" + libVersion + \" staged as \" + shinyType)\n                    end if\n                end if\n            end if\n        end if\n    end if\n\n    // Store metadata to per-target DB and exploit KB\n    storable = []\n    for r in results\n        entry = {}\n        entry.address   = r.address\n        entry.exploit   = r.exploit\n        entry.rtype     = r.rtype\n        entry.privilege = r.privilege\n        storable.push(entry)\n\n        // Record in KB - determine outcome from rtype\n        kbOutcome = \"uncertain\"\n        kbRtype   = r.rtype\n        kbPath    = \"\"\n        kbPriv    = \"\"\n        if r.rtype == \"shell\" or r.rtype == \"computer\" then\n            kbOutcome = \"success\"\n            kbPriv    = r.privilege\n        else if r.rtype == \"file\" then\n            kbOutcome = \"success\"\n            kbPath    = r.privilege  // privilege field holds path for file results\n        else if r.rtype == \"Failed\" then\n            kbOutcome = \"uncertain\"\n        end if\n        // Constraints not available from hack() - will be populated on explicit exploit attempt\n        dbManager.kbRecord(libName, libVersion, r.address, r.exploit, kbOutcome, [], kbRtype, kbPath, kbPriv, \"\")\n    end for\n\n    dbManager.storeExploits(target.id, libKey, storable)\n\n    hasBetter = false\n    for r in results\n        if r.rtype == \"shell\" or r.rtype == \"computer\" then\n            hasBetter = true\n        end if\n    end for\n    if hasBetter then\n        dbManager.setTargetStatus(target.id, TARGET_STATUS.SCANNED)\n    end if\n\n    portRecord = {}\n    portRecord.port      = port\n    portRecord.service   = libName\n    portRecord.version   = libVersion\n    portRecord.forwarded = true\n    portRecord.exploited = false\n    targetData = {}\n    targetData.public_ip = publicIp\n    targetData.lan_ip    = lanIp\n    targetData.ports     = [portRecord]\n    dbManager.upsertTarget(targetData)\n    dbManager.save()\n    return storable\nend function\n\nAttackManager.exploit = function(publicIp, port, lanIp, routerIp, resultIndex)\n    // Run a specific exploit by index from the stored results.\n    ui           = self.mediator.getExtension(\"corvidUi\")\n    dbManager    = self.mediator.getExtension(\"databaseManager\")\n    metaxManager = self.mediator.getExtension(\"metaxploitManager\")\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n\n    // Get target and lib key\n    metaxploit = metaxManager.getMetaxploit()\n    if metaxploit isa Error then\n        return metaxploit\n    end if\n\n    session = metaxploit.netUse(publicIp, port)\n    if session isa Error then\n        return session\n    end if\n    rawLib = session.dump_lib()\n    if rawLib == null then\n        return Error.New(\"Could not get target library\", \"DUMP_LIB_ERROR\")\n    end if\n    libKey = self.buildLibKey(rawLib)\n\n    target = self.getOrCreateTarget(publicIp, lanIp, routerIp)\n    storedResults = dbManager.getExploits(target.id, libKey)\n    if storedResults.len == 0 then\n        return Error.New(\"No scan data found. Run scan first.\", \"NO_SCAN_DATA\")\n    end if\n\n    if resultIndex == null then\n        // Auto-select best\n        selected = self.autoSelectBest(storedResults)\n    else\n        if not storedResults.hasIndex(resultIndex) then\n            return Error.New(\"Invalid result index: \" + resultIndex, \"OUT_OF_RANGE\")\n        end if\n        selected = storedResults[resultIndex]\n    end if\n\n    if selected == null then\n        return Error.New(\"No usable exploit found in stored results\", \"NO_EXPLOIT\")\n    end if\n\n    ui.info(\"Running exploit: \" + selected.address + \" | \" + selected.exploit)\n\n    // If this is a password-change exploit, attempt to harvest the CURRENT\n    // root password BEFORE we change it, so native_pass can be preserved\n    if selected.hasIndex(\"privilege\") and selected.privilege.len > 0 and selected.privilege != \"none\" and selected.privilege != \"guest\" then\n        ui.info(\"Password-change exploit detected - attempting to read current passwd first...\")\n        crypto = include_lib(\"/lib/crypto.so\")\n        if crypto == null then\n            crypto = include_lib(current_path + \"/crypto.so\")\n        end if\n        if crypto != null then\n            // Try to get the target computer via a net_use connection\n            preNet = metaxploit.netUse(publicIp, port)\n            if not (preNet isa Error) then\n                // Use the session to get computer object if possible\n                // Attempt via any existing shell session for this IP\n                existingSessions = sessionManager.sessions\n                for es in existingSessions\n                    if es.data.ip.public != publicIp then\n                        continue\n                    end if\n                    if not (es.handler isa ShellSession) then\n                        continue\n                    end if\n                    // Try to read /etc/passwd on the target\n                    passwdFile = es.handler.getFile(\"/etc/passwd\")\n                    if passwdFile isa Error then\n                        continue\n                    end if\n                    rawHash = passwdFile.content()\n                    if rawHash isa Error or rawHash.len == 0 then\n                        continue\n                    end if\n                    nativePass = crypto.decipher(rawHash)\n                    if nativePass != null and nativePass.len > 0 then\n                        ui.success(\"  Native root password captured: \" + nativePass)\n                        // Save as native credential BEFORE the change\n                        nativeCred = {}\n                        nativeCred.type      = \"system\"\n                        nativeCred.username  = selected.privilege\n                        nativeCred.password  = nativePass\n                        nativeCred.public_ip = publicIp\n                        nativeCred.lan_ip    = lanIp\n                        nativeCred.source    = \"native\"\n                        dbManager.upsertCredential(nativeCred)\n                        dbManager.save()\n                        ui.info(\"  Saved native credential to DB before password change\")\n                    end if\n                    break\n                end for\n            end if\n        end if\n    end if\n\n    // Generate a clean alphanumeric password for password-change exploits\n    genPass = genRandomPass(12, selected.address)\n\n    // Fresh connection - capture lib name/version for KB recording\n    freshSession = metaxploit.netUse(publicIp, port)\n    if freshSession isa Error then\n        return freshSession\n    end if\n    freshLib = freshSession.dump_lib()\n    if freshLib == null then\n        return Error.New(\"Could not reconnect\", \"CONNECT_ERROR\")\n    end if\n\n    kbLibName    = freshLib.lib_name\n    kbLibVersion = freshLib.version\n\n    // Check constraint state before attempting - record as blocked not failed\n    kbConstraints = []\n    kbExploitKb   = dbManager.getExploitKb()\n    // Look up known constraints for this exploit\n    kbExisting = dbManager.kbLookup(kbLibName, kbLibVersion)\n    for kbe in kbExisting\n        if kbe.address == selected.address and kbe.exploit == selected.exploit then\n            if kbe.hasIndex(\"constraints\") and kbe.constraints.len > 0 then\n                for cs in kbe.constraints.split(\" \")\n                    if cs.len > 0 then\n                        kbConstraints.push(cs)\n                    end if\n                end for\n            end if\n        end if\n    end for\n\n    // Check if any known constraints are currently unmet\n    if kbConstraints.len > 0 then\n        blockedBy = kbExploitKb.checkConstraints(kbConstraints, freshSession, lanIp)\n        if blockedBy.len > 0 then\n            ui.warning(\"Constraint not met: \" + blockedBy + \" - recording as blocked, not failed\")\n            dbManager.kbRecord(kbLibName, kbLibVersion, selected.address, selected.exploit, \"constraint_blocked\", kbConstraints, selected.rtype, \"\", \"\", blockedBy)\n            dbManager.save()\n            return Error.New(\"Constraint not met: \" + blockedBy, \"CONSTRAINT_BLOCKED\")\n        end if\n    end if\n\n    // Try WITHOUT genPass first - avoids changing root password unnecessarily\n    // Only fall back to genPass if this is a password-change exploit and the clean attempt failed\n    raw = freshLib.overflow(selected.address, selected.exploit)\n    passwordWasChanged = false\n\n    if (raw == null or typeof(raw) == \"string\") and self.isPasswordChange(selected) then\n        ui.dim(\"  Non-destructive attempt failed - trying password-change path...\")\n        raw = freshLib.overflow(selected.address, selected.exploit, genPass)\n        if raw != null and typeof(raw) != \"string\" then\n            passwordWasChanged = true\n        end if\n    end if\n\n    if raw == null then\n        dbManager.kbRecord(kbLibName, kbLibVersion, selected.address, selected.exploit, \"uncertain\", kbConstraints, selected.rtype, \"\", \"\", \"\")\n        dbManager.save()\n        return Error.New(\"Exploit returned null\", \"EXPLOIT_FAILED\")\n    end if\n    if typeof(raw) == \"string\" and raw.indexOf(\"alphanumeric\") != null then\n        dbManager.kbRecord(kbLibName, kbLibVersion, selected.address, selected.exploit, \"uncertain\", kbConstraints, selected.rtype, \"\", \"\", \"\")\n        dbManager.save()\n        return Error.New(\"Exploit failed: \" + raw + \" (password-change exploit with special chars)\", \"ALPHANUMERIC_ERROR\")\n    end if\n    if typeof(raw) == \"string\" then\n        dbManager.kbRecord(kbLibName, kbLibVersion, selected.address, selected.exploit, \"uncertain\", kbConstraints, selected.rtype, \"\", \"\", \"\")\n        dbManager.save()\n        return Error.New(\"Exploit failed: \" + raw, \"EXPLOIT_FAILED\")\n    end if\n\n    // Wrap result\n    result = computerObjectFactory(raw)\n    if result isa Error then\n        return result\n    end if\n\n    // Determine privilege\n    privilege = \"unknown\"\n    if result isa Shell then\n        comp = result.getComputer()\n        if not (comp isa Error) then\n            privilege = metaxManager.detectPrivilege(comp.computer)\n        end if\n    else if result isa Computer then\n        privilege = metaxManager.detectPrivilege(result.computer)\n    end if\n\n    // Record success in exploit KB\n    kbRtype   = typeof(result)\n    kbPath    = \"\"\n    kbPriv    = privilege\n    if result isa File then\n        kbPath  = result.path()\n        kbPriv  = \"\"\n    end if\n    dbManager.kbRecord(kbLibName, kbLibVersion, selected.address, selected.exploit, \"success\", kbConstraints, kbRtype, kbPath, kbPriv, \"\")\n\n    // Only save generated password if we actually changed it\n    // If the non-destructive path worked, the original password is intact\n    if passwordWasChanged and selected.hasIndex(\"privilege\") and selected.privilege.len > 0 then\n        credData = {}\n        credData.username  = selected.privilege\n        credData.password  = genPass\n        credData.type      = \"system\"\n        credData.public_ip = publicIp\n        credData.lan_ip    = lanIp\n        credData.source    = \"exploit_generated\"\n        dbManager.upsertCredential(credData)\n        ui.info(\"Password changed for \" + selected.privilege + \": \" + genPass)\n    end if\n\n    // Update database\n    dbManager.setTargetStatus(target.id, TARGET_STATUS.EXPLOITED)\n    targetData = {}\n    targetData.public_ip = publicIp\n    targetData.lan_ip    = lanIp\n    targetData.privilege = privilege\n    targetData.status    = TARGET_STATUS.EXPLOITED\n    dbManager.upsertTarget(targetData)\n    dbManager.save()\n\n    // Add as new session\n    newSession = sessionManager.addSession(raw, publicIp + \":\" + port)\n    if newSession isa Error then\n        return newSession\n    end if\n    sessionManager.setCurrentSession(newSession)\n\n    ui.success(\"Exploit succeeded. Session opened as: \" + privilege)\n\n    // Show shinylibs notification if anything was staged during runScan\n    shinyMgr = self.mediator.getExtension(\"shinyLibsManager\")\n    if shinyMgr != null and shinyMgr.db.staged.len > 0 then\n        shinyMgr.showStagedNotification()\n    end if\n\n    return result\nend function\n\nAttackManager.escalate = function()\n    // Attempt privilege escalation on current session.\n    // Strategy order:\n    //   0. Decipher /etc/passwd to surface root password\n    //   1. GCO sudo (get_shell) - works from guest, no open port required\n    //   2. Stored exploit direct root shell\n    //   3. connect_service SSH/FTP with known passwords (known ports only)\n    //   4. SCP local lib scan\n    //   5. Chainsaw password cracker via GCO RCE\n\n    ui             = self.mediator.getExtension(\"corvidUi\")\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    dbManager      = self.mediator.getExtension(\"databaseManager\")\n    metaxManager   = self.mediator.getExtension(\"metaxploitManager\")\n\n    currentSession = sessionManager.currentSession\n    handler        = currentSession.handler\n    if handler.type() != \"shell\" then\n        return Error.New(\"Escalation requires a shell session\", \"TYPE_ERROR\")\n    end if\n\n    if handler.privilege() == \"root\" then\n        ui.success(\"Already root.\")\n        return\n    end if\n\n    ip    = currentSession.data.ip.public\n    lanIp = currentSession.data.ip.local\n    rawShell = handler.shell.shell\n\n    // Collect root passwords to try (current + native)\n    creds = dbManager.findCredentialsByIp(ip)\n    if lanIp.len > 0 and lanIp != ip then\n        lanCreds = dbManager.findCredentialsByIp(lanIp)\n        for lc in lanCreds\n            creds.push(lc)\n        end for\n    end if\n\n    rootPasswords = dbManager.extractRootPasswords(ip)\n\n    // ── Pre-strategy: harvest current session to surface credentials ───────\n    // Harvest passwd, mail, bank before trying credentials - populates DB\n    // so that Strategy 2 has the best credential data to work with\n    intelManager = self.mediator.getExtension(\"intelManager\")\n    if not (intelManager isa Error) then\n        ui.info(\"Harvesting session before escalation attempt...\")\n        harvestResult = intelManager.harvestAll(ip, lanIp, true)\n        if not (harvestResult isa Error) then\n            ui.success(\"Harvest complete - credentials updated in DB\")\n            // Refresh creds from DB after harvest\n            creds = dbManager.findCredentialsByIp(ip)\n            if lanIp.len > 0 and lanIp != ip then\n                lanCreds = dbManager.findCredentialsByIp(lanIp)\n                for lc in lanCreds\n                    creds.push(lc)\n                end for\n            end if\n            rootPasswords = dbManager.extractRootPasswords(ip)\n        end if\n    end if\n\n    // Load metaxploit once for all strategies\n    // Always use the current lib from libManager - this will be the roost\n    // node's lib if roost pick was used, otherwise falls back to Nest lib.\n    // Strategy 1 uses net_use which always routes from Nest regardless - skip\n    // it when on a non-pivot session to avoid exposing Nest IP.\n    metaLib = metaxManager.getMetaxploit()\n    if metaLib isa Error then\n        meta = null\n    else\n        meta = metaLib.metaxploit\n    end if\n\n    onPivot = (currentSession == sessionManager.pivotSession)\n\n    // ── Strategy 0: decipher /etc/passwd directly ────────────────────────\n    // Always attempt this regardless of what's in DB - we need the current\n    // machine's root hash cracked. Bypass harvest skip logic entirely.\n    ui.info(\"Deciphering /etc/passwd...\")\n    passwdResult = intelManager.harvestPasswd(currentSession.handler, ip, lanIp)\n    if passwdResult isa Error then\n        ui.warning(\"passwd: \" + passwdResult.message)\n    else\n        ui.success(\"passwd: \" + str(passwdResult.cracked) + \" cracked, \" + str(passwdResult.failed) + \" failed\")\n        // Refresh rootPasswords from DB after decipher\n        creds = dbManager.findCredentialsByIp(ip)\n        if lanIp.len > 0 and lanIp != ip then\n            for lc in dbManager.findCredentialsByIp(lanIp)\n                creds.push(lc)\n            end for\n        end if\n        rootPasswords = []\n        for cred in creds\n            if cred.type != CRED_TYPES.SYSTEM then\n                continue\n            end if\n            if cred.username != \"root\" then\n                continue\n            end if\n            if cred.password.len > 0 and rootPasswords.indexOf(cred.password) == null then\n                rootPasswords.push(cred.password)\n            end if\n            if cred.hasIndex(\"native_pass\") and cred.native_pass.len > 0 then\n                if rootPasswords.indexOf(cred.native_pass) == null then\n                    rootPasswords.push(cred.native_pass)\n                end if\n            end if\n        end for\n    end if\n\n    ui.info(\"Checking stored exploits for direct root shell...\")\n    targets = dbManager.findTarget(ip)\n    foundRootShell = false\n\n    // ── Strategy 1: GCO sudo (get_shell without SSH port) ────────────────\n    // First attempt - works from guest and user, no open port required.\n    // Requires a cracked root password in rootPasswords AND a writable path.\n    if rootPasswords.len > 0 then\n        ui.info(\"Strategy 1: attempting escalation via Clover Method...\")\n        wp3 = findWritePerms(rawShell)\n        if wp3 == null then\n            ui.dim(\"  GCO: no writable path found - skipping\")\n        else\n            sudoPass3 = rootPasswords[0]\n            q = char(34)\n            sudoSrcLines = \"cob = get_custom_object\" + char(10)\n            sudoSrcLines = sudoSrcLines + \"cob.shell = get_shell(\" + q + \"root\" + q + \", \" + q + sudoPass3 + q + \")\"\n            rawShell.host_computer.touch(wp3.path, \"csudo.src\")\n            sudoSrcFile = rawShell.host_computer.File(wp3.path + \"/csudo.src\")\n            if sudoSrcFile == null then\n                ui.dim(\"  GCO: could not create script file - skipping\")\n            else\n                sudoSrcFile.set_content(sudoSrcLines)\n                buildResult3 = rawShell.build(wp3.path + \"/csudo.src\", wp3.path)\n                if buildResult3.len > 0 then\n                    ui.dim(\"  GCO: build failed - \" + buildResult3)\n                    csudoSrc = rawShell.host_computer.File(wp3.path + \"/csudo.src\")\n                    if csudoSrc != null then\n                        csudoSrc.delete()\n                    end if\n                else\n                    rawShell.launch(wp3.path + \"/csudo\")\n                    cob3 = get_custom_object\n                    if cob3.hasIndex(\"shell\") and typeof(cob3.shell) == \"shell\" then\n                        sudoShell3 = cob3.shell\n                        for s3name in [\"csudo.src\", \"csudo\"]\n                            s3f = rawShell.host_computer.File(wp3.path + \"/\" + s3name)\n                            if s3f != null then\n                                s3f.delete()\n                            end if\n                        end for\n                        newSess3 = sessionManager.addSession(sudoShell3, \"root@\" + ip)\n                        if not (newSess3 isa Error) then\n                            sessionManager.setCurrentSession(newSess3)\n                            targetsForUpdate = dbManager.findTarget(ip)\n                            if targetsForUpdate.len > 0 then\n                                dbManager.setTargetStatus(targetsForUpdate[0].id, TARGET_STATUS.EXPLOITED)\n                                updateData3 = {}\n                                updateData3.public_ip = ip\n                                updateData3.lan_ip    = lanIp\n                                updateData3.privilege = \"root\"\n                                updateData3.status    = TARGET_STATUS.EXPLOITED\n                                dbManager.upsertTarget(updateData3)\n                            end if\n                            credUpdate3 = {}\n                            credUpdate3.type      = CRED_TYPES.SYSTEM\n                            credUpdate3.username  = \"root\"\n                            credUpdate3.password  = sudoPass3\n                            credUpdate3.public_ip = ip\n                            credUpdate3.lan_ip    = lanIp\n                            credUpdate3.source    = \"sudo_escalation\"\n                            dbManager.upsertCredential(credUpdate3)\n                            dbManager.save()\n                            ui.success(\"Escalated to root via Clover Method\")\n                            return newSess3\n                        end if\n                    else\n                        ui.dim(\"  GCO: get_shell returned no shell - skipping\")\n                        for s3name in [\"csudo.src\", \"csudo\"]\n                            s3f2 = rawShell.host_computer.File(wp3.path + \"/\" + s3name)\n                            if s3f2 != null then\n                                s3f2.delete()\n                            end if\n                        end for\n                    end if\n                end if\n            end if\n        end if\n    else\n        ui.dim(\"  GCO: no cracked root password available - skipping\")\n    end if\n\n    // ── Strategy 2: stored exploit direct root shell ──────────────────────\n    if true then\n        for tgt in targets\n            if foundRootShell then\n                break\n            end if\n            if not tgt.hasIndex(\"exploit_db\") then\n                continue\n            end if\n            for libKey in tgt.exploit_db.indexes\n                if foundRootShell then\n                    break\n                end if\n                for ex in tgt.exploit_db[libKey]\n                    if ex.rtype != \"shell\" then\n                        continue\n                    end if\n                    if ex.privilege != \"root\" then\n                        continue\n                    end if\n                    targetPort = 0\n                    for pr in tgt.ports\n                        lm = pr.service + \"_\" + pr.version\n                        if libKey.indexOf(lm) != null then\n                            targetPort = pr.port\n                        end if\n                    end for\n                    if targetPort == 0 then\n                        continue\n                    end if\n                    if meta == null then\n                        continue\n                    end if\n                    netSess = meta.net_use(ip, targetPort)\n                    if not netSess then\n                        continue\n                    end if\n                    rawLib = netSess.dump_lib\n                    if not rawLib then\n                        continue\n                    end if\n                    result = rawLib.overflow(ex.address, ex.exploit)\n                    if result == null or typeof(result) == \"string\" then\n                        continue\n                    end if\n                    if typeof(result) != \"shell\" then\n                        continue\n                    end if\n                    newSession = sessionManager.addSession(result, \"root@\" + ip)\n                    if newSession isa Error then\n                        continue\n                    end if\n                    sessionManager.setCurrentSession(newSession)\n                    ui.success(\"Escalated to root via direct exploit on port \" + str(targetPort))\n                    foundRootShell = true\n                    return newSession\n                end for\n            end for\n        end for\n    end if\n\n    // ── Strategy 3: connect_service SSH and FTP ports ─────────────────────\n    // Only tries ports actually found on the target - no blind port 22/21\n    // fallback since GCO already handles the no-SSH case above.\n    sshPorts = []\n    ftpPorts = []\n    for tgt in targets\n        if not tgt.hasIndex(\"ports\") then\n            continue\n        end if\n        for pr in tgt.ports\n            if pr.service == \"ssh\" then\n                alreadyIn = false\n                for ep in sshPorts\n                    if ep.port == pr.port then\n                        alreadyIn = true\n                    end if\n                end for\n                if not alreadyIn then\n                    sshPorts.push(pr)\n                end if\n            else if pr.service == \"ftp\" then\n                alreadyIn = false\n                for ep in ftpPorts\n                    if ep.port == pr.port then\n                        alreadyIn = true\n                    end if\n                end for\n                if not alreadyIn then\n                    ftpPorts.push(pr)\n                end if\n            end if\n        end for\n    end for\n\n    if rootPasswords.len == 0 then\n        ui.warning(\"No root credentials found - skipping connect_service attempts\")\n    else\n        ui.info(\"Trying \" + str(rootPasswords.len) + \" root password(s) across available service ports...\")\n        for pass in rootPasswords\n            for portRec in sshPorts\n                ui.info(\"  Trying ssh port \" + str(portRec.port) + \" with password: \" + pass + \"...\")\n                result = rawShell.connect_service(ip, portRec.port, \"root\", pass, \"ssh\")\n                if typeof(result) == \"shell\" then\n                    newSession = sessionManager.addSession(result, \"root@\" + ip)\n                    if not (newSession isa Error) then\n                        sessionManager.setCurrentSession(newSession)\n                        ui.success(\"Escalated to root via ssh port \" + str(portRec.port))\n                        return newSession\n                    end if\n                end if\n            end for\n            for portRec in ftpPorts\n                ui.info(\"  Trying ftp port \" + str(portRec.port) + \" with password: \" + pass + \"...\")\n                result = rawShell.connect_service(ip, portRec.port, \"root\", pass, \"ftp\")\n                if typeof(result) == \"shell\" then\n                    newSession = sessionManager.addSession(result, \"ftp-root@\" + ip)\n                    if not (newSession isa Error) then\n                        sessionManager.setCurrentSession(newSession)\n                        ui.success(\"Got ftp root access on port \" + str(portRec.port))\n                        return newSession\n                    end if\n                end if\n            end for\n        end for\n    end if // end of Strategy 3\n\n    // ── Strategy 4: SCP local lib scan ─────────────────────────────────\n    // Pull target's .so files to Nest, scan with metaxploit, try overflows\n    // against target's open ports. Records all results in exploit KB.\n    ui.info(\"Strategy 4: scanning target local libraries via SCP...\")\n    pivotSession2 = sessionManager.pivotSession\n    pivotHandler2 = pivotSession2.handler\n    pivotShell2   = pivotHandler2.shell.shell\n    nestComp      = pivotShell2.host_computer\n\n    // Get target lib folder\n    targetLibFolder = handler.getFile(\"/lib\")\n    localLibWorked  = false\n\n    if not (targetLibFolder isa Error) then\n        libFiles = targetLibFolder.children()\n        if libFiles != null then\n            scannedLibs = []\n            for lf in libFiles\n                lfName = lf.name()\n                if lfName.indexOf(\".so\") == null then\n                    continue\n                end if\n                if lf.isBinary() == false then\n                    continue\n                end if\n\n                // SCP the lib file to Nest /tmp\n                scpDest = \"/shiny/\" + lfName\n                scpErr = pivotShell2.scp(lf.path(), \"/shiny\", handler.shell.shell)\n                if typeof(scpErr) == \"string\" and scpErr.len > 0 then\n                    continue\n                end if\n\n                // Load it on Nest with metaxploit\n                if meta == null then\n                    continue\n                end if\n                nestLib = meta.load(scpDest)\n                if nestLib == null then\n                    // Clean up and skip\n                    tmpF = nestComp.File(scpDest)\n                    if tmpF != null then\n                        tmpF.delete()\n                    end if\n                    continue\n                end if\n\n                ui.info(\"  Scanning \" + lfName + \" v\" + nestLib.version + \"...\")\n                scannedLibs.push(scpDest)\n\n                // Scan for vulnerable addresses\n                addresses = meta.scan(nestLib)\n                if addresses == null or addresses.len == 0 then\n                    continue\n                end if\n\n                // Try each address against all open ports on target\n                for addr in addresses\n                    scanText = meta.scan_address(nestLib, addr)\n                    if scanText == null then\n                        continue\n                    end if\n\n                    // Parse exploit names\n                    vulnNames = []\n                    chunks = scanText.split(\"Unsafe check: \")\n                    for chunk in chunks\n                        if chunk == chunks[0] then\n                            continue\n                        end if\n                        bStart = chunk.indexOf(\"<b>\")\n                        bEnd   = chunk.indexOf(\"</b>\")\n                        if bStart != null and bEnd != null then\n                            vn = chunk[bStart+3:bEnd]\n                            if vn.len > 0 then\n                                vulnNames.push(vn)\n                            end if\n                        end if\n                    end for\n\n                    for vn in vulnNames\n                        // Try overflow - no port needed for local lib\n                        result4 = nestLib.overflow(addr, vn)\n                        if result4 == null then\n                            continue\n                        end if\n                        r4Type = typeof(result4)\n                        if r4Type == \"string\" then\n                            continue\n                        end if\n\n                        // Record in KB\n                        kbLibName4  = nestLib.lib_name\n                        kbLibVer4   = nestLib.version\n                        r4Priv = \"\"\n                        if r4Type == \"shell\" then\n                            r4Priv = \"user\"\n                        end if\n                        dbManager.kbRecord(kbLibName4, kbLibVer4, addr, vn, \"success\", [], r4Type, \"\", r4Priv, ip)\n                        dbManager.save()\n\n                        ui.success(\"  Local lib hit: \" + lfName + \" / \" + vn + \" -> \" + r4Type)\n\n                        if r4Type == \"shell\" then\n                            newSess4 = sessionManager.addSession(result4, \"user@\" + ip)\n                            if not (newSess4 isa Error) then\n                                sessionManager.setCurrentSession(newSess4)\n                                localLibWorked = true\n                                // Clean up scp'd files\n                                for scpPath in scannedLibs\n                                    cF = nestComp.File(scpPath)\n                                    if cF != null then\n                                        cF.delete()\n                                    end if\n                                end for\n                                ui.success(\"Got user shell via local lib exploit on \" + ip)\n                                return newSess4\n                            end if\n                        end if\n                    end for\n                end for\n\n                // Clean up this lib from Nest /tmp\n                tmpF2 = nestComp.File(scpDest)\n                if tmpF2 != null then\n                    tmpF2.delete()\n                end if\n            end for\n\n            // Clean up any remaining scp'd files\n            for scpPath in scannedLibs\n                cF2 = nestComp.File(scpPath)\n                if cF2 != null then\n                    cF2.delete()\n                end if\n            end for\n        end if\n    end if\n\n    if localLibWorked then\n        return\n    end if\n\n    // ── Strategy 5: Chainsaw via GCO RCE ───────────────────────────────────\n    // SCP chainsaw binary to target, run it there via RCE.\n    // Chainsaw loads into GCO on target, cracks root locally, returns shell.\n    ui.info(\"Chainsaw: attempting escalation via GCO RCE...\")\n    csBinPath = \"/Corvid/tools/chainsaw/chainsaw\"\n    csBinFile = sessionManager.pivotSession.handler.getFile(csBinPath)\n    if csBinFile isa Error then\n        ui.dim(\"  Chainsaw binary not found - run: chainsaw build\")\n    else\n        wp = findWritePerms(rawShell)\n        if wp != null then\n            // SCP chainsaw binary to target\n            pivotShell = sessionManager.pivotSession.handler.shell.shell\n            scpResult = pivotShell.scp(csBinPath, wp.path, rawShell)\n            if typeof(scpResult) == \"string\" and scpResult.len > 0 then\n                ui.dim(\"  Chainsaw RCE: SCP failed - \" + scpResult)\n            else\n                // Write RCE script that loads chainsaw and cracks\n                q = char(34)\n                nl = char(10)\n                rceLines = \"chainsaw = get_custom_object.chainsaw\" + nl\n                rceLines = rceLines + \"chainsaw.init()\" + nl\n                rceLines = rceLines + \"chainsaw.crack()\"\n                rawShell.host_computer.touch(wp.path, \"cs_esc.src\")\n                rceFile = rawShell.host_computer.File(wp.path + \"/cs_esc.src\")\n                if rceFile != null then\n                    rceFile.set_content(rceLines)\n                    // Launch chainsaw binary first (--load puts it in GCO)\n                    rawShell.launch(wp.path + \"/chainsaw\", \"load\")\n                    // Build and run RCE script\n                    buildResult = rawShell.build(wp.path + \"/cs_esc.src\", wp.path)\n                    if buildResult.len == 0 then\n                        rawShell.launch(wp.path + \"/cs_esc\")\n                        if get_custom_object.hasIndex(\"chainsaw\") and get_custom_object.chainsaw != null then\n                            csRceShell = get_custom_object.chainsaw.shell\n                            csRcePass  = get_custom_object.chainsaw.password\n                            if typeof(csRceShell) == \"shell\" then\n                                ui.success(\"Chainsaw RCE cracked root password: \" + csRcePass)\n                                csRceCredData = {}\n                                csRceCredData.type      = CRED_TYPES.SYSTEM\n                                csRceCredData.username  = \"root\"\n                                csRceCredData.password  = csRcePass\n                                csRceCredData.public_ip = ip\n                                csRceCredData.lan_ip    = lanIp\n                                csRceCredData.source    = \"chainsaw\"\n                                dbManager.upsertCredential(csRceCredData)\n                                dbManager.save()\n                                // Clean up\n                                for cleanName in [\"chainsaw\", \"cs_esc.src\", \"cs_esc\"]\n                                    cf = rawShell.host_computer.File(wp.path + \"/\" + cleanName)\n                                    if cf != null then\n                                        cf.delete()\n                                    end if\n                                end for\n                                newSessRce = sessionManager.addSession(csRceShell, \"root@\" + ip)\n                                if not (newSessRce isa Error) then\n                                    sessionManager.setCurrentSession(newSessRce)\n                                    ui.success(\"Escalated to root via Chainsaw RCE\")\n                                    return newSessRce\n                                end if\n                            end if\n                        end if\n                    else\n                        ui.dim(\"  Chainsaw RCE: build failed - \" + buildResult)\n                    end if\n                    // Clean up regardless\n                    for cleanName in [\"chainsaw\", \"cs_esc.src\", \"cs_esc\"]\n                        cf2 = rawShell.host_computer.File(wp.path + \"/\" + cleanName)\n                        if cf2 != null then\n                            cf2.delete()\n                        end if\n                    end for\n                end if\n            end if\n        else\n            ui.dim(\"  Chainsaw RCE: no writable path found\")\n        end if\n    end if\n\n    // ── All strategies exhausted ─────────────────────────────────────────\n    ui.warning(\"Auto-escalation failed on all paths.\")\n    ui.print(\"\")\n    if rootPasswords.len > 0 then\n        ui.info(\"Root password(s) found - try manually:\")\n        for pass in rootPasswords\n            ui.success(\"  sudo -s  ->  \" + pass)\n        end for\n    end if\n    ui.info(\"Tips:\")\n    ui.print(\"  portfwd add 2222 22 \" + lanIp + \"  then re-run escalate\")\n    ui.print(\"  Or activate a native terminal and run: sudo -s\")\n    return Error.New(\"Auto-escalation failed - manual sudo required\", \"MANUAL_REQUIRED\")\nend function\n\nAttackManager.isPasswordChange = function(r)\n    // A password-change exploit has privilege set to the username whose password is changed\n    // (not root, guest, none, unknown, or empty)\n    if not r.hasIndex(\"privilege\") then\n        return false\n    end if\n    p = r.privilege\n    if p.len == 0 then\n        return false\n    end if\n    if p == \"root\" or p == \"guest\" or p == \"none\" or p == \"unknown\" then\n        return false\n    end if\n    return true\nend function\n\nAttackManager.autoSelectBest = function(results)\n    // Pass 1: root shell, non-password-change\n    for r in results\n        if r.rtype == \"shell\" and r.privilege == \"root\" and not self.isPasswordChange(r) then\n            return r\n        end if\n    end for\n    // Pass 2: any shell, non-password-change\n    for r in results\n        if r.rtype == \"shell\" and not self.isPasswordChange(r) then\n            return r\n        end if\n    end for\n    // Pass 3: root computer, non-password-change\n    for r in results\n        if r.rtype == \"computer\" and r.privilege == \"root\" and not self.isPasswordChange(r) then\n            return r\n        end if\n    end for\n    // Pass 4: any computer, non-password-change\n    for r in results\n        if r.rtype == \"computer\" and not self.isPasswordChange(r) then\n            return r\n        end if\n    end for\n    // Pass 5: file result\n    for r in results\n        if r.rtype == \"file\" then\n            return r\n        end if\n    end for\n    // Pass 6: password-change exploits as last resort\n    for r in results\n        if r.rtype == \"shell\" and r.privilege == \"root\" then\n            return r\n        end if\n    end for\n    for r in results\n        if r.rtype == \"shell\" then\n            return r\n        end if\n    end for\n    for r in results\n        if r.rtype == \"computer\" then\n            return r\n        end if\n    end for\n    return null\nend function\n\nAttackManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nAttackManager.New = function()\n    result = new AttackManager\n    return result\nend function\n",1)
m("/Corvid/source/managers/bounce-manager.txt","// ============================================================\n// CORVID 2.0 | managers/bounce/bounce-manager\n// Manages bounce chain sessions.\n// Bounce points are sessions tagged with bounce metadata.\n// Handles chain building, verification, and cleanup.\n// ============================================================\n\nBOUNCE_TYPES = {}\nBOUNCE_TYPES.OWNED       = \"owned\"\nBOUNCE_TYPES.COMPROMISED = \"compromised\"\n\nBounceManager = {}\nBounceManager.mediator = null\n\nBounceManager.getBounceTargets = function()\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    return dbManager.findBounces()\nend function\n\nBounceManager.addBounce = function(publicIp, lanIp, port, username, password, bounceType, sourceIp)\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    ui        = self.mediator.getExtension(\"corvidUi\")\n\n    if bounceType == null then\n        bounceType = BOUNCE_TYPES.COMPROMISED\n    end if\n\n    // Avoid creating a duplicate target record. If a record for this public_ip\n    // already exists, reuse its lan_ip so upsert's matchExisting succeeds and\n    // we update the existing row instead of inserting a second one.\n    existingForIp = dbManager.findTarget(publicIp)\n    if existingForIp.len > 0 then\n        rec0 = existingForIp[0]\n        if rec0.hasIndex(\"lan_ip\") and rec0.lan_ip.len > 0 then\n            // Existing record has a lan_ip - reuse it\n            lanIp = rec0.lan_ip\n        end if\n    end if\n\n    portRecord = {}\n    portRecord.port      = port\n    portRecord.service   = \"ssh\"\n    portRecord.version   = \"unknown\"\n    portRecord.forwarded = true\n    portRecord.exploited = true\n\n    targetData = {}\n    targetData.public_ip = publicIp\n    targetData.lan_ip    = lanIp\n    targetData.status    = TARGET_STATUS.BOUNCE\n    targetData.ports     = [portRecord]\n    // Don't append notes - existing record will keep its notes via upsert merge\n    // Only set notes on new records (upsert handles merge)\n    targetData.notes     = \"\"\n\n    id = dbManager.upsertTarget(targetData)\n\n    // Set the bounce marker only if not already present\n    existing = dbManager.findTarget(publicIp)\n    if existing.len > 0 then\n        rec = existing[0]\n        existingNotes = \"\"\n        if rec.hasIndex(\"notes\") then\n            existingNotes = rec.notes\n        end if\n        if existingNotes.indexOf(\"bounce:\" + bounceType) == null then\n            dbManager.addNote(\"target\", rec.id, \"bounce:\" + bounceType + \" source:\" + sourceIp)\n        end if\n    end if\n\n    // Store SSH credentials. Use \"owned\" as source - \"hardened\" is reserved for\n    // credentials that have actually been rotated by `bounces harden`.\n    credData = {}\n    credData.type      = \"system\"\n    credData.username  = username\n    credData.password  = password\n    credData.public_ip = publicIp\n    credData.lan_ip    = lanIp\n    credData.source    = \"owned\"\n    dbManager.upsertCredential(credData)\n    dbManager.save()\n\n    ui.success(\"Bounce point added: \" + publicIp + \" (\" + bounceType + \")\")\n    return id\nend function\n\nBounceManager.listBounces = function()\n    return self.getBounceTargets()\nend function\n\nBounceManager.verifyBounce = function(target)\n    ui           = self.mediator.getExtension(\"corvidUi\")\n    dbManager    = self.mediator.getExtension(\"databaseManager\")\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n\n    // Find SSH credentials using helper\n    sshCreds = dbManager.findRootSshCredentials(target.public_ip)\n    sshPass = sshCreds.password\n    sshNative = sshCreds.native_pass\n\n    if sshPass.len == 0 and sshNative.len == 0 then\n        ui.warning(\"No credentials found for: \" + target.public_ip)\n        return false\n    end if\n\n    sshPort = 22\n    for port in target.ports\n        if port.service == \"ssh\" then\n            sshPort = port.port\n        end if\n    end for\n\n    // Attempt connection - try current password then native_pass\n    pivotShell = sessionManager.pivotSession.handler.shell\n    result = null\n    if sshPass.len > 0 then\n        result = pivotShell.shell.connect_service(target.public_ip, sshPort, \"root\", sshPass, \"ssh\")\n    end if\n    if typeof(result) != \"shell\" and sshNative.len > 0 and sshNative != sshPass then\n        result = pivotShell.shell.connect_service(target.public_ip, sshPort, \"root\", sshNative, \"ssh\")\n    end if\n    if typeof(result) == \"shell\" then\n        ui.success(\"Bounce verified: \" + target.public_ip)\n        return true\n    else\n        ui.warning(\"Bounce unreachable: \" + target.public_ip + \"  -  \" + str(result))\n        return false\n    end if\nend function\n\nBounceManager.verifyAll = function()\n    bounces = self.getBounceTargets()\n    if bounces.len == 0 then\n        return Error.New(\"No bounce points configured\", \"EMPTY\")\n    end if\n    results = {}\n    for bTarget in bounces\n        results[bTarget.public_ip] = self.verifyBounce(bTarget)\n    end for\n    return results\nend function\n\nBounceManager.connect = function(target)\n    // Establish a session through a bounce point\n    ui             = self.mediator.getExtension(\"corvidUi\")\n    dbManager      = self.mediator.getExtension(\"databaseManager\")\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n\n    sshCreds = dbManager.findRootSshCredentials(target.public_ip)\n    sshPass = sshCreds.password\n    sshNative = sshCreds.native_pass\n\n    if sshPass.len == 0 and sshNative.len == 0 then\n        return Error.New(\"No credentials for bounce point: \" + target.public_ip, \"NO_CREDS\")\n    end if\n\n    sshPort = 22\n    for port in target.ports\n        if port.service == \"ssh\" then\n            sshPort = port.port\n        end if\n    end for\n\n    currentShell = sessionManager.currentSession.handler.shell\n    newShell = null\n    if sshPass.len > 0 then\n        newShell = currentShell.shell.connect_service(target.public_ip, sshPort, \"root\", sshPass, \"ssh\")\n    end if\n    if typeof(newShell) != \"shell\" and sshNative.len > 0 and sshNative != sshPass then\n        newShell = currentShell.shell.connect_service(target.public_ip, sshPort, \"root\", sshNative, \"ssh\")\n    end if\n\n    if typeof(newShell) != \"shell\" then\n        return Error.New(\"Could not connect to bounce: \" + target.public_ip + \"  -  \" + str(newShell), \"CONNECT_ERROR\")\n    end if\n\n    newSession = sessionManager.addSession(newShell, \"bounce@\" + target.public_ip)\n    if newSession isa Error then\n        return newSession\n    end if\n    sessionManager.setCurrentSession(newSession)\n    ui.success(\"Connected through bounce: \" + target.public_ip)\n    return newSession\nend function\n\nBounceManager.cleanBounce = function(target)\n    // Clean logs on a bounce machine and disconnect\n    ui             = self.mediator.getExtension(\"corvidUi\")\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n\n    notes = target.notes\n    bounceType = BOUNCE_TYPES.COMPROMISED\n    if notes.indexOf(\"bounce:owned\") != null then\n        bounceType = BOUNCE_TYPES.OWNED\n    end if\n\n    if bounceType == BOUNCE_TYPES.OWNED then\n        // Owned  -  wipe all logs freely\n        handler = sessionManager.currentSession.handler\n        result  = handler.corruptLogs()\n        if result isa Error then\n            ui.warning(\"Log wipe failed: \" + result.message)\n        else\n            ui.success(\"Logs wiped on owned bounce: \" + target.public_ip)\n        end if\n    else\n        // Compromised  -  manual checklist only\n        ui.print(\"\")\n        ui.info(\"Bounce cleanup checklist for COMPROMISED machine \" + target.public_ip + \":\")\n        ui.print(\"  1. cd /var\")\n        ui.print(\"  2. LogViewer.exe system.log\")\n        ui.print(\"  3. Delete: shell obtained, connection routed entries\")\n        ui.print(\"  4. Keep: connect and disconnect entries\")\n        ui.print(\"  5. Verify nothing else is suspicious\")\n        ui.print(\"\")\n    end if\nend function\n\nBounceManager.removeBounce = function(publicIp)\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    ui        = self.mediator.getExtension(\"corvidUi\")\n\n    // CRITICAL: use findBounces + filter by IP, NOT findTarget()\n    // findTarget uses ipIndex which only holds ONE record per public IP -\n    // it would return the router record, not the bounce record\n    allBounces = dbManager.findBounces()\n    targets = []\n    for b in allBounces\n        if b.hasIndex(\"public_ip\") and b.public_ip == publicIp then\n            targets.push(b)\n        end if\n    end for\n\n    if targets.len == 0 then\n        return Error.New(\"Bounce not found: \" + publicIp, \"NOT_FOUND\")\n    end if\n\n    // Update each matching bounce record directly via targetDb\n    for target in targets\n        target.status = TARGET_STATUS.OWNED\n        existingNotes = \"\"\n        if target.hasIndex(\"notes\") then\n            existingNotes = target.notes\n        end if\n        if existingNotes.indexOf(\"removed_bounce\") == null then\n            if existingNotes.len > 0 then\n                existingNotes = existingNotes + char(10)\n            end if\n            target.notes = existingNotes + \"removed_bounce\"\n        end if\n        dbManager.targetDb.db.set(target.id, target)\n        dbManager.targetDb.db.dirty = true\n    end for\n\n    dbManager.save()\n    ui.success(\"Bounce removed: \" + publicIp)\nend function\n\nBounceManager.findBounce = function(publicIp)\n    bounces = self.getBounceTargets()\n    for b in bounces\n        if b.hasIndex(\"public_ip\") and b.public_ip == publicIp then\n            return b\n        end if\n    end for\n    return null\nend function\n\nBounceManager.setStatus = function(publicIp, status)\n    dbManager = self.mediator.getExtension(\"databaseManager\")\n    bounces = self.getBounceTargets()\n    for b in bounces\n        if b.hasIndex(\"public_ip\") and b.public_ip == publicIp then\n            // Store health in notes, NOT in status\n            // status must stay \"bounce\" so findBounces() keeps finding this record\n            existingNotes = \"\"\n            if b.hasIndex(\"notes\") then\n                existingNotes = b.notes\n            end if\n            // Replace health marker - use direct DB set to avoid upsert status protection\n            newNotes = \"\"\n            for part in existingNotes.split(\" \")\n                trimPart = part.trim\n                if trimPart.len > 0 and trimPart.indexOf(\"health:\") != 0 then\n                    if newNotes.len > 0 then\n                        newNotes = newNotes + \" \"\n                    end if\n                    newNotes = newNotes + trimPart\n                end if\n            end for\n            if newNotes.len > 0 then\n                newNotes = newNotes + \" \"\n            end if\n            newNotes = newNotes + \"health:\" + status\n            b.notes = newNotes\n            dbManager.targetDb.db.set(b.id, b)\n            dbManager.targetDb.db.dirty = true\n            dbManager.save()\n            return true\n        end if\n    end for\n    return false\nend function\n\nBounceManager.getHealth = function(b)\n    if not b.hasIndex(\"notes\") then\n        return \"unknown\"\n    end if\n    for part in b.notes.split(\" \")\n        if part.indexOf(\"health:\") == 0 then\n            return part[7:]\n        end if\n    end for\n    return \"unknown\"\nend function\n\nBounceManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nBounceManager.New = function()\n    result = new BounceManager\n    return result\nend function\n",1)
m("/Corvid/source/managers/roost-db.txt","// ============================================================\n// CORVID 2.0 | managers/roost/roost-db\n// Database collection for roost nodes.\n// Stored separately from bounce pool.\n// ============================================================\n\nRoostDb = {}\nRoostDb.records = []\nRoostDb.mediator = null\n\nROOST_STATUS = {}\nROOST_STATUS.ACTIVE   = \"active\"\nROOST_STATUS.DORMANT  = \"dormant\"\nROOST_STATUS.DEAD     = \"dead\"\n\nRoostDb.add = function(publicIp, lanIp, processName)\n    // Check for duplicate\n    for r in self.records\n        if r.public_ip == publicIp then\n            r.status = ROOST_STATUS.ACTIVE\n            r.process_name = processName\n            r.last_used = 0\n            return r\n        end if\n    end for\n    record = {}\n    record.public_ip     = publicIp\n    record.lan_ip        = lanIp\n    record.process_name  = processName\n    record.status        = ROOST_STATUS.ACTIVE\n    record.last_used     = 0\n    self.records.push(record)\n    return record\nend function\n\nRoostDb.remove = function(publicIp)\n    for i in range(0, self.records.len - 1)\n        if self.records[i].public_ip == publicIp then\n            self.records.remove(i)\n            return true\n        end if\n    end for\n    return false\nend function\n\nRoostDb.find = function(publicIp)\n    for r in self.records\n        if r.public_ip == publicIp then\n            return r\n        end if\n    end for\n    return null\nend function\n\nRoostDb.setStatus = function(publicIp, status)\n    r = self.find(publicIp)\n    if r != null then\n        r.status = status\n    end if\nend function\n\nRoostDb.markUsed = function(publicIp)\n    r = self.find(publicIp)\n    if r != null then\n        r.last_used = time\n    end if\nend function\n\nRoostDb.listActive = function()\n    result = []\n    for r in self.records\n        if r.status == ROOST_STATUS.ACTIVE then\n            result.push(r)\n        end if\n    end for\n    return result\nend function\n\nRoostDb.pickLeastUsed = function()\n    active = self.listActive()\n    if active.len == 0 then\n        return null\n    end if\n    best = active[0]\n    for r in active\n        if r.last_used < best.last_used then\n            best = r\n        end if\n    end for\n    return best\nend function\n\nRoostDb.load = function(data)\n    if data == null then\n        return\n    end if\n    if data.hasIndex(\"roost\") then\n        self.records = data.roost\n    end if\nend function\n\nRoostDb.save = function(data)\n    data.roost = self.records\nend function\n\nRoostDb.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n",1)
m("/Corvid/source/managers/roost-manager.txt","// ============================================================\n// CORVID 2.0 | managers/roost/roost-manager\n// Manages the roost node pool.\n// Handles deploy, adopt, pick, verify, nuke operations.\n// Inspired by Scion/Arborist by NitroCynic (MIT License).\n// ============================================================\n\nRoostManager = {}\nRoostManager.mediator = null\nRoostManager.db = null\n\nROOST_PROCESS_NAMES = [\"stick\", \"shiny\", \"grub\", \"wing\"]\n\nRoostManager.init = function()\n    self.db = RoostDb\n    self.db.setMediator(self.mediator)\nend function\n\nRoostManager.randomProcessName = function()\n    idx = floor(time * 13) % ROOST_PROCESS_NAMES.len\n    return ROOST_PROCESS_NAMES[idx]\nend function\n\nRoostManager.list = function()\n    return self.db.records\nend function\n\nRoostManager.listActive = function()\n    return self.db.listActive()\nend function\n\nRoostManager.add = function(publicIp, lanIp, processName)\n    return self.db.add(publicIp, lanIp, processName)\nend function\n\nRoostManager.remove = function(publicIp)\n    return self.db.remove(publicIp)\nend function\n\nRoostManager.find = function(publicIp)\n    return self.db.find(publicIp)\nend function\n\nRoostManager.setStatus = function(publicIp, status)\n    self.db.setStatus(publicIp, status)\nend function\n\nRoostManager.markUsed = function(publicIp)\n    self.db.markUsed(publicIp)\nend function\n\nRoostManager.pickLeastUsed = function()\n    return self.db.pickLeastUsed()\nend function\n\nRoostManager.load = function(data)\n    self.db.load(data)\nend function\n\nRoostManager.save = function(data)\n    self.db.save(data)\nend function\n\nRoostManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nRoostManager.New = function()\n    result = new RoostManager\n    return result\nend function\n\n// ── adoptNode ────────────────────────────────────────────────\n// Shared adoption logic used by both roost pick and roost adopt.\n// Finds the flock connection, creates a session, loads node metaxploit.\nRoostManager.adoptNode = function(node, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n    libManager     = mediator.getExtension(\"libManager\")\n\n    ui.info(\"Connecting to: \" + node.public_ip + \" (process: \" + node.process_name + \")\")\n\n    // Find this node in active flock connections\n    meta = include_lib(\"/lib/metaxploit.so\")\n    if meta == null then\n        return Error.New(\"metaxploit.so not available\", \"NO_META\")\n    end if\n\n    shells = meta.rshell_server()\n    if shells == null or shells.len == 0 then\n        return Error.New(\"No active flock connections - node may be dead\", \"NO_RSHELL\")\n    end if\n\n    targetShell = null\n    for sh in shells\n        if typeof(sh) != \"shell\" then\n            continue\n        end if\n        comp = sh.host_computer\n        if comp != null then\n            if comp.public_ip == node.public_ip and comp.local_ip == node.lan_ip then\n                targetShell = sh\n                break\n            end if\n        end if\n    end for\n\n    if targetShell == null then\n        // Fallback: match on public IP only, prefer root\n        for sh in shells\n            if typeof(sh) != \"shell\" then\n                continue\n            end if\n            comp = sh.host_computer\n            if comp != null then\n                if comp.public_ip == node.public_ip then\n                    rootDir = sh.host_computer.File(\"/root\")\n                    if rootDir != null and rootDir.has_permission(\"w\") then\n                        targetShell = sh\n                        break\n                    end if\n                end if\n            end if\n        end for\n    end if\n\n    if targetShell == null then\n        dbManager.roostDb.setStatus(node.public_ip, ROOST_STATUS.DEAD)\n        dbManager.save()\n        return Error.New(\"Could not find flock connection for \" + node.public_ip + \" - marked dead\", \"NO_SHELL\")\n    end if\n\n    // Adopt as session\n    newSession = sessionManager.addSession(targetShell, \"roost@\" + node.public_ip)\n    if newSession isa Error then\n        return newSession\n    end if\n    sessionManager.setCurrentSession(newSession)\n    dbManager.roostDb.markUsed(node.public_ip)\n    dbManager.save()\n\n    // Load roost node's local metaxploit as current lib\n    ui.info(\"Loading roost node metaxploit library...\")\n    pivotHandler = sessionManager.pivotSession.handler\n    pivotShell   = pivotHandler.shell.shell\n\n    nodeMetaFile = targetShell.host_computer.File(\"/lib/metaxploit.so\")\n    if nodeMetaFile != null then\n        scpDest = \"/shiny/metaxploit.so\"\n        scpErr  = pivotShell.scp(\"/lib/metaxploit.so\", \"/shiny\", targetShell)\n        if typeof(scpErr) != \"string\" or scpErr.len == 0 then\n            nestComp    = pivotShell.host_computer\n            rawNodeMeta = include_lib(scpDest)\n            if rawNodeMeta != null then\n                nodeIpData       = {}\n                nodeIpData.ip    = {\"public\": node.public_ip, \"local\": node.lan_ip}\n                nodeIpData.path  = scpDest\n                nodeLib = libManager.addLib(rawNodeMeta, nodeIpData)\n                if not (nodeLib isa Error) then\n                    libManager.setCurrentLib(nodeLib)\n                    ui.success(\"Roost node metaxploit loaded (v\" + rawNodeMeta.version + \")\")\n                else\n                    ui.dim(\"  Could not register node lib: \" + nodeLib.message)\n                end if\n            else\n                ui.dim(\"  include_lib failed for node metaxploit - using Nest lib\")\n            end if\n            cleanFile = nestComp.File(scpDest)\n            if cleanFile != null then\n                cleanFile.delete()\n            end if\n        else\n            ui.dim(\"  Could not SCP node metaxploit - using Nest lib\")\n        end if\n    else\n        ui.dim(\"  Node has no /lib/metaxploit.so - using Nest lib\")\n    end if\n\n    ui.success(\"Now on roost node: \" + node.public_ip)\n    ui.info(\"Run attack commands from here. All connections originate from this node.\")\n    ui.separator()\nend function\n",1)
m("/Corvid/source/managers/platform-manager.txt","// ============================================================\n// CORVID 2.0 | managers/platform-manager\n// Manages attack platform mode. When active, exploit traffic\n// originates from a roost node rather than the Nest.\n// Corvid continues running on Nest - DB, sessions, and UI\n// are all unaffected. Only net_use calls are rerouted.\n//\n// Requires: metaxploit.so and crypto.so on the roost node.\n// If not present, they are uploaded from Nest automatically.\n// Tracks what was uploaded so wipe() removes only those files.\n// ============================================================\n\nPlatformManager = {}\nPlatformManager.mediator        = null\nPlatformManager.active          = false\nPlatformManager.nodeIp          = \"\"    // IP of the active platform node\nPlatformManager.roostShell      = null  // raw shell on node\nPlatformManager.roostMeta       = null  // Metaxploit facade loaded from node\nPlatformManager.roostCrypto     = null  // Crypto facade loaded from node\nPlatformManager.uploadedMeta    = false // true if we had to upload metaxploit.so\nPlatformManager.uploadedCrypto  = false // true if we had to upload crypto.so\nPlatformManager.metaPath        = \"\"    // path to metaxploit.so on node\nPlatformManager.cryptoPath      = \"\"    // path to crypto.so on node\n\n// ── activate ────────────────────────────────────────────────────────────────\n// Activates platform mode on the current session. The current session's\n// machine becomes the attack origin for all net_use calls.\n// Use roost pick, bounces chain, or flock adopt first to position yourself\n// on the desired node, then run platform deploy.\n\nPlatformManager.activate = function()\n    ui             = self.mediator.getExtension(\"corvidUi\")\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    pivotSession   = sessionManager.pivotSession\n    pivotHandler   = pivotSession.handler\n    pivotShell     = pivotHandler.shell.shell\n    currentSession = sessionManager.currentSession\n\n    if self.active then\n        ui.warning(\"Platform already deployed on \" + self.nodeIp + \" - run: platform wipe  or  platform sleep  first\")\n        return Error.New(\"Already active\", \"ALREADY_ACTIVE\")\n    end if\n\n    if currentSession == pivotSession then\n        return Error.New(\"Cannot deploy platform on Nest - switch to a remote session first\", \"IS_NEST\")\n    end if\n\n    handler    = currentSession.handler\n    nodeShell  = handler.shell.shell\n    nodeComp   = nodeShell.host_computer\n    nodeIp     = currentSession.data.ip.public\n\n    ui.info(\"Activating platform on current session: \" + nodeIp + \"...\")\n\n    // ── Ensure /shiny exists on node ─────────────────────────────────────\n    shinyDir = nodeComp.File(\"/shiny\")\n    if shinyDir == null then\n        nodeComp.create_folder(\"/\", \"shiny\")\n    end if\n\n    // ── Ensure metaxploit.so is available ────────────────────────────────\n    metaFile = nodeComp.File(\"/lib/metaxploit.so\")\n    if metaFile == null then\n        metaFile = nodeComp.File(\"/usr/lib/metaxploit.so\")\n    end if\n\n    if metaFile == null then\n        ui.info(\"  metaxploit.so not found on node - uploading from Nest...\")\n        nestMeta = pivotHandler.getFile(\"/lib/metaxploit.so\")\n        if nestMeta isa Error then\n            return Error.New(\"metaxploit.so not found on Nest either\", \"NO_META\")\n        end if\n        scpMeta = pivotShell.scp(\"/lib/metaxploit.so\", \"/lib\", nodeShell)\n        if typeof(scpMeta) == \"string\" and scpMeta.len > 0 then\n            scpMeta = pivotShell.scp(\"/lib/metaxploit.so\", \"/shiny\", nodeShell)\n            if typeof(scpMeta) == \"string\" and scpMeta.len > 0 then\n                return Error.New(\"Could not upload metaxploit.so: \" + scpMeta, \"UPLOAD_FAILED\")\n            end if\n            self.metaPath = \"/shiny/metaxploit.so\"\n        else\n            self.metaPath = \"/lib/metaxploit.so\"\n        end if\n        self.uploadedMeta = true\n        ui.success(\"  Uploaded metaxploit.so -> \" + self.metaPath)\n    else\n        self.metaPath = metaFile.path\n        self.uploadedMeta = false\n        ui.dim(\"  metaxploit.so found at \" + self.metaPath)\n    end if\n\n    // ── Ensure crypto.so is available ────────────────────────────────────\n    cryptoFile = nodeComp.File(\"/lib/crypto.so\")\n    if cryptoFile == null then\n        cryptoFile = nodeComp.File(\"/usr/lib/crypto.so\")\n    end if\n\n    if cryptoFile == null then\n        ui.info(\"  crypto.so not found on node - uploading from Nest...\")\n        nestCrypto = pivotHandler.getFile(\"/lib/crypto.so\")\n        if nestCrypto isa Error then\n            ui.warning(\"  crypto.so not found on Nest - some operations may be limited\")\n            self.cryptoPath = \"\"\n            self.uploadedCrypto = false\n        else\n            scpCrypto = pivotShell.scp(\"/lib/crypto.so\", \"/lib\", nodeShell)\n            if typeof(scpCrypto) == \"string\" and scpCrypto.len > 0 then\n                scpCrypto = pivotShell.scp(\"/lib/crypto.so\", \"/shiny\", nodeShell)\n                if typeof(scpCrypto) == \"string\" and scpCrypto.len > 0 then\n                    ui.warning(\"  Could not upload crypto.so - some operations may be limited\")\n                    self.cryptoPath = \"\"\n                    self.uploadedCrypto = false\n                else\n                    self.cryptoPath = \"/shiny/crypto.so\"\n                    self.uploadedCrypto = true\n                    ui.success(\"  Uploaded crypto.so -> \" + self.cryptoPath)\n                end if\n            else\n                self.cryptoPath = \"/lib/crypto.so\"\n                self.uploadedCrypto = true\n                ui.success(\"  Uploaded crypto.so -> \" + self.cryptoPath)\n            end if\n        end if\n    else\n        self.cryptoPath = cryptoFile.path\n        self.uploadedCrypto = false\n        ui.dim(\"  crypto.so found at \" + self.cryptoPath)\n    end if\n\n    // ── Load metaxploit from node ─────────────────────────────────────────\n    rawMeta = include_lib(self.metaPath)\n    if rawMeta == null then\n        return Error.New(\"include_lib failed for \" + self.metaPath, \"LIB_LOAD_FAILED\")\n    end if\n    self.roostMeta = Metaxploit.New(rawMeta)\n    if self.roostMeta isa Error then\n        return Error.New(\"Could not wrap node metaxploit: \" + self.roostMeta.message, \"LIB_WRAP_FAILED\")\n    end if\n\n    // ── Load crypto from node if available ───────────────────────────────\n    if self.cryptoPath.len > 0 then\n        rawCrypto = include_lib(self.cryptoPath)\n        if rawCrypto != null then\n            self.roostCrypto = Crypto.New(rawCrypto)\n        end if\n    end if\n\n    self.active    = true\n    self.nodeIp    = nodeIp\n    self.roostShell = nodeShell\n\n    ui.success(\"Platform deployed - attacks will originate from \" + nodeIp)\n    return null\nend function\n\n// ── deactivate ───────────────────────────────────────────────────────────────\n\nPlatformManager.deactivate = function()\n    ui = self.mediator.getExtension(\"corvidUi\")\n    if not self.active then\n        ui.warning(\"Platform not active\")\n        return\n    end if\n    nodeIp = self.nodeIp\n    self.active         = false\n    self.nodeIp         = \"\"\n    self.roostShell     = null\n    self.roostMeta      = null\n    self.roostCrypto    = null\n    self.metaPath       = \"\"\n    self.cryptoPath     = \"\"\n    self.uploadedMeta   = false\n    self.uploadedCrypto = false\n    ui.success(\"Platform sleeping - attacks returning to Nest context\")\nend function\n\n// ── wipe ─────────────────────────────────────────────────────────────────────\n// Remove only what platform uploaded. Never deletes native libs or touches\n// anything else on the node. Node stays healthy for future use.\n\nPlatformManager.wipe = function()\n    ui = self.mediator.getExtension(\"corvidUi\")\n    if not self.active then\n        ui.warning(\"Platform not active - nothing to wipe\")\n        return\n    end if\n\n    roostComp = self.roostShell.host_computer\n    wiped = []\n\n    if self.uploadedMeta and self.metaPath.len > 0 then\n        f = roostComp.File(self.metaPath)\n        if f != null then\n            f.delete()\n            wiped.push(self.metaPath)\n        end if\n    end if\n\n    if self.uploadedCrypto and self.cryptoPath.len > 0 then\n        f = roostComp.File(self.cryptoPath)\n        if f != null then\n            f.delete()\n            wiped.push(self.cryptoPath)\n        end if\n    end if\n\n    if wiped.len > 0 then\n        for w in wiped\n            ui.success(\"  Removed: \" + w)\n        end for\n    else\n        ui.dim(\"  Nothing to remove (no files were uploaded)\")\n    end if\n\n    // Corrupt logs on the platform node before deactivating\n    // Uses the move trick: create empty file, move onto system.log\n    ui.info(\"  Wiping logs on platform node...\")\n    logFile = roostComp.File(\"/var/system.log\")\n    if logFile == null then\n        ui.dim(\"  Log file not found - skipping\")\n    else\n        roostComp.touch(\"/var\", \"t\")\n        emptyFile = roostComp.File(\"/var/t\")\n        if emptyFile != null then\n            moveResult = emptyFile.move(\"/var\", \"system.log\")\n            if moveResult == 1 then\n                ui.success(\"  Logs wiped\")\n            else\n                emptyFile.delete()\n                ui.dim(\"  Log wipe failed - may need root access\")\n            end if\n        end if\n    end if\n\n    // Clean up node-attacker, node-router, and job/results files\n    cleanNames = [\"node-attacker\", \"node-router\", \"corvid-job.json\", \"corvid-results.json\", \"corvid-router-job.json\", \"corvid-router-results.json\"]\n    for cleanName in cleanNames\n        cf = roostComp.File(\"/shiny/\" + cleanName)\n        if cf != null then\n            cf.delete()\n            ui.success(\"  Removed: /shiny/\" + cleanName)\n        end if\n    end for\n\n    self.deactivate()\nend function\n\n// ── getters ──────────────────────────────────────────────────────────────────\n\nPlatformManager.getMeta = function()\n    if self.active and self.roostMeta != null then\n        return self.roostMeta\n    end if\n    return null\nend function\n\nPlatformManager.getCrypto = function()\n    if self.active and self.roostCrypto != null then\n        return self.roostCrypto\n    end if\n    return null\nend function\n\nPlatformManager.status = function()\n    if not self.active then\n        return \"inactive\"\n    end if\n    return self.nodeIp\nend function\n\nPlatformManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nPlatformManager.New = function()\n    result = new PlatformManager\n    result.active         = false\n    result.nodeIp         = \"\"\n    result.roostShell     = null\n    result.roostMeta      = null\n    result.roostCrypto    = null\n    result.uploadedMeta   = false\n    result.uploadedCrypto = false\n    result.metaPath       = \"\"\n    result.cryptoPath     = \"\"\n    return result\nend function\n",1)
m("/Corvid/source/managers/sniffer-db.txt","// ============================================================\n// CORVID 2.0 | managers/sniffer/sniffer-db\n// Persistent store for sniffer captures.\n// Separate from credential DB - captures are staged here\n// until promoted to main creds via 'sniffer promote'.\n// ============================================================\n\nSnifferDb = {}\nSnifferDb.records  = []\nSnifferDb.mediator = null\nSnifferDb.nextId   = 1\n\nSnifferDb.parse = function(raw)\n    // Parse meta.sniffer(0) output into structured record\n    // Format:\n    //   Incoming data captured.\n    //   Source: <ip>\n    //   Destination: <ip>\n    //   Protocol: <port>\n    //   USER: <user>\n    //   PASSWORD: <pass>\n    result = {}\n    result.source_ip  = \"\"\n    result.dest_ip    = \"\"\n    result.protocol   = \"\"\n    result.username   = \"\"\n    result.password   = \"\"\n\n    lines = raw.split(char(10))\n    for line in lines\n        line = line.trim\n        if line.indexOf(\"Source: \") == 0 then\n            result.source_ip = line[8:]\n        else if line.indexOf(\"Destination: \") == 0 then\n            result.dest_ip = line[13:]\n        else if line.indexOf(\"Protocol: \") == 0 then\n            result.protocol = line[10:]\n        else if line.indexOf(\"USER: \") == 0 then\n            result.username = line[6:]\n        else if line.indexOf(\"PASSWORD: \") == 0 then\n            result.password = line[10:]\n        end if\n    end for\n\n    return result\nend function\n\nSnifferDb.add = function(raw, capturedFrom)\n    parsed = self.parse(raw)\n    record = {}\n    record.id           = \"sn_\" + str(self.nextId)\n    record.source_ip    = parsed.source_ip\n    record.dest_ip      = parsed.dest_ip\n    record.protocol     = parsed.protocol\n    record.username     = parsed.username\n    record.password     = parsed.password\n    record.captured_from = capturedFrom\n    record.timestamp    = str(floor(time))\n    record.raw          = raw\n    self.records.push(record)\n    self.nextId = self.nextId + 1\n    return record\nend function\n\nSnifferDb.find = function(id)\n    for r in self.records\n        if r.id == id then\n            return r\n        end if\n    end for\n    return null\nend function\n\nSnifferDb.remove = function(id)\n    newRecords = []\n    for r in self.records\n        if r.id != id then\n            newRecords.push(r)\n        end if\n    end for\n    self.records = newRecords\nend function\n\nSnifferDb.load = function(data)\n    if data.hasIndex(\"sniffer_captures\") then\n        self.records = data.sniffer_captures\n        if self.records.len > 0 then\n            lastId = self.records[self.records.len - 1].id\n            numStr = lastId[3:]\n            self.nextId = numStr.val + 1\n        end if\n    end if\nend function\n\nSnifferDb.save = function(data)\n    data.sniffer_captures = self.records\nend function\n\nSnifferDb.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n",1)
m("/Corvid/source/managers/shinylibs-db.txt","// ============================================================\n// CORVID | managers/shinylibs-db.txt\n// ShinyLibsDb — persistent store for scored library binaries\n// Keys: \"<libname>/<version>\" e.g. \"kernel_router.so/1.2.3\"\n// ============================================================\n\nShinyLibsDb = {}\n\n// Remote-access lib names we prioritise in display\nShinyLibsDb.REMOTE_LIBS = [\n    \"kernel_router.so\",\n    \"kernel_module.so\",\n    \"libssh.so\",\n    \"libhttp.so\",\n    \"libftp.so\",\n    \"libsmtp.so\"\n]\n\n// Constraint penalty values used in scoring\nShinyLibsDb.PENALTY_ADMIN_ACTIVE   = 40\nShinyLibsDb.PENALTY_ANY_USER       = 20\nShinyLibsDb.PENALTY_USER_COUNT     = 10\nShinyLibsDb.PENALTY_PORT_FORWARD   = 10\nShinyLibsDb.PENALTY_FIREWALL_OFF   = 15\n\n// Result type base scores\nShinyLibsDb.SCORE_ROOT_SHELL       = 100\nShinyLibsDb.SCORE_USER_SHELL       = 60\nShinyLibsDb.SCORE_COMPUTER         = 20\nShinyLibsDb.SCORE_FILE             = 10\nShinyLibsDb.SCORE_NUMBER           = 5\n\n// ── init ─────────────────────────────────────────────────────\nShinyLibsDb.init = function()\n    self.records   = {}   // keyed by libname/version\n    self.staged    = []   // pending collection: {libName, version, filePath, exploits, score, isRemote}\n    self.dataPath  = \"/Corvid/Data/shinylibs\"\n    self.dbPath    = \"/Corvid/Data/shinylibs.json\"\nend function\n\n// ── scoreExploit ─────────────────────────────────────────────\n// Parse a single scan_address result string and return a scored exploit map\nShinyLibsDb.scoreExploit = function(scanText)\n    exploit = {}\n    exploit.raw        = scanText\n    exploit.resultType = \"unknown\"\n    exploit.score      = 0\n    exploit.conditions = []\n    exploit.isLocal    = false\n\n    lower = scanText.lower\n\n    // Determine result type\n    if lower.indexOf(\"root\") != null and lower.indexOf(\"shell\") != null then\n        exploit.resultType = \"root_shell\"\n        exploit.score      = ShinyLibsDb.SCORE_ROOT_SHELL\n    else if lower.indexOf(\"shell\") != null then\n        exploit.resultType = \"user_shell\"\n        exploit.score      = ShinyLibsDb.SCORE_USER_SHELL\n    else if lower.indexOf(\"computer\") != null then\n        exploit.resultType = \"computer\"\n        exploit.score      = ShinyLibsDb.SCORE_COMPUTER\n    else if lower.indexOf(\"file\") != null then\n        exploit.resultType = \"file\"\n        exploit.score      = ShinyLibsDb.SCORE_FILE\n    else if lower.indexOf(\"firewall\") != null or lower.indexOf(\"number\") != null then\n        exploit.resultType = \"number\"\n        exploit.score      = ShinyLibsDb.SCORE_NUMBER\n    end if\n\n    // Local-only flag\n    if lower.indexOf(\"local\") != null then\n        exploit.isLocal = true\n    end if\n\n    // Parse constraints from \"* Checking ...\" lines\n    lines = scanText.split(\"\\n\")\n    for line in lines\n        l = line.trim.lower\n        if l.indexOf(\"* checking\") != 0 then\n            continue\n        end if\n        if l.indexOf(\"admin\") != null or (l.indexOf(\"active user\") != null and l.indexOf(\"any\") == null) then\n            exploit.conditions.push(\"admin_active\")\n            exploit.score = exploit.score - ShinyLibsDb.PENALTY_ADMIN_ACTIVE\n        else if l.indexOf(\"any user\") != null then\n            exploit.conditions.push(\"any_user_active\")\n            exploit.score = exploit.score - ShinyLibsDb.PENALTY_ANY_USER\n        else if l.indexOf(\"registered users\") != null or l.indexOf(\"user count\") != null then\n            exploit.conditions.push(\"user_count\")\n            exploit.score = exploit.score - ShinyLibsDb.PENALTY_USER_COUNT\n        else if l.indexOf(\"port forward\") != null then\n            exploit.conditions.push(\"port_forward\")\n            exploit.score = exploit.score - ShinyLibsDb.PENALTY_PORT_FORWARD\n        else if l.indexOf(\"firewall\") != null then\n            exploit.conditions.push(\"firewall_off\")\n            exploit.score = exploit.score - ShinyLibsDb.PENALTY_FIREWALL_OFF\n        end if\n    end for\n\n    if exploit.score < 0 then\n        exploit.score = 0\n    end if\n\n    return exploit\nend function\n\n// ── scoreLib ─────────────────────────────────────────────────\n// Given a list of exploit scan strings, return aggregate score and exploit list\nShinyLibsDb.scoreLib = function(libName, version, exploitTexts)\n    result = {}\n    result.libName   = libName\n    result.version   = version\n    result.exploits  = []\n    result.topScore  = 0\n    result.totalScore = 0\n    result.hasRootNoCondition = false\n    result.isRemote  = ShinyLibsDb.REMOTE_LIBS.indexOf(libName) != null\n\n    for txt in exploitTexts\n        e = ShinyLibsDb.scoreExploit(txt)\n        result.exploits.push(e)\n        result.totalScore = result.totalScore + e.score\n        if e.score > result.topScore then\n            result.topScore = e.score\n        end if\n        if e.resultType == \"root_shell\" and e.conditions.len == 0 then\n            result.hasRootNoCondition = true\n        end if\n    end for\n\n    return result\nend function\n\n// ── stage ─────────────────────────────────────────────────────\n// Add a scored lib result to staged list if it's shiny vs existing records\n// Returns: \"offensive\" | \"defensive\" | \"both\" | null\nShinyLibsDb.stage = function(libName, version, exploitTexts, srcPath)\n    scored = ShinyLibsDb.scoreLib(libName, version, exploitTexts)\n    scored.srcPath   = srcPath\n    scored.collected = false\n\n    // Find best offensive and defensive we already have for this lib name\n    bestOffScore = 0\n    bestDefScore = 999999\n    for key in self.records\n        rec = self.records[key]\n        if rec.libName != libName then\n            continue\n        end if\n        if rec.topScore > bestOffScore then\n            bestOffScore = rec.topScore\n        end if\n        if rec.topScore < bestDefScore then\n            bestDefScore = rec.topScore\n        end if\n    end for\n\n    isOffensive = scored.topScore > bestOffScore\n    isDefensive = (bestDefScore == 999999 and scored.exploits.len == 0) or (scored.topScore < bestDefScore and scored.exploits.len == 0)\n\n    if not isOffensive and not isDefensive then\n        return null\n    end if\n\n    scored.shinyType = \"\"\n    if isOffensive and isDefensive then\n        scored.shinyType = \"both\"\n    else if isOffensive then\n        scored.shinyType = \"offensive\"\n    else\n        scored.shinyType = \"defensive\"\n    end if\n\n    // Check not already staged\n    for s in self.staged\n        if s.libName == libName and s.version == version then\n            return null\n        end if\n    end for\n\n    self.staged.push(scored)\n    return scored.shinyType\nend function\n\n// ── collect ──────────────────────────────────────────────────\n// Move a staged lib into the DB (after user confirms and binary is copied)\nShinyLibsDb.collect = function(libName, version, localFilePath)\n    key = libName + \"/\" + version\n    scored = null\n    for s in self.staged\n        if s.libName == libName and s.version == version then\n            scored = s\n            break\n        end if\n    end for\n\n    if scored == null then\n        return Error.New(\"Not in staged list\", \"NOT_STAGED\")\n    end if\n\n    scored.localPath = localFilePath\n    scored.collected = true\n    self.records[key] = scored\n\n    // Remove from staged\n    newStaged = []\n    for s in self.staged\n        if s.libName != libName or s.version != version then\n            newStaged.push(s)\n        end if\n    end for\n    self.staged = newStaged\n\n    return scored\nend function\n\n// ── getBestOffensive / getBestDefensive ───────────────────────\nShinyLibsDb.getBestForLib = function(libName)\n    best = null\n    for key in self.records\n        rec = self.records[key]\n        if rec.libName != libName then\n            continue\n        end if\n        if best == null or rec.topScore > best.topScore then\n            best = rec\n        end if\n    end for\n    return best\nend function\n\nShinyLibsDb.getMostSecureForLib = function(libName)\n    best = null\n    for key in self.records\n        rec = self.records[key]\n        if rec.libName != libName then\n            continue\n        end if\n        // Most secure = fewest exploits, lowest score\n        if best == null or rec.topScore < best.topScore then\n            best = rec\n        end if\n    end for\n    return best\nend function\n\n// ── allLibNames ───────────────────────────────────────────────\nShinyLibsDb.allLibNames = function()\n    names = []\n    for key in self.records\n        rec = self.records[key]\n        if names.indexOf(rec.libName) == null then\n            names.push(rec.libName)\n        end if\n    end for\n    return names\nend function\n\n// ── serialize / deserialize ───────────────────────────────────\nShinyLibsDb.serialize = function()\n    return self.records\nend function\n\nShinyLibsDb.deserialize = function(data)\n    self.records = data\nend function\n",1)
m("/Corvid/source/managers/shinylibs-manager.txt","// ============================================================\n// CORVID | managers/shinylibs-manager.txt\n// ShinyLibsManager — scan, collect, display, put shiny libs\n// ============================================================\n\nShinyLibsManager = {}\n\nShinyLibsManager.init = function(mediator)\n    self.mediator = mediator\n    self.db       = ShinyLibsDb\n    // Note: db.init() is called by databaseManager before this runs.\n    // Do NOT call self.db.init() here - it would wipe loaded records.\nend function\n\n// ── scanSession ──────────────────────────────────────────────\n// Scan all libs on current session, stage any shiny ones.\n// Returns list of shiny results found.\nShinyLibsManager.scanSession = function(sessionHandler, metaxploit)\n    ui = self.mediator.getExtension(\"corvidUi\")\n    found = []\n\n    comp = sessionHandler.shell.shell.host_computer\n    libFolder = comp.File(\"/lib\")\n    if libFolder == null or not libFolder.is_folder then\n        return found\n    end if\n\n    libFiles = libFolder.get_files\n    if libFiles == null then\n        return found\n    end if\n\n    for libFile in libFiles\n        if libFile.name.indexOf(\".so\") == null then\n            continue\n        end if\n        shinyType = self.checkLib(libFile, metaxploit)\n        if shinyType != null then\n            found.push({\n                \"libName\": libFile.name,\n                \"shinyType\": shinyType\n            })\n        end if\n    end for\n\n    return found\nend function\n\n// ── checkLib ─────────────────────────────────────────────────\n// Load one lib, score it, stage if shiny. Returns shinyType or null.\nShinyLibsManager.checkLib = function(libFile, metaxploit)\n    metalib = metaxploit.load(libFile.path)\n    if metalib == null or metalib isa Error then\n        return null\n    end if\n\n    version     = metalib.version\n    libName     = libFile.name\n    memAddrs    = metaxploit.scan(metalib)\n    if memAddrs == null then\n        memAddrs = []\n    end if\n\n    exploitTexts = []\n    for addr in memAddrs\n        txt = metaxploit.scanAddress(metalib, addr)\n        if txt != null then\n            exploitTexts.push(txt)\n        end if\n    end for\n\n    return self.db.stage(libName, version, exploitTexts, libFile.path)\nend function\n\n// ── showStagedNotification ────────────────────────────────────\n// Rainbow attention message shown during/after attack flow\nShinyLibsManager.showStagedNotification = function()\n    if self.db.staged.len == 0 then\n        return\n    end if\n\n    ui = self.mediator.getExtension(\"corvidUi\")\n\n    // Build rainbow lib list\n    colors = [\"#FF0000\", \"#FF6600\", \"#FFD700\", \"#FFFF00\", \"#00FF00\",\n              \"#00FFFF\", \"#0088FF\", \"#8800FF\", \"#FF00FF\", \"#C0C0C0\",\n              \"#FFD700\", \"#FFFFFF\"]\n\n    offCount = 0\n    defCount = 0\n    libList  = \"\"\n    colorIdx = 0\n    for s in self.db.staged\n        if s.shinyType == \"offensive\" or s.shinyType == \"both\" then\n            offCount = offCount + 1\n        end if\n        if s.shinyType == \"defensive\" or s.shinyType == \"both\" then\n            defCount = defCount + 1\n        end if\n        col = colors[colorIdx % colors.len]\n        colorIdx = colorIdx + 1\n        tag = \"\"\n        if s.shinyType == \"offensive\" then\n            tag = \"<color=#FFD700>[VULN]</color>\"\n        else if s.shinyType == \"defensive\" then\n            tag = \"<color=#C0C0C0>[SECURE]</color>\"\n        else\n            tag = \"<color=#00FFFF>[BOTH]</color>\"\n        end if\n        libList = libList + \"  \" + tag + \" <color=\" + col + \">\" + s.libName + \" v\" + s.version + \"</color>\\n\"\n    end for\n\n    ui.print(\"\")\n    ui.print(\"<color=#FFD700>✦ ✦ ✦ ✦ ✦ ✦  <color=#FFFFFF>SHINY LIBRARIES DETECTED</color>  ✦ ✦ ✦ ✦ ✦ ✦</color>\")\n    ui.print(libList.trim)\n    ui.print(\"<color=#00FF00>\" + self.db.staged.len + \" shiny lib(s) staged</color> — \" +\n        \"<color=#FFD700>offensive: \" + offCount + \"</color>  \" +\n        \"<color=#C0C0C0>defensive: \" + defCount + \"</color>\")\n    ui.print(\"<color=#00FFFF>Run <color=#FFFFFF>shinylibs get</color> to collect, or <color=#FFFFFF>shinylibs scan</color> for a full lib scan.</color>\")\n    ui.print(\"<color=#FFD700>✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦ ✦</color>\")\n    ui.print(\"\")\nend function\n\n// ── collectStaged ─────────────────────────────────────────────\n// For each staged lib: show details, prompt y/n, SCP and store if yes.\nShinyLibsManager.collectStaged = function(sessionHandler, pivotHandler)\n    ui = self.mediator.getExtension(\"corvidUi\")\n\n    if self.db.staged.len == 0 then\n        ui.info(\"No shiny libs staged. Run shinylibs scan first.\")\n        return\n    end if\n\n    pivotShell = pivotHandler.shell.shell\n    pivotComp  = pivotShell.host_computer\n\n    collected = 0\n    skipped   = 0\n\n    for staged in self.db.staged\n        ui.separator()\n        // Show exploit summary\n        typeColor = \"#FFD700\"\n        if staged.shinyType == \"defensive\" then\n            typeColor = \"#C0C0C0\"\n        else if staged.shinyType == \"both\" then\n            typeColor = \"#00FFFF\"\n        end if\n        ui.print(\"<color=\" + typeColor + \">★ \" + staged.libName + \" v\" + staged.version + \"  [\" + staged.shinyType.upper + \"]</color>\")\n        ui.print(\"  Top score: \" + staged.topScore + \"  |  Exploits: \" + staged.exploits.len)\n\n        for e in staged.exploits\n            cond = \"\"\n            if e.conditions.len > 0 then\n                cond = \"  (\" + e.conditions.join(\", \") + \")\"\n            end if\n            ui.print(\"  <color=#888888>• \" + e.resultType + \"  score:\" + e.score + cond + \"</color>\")\n        end for\n\n        answer = user_input(\"Collect \" + staged.libName + \" v\" + staged.version + \"? (y/n) \", false)\n        if answer.lower != \"y\" then\n            skipped = skipped + 1\n            continue\n        end if\n\n        // Create dest path: /Corvid/Data/shinylibs/<libname_no_ext>/<version>/\n        libBaseName = staged.libName\n        if libBaseName.indexOf(\".so\") != null then\n            libBaseName = libBaseName[:-3]\n        end if\n        destDir = self.db.dataPath + \"/\" + libBaseName + \"/\" + staged.version\n        self.ensureDir(pivotComp, destDir)\n\n        // SCP from current session to Nest\n        scpResult = pivotShell.scp(staged.srcPath, destDir, sessionHandler.shell.shell)\n        if typeof(scpResult) == \"string\" and scpResult.len > 0 then\n            ui.warning(\"SCP failed: \" + scpResult)\n            skipped = skipped + 1\n            continue\n        end if\n\n        localPath = destDir + \"/\" + staged.libName\n        result = self.db.collect(staged.libName, staged.version, localPath)\n        if result isa Error then\n            ui.warning(\"DB collect failed: \" + result.message)\n        else\n            ui.success(\"Collected \" + staged.libName + \" v\" + staged.version + \" -> \" + localPath)\n            collected = collected + 1\n        end if\n    end for\n\n    ui.separator()\n    ui.info(\"Collected: \" + collected + \"  Skipped: \" + skipped)\nend function\n\n// ── scan ─────────────────────────────────────────────────────\n// Full lib scan of current session\nShinyLibsManager.scan = function(sessionHandler)\n    ui      = self.mediator.getExtension(\"corvidUi\")\n    libMgr  = self.mediator.getExtension(\"libManager\")\n    meta    = libMgr.getMetaxploit()\n\n    if meta == null or meta isa Error then\n        return Error.New(\"metaxploit not available\", \"NO_META\")\n    end if\n\n    ui.info(\"Scanning /lib/ on current session...\")\n    ui.dim(\"(File reads through existing session — no additional log entries created)\")\n    found = self.scanSession(sessionHandler, meta)\n\n    if found.len == 0 then\n        ui.info(\"No new shiny libs found.\")\n        return\n    end if\n\n    self.showStagedNotification()\nend function\n\n// ── resweep ──────────────────────────────────────────────────\n// Re-score all stored libs against current metaxploit\nShinyLibsManager.resweep = function(pivotHandler)\n    ui     = self.mediator.getExtension(\"corvidUi\")\n    libMgr = self.mediator.getExtension(\"libManager\")\n    meta   = libMgr.getMetaxploit()\n\n    if meta == null or meta isa Error then\n        return Error.New(\"metaxploit not available on pivot\", \"NO_META\")\n    end if\n\n    ui.info(\"Resweeping all stored libs with current metaxploit...\")\n    updated = 0\n\n    for key in self.db.records\n        rec = self.db.records[key]\n        localFile = pivotHandler.shell.shell.host_computer.File(rec.localPath)\n        if localFile == null then\n            ui.warning(\"Missing file: \" + rec.localPath + \" — skipping\")\n            continue\n        end if\n\n        metalib = meta.load(rec.localPath)\n        if metalib == null or metalib isa Error then\n            ui.warning(\"Could not load \" + rec.localPath + \" — skipping\")\n            continue\n        end if\n\n        memAddrs = meta.scan(metalib)\n        if memAddrs == null then\n            memAddrs = []\n        end if\n\n        exploitTexts = []\n        for addr in memAddrs\n            txt = meta.scanAddress(metalib, addr)\n            if txt != null then\n                exploitTexts.push(txt)\n            end if\n        end for\n\n        scored = self.db.scoreLib(rec.libName, rec.version, exploitTexts)\n        rec.exploits  = scored.exploits\n        rec.topScore  = scored.topScore\n        rec.totalScore = scored.totalScore\n        rec.hasRootNoCondition = scored.hasRootNoCondition\n        self.db.records[key] = rec\n        updated = updated + 1\n        ui.info(\"Updated: \" + rec.libName + \" v\" + rec.version + \"  top score: \" + rec.topScore)\n    end for\n\n    ui.success(\"Resweep complete. \" + updated + \" lib(s) updated.\")\nend function\n\n// ── list ─────────────────────────────────────────────────────\nShinyLibsManager.list = function()\n    ui = self.mediator.getExtension(\"corvidUi\")\n\n    if self.db.records.len == 0 then\n        ui.info(\"No shiny libs collected yet. Run shinylibs scan then shinylibs get.\")\n        return\n    end if\n\n    // Separate into remote and local libs, get best of each type per lib name\n    remoteLibs = []\n    localLibs  = []\n\n    libNames = self.db.allLibNames()\n    for name in libNames\n        bestOff = self.db.getBestForLib(name)\n        bestDef = self.db.getMostSecureForLib(name)\n        isRemote = ShinyLibsDb.REMOTE_LIBS.indexOf(name) != null\n        entry = {\"name\": name, \"bestOff\": bestOff, \"bestDef\": bestDef, \"isRemote\": isRemote}\n        if isRemote then\n            remoteLibs.push(entry)\n        else\n            localLibs.push(entry)\n        end if\n    end for\n\n    // Sort remote by top offensive score desc\n    // (simple bubble sort — small list)\n    if remoteLibs.len > 1 then\n        for i in range(0, remoteLibs.len - 2)\n            for j in range(0, remoteLibs.len - 2 - i)\n                if remoteLibs[j].bestOff.topScore < remoteLibs[j+1].bestOff.topScore then\n                    tmp = remoteLibs[j]\n                    remoteLibs[j] = remoteLibs[j+1]\n                    remoteLibs[j+1] = tmp\n                end if\n            end for\n        end for\n    end if\n\n    ui.separator()\n    ui.highlight(\"SHINY LIBS — REMOTE ACCESS\")\n    ui.separator()\n    self.printLibEntries(remoteLibs, ui)\n\n    ui.separator()\n    ui.highlight(\"SHINY LIBS — LOCAL\")\n    ui.separator()\n    self.printLibEntries(localLibs, ui)\n\n    if self.db.staged.len > 0 then\n        ui.print(\"\")\n        ui.print(\"<color=#FFD700>\" + self.db.staged.len + \" lib(s) staged and awaiting collection — run shinylibs get</color>\")\n    end if\nend function\n\nShinyLibsManager.printLibEntries = function(entries, ui)\n    if entries.len == 0 then\n        ui.dim(\"  (none)\")\n        return\n    end if\n    for entry in entries\n        off = entry.bestOff\n        def = entry.bestDef\n        rootFlag = \"\"\n        if off.hasRootNoCondition then\n            rootFlag = \" <color=#FF0000>★ROOT</color>\"\n        end if\n        ui.print(\"<color=#FFD700>\" + entry.name + \"</color>\")\n        ui.print(\"  <color=#FF6600>VULN</color>  v\" + off.version + \"  score:\" + off.topScore + rootFlag + \"  exploits:\" + off.exploits.len)\n        if def.version != off.version then\n            ui.print(\"  <color=#C0C0C0>SECURE</color> v\" + def.version + \"  score:\" + def.topScore + \"  exploits:\" + def.exploits.len)\n        end if\n    end for\nend function\n\n// ── put ──────────────────────────────────────────────────────\nShinyLibsManager.put = function(mode, sessionHandler, pivotHandler)\n    ui = self.mediator.getExtension(\"corvidUi\")\n\n    if mode != \"harden\" and mode != \"vuln\" then\n        return Error.New(\"mode must be harden or vuln\", \"BAD_MODE\")\n    end if\n\n    ui.separator()\n    if mode == \"harden\" then\n        ui.highlight(\"SHINYLIBS PUT — HARDEN\")\n    else\n        ui.highlight(\"SHINYLIBS PUT — VULN\")\n    end if\n    ui.warning(\"SCP writes to the target machine — log entries will be created on the TARGET.\")\n    ui.warning(\"Run corruptlogs or leave wipe on this session when done.\")\n    ui.separator()\n\n    sessionComp = sessionHandler.shell.shell.host_computer\n    pivotShell  = pivotHandler.shell.shell\n\n    // Get existing libs on target\n    libFolder = sessionComp.File(\"/lib\")\n    if libFolder == null or not libFolder.is_folder then\n        return Error.New(\"No /lib folder on target\", \"NO_LIB\")\n    end if\n\n    targetLibs = {}\n    libFiles = libFolder.get_files\n    if libFiles != null then\n        for f in libFiles\n            if f.name.indexOf(\".so\") != null then\n                targetLibs[f.name] = f\n            end if\n        end for\n    end if\n\n    replaced = 0\n    skipped  = 0\n\n    for libName in targetLibs\n        // Find our best or most secure version\n        candidate = null\n        if mode == \"harden\" then\n            candidate = self.db.getMostSecureForLib(libName)\n        else\n            candidate = self.db.getBestForLib(libName)\n        end if\n\n        if candidate == null then\n            skipped = skipped + 1\n            continue\n        end if\n\n        // Compare target lib version against candidate\n        targetFile = targetLibs[libName]\n        targetMeta = null\n        libMgr = self.mediator.getExtension(\"libManager\")\n        meta   = libMgr.getMetaxploit()\n        targetScore = -1\n        targetVersion = \"\"\n        \n        if meta != null and not (meta isa Error) then\n            // Try to load target lib for version detection\n            targetMeta = meta.load(targetFile.path)\n            if targetMeta != null and not (targetMeta isa Error) then\n                targetVersion = targetMeta.version\n                \n                // Check if we have this version in our DB already\n                key = libName + \"/\" + targetVersion\n                if self.db.records.hasIndex(key) then\n                    targetScore = self.db.records[key].topScore\n                else\n                    // CRITICAL FIX: Real-time scoring of unknown target version\n                    ui.dim(\"  Analyzing unknown target version: \" + libName + \" v\" + targetVersion)\n                    memAddrs = meta.scan(targetMeta)\n                    if memAddrs == null then\n                        memAddrs = []\n                    end if\n                    \n                    exploitTexts = []\n                    for addr in memAddrs\n                        txt = meta.scanAddress(targetMeta, addr)\n                        if txt != null then\n                            exploitTexts.push(txt)\n                        end if\n                    end for\n                    \n                    // Score the unknown target library\n                    scored = ShinyLibsDb.scoreLib(libName, targetVersion, exploitTexts)\n                    targetScore = scored.topScore\n                    ui.dim(\"    Target score: \" + targetScore + \" (real-time analysis)\")\n                end if\n            end if\n        end if\n\n        // If candidate is same version as target, skip\n        if candidate.version == targetVersion then\n            ui.dim(\"  Skipping \" + libName + \" — target already has candidate version \" + candidate.version)\n            skipped = skipped + 1\n            continue\n        end if\n\n        // Skip if target score already better for our purpose\n        if targetScore >= 0 then\n            if mode == \"harden\" and targetScore <= candidate.topScore then\n                ui.dim(\"  Skipping \" + libName + \" — target already at or below candidate score\")\n                skipped = skipped + 1\n                continue\n            end if\n            if mode == \"vuln\" and targetScore >= candidate.topScore then\n                ui.dim(\"  Skipping \" + libName + \" — target already at or above candidate score\")\n                skipped = skipped + 1\n                continue\n            end if\n        else\n            // Target score unknown (couldn't load/analyze target library)\n            // Conservative approach: require user confirmation for blind deployment\n            ui.warning(\"  Cannot analyze target \" + libName + \" v\" + targetVersion)\n            deployAnswer = user_input(\"  Deploy \" + candidate.libName + \" v\" + candidate.version + \" anyway? (y/n) \", false)\n            if deployAnswer.lower != \"y\" then\n                ui.dim(\"  Skipped \" + libName + \" — user declined blind deployment\")\n                skipped = skipped + 1\n                continue\n            end if\n        end if\n\n        // SCP from Nest to target\n        scpResult = pivotShell.scp(candidate.localPath, \"/lib\", sessionHandler.shell.shell)\n        if typeof(scpResult) == \"string\" and scpResult.len > 0 then\n            ui.warning(\"SCP failed for \" + libName + \": \" + scpResult)\n            skipped = skipped + 1\n            continue\n        end if\n\n        ui.success(\"Replaced \" + libName + \" v\" + targetScore + \" -> v\" + candidate.version + \" [score: \" + candidate.topScore + \"]\")\n        replaced = replaced + 1\n    end for\n\n    ui.separator()\n    ui.info(\"Replaced: \" + replaced + \"  Skipped: \" + skipped)\n    if replaced > 0 then\n        ui.warning(\"Target logs updated — run corruptlogs or leave wipe to clean up.\")\n    end if\nend function\n\n// ── ensureDir ─────────────────────────────────────────────────\nShinyLibsManager.ensureDir = function(comp, fullPath)\n    parts = fullPath.split(\"/\")\n    parts = parts[1:]  // drop leading empty from /\n    current = \"\"\n    for part in parts\n        current = current + \"/\" + part\n        f = comp.File(current)\n        if f == null then\n            // Calculate parent path by removing trailing /part\n            parentEnd = current.len - part.len - 1\n            if parentEnd <= 0 then\n                parent = \"/\"\n            else\n                parent = current[:parentEnd]\n            end if\n            comp.create_folder(parent, part)\n        end if\n    end for\nend function\n\nShinyLibsManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n",1)
m("/Corvid/source/managers/macro-manager.txt","// ============================================================\n// CORVID 2.0 | managers/macro/macro-manager\n// Stores and executes macro scripts.\n// Macros live in /Config/Macros/ on the pivot session.\n// The 'init' macro runs automatically on startup.\n// Trigger any macro mid-session with @macroname.\n// ============================================================\n\nMacroManager = {}\nMacroManager.mediator = null\n\nMacroManager.getMacroFolder = function()\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler        = sessionManager.pivotSession.handler\n\n    user   = handler.user\n    cfgPath = \"/home/guest/Config\"\n    if user == \"root\" then\n        cfgPath = \"/root/Config\"\n    else if user != \"guest\" then\n        cfgPath = \"/home/\" + user + \"/Config\"\n    end if\n\n    folder = handler.getFile(cfgPath)\n    if folder isa Error then\n        return folder\n    end if\n\n    macroFolder = handler.getFile(cfgPath + \"/Macros\")\n    if macroFolder isa Error then\n        result = handler.createFolder(cfgPath + \"/Macros\")\n        if result isa Error then\n            return result\n        end if\n        macroFolder = handler.getFile(cfgPath + \"/Macros\")\n        if macroFolder isa Error then\n            return macroFolder\n        end if\n    end if\n\n    return macroFolder\nend function\n\nMacroManager.getMacro = function(name)\n    folder = self.getMacroFolder()\n    if folder isa Error then\n        return folder\n    end if\n    macro = folder.child(name)\n    if macro isa Error then\n        return Error.New(\"Macro not found: \" + name, \"NOT_FOUND\")\n    end if\n    content = macro.content()\n    if content isa Error then\n        return content\n    end if\n    return content\nend function\n\nMacroManager.runMacro = function(name)\n    commandManager = self.mediator.getExtension(\"commandManager\")\n    content = self.getMacro(name)\n    if content isa Error then\n        return content\n    end if\n    lines = content.split(char(10))\n    for line in lines\n        trimmed = line.trim\n        if trimmed.len == 0 then\n            continue\n        end if\n        if startsWith(trimmed, \"//\") then\n            continue\n        end if\n        commandManager.execute(trimmed)\n        commandManager.run()\n    end for\nend function\n\nMacroManager.init = function()\n    // Run init macro if it exists  -  silently skip if not\n    macro = self.getMacro(\"init\")\n    if macro isa Error then\n        return\n    end if\n    self.runMacro(\"init\")\nend function\n\nMacroManager.listMacros = function()\n    folder = self.getMacroFolder()\n    if folder isa Error then\n        return []\n    end if\n    kids = folder.children()\n    if kids isa Error then\n        return []\n    end if\n    names = []\n    for kid in kids\n        names.push(kid.name())\n    end for\n    return names\nend function\n\nMacroManager.saveMacro = function(name, content)\n    folder = self.getMacroFolder()\n    if folder isa Error then\n        return folder\n    end if\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler        = sessionManager.pivotSession.handler\n\n    existing = folder.child(name)\n    if existing isa Error then\n        result = handler.createFile(folder.path() + \"/\" + name)\n        if result isa Error then\n            return result\n        end if\n    end if\n\n    file = handler.getFile(folder.path() + \"/\" + name)\n    if file isa Error then\n        return file\n    end if\n    return file.setContent(content)\nend function\n\nMacroManager.deleteMacro = function(name)\n    folder = self.getMacroFolder()\n    if folder isa Error then\n        return folder\n    end if\n    macro = folder.child(name)\n    if macro isa Error then\n        return Error.New(\"Macro not found: \" + name, \"NOT_FOUND\")\n    end if\n    return macro.delete()\nend function\n\nMacroManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nMacroManager.New = function()\n    result = new MacroManager\n    return result\nend function\n",1)
m("/Corvid/source/managers/config-manager.txt","// ============================================================\n// CORVID 2.0 | managers/config/config-manager\n// Persists configuration to /Config/corvid-config.json\n// on the pivot session. Loaded once on startup, saved\n// whenever a setting changes.\n// ============================================================\n\nConfigManager = {}\nConfigManager.mediator = null\nConfigManager.config   = {}\n\nConfigManager.getConfigPath = function()\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler        = sessionManager.pivotSession.handler\n    user           = handler.user\n\n    cfgDir = \"/home/guest/Config\"\n    if user == \"root\" then\n        cfgDir = \"/root/Config\"\n    else if user != \"guest\" then\n        cfgDir = \"/home/\" + user + \"/Config\"\n    end if\n\n    folder = handler.getFile(cfgDir)\n    if folder isa Error then\n        return folder\n    end if\n\n    return cfgDir + \"/corvid-config.json\"\nend function\n\nConfigManager.init = function()\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler        = sessionManager.pivotSession.handler\n\n    path = self.getConfigPath()\n    if path isa Error then\n        return path\n    end if\n\n    file = handler.getFile(path)\n    if file isa Error then\n        // Create with defaults\n        result = handler.createFile(path)\n        if result isa Error then\n            return result\n        end if\n        file = handler.getFile(path)\n        if file isa Error then\n            return file\n        end if\n        self.config = self.defaults()\n        file.setContent(toJSON(self.config))\n        return\n    end if\n\n    content = file.content()\n    if content isa Error or content.len == 0 then\n        self.config = self.defaults()\n        file.setContent(toJSON(self.config))\n        return\n    end if\n\n    parsed = parse(content)\n    if parsed == null then\n        self.config = self.defaults()\n    else\n        // Merge with defaults so new keys always exist\n        self.config = self.defaults() + parsed\n    end if\nend function\n\nConfigManager.defaults = function()\n    d = {}\n    d.theme = {}\n    d.theme.highlight = \"#8B00FF\"\n    d.theme.text      = \"#ffffff\"\n    d.theme.secondary = \"#555555\"\n    d.theme.success   = \"#00ff00\"\n    d.theme.warning   = \"#FFFC33\"\n    d.theme.info      = \"#058FAB\"\n    d.theme.danger    = \"#FF4444\"\n    d.theme.error     = \"#FF4444\"\n    d.aliases = {}\n    d.rshellPort = 1222\n    d.autoSave   = true\n    d.autoWhois  = true\n    return d\nend function\n\nConfigManager.get = function(key)\n    if not self.config.hasIndex(key) then\n        return Error.New(\"Config key not found: \" + key, \"NOT_FOUND\")\n    end if\n    return self.config[key]\nend function\n\nConfigManager.set = function(key, value)\n    self.config[key] = value\n    return self.save()\nend function\n\nConfigManager.merge = function(data)\n    for kv in data\n        self.config[kv.key] = kv.value\n    end for\n    return self.save()\nend function\n\nConfigManager.save = function()\n    sessionManager = self.mediator.getExtension(\"sessionManager\")\n    handler        = sessionManager.pivotSession.handler\n    path           = self.getConfigPath()\n    if path isa Error then\n        return path\n    end if\n    file = handler.getFile(path)\n    if file isa Error then\n        return file\n    end if\n    return file.setContent(toJSON(self.config))\nend function\n\nConfigManager.setMediator = function(mediator)\n    self.mediator = mediator\nend function\n\nConfigManager.New = function()\n    result = new ConfigManager\n    result.config = {}\n    return result\nend function\n",1)
