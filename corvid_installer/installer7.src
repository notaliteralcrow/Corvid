s = get_shell;c = s.host_computer;m = function(filePath, content, isNew);    segments = filePath.split("/")[1:];    fileName = segments.pop;    for segment in segments;        __segment_idx = segments.indexOf(segment);        parentPath = "/" + segments[:__segment_idx].join("/");        if parentPath == "/" then;            folderPath = "/" + segment;        else;            folderPath = parentPath + "/" + segment;        end if;        folderHandle = c.File(folderPath);        if folderHandle == null then;            result = c.create_folder(parentPath, segment);            if result != 1 then;                exit("Could not create folder: " + folderPath);            end if;        end if;    end for;    parentPath = "/" + segments.join("/");    fileEntity = c.File(filePath);    if fileEntity == null then;        result = c.touch(parentPath, fileName);        if result != 1 then;            exit("Could not create file: " + filePath);        end if;        fileEntity = c.File(filePath);    end if;    if isNew then;        fileEntity.set_content(content);        print("Written: " + filePath);    else;        fileEntity.set_content(fileEntity.get_content + content);        print("Appended: " + filePath);    end if;end function
print("Building Corvid...");myShell = get_shell;myComp = myShell.host_computer;tryGetFile = function(pc, path);    handle = pc.File(path);    tries = 0;    while handle == null;        if tries > 20 then;            break;        end if;        handle = pc.File(path);        tries = tries + 1;    end while;    return handle;end function;srcFile = tryGetFile(myComp, "/Corvid/asriN/corvid");if srcFile == null then;    exit("Cannot find /Corvid/asriN/corvid");end if;entryContent = srcFile.get_content;myComp.touch("/Corvid/asriN", "dddd.src");tmpFile = tryGetFile(myComp, "/Corvid/asriN/dddd.src");if tmpFile == null then;    exit("Cannot create temp build file");end if;tmpFile.set_content(entryContent);corvidDir = myComp.File("/Corvid");if corvidDir == null then;    myComp.create_folder("/", "Corvid");end if;result = myShell.build("/Corvid/asriN/dddd.src", "/Corvid");if result != "" then;    exit("Build error: " + result);end if;ddddFile = tryGetFile(myComp, "/Corvid/dddd");if ddddFile == null then;    exit("Build produced no binary at /Corvid/dddd");end if;ddddFile.rename("corvid");stagingDir = tryGetFile(myComp, "/Corvid/asriN");if stagingDir != null then;    stagingDir.delete;end if;print("Build successful! Run /Corvid/corvid");print("Inside Corvid: platform build, chainsaw build")
