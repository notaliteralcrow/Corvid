m("/Corvid/asriN/corvid", "// ============================================================" + char(10) + "// INIT" + char(10) + "// ============================================================" + char(10) + "" + char(10) + "init = function()" + char(10) + "    // 1  -  Add Nest as first session (pivot)" + char(10) + "    nestShell = get_shell" + char(10) + "    session   = sessionManager.addSession(nestShell, ""Nest"")" + char(10) + "    if session isa Error then" + char(10) + "        exit(""CORVID: Could not establish Nest session: "" + session.message)" + char(10) + "    end if" + char(10) + "" + char(10) + "    // 2  -  Load config first (theme depends on it)" + char(10) + "    configResult = configManager.init()" + char(10) + "    if configResult isa Error then" + char(10) + "        print(""[!] Config init failed: "" + configResult.message + ""  -  using defaults"")" + char(10) + "    end if" + char(10) + "" + char(10) + "    // 3  -  Init theme from config" + char(10) + "    themeManager.init()" + char(10) + "" + char(10) + "    // 4  -  Init database (needs pivot session)" + char(10) + "    dbResult = databaseManager.init()" + char(10) + "    if dbResult isa Error then" + char(10) + "        exit(""CORVID: Database init failed: "" + dbResult.message)" + char(10) + "    end if" + char(10) + "" + char(10) + "    // 5  -  Load metaxploit.so from Nest" + char(10) + "    nestHandler = sessionManager.pivotSession.handler" + char(10) + "    metaFile    = nestHandler.getFile(""/lib/metaxploit.so"")" + char(10) + "    if metaFile isa Error then" + char(10) + "        metaFile = nestHandler.getFile(""metaxploit.so"")" + char(10) + "    end if" + char(10) + "    if not (metaFile isa Error) then" + char(10) + "        rawMeta = include_lib(metaFile.path())" + char(10) + "        if rawMeta != null then" + char(10) + "            ipData = {}" + char(10) + "            ipData.ip = sessionManager.pivotSession.data.ip" + char(10) + "            ipData.path = metaFile.path()