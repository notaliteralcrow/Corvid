m("/Corvid/asriN/corvid", "    flockAptRepo = configManager.get(""flockAptRepo"")" + char(10) + "    if flockAptRepo isa Error then" + char(10) + "        configManager.set(""flockAptRepo"", ""30.225.197.154"")" + char(10) + "    end if" + char(10) + "    if autoShiny == ""1"" and shinyLibsManager.db.records.len == 0 then" + char(10) + "        nestHandler = sessionManager.pivotSession.handler" + char(10) + "        nestComp    = nestHandler.shell.shell.host_computer" + char(10) + "        nestLibDir  = nestComp.File(""/lib"")" + char(10) + "        if nestLibDir != null and nestLibDir.is_folder then" + char(10) + "            corvidUi.dim(""Scanning Nest /lib/ for shinylibs baseline..."")" + char(10) + "            libFiles = nestLibDir.get_files" + char(10) + "            if libFiles != null then" + char(10) + "                rawMeta = include_lib(""/lib/metaxploit.so"")" + char(10) + "                if rawMeta != null then" + char(10) + "                    for nestLib in libFiles" + char(10) + "                        if nestLib.name.indexOf("".so"") == null then" + char(10) + "                            continue" + char(10) + "                        end if" + char(10) + "                        metalib = rawMeta.load(nestLib.path)" + char(10) + "                        if metalib == null then" + char(10) + "                            continue" + char(10) + "                        end if" + char(10) + "                        addrs = rawMeta.scan(metalib)" + char(10) + "                        if addrs == null then" + char(10) + "                            addrs = []" + char(10) + "                        end if" + char(10) + "                        exploitTexts = []" + char(10) + "                        for addr in addrs" + char(10) + "                            txt = rawMeta.scan_address(metalib, addr)" + char(10) + "                            if txt != null then" + char(10) + "                                exploitTexts.push(txt)" + char(10) + "                            end if" + char(10) + "                        end for" + char(10) + "                        shinyLibsManager.db.stage(nestLib.name, metalib.version, exploitTexts, nestLib.path)" + char(10) + "                    end for" + char(10) + "                end if" + char(10) + "            end if" + char(10) + "            // Auto-collect all staged Nest libs into DB (no SCP needed - already local)" + char(10) + "            for staged in shinyLibsManager.db.staged" + char(10) + "                shinyLibsManager.db.collect(staged.libName, staged.version, staged.srcPath)" + char(10) + "            end for" + char(10) + "            databaseManager.save()" + char(10) + "            corvidUi.dim(""Shinylibs baseline: "" + str(shinyLibsManager.db.records.len) + "" lib(s) recorded from Nest."")" + char(10) + "        end if" + char(10) + "    end if" + char(10) + "" + char(10) + "    // 11 -  Run init macro if present" + char(10) + "    macroManager.init()" + char(10) + "end function" + char(10) + "" + char(10) + "// ============================================================" + char(10) + "// ENTRY" + char(10) + "// ============================================================" + char(10) + "" + char(10) + "init()" + char(10) + "" + char(10) + "// Show menu on startup" + char(10) + "showMainMenu = true" + char(10) + "" + char(10) + "while true" + char(10) + "    // -- Session health check -----------------------------------------------------" + char(10) + "    currentSess = sessionManager.currentSession" + char(10) + "    if currentSess != null and currentSess != sessionManager.pivotSession then" + char(10) + "        sessHandler = currentSess.handler" + char(10) + "        sessionDead = false" + char(10) + "        if sessHandler isa ShellSession then" + char(10) + "            rawShell = sessHandler.shell.shell" + char(10) + "            if rawShell == null then" + char(10) + "                sessionDead = true" + char(10) + "            else" + c