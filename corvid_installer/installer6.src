s = get_shell
c = s.host_computer
m = function(filePath, content, isNew)
    segments = filePath.split("/")[1:]
    fileName = segments.pop
    for segment in segments
        __segment_idx = segments.indexOf(segment)
        parentPath = "/" + segments[:__segment_idx].join("/")
        if parentPath == "/" then
            folderPath = "/" + segment
        else
            folderPath = parentPath + "/" + segment
        end if
        folderHandle = c.File(folderPath)
        if folderHandle == null then
            result = c.create_folder(parentPath, segment)
            if result != 1 then
                exit("Could not create folder: " + folderPath)
            end if
        end if
    end for
    parentPath = "/" + segments.join("/")
    fileEntity = c.File(filePath)
    if fileEntity == null then
        result = c.touch(parentPath, fileName)
        if result != 1 then
            exit("Could not create file: " + filePath)
        end if
        fileEntity = c.File(filePath)
    end if
    if isNew then
        fileEntity.set_content(content)
        print("Written: " + filePath)
    else
        fileEntity.set_content(fileEntity.get_content + content)
        print("Appended: " + filePath)
    end if
end function
m("/Corvid/source/commands_4.txt",": false, \"default\": \"\"}), StringParameter.New({\"name\": \"arg3\", \"required\": false, \"default\": \"\"}), StringParameter.New({\"name\": \"arg4\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n\n    sub  = params.subcommand.trim.lower\n    arg1 = params.arg1.trim\n    arg2 = params.arg2.trim\n    arg3 = params.arg3.trim\n    arg4 = params.arg4.trim\n\n    // Determine router IP - use arg1 for list, arg4 for add/remove (optional last arg)\n    // For list: portfwd list [routerip]\n    // For add:  portfwd add <extport> <intport> <lanip> [routerip]\n    // For remove: portfwd remove <extport> <lanip> [routerip]\n    routerIp = \"\"\n    if sub == \"list\" then\n        routerIp = arg1\n    else if sub == \"add\" then\n        routerIp = arg4\n    else if sub == \"remove\" then\n        routerIp = arg3\n    end if\n\n    // Get router object\n    rawRouter = null\n    if routerIp.len > 0 and is_valid_ip(routerIp) then\n        rawRouter = get_router(routerIp)\n    else\n        rawRouter = get_router()\n    end if\n    if rawRouter == null then\n        routerDesc = \" (local)\"\n        if routerIp.len > 0 then\n            routerDesc = \" at \" + routerIp\n        end if\n        return Error.New(\"Could not access router\" + routerDesc, \"NO_ROUTER\")\n    end if\n\n    if sub == \"list\" then\n        ui.separator()\n        ui.highlight(\"PORT FORWARDING  [\" + rawRouter.public_ip + \"]\")\n        ui.separator()\n        usedPorts = rawRouter.used_ports\n        if usedPorts == null or usedPorts.len == 0 then\n            ui.info(\"No port forwarding rules configured\")\n        else\n            ui.info(\"External Port  ->  LAN IP  :  Internal Port\")\n            for p in usedPorts\n                extPort = p.port_number\n                lanIp   = p.get_lan_ip\n                status  = \"\"\n                if p.is_closed then\n                    status = \"  [closed]\"\n                end if\n                // Get service info\n                infoStr = rawRouter.port_info(extPort)\n                svcStr = \"\"\n                if infoStr != null and infoStr.len > 0 then\n                    svcStr = \"  (\" + infoStr + \")\"\n                end if\n                ui.info(\"  \" + str(extPort) + \"  ->  \" + lanIp + svcStr + status)\n            end for\n        end if\n        ui.separator()\n\n    else if sub == \"add\" then\n        if arg1.len == 0 or arg2.len == 0 or arg3.len == 0 then\n            return Error.New(\"Usage: portfwd add <extport> <intport> <lanip> [routerip]\", \"USAGE\")\n        end if\n        extPort = arg1.val\n        intPort = arg2.val\n        lanIp   = arg3\n        if extPort <= 0 then\n            return Error.New(\"Invalid external port: \" + arg1, \"INVALID_PORT\")\n        end if\n        if intPort <= 0 then\n            return Error.New(\"Invalid internal port: \" + arg2, \"INVALID_PORT\")\n        end if\n        if not is_valid_ip(lanIp) then\n            return Error.New(\"Invalid LAN IP: \" + lanIp, \"INVALID_IP\")\n        end if\n\n        ui.info(\"Adding port forward: \" + str(extPort) + \" -> \" + lanIp + \":\" + str(intPort) + \"...\")\n        result = rawRouter.port_forward_rule(extPort, intPort, lanIp)\n        if typeof(result) == \"string\" and result.len > 0 then\n            return Error.New(\"Failed: \" + result, \"FORWARD_FAILED\")\n        end if\n        ui.success(\"Port forward added: external \" + str(extPort) + \" -> \" + lanIp + \":\" + str(intPort))\n\n    else if sub == \"remove\" then\n        if arg1.len == 0 or arg2.len == 0 then\n            return Error.New(\"Usage: portfwd remove <extport> <lanip> [routerip]\", \"USAGE\")\n        end if\n        extPort = arg1.val\n        lanIp   = arg2\n        if extPort <= 0 then\n            return Error.New(\"Invalid port: \" + arg1, \"INVALID_PORT\")\n        end if\n        if not is_valid_ip(lanIp) then\n            return Error.New(\"Invalid LAN IP: \" + lanIp, \"INVALID_IP\")\n        end if\n\n        ui.info(\"Removing port forward: \" + str(extPort) + \" -> \" + lanIp + \"...\")\n        result = rawRouter.close_port(extPort, lanIp)\n        if typeof(result) == \"string\" and result.len > 0 then\n            return Error.New(\"Failed: \" + result, \"REMOVE_FAILED\")\n        end if\n        ui.success(\"Port forward removed: \" + str(extPort) + \" -> \" + lanIp)\n\n    else\n        return Error.New(\"Unknown subcommand: \" + sub + \". Use: list, add, remove\", \"UNKNOWN_SUB\")\n    end if\nend function\ncommandManager.register(_cmd)\n\n// ── intel ─────────────────────────────────────────────────────────────────\n// Aggregated intel view for a target IP from DB\n_cmd = new Command\n_cmd.name = \"intel\"\n_cmd.description = \"Show all stored intel for a target IP. Usage: intel <ip>\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\", \"required\": true})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui        = mediator.getExtension(\"corvidUi\")\n    dbManager = mediator.getExtension(\"databaseManager\")\n\n    targetIp = params.ip.trim\n    if not is_valid_ip(targetIp) then\n        return Error.New(\"Invalid IP: \" + targetIp, \"INVALID_IP\")\n    end if\n\n    ui.separator()\n    ui.highlight(\"INTEL  [\" + targetIp + \"]\")\n    ui.separator()\n\n    // Find all target records for this IP\n    targets = dbManager.findTarget(targetIp)\n    if targets.len == 0 then\n        ui.warning(\"No target records found for \" + targetIp)\n        ui.info(\"Run: nmap \" + targetIp + \" to scan first\")\n        return\n    end if\n\n    // Show each LAN record\n    for tgt in targets\n        lanIp = \"\"\n        if tgt.hasIndex(\"lan_ip\") then\n            lanIp = tgt.lan_ip\n        end if\n        status = \"\"\n        if tgt.hasIndex(\"status\") then\n            status = tgt.status\n        end if\n        priv = \"\"\n        if tgt.hasIndex(\"privilege\") then\n            priv = tgt.privilege\n        end if\n\n        label = tgt.id + \"  \" + targetIp\n        if lanIp.len > 0 and lanIp != \"unknown\" then\n            label = label + \" / \" + lanIp\n        end if\n        ui.highlight(\"  \" + label)\n\n        // Status and privilege\n        statusLine = \"  Status: \" + status\n        if priv.len > 0 and priv != \"unknown\" then\n            statusLine = statusLine + \"  |  Privilege: \" + priv\n        end if\n        ui.info(statusLine)\n\n        // Ports\n        if tgt.hasIndex(\"ports\") and tgt.ports.len > 0 then\n            ui.print(\"\")\n            ui.info(\"  PORTS:\")\n            for pr in tgt.ports\n                fwdStr = \"\"\n                if pr.forwarded then\n                    fwdStr = \" [fwd]\"\n                end if\n                exStr = \"\"\n                if pr.exploited then\n                    exStr = \" [exploited]\"\n                end if\n                ui.print(\"    \" + str(pr.port) + \"  \" + pr.service + \" v\" + pr.version + fwdStr + exStr)\n            end for\n        end if\n\n        // Exploit results summary\n        if tgt.hasIndex(\"exploit_db\") then\n            totalExploits = 0\n            workingExploits = 0\n            for libKey in tgt.exploit_db.indexes\n                for ex in tgt.exploit_db[libKey]\n                    totalExploits = totalExploits + 1\n                    if ex.rtype != \"Failed\" then\n                        workingExploits = workingExploits + 1\n                    end if\n                end for\n            end for\n            if totalExploits > 0 then\n                ui.print(\"\")\n                ui.info(\"  EXPLOITS: \" + str(workingExploits) + \" working / \" + str(totalExploits) + \" total across \" + str(tgt.exploit_db.indexes.len) + \" lib(s)\")\n                // Show working ones\n                for libKey in tgt.exploit_db.indexes\n                    for ex in tgt.exploit_db[libKey]\n                        if ex.rtype != \"Failed\" then\n                            ui.success(\"    \" + ex.exploit + \"  ->  \" + ex.rtype + \" (\" + ex.privilege + \")  [\" + libKey + \"]\")\n                        end if\n                    end for\n                end for\n            end if\n        end if\n\n        // Notes (cleaned)\n        if tgt.hasIndex(\"notes\") and tgt.notes.len > 0 then\n            noteLines = tgt.notes.split(char(10))\n            if noteLines.len > 0 then\n                ui.print(\"\")\n                ui.info(\"  NOTES:\")\n                for nl in noteLines\n                    nl = nl.trim\n                    if nl.len > 0 then\n                        ui.dim(\"    \" + nl)\n                    end if\n                end for\n            end if\n        end if\n\n        ui.print(\"\")\n    end for\n\n    // Credentials for this IP\n    creds = dbManager.findCredentialsByIp(targetIp)\n    if creds.len > 0 then\n        ui.separator()\n        ui.info(\"CREDENTIALS  (\" + str(creds.len) + \")\")\n        for cr in creds\n            typeStr = \"\"\n            if cr.hasIndex(\"type\") then\n                typeStr = \"[\" + cr.type + \"] \"\n            end if\n            srcStr = \"\"\n            if cr.hasIndex(\"source\") then\n                srcStr = \"  (source: \" + cr.source + \")\"\n            end if\n            ui.success(\"  \" + typeStr + cr.username + \" / \" + cr.password + srcStr)\n        end for\n        ui.print(\"\")\n    end if\n\n    // Persons associated with this IP\n    persons = dbManager.allPersons()\n    ipPersons = []\n    for p in persons\n        if p.hasIndex(\"public_ip\") and p.public_ip == targetIp then\n            ipPersons.push(p)\n        else if p.hasIndex(\"ip\") and p.ip == targetIp then\n            ipPersons.push(p)\n        end if\n    end for\n    if ipPersons.len > 0 then\n        ui.separator()\n        ui.info(\"PERSONS  (\" + str(ipPersons.len) + \")\")\n        for p in ipPersons\n            line = \"  \" + p.username\n            if p.hasIndex(\"email\") and p.email.len > 0 then\n                line = line + \"  <\" + p.email + \">\"\n            end if\n            if p.hasIndex(\"lan_ip\") and p.lan_ip.len > 0 then\n                line = line + \"  (LAN: \" + p.lan_ip + \")\"\n            end if\n            ui.info(line)\n        end for\n        ui.print(\"\")\n    end if\n\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// ── su ────────────────────────────────────────────────────────────────────\n// Escalate privileges on current session using credentials\n// Uses connect_service back to same machine - no SSH dependency\n_cmd = new Command\n_cmd.name = \"su\"\n_cmd.description = \"Escalate privileges on current session. Tries DB credentials then prompts. Usage: su [user] [password]\"\n_cmd.parameters = [StringParameter.New({\"name\": \"user\", \"required\": false, \"default\": \"root\"}), StringParameter.New({\"name\": \"password\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n\n    currentSession = sessionManager.currentSession\n    if currentSession == null then\n        return Error.New(\"No active session\", \"NO_SESSION\")\n    end if\n\n    if not (currentSession.handler isa ShellSession) then\n        return Error.New(\"su requires a shell session\", \"NOT_SHELL\")\n    end if\n\n    currentPriv = currentSession.handler.privilege()\n    if currentPriv == \"root\" then\n        ui.info(\"Already root on this session\")\n        return\n    end if\n\n    targetUser = params.user.trim\n    if targetUser.len == 0 then\n        targetUser = \"root\"\n    end if\n    targetPass = params.password.trim\n\n    // Get target IP from current session\n    targetIp = currentSession.data.ip.public\n    if targetIp == null or targetIp.len == 0 or targetIp == \"unknown\" then\n        targetIp = currentSession.data.ip.local\n    end if\n\n    ui.separator()\n    ui.highlight(\"PRIVILEGE ESCALATION\")\n    ui.separator()\n    ui.info(\"Current: \" + currentPriv + \" on \" + targetIp)\n    ui.info(\"Target:  \" + targetUser)\n    ui.print(\"\")\n\n    // Build list of passwords to try: param first, then DB for this IP, then prompt\n    toTry = []\n    if targetPass.len > 0 then\n        toTry.push({\"user\": targetUser, \"pass\": targetPass, \"src\": \"argument\"})\n    end if\n\n    // Check DB for credentials matching this IP and user\n    creds = dbManager.findCredentialsByIp(targetIp)\n    for cr in creds\n        if cr.username == targetUser or cr.username == \"root\" then\n            alreadyIn = false\n            for t in toTry\n                if t.pass == cr.password then\n                    alreadyIn = true\n                end if\n            end for\n            if not alreadyIn and cr.password.len > 0 then\n                toTry.push({\"user\": cr.username, \"pass\": cr.password, \"src\": \"db\"})\n            end if\n            if cr.hasIndex(\"native_pass\") and cr.native_pass.len > 0 then\n                alreadyIn = false\n                for t in toTry\n                    if t.pass == cr.native_pass then\n                        alreadyIn = true\n                    end if\n                end for\n                if not alreadyIn then\n                    toTry.push({\"user\": cr.username, \"pass\": cr.native_pass, \"src\": \"db\"})\n                end if\n            end if\n        end if\n    end for\n\n    // If nothing in DB, prompt\n    if toTry.len == 0 then\n        manualPass = user_input(\"  Password for \" + targetUser + \": \")\n        if manualPass.trim.len > 0 then\n            toTry.push({\"user\": targetUser, \"pass\": manualPass.trim, \"src\": \"manual\"})\n        end if\n    end if\n\n    if toTry.len == 0 then\n        return Error.New(\"No credentials to try\", \"NO_CREDS\")\n    end if\n\n    // Try each credential using connect_service from the current shell\n    // This uses the already-established network path so works for LAN machines too\n    currentShell = currentSession.handler.shell.shell\n    targetLocalIp  = currentSession.data.ip.local\n    targetPublicIp = currentSession.data.ip.public\n\n    // Find an SSH port to connect back on - check DB ports first\n    sshPort = 22\n    targets = dbManager.findTarget(targetIp)\n    if targets.len > 0 then\n        for tgt in targets\n            if not tgt.hasIndex(\"ports\") then\n                continue\n            end if\n            for pr in tgt.ports\n                if pr.service == \"ssh\" then\n                    sshPort = pr.port\n                end if\n            end for\n        end for\n    end if\n    ui.info(\"Using port \" + str(sshPort) + \" for re-connection\")\n\n    // Determine which IP to connect to:\n    // If we have a local IP and it differs from public, use local (LAN machine)\n    connectIp = targetPublicIp\n    if targetLocalIp.len > 0 and targetLocalIp != \"unknown\" and targetLocalIp != targetPublicIp then\n        connectIp = targetLocalIp\n    end if\n\n    for cred in toTry\n        ui.info(\"Trying \" + cred.user + \" / *** (from \" + cred.src + \")...\")\n        result = currentShell.connect_service(connectIp, sshPort, cred.user, cred.pass, \"ssh\")\n        if typeof(result) == \"shell\" then\n            newSession = sessionManager.addSession(result, cred.user + \"@\" + connectIp + \" [su]\")\n            if not (newSession isa Error) then\n                sessionManager.setCurrentSession(newSession)\n                newPriv = newSession.handler.privilege()\n                ui.success(\"Escalated to: \" + newPriv + \" on \" + connectIp)\n                if cred.src != \"db\" then\n                    credData = {}\n                    credData.username = cred.user ; credData.password = cred.pass\n                    credData.type = \"system\" ; credData.public_ip = targetPublicIp\n                    credData.lan_ip = targetLocalIp ; credData.source = \"native\"\n                    dbManager.upsertCredential(credData) ; dbManager.save()\n                    ui.info(\"Credential saved to DB\")\n                end if\n                return\n            end if\n        end if\n        ui.dim(\"  -> failed\")\n    end for\n\n    ui.warning(\"All credentials failed for \" + targetUser + \" on \" + connectIp)\n    ui.info(\"Tip: Run 'harvest' to collect more credentials, or try 'attack' for deep escalation\")\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// ── sniffer ───────────────────────────────────────────────────────────────\n// Run metaxploit sniffer on a router and save captured credentials to DB\n\n// ── setscanlan ────────────────────────────────────────────────────────────\n\n// ── scanlan ───────────────────────────────────────────────────────────────\n\n// ── desktop ───────────────────────────────────────────────────────────────\n// Launch AdminMonitor, FileExplorer, Browser and Mail all at once.\n_cmd = new Command\n_cmd.name = \"desktop\"\n_cmd.description = \"Launch AdminMonitor, FileExplorer, Browser and Mail in one command.\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n\n    handler = sessionManager.currentSession.handler\n\n    launched = []\n    failed   = []\n\n    apps = [\n        {\"name\": \"AdminMonitor\", \"bin\": \"AdminMonitor.exe\"},\n        {\"name\": \"FileExplorer\", \"bin\": \"FileExplorer.exe\"},\n        {\"name\": \"Browser\",      \"bin\": \"Browser.exe\"},\n        {\"name\": \"Mail\",         \"bin\": \"Mail.exe\"},\n    ]\n\n    first = true\n    for app in apps\n        // Search /usr/bin then /bin\n        binPath = \"\"\n        f1 = handler.getFile(\"/usr/bin/\" + app.bin)\n        if not (f1 isa Error) then\n            binPath = \"/usr/bin/\" + app.bin\n        end if\n        if binPath.len == 0 then\n            f2 = handler.getFile(\"/bin/\" + app.bin)\n            if not (f2 isa Error) then\n                binPath = \"/bin/\" + app.bin\n            end if\n        end if\n        if binPath.len == 0 then\n            failed.push(app.name)\n            continue\n        end if\n        // Grey Hack requires 2 second gap between GUI launches\n        if not first then\n            wait(2)\n        end if\n        handler.shell.launch(binPath, \"\")\n        launched.push(app.name)\n        first = false\n    end for\n\n    if launched.len > 0 then\n        ui.success(\"Launched: \" + launched.join(\", \"))\n    end if\n    if failed.len > 0 then\n        ui.warning(\"Not found: \" + failed.join(\", \"))\n    end if\nend function\ncommandManager.register(_cmd)\n\n\n// ── aptsetup ──────────────────────────────────────────────────────────────\n// Install aptclient.so from Nest and write sources.txt on current root session.\n// Prepares a target router/machine to run apt-get for package installation.\n\n\n// ── smtpgrab ──────────────────────────────────────────────────────────────\n// Use crypto.smtp_user_list to enumerate email users on the current session's\n// SMTP server. Saves results to persons DB for social engineering.\n_cmd = new Command\n_cmd.name = \"smtpgrab\"\n_cmd.description = \"Enumerate SMTP email users on current session. Saves to DB for social engineering.\"\n_cmd.parameters = [StringParameter.New({\"name\": \"ip\", \"required\": false, \"default\": \"\"}), StringParameter.New({\"name\": \"port\", \"required\": false, \"default\": \"25\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n\n    // Resolve target IP - default to current session\n    targetIp = params.ip.trim\n    targetPort = params.port.val\n    if targetIp.len == 0 then\n        targetIp = sessionManager.currentSession.data.ip.public\n    end if\n    if targetPort <= 0 then\n        targetPort = 25\n    end if\n\n    ui.separator()\n    ui.highlight(\"SMTP USER GRAB  \" + targetIp + \":\" + str(targetPort))\n    ui.separator()\n\n    // Load crypto from Nest\n    crypto = include_lib(\"/lib/crypto.so\")\n    if crypto == null then\n        return Error.New(\"crypto.so not found in /lib - cannot run smtp_user_list\", \"NO_CRYPTO\")\n    end if\n\n    ui.info(\"Querying SMTP user list on \" + targetIp + \":\" + str(targetPort) + \"...\")\n    result = crypto.smtp_user_list(targetIp, targetPort)\n\n    if result == null then\n        ui.warning(\"No result returned - SMTP may not be accessible or smtp_user_list unsupported in this game version.\")\n        ui.info(\"Try: verify port 25 is open and forwarded on \" + targetIp)\n        return\n    end if\n\n    if typeof(result) == \"string\" and result.len == 0 then\n        ui.warning(\"Empty result - no users found or SMTP not responding.\")\n        return\n    end if\n\n    // Parse results - smtp_user_list may return:\n    //   \"user@domain.com\" - full email\n    //   \"username\" - plain username\n    //   \"username email not found\" - username with no mail config\n    ui.print(\"\")\n    ui.highlight(\"SMTP USERS FOUND\")\n    ui.separator()\n\n    users = []\n    if typeof(result) == \"list\" then\n        users = result\n    else\n        for line in result.split(char(10))\n            t = line.trim\n            if t.len > 0 then\n                if t.indexOf(\" email not found\") != null then\n                    t = t.split(\" email not found\")[0].trim\n                end if\n                if t.len > 0 then\n                    users.push(t)\n                end if\n            end if\n        end for\n    end if\n\n    if users.len == 0 then\n        ui.warning(\"Could not parse any users from result.\")\n        ui.info(\"Raw result: \" + str(result))\n        return\n    end if\n\n    // Try to get domain hint from existing persons DB for this IP\n    smtpDomain = \"\"\n    existingPersons = dbManager.allPersons()\n    for ep in existingPersons\n        if smtpDomain.len > 0 then\n            break\n        end if\n        epIp = \"\"\n        if ep.hasIndex(\"public_ip\") then\n            epIp = ep.public_ip\n        end if\n        if epIp == targetIp and ep.hasIndex(\"email\") then\n            eParts = ep.email.split(\"@\")\n            if eParts.len >= 2 then\n                smtpDomain = eParts[1]\n            end if\n        end if\n    end for\n\n    saved = 0\n    for u in users\n        pd = {}\n        pd.public_ip = targetIp\n        pd.source    = \"smtpgrab\"\n        if u.indexOf(\"@\") != null then\n            parts = u.split(\"@\")\n            pd.username = parts[0]\n            pd.email    = u\n            ui.info(\"  \" + u + \"  → social engineering target\")\n        else\n            pd.username = u\n            if smtpDomain.len > 0 then\n                pd.email = u + \"@\" + smtpDomain\n                ui.info(\"  \" + u + \" (\" + pd.email + \")  → social engineering target\")\n            else\n                ui.info(\"  \" + u + \"  → social engineering target\")\n            end if\n        end if\n        dbManager.upsertPerson(pd)\n        saved = saved + 1\n    end for\n\n    dbManager.save()\n    ui.print(\"\")\n    ui.success(\"Saved \" + str(saved) + \" user(s) to DB.\")\n    ui.info(\"Mail.exe -> PF -> Funny Game -> send your Nest IP + port 1222\")\n    ui.info(\"Use: persons  to view saved records\")\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// ── dbsync ────────────────────────────────────────────────────────────────\n// Transfers DB files to/from a remote Corvid server via SSH.\n// push: sends local DB files to remote /Corvid/Data/incoming/\n// pull: fetches remote DB files to local /Corvid/Data/incoming/\n// Run dbmerge after either to integrate the incoming files.\n_cmd = new Command\n_cmd.name = \"dbsync\"\n_cmd.description = \"Sync DB files with a remote Corvid server. Subcommands: push pull\"\n_cmd.parameters = [OptionsParameter.New({\"name\": \"subcommand\", \"required\": true, \"options\": {\"push\": \"push\", \"pull\": \"pull\"}})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    sub            = params.subcommand\n\n    ui.separator()\n    if sub == \"push\" then\n        ui.highlight(\"DBSYNC PUSH  -  send local DB to remote server\")\n    else\n        ui.highlight(\"DBSYNC PULL  -  fetch remote DB to local incoming/\")\n    end if\n    ui.separator()\n\n    // Prompt for remote server credentials\n    remoteIp   = user_input(\"  Remote server IP: \").trim\n    remoteUser = user_input(\"  Username (default: root): \").trim\n    remotePass = user_input(\"  Password: \").trim\n\n    if remoteIp.len == 0 then\n        return Error.New(\"Remote IP required\", \"MISSING_PARAM\")\n    end if\n    if remoteUser.len == 0 then\n        remoteUser = \"root\"\n    end if\n    if remotePass.len == 0 then\n        return Error.New(\"Password required\", \"MISSING_PARAM\")\n    end if\n\n    // Open SSH connection to remote\n    ui.info(\"Connecting to \" + remoteIp + \" as \" + remoteUser + \"...\")\n    pivotHandler = sessionManager.pivotSession.handler\n    localShell   = pivotHandler.shell.shell\n\n    remoteShell = localShell.connect_service(remoteIp, 22, remoteUser, remotePass, \"ssh\")\n    if typeof(remoteShell) != \"shell\" then\n        return Error.New(\"SSH connection failed - check IP, user, and password\", \"CONNECT_FAILED\")\n    end if\n    ui.success(\"Connected to \" + remoteIp)\n\n    remoteComp = remoteShell.host_computer\n\n    // DB files to transfer\n    dbFiles = [\n        \"credentials.json\",\n        \"targets.json\",\n        \"persons.json\",\n        \"orgs.json\",\n        \"exploit-kb.json\",\n        \"roost.json\",\n    ]\n\n    localDataPath  = \"/Corvid/Data\"\n    remoteDataPath = \"/Corvid/Data\"\n    incomingPath   = \"/Corvid/Data/incoming\"\n\n    transferred = 0\n    failed      = 0\n\n    if sub == \"push\" then\n        // Ensure remote incoming/ dir exists\n        remoteIncoming = remoteComp.File(incomingPath)\n        if remoteIncoming == null then\n            remoteComp.create_folder(remoteDataPath, \"incoming\")\n            ui.dim(\"  Created remote /Corvid/Data/incoming/\")\n        end if\n\n        // SCP each local DB file to remote incoming/\n        for fname in dbFiles\n            localPath = localDataPath + \"/\" + fname\n            localFile = pivotHandler.getFile(localPath)\n            if localFile isa Error then\n                ui.dim(\"  Skipping \" + fname + \" (not found locally)\")\n                continue\n            end if\n            ui.info(\"  Pushing \" + fname + \"...\")\n            scpResult = localShell.scp(localPath, incomingPath, remoteShell)\n            if typeof(scpResult) == \"string\" and scpResult.len > 0 then\n                ui.warning(\"  Failed: \" + fname + \" - \" + scpResult)\n                failed = failed + 1\n            else\n                ui.success(\"  Pushed: \" + fname)\n                transferred = transferred + 1\n            end if\n        end for\n\n    else\n        // pull - ensure local incoming/ dir exists\n        localIncoming = pivotHandler.getFile(incomingPath)\n        if localIncoming isa Error then\n            localShell.host_computer.create_folder(localDataPath, \"incoming\")\n            ui.dim(\"  Created local /Corvid/Data/incoming/\")\n        end if\n\n        // SCP each remote DB file to local incoming/\n        // We call SCP on the remote shell to push to us\n        for fname in dbFiles\n            remotePath = remoteDataPath + \"/\" + fname\n            remoteFile = remoteComp.File(remotePath)\n            if remoteFile == null then\n                ui.dim(\"  Skipping \" + fname + \" (not found on remote)\")\n                continue\n            end if\n            ui.info(\"  Pulling \" + fname + \"...\")\n            scpResult = remoteShell.scp(remotePath, incomingPath, localShell)\n            if typeof(scpResult) == \"string\" and scpResult.len > 0 then\n                ui.warning(\"  Failed: \" + fname + \" - \" + scpResult)\n                failed = failed + 1\n            else\n                ui.success(\"  Pulled: \" + fname)\n                transferred = transferred + 1\n            end if\n        end for\n    end if\n\n    ui.print(\"\")\n    ui.info(\"Transferred: \" + str(transferred) + \"  Failed: \" + str(failed))\n    if transferred > 0 then\n        ui.success(\"Run: dbmerge  to integrate incoming files into live DB\")\n    end if\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// ── dbmerge ───────────────────────────────────────────────────────────────\n// Reads DB files from /Corvid/Data/incoming/ and merges them into\n// the live DB using existing upsert logic. Safe to run multiple times.\n_cmd = new Command\n_cmd.name = \"dbmerge\"\n_cmd.description = \"Merge incoming DB files from /Corvid/Data/incoming/ into live DB\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui        = mediator.getExtension(\"corvidUi\")\n    dbManager = mediator.getExtension(\"databaseManager\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n\n    ui.separator()\n    ui.highlight(\"DBMERGE  -  integrating incoming DB files\")\n    ui.separator()\n\n    pivotHandler  = sessionManager.pivotSession.handler\n    incomingPath  = \"/Corvid/Data/incoming\"\n\n    incomingDir = pivotHandler.getFile(incomingPath)\n    if incomingDir isa Error then\n        return Error.New(\"No incoming/ directory found. Run dbsync push/pull first.\", \"NOT_FOUND\")\n    end if\n\n    // ── Credentials ───────────────────────────────────────────────────────\n    credFile = pivotHandler.getFile(incomingPath + \"/credentials.json\")\n    credAdded = 0\n    credSkipped = 0\n    if not (credFile isa Error) then\n        raw = credFile.content()\n        if not (raw isa Error) and raw.len > 0 then\n            parsed = parse(raw)\n            if parsed != null and typeof(parsed) == \"map\" then\n                for kv in parsed\n                    rec = kv.value\n                    if not rec.hasIndex(\"type\") or not rec.hasIndex(\"username\") then\n                        credSkipped = credSkipped + 1\n                        continue\n                    end if\n                    dbManager.upsertCredential(rec)\n                    credAdded = credAdded + 1\n                end for\n            end if\n        end if\n        ui.success(\"Credentials: \" + str(credAdded) + \" merged, \" + str(credSkipped) + \" skipped\")\n    else\n        ui.dim(\"Credentials: no incoming file\")\n    end if\n\n    // ── Targets ───────────────────────────────────────────────────────────\n    targetFile = pivotHandler.getFile(incomingPath + \"/targets.json\")\n    targetAdded = 0\n    targetSkipped = 0\n    if not (targetFile isa Error) then\n        raw = targetFile.content()\n        if not (raw isa Error) and raw.len > 0 then\n            parsed = parse(raw)\n            if parsed != null and typeof(parsed) == \"map\" then\n                for kv in parsed\n                    rec = kv.value\n                    if not rec.hasIndex(\"public_ip\") then\n                        targetSkipped = targetSkipped + 1\n                        continue\n                    end if\n                    dbManager.upsertTarget(rec)\n                    targetAdded = targetAdded + 1\n                end for\n            end if\n        end if\n        ui.success(\"Targets: \" + str(targetAdded) + \" merged, \" + str(targetSkipped) + \" skipped\")\n    else\n        ui.dim(\"Targets: no incoming file\")\n    end if\n\n    // ── Persons ───────────────────────────────────────────────────────────\n    personFile = pivotHandler.getFile(incomingPath + \"/persons.json\")\n    personAdded = 0\n    personSkipped = 0\n    if not (personFile isa Error) then\n        raw = personFile.content()\n        if not (raw isa Error) and raw.len > 0 then\n            parsed = parse(raw)\n            if parsed != null and typeof(parsed) == \"map\" then\n                for kv in parsed\n                    rec = kv.value\n                    if not rec.hasIndex(\"email\") or rec.email.len == 0 then\n                        personSkipped = personSkipped + 1\n                        continue\n                    end if\n                    dbManager.upsertPerson(rec)\n                    personAdded = personAdded + 1\n                end for\n            end if\n        end if\n        ui.success(\"Persons: \" + str(personAdded) + \" merged, \" + str(personSkipped) + \" skipped\")\n    else\n        ui.dim(\"Persons: no incoming file\")\n    end if\n\n    // ── Orgs ──────────────────────────────────────────────────────────────\n    orgFile = pivotHandler.getFile(incomingPath + \"/orgs.json\")\n    orgAdded = 0\n    orgSkipped = 0\n    if not (orgFile isa Error) then\n        raw = orgFile.content()\n        if not (raw isa Error) and raw.len > 0 then\n            parsed = parse(raw)\n            if parsed != null and typeof(parsed) == \"map\" then\n                for kv in parsed\n                    rec = kv.value\n                    if not rec.hasIndex(\"domain\") or rec.domain.len == 0 then\n                        orgSkipped = orgSkipped + 1\n                        continue\n                    end if\n                    dbManager.upsertOrg(rec)\n                    orgAdded = orgAdded + 1\n                end for\n            end if\n        end if\n        ui.success(\"Orgs: \" + str(orgAdded) + \" merged, \" + str(orgSkipped) + \" skipped\")\n    else\n        ui.dim(\"Orgs: no incoming file\")\n    end if\n\n    // ── Exploit KB ────────────────────────────────────────────────────────\n    kbFile = pivotHandler.getFile(incomingPath + \"/exploit-kb.json\")\n    kbAdded = 0\n    kbSkipped = 0\n    if not (kbFile isa Error) then\n        raw = kbFile.content()\n        if not (raw isa Error) and raw.len > 0 then\n            parsed = parse(raw)\n            if parsed != null and typeof(parsed) == \"map\" then\n                for kv in parsed\n                    rec = kv.value\n                    if not rec.hasIndex(\"lib_name\") or not rec.hasIndex(\"lib_version\") or not rec.hasIndex(\"address\") or not rec.hasIndex(\"exploit\") then\n                        kbSkipped = kbSkipped + 1\n                        continue\n                    end if\n                    // Use kbRecord to merge - it handles success_count, fail_count correctly\n                    outcome = \"uncertain\"\n                    if rec.hasIndex(\"outcome\") then\n                        outcome = rec.outcome\n                    end if\n                    rtype = \"\"\n                    if rec.hasIndex(\"rtype\") then\n                        rtype = rec.rtype\n                    end if\n                    resultPath = \"\"\n                    if rec.hasIndex(\"result_path\") then\n                        resultPath = rec.result_path\n                    end if\n                    privilege = \"\"\n                    if rec.hasIndex(\"privilege\") then\n                        privilege = rec.privilege\n                    end if\n                    constraints = []\n                    if rec.hasIndex(\"constraints\") and rec.constraints.len > 0 then\n                        constraints = rec.constraints.split(\" \")\n                    end if\n                    blockedBy = \"\"\n                    if rec.hasIndex(\"blocked_by\") then\n                        blockedBy = rec.blocked_by\n                    end if\n                    dbManager.kbRecord(rec.lib_name, rec.lib_version, rec.address, rec.exploit, outcome, constraints, rtype, resultPath, privilege, blockedBy)\n                    kbAdded = kbAdded + 1\n                end for\n            end if\n        end if\n        ui.success(\"Exploit KB: \" + str(kbAdded) + \" merged, \" + str(kbSkipped) + \" skipped\")\n    else\n        ui.dim(\"Exploit KB: no incoming file\")\n    end if\n\n    // ── Roost pool ─────────────────────────────────────────────────────\n    roostFile = pivotHandler.getFile(incomingPath + \"/roost.json\")\n    roostAdded = 0\n    if not (roostFile isa Error) then\n        raw = roostFile.content()\n        if not (raw isa Error) and raw.len > 0 then\n            parsed = parse(raw)\n            if parsed != null and typeof(parsed) == \"list\" then\n                statusOrder = [ROOST_STATUS.DEAD, ROOST_STATUS.DORMANT, ROOST_STATUS.ACTIVE]\n                for inNode in parsed\n                    if not inNode.hasIndex(\"public_ip\") then\n                        continue\n                    end if\n                    // Find existing node with same public IP\n                    existing = dbManager.roostDb.find(inNode.public_ip)\n                    if existing == null then\n                        // New node - add it\n                        procName = \"unknown\"\n                        if inNode.hasIndex(\"process_name\") then\n                            procName = inNode.process_name\n                        end if\n                        lanIp = \"\"\n                        if inNode.hasIndex(\"lan_ip\") then\n                            lanIp = inNode.lan_ip\n                        end if\n                        dbManager.roostDb.add(inNode.public_ip, lanIp, procName)\n                        // Set status and last_used on the newly added record\n                        newRec = dbManager.roostDb.find(inNode.public_ip)\n                        if newRec != null then\n                            if inNode.hasIndex(\"status\") then\n                                newRec.status = inNode.status\n                            end if\n                            if inNode.hasIndex(\"last_used\") then\n                                newRec.last_used = inNode.last_used\n                            end if\n                        end if\n                        roostAdded = roostAdded + 1\n                    else\n                        // Existing node - merge: prefer higher status, keep latest last_used\n                        if inNode.hasIndex(\"status\") then\n                            existingStatusIdx = statusOrder.indexOf(existing.status)\n                            incomingStatusIdx = statusOrder.indexOf(inNode.status)\n                            if existingStatusIdx == null then\n                                existingStatusIdx = 0\n                            end if\n                            if incomingStatusIdx == null then\n                                incomingStatusIdx = 0\n                            end if\n                            if incomingStatusIdx > existingStatusIdx then\n                                existing.status = inNode.status\n                            end if\n                        end if\n                        if inNode.hasIndex(\"last_used\") and inNode.last_used > existing.last_used then\n                            existing.last_used = inNode.last_used\n                        end if\n                        if inNode.hasIndex(\"process_name\") and (not existing.hasIndex(\"process_name\") or existing.process_name.len == 0) then\n                            existing.process_name = inNode.process_name\n                        end if\n                    end if\n                end for\n            end if\n        end if\n        ui.success(\"Roost pool: \" + str(roostAdded) + \" new nodes merged\")\n    else\n        ui.dim(\"Roost pool: no incoming file\")\n    end if\n\n    // ── Save and report ───────────────────────────────────────────────────\n    dbManager.save()\n    ui.print(\"\")\n    ui.success(\"Merge complete. DB saved.\")\n    ui.info(\"Incoming files preserved in /Corvid/Data/incoming/ - delete manually when done\")\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n\n\n",0)
m("/Corvid/source/commands_bounces.txt","// ============================================================\n// CORVID 2.0 | commands_bounces\n// Bounce network management command. Extracted from commands_4.txt\n// to keep that file under the 160k character per-file limit.\n// Subcommands: update map chain verify wipe harden reset remove\n//              add revive restore\n// ============================================================\n\n// --- bounces ---\n_cmd = new Command\n_cmd.name = \"bounces\"\n_cmd.description = \"Bounce network management. Subcommands: update map chain verify wipe harden reset remove add revive restore\"\n_cmd.parameters = [OptionsParameter.New({\"name\": \"subcommand\", \"required\": true, \"options\": {\"update\": \"update\", \"map\": \"map\", \"chain\": \"chain\", \"verify\": \"verify\", \"wipe\": \"wipe\", \"harden\": \"harden\", \"reset\": \"reset\", \"remove\": \"remove\", \"add\": \"add\", \"revive\": \"revive\", \"restore\": \"restore\"}}), StringParameter.New({\"name\": \"subcommand2\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n    bounceManager  = mediator.getExtension(\"bounceManager\")\n    configManager  = mediator.getExtension(\"configManager\")\n    attackManager  = mediator.getExtension(\"attackManager\")\n    sub            = params.subcommand\n\n    // ── build ─────────────────────────────────────────────────────────────\n    if sub == \"update\" then\n        ui.separator()\n        ui.highlight(\"UPDATING BOUNCE NETWORK FROM OWNED TARGETS\")\n        ui.separator()\n\n        // First clean out dead bounces before repopulating.\n        // Track IPs removed THIS run so the removed_bounce filter below\n        // doesn't block them from being re-added in the same invocation.\n        allBouncesPreClean = bounceManager.listBounces()\n        deadRemoved = 0\n        justRemovedIps = []\n        for b in allBouncesPreClean\n            bHealth = bounceManager.getHealth(b)\n            if bHealth == \"dead\" or bHealth == \"dead_port\" or bHealth == \"dead_creds\" then\n                bIp = \"\"\n                if b.hasIndex(\"public_ip\") then\n                    bIp = b.public_ip\n                end if\n                if bIp.len > 0 then\n                    bounceManager.removeBounce(bIp)\n                    justRemovedIps.push(bIp)\n                    ui.dim(\"  Removed dead: \" + bIp)\n                    deadRemoved = deadRemoved + 1\n                end if\n            end if\n        end for\n        if deadRemoved > 0 then\n            ui.print(\"\")\n        end if\n\n        allTargets = dbManager.allTargets()\n        added = 0\n        skipped = 0\n        noSsh = 0\n\n        for target in allTargets\n            tStatus = \"\"\n            if target.hasIndex(\"status\") then\n                tStatus = target.status\n            end if\n            // Include both \"owned\" targets and existing \"bounce\" targets\n            if tStatus != \"owned\" and tStatus != \"bounce\" then\n                continue\n            end if\n            // Skip targets that were explicitly removed from bounce network\n            pubIp = \"\"\n            if target.hasIndex(\"public_ip\") then\n                pubIp = target.public_ip\n            end if\n            if pubIp.len == 0 then\n                continue\n            end if\n\n            // If we just removed this IP as dead earlier in THIS update,\n            // strip the removed_bounce marker so we can re-add it cleanly.\n            wasJustRemoved = false\n            for jr in justRemovedIps\n                if jr == pubIp then\n                    wasJustRemoved = true\n                end if\n            end for\n            if wasJustRemoved and target.hasIndex(\"notes\") and target.notes.indexOf(\"removed_bounce\") != null then\n                cleanedNotes = target.notes.replace(\"removed_bounce\", \"\").trim\n                while cleanedNotes.indexOf(\"  \") != null\n                    cleanedNotes = cleanedNotes.replace(\"  \", \" \")\n                end while\n                target.notes = cleanedNotes.trim\n                dbManager.targetDb.db.set(target.id, target)\n                dbManager.targetDb.db.dirty = true\n            end if\n\n            tNotes = \"\"\n            if target.hasIndex(\"notes\") then\n                tNotes = target.notes\n            end if\n            if tNotes.indexOf(\"removed_bounce\") != null then\n                ui.dim(\"  \" + pubIp + \" - previously removed (use: bounces reset \" + pubIp + \" to re-add)\")\n                skipped = skipped + 1\n                continue\n            end if\n\n            // Need SSH credentials using helper\n            systemCreds = dbManager.findAnySystemCredentials(pubIp)\n            rootUser = systemCreds.username\n            rootPass = systemCreds.password\n\n            if rootPass.len == 0 then\n                ui.warning(\"  \" + pubIp + \" - no system credentials found, skipping\")\n                noSsh = noSsh + 1\n                continue\n            end if\n\n            // Check if already in bounce list - verify record actually exists.\n            // Don't trust tStatus alone: if the bounce record is missing/malformed\n            // we want to fall through and re-add it.\n            existingBounce = bounceManager.findBounce(pubIp)\n            if existingBounce != null then\n                ui.info(\"  \" + pubIp + \" - already in bounce list, skipping\")\n                skipped = skipped + 1\n                continue\n            end if\n            // Status says bounce but no record found - log it and proceed to re-add\n            if tStatus == \"bounce\" then\n                ui.dim(\"  \" + pubIp + \" - status=bounce but no record, re-registering\")\n            end if\n\n            // Add to bounce list\n            lanIp = \"\"\n            if target.hasIndex(\"lan_ip\") then\n                lanIp = target.lan_ip\n            end if\n            nestIp = sessionManager.sessions[0].data.ip.public\n            bounceManager.addBounce(pubIp, lanIp, 22, rootUser, rootPass, \"owned\", nestIp)\n            ui.success(\"  \" + pubIp + \" - added to bounce network\")\n            added = added + 1\n        end for\n\n        ui.print(\"\")\n        ui.info(\"Added: \" + str(added) + \"  Skipped (existing): \" + str(skipped) + \"  No creds: \" + str(noSsh) + \"  Dead removed: \" + str(deadRemoved))\n        ui.separator()\n\n    // ── map ───────────────────────────────────────────────────────────────\n    else if sub == \"map\" then\n        ui.separator()\n        ui.highlight(\"BOUNCE NETWORK MAP\")\n        ui.separator()\n\n        bounces = bounceManager.listBounces()\n        if bounces.len == 0 then\n            ui.warning(\"No bounce points registered. Run: bounces update\")\n            return\n        end if\n\n        nestIp = sessionManager.sessions[0].data.ip.public\n        ui.print(\"\")\n        ui.print(ui.mediator.getExtension(\"themeManager\").highlight(\"  YOUR NEST (\" + nestIp + \")\"))\n        ui.print(\"      |\")\n\n        for i in range(0, bounces.len - 1)\n            b = bounces[i]\n            bIp = \"\"\n            if b.hasIndex(\"public_ip\") then\n                bIp = b.public_ip\n            end if\n            // Health is stored in notes field, status is always \"bounce\"\n            bHealth = \"unknown\"\n            if b.hasIndex(\"notes\") then\n                for notePart in b.notes.split(\" \")\n                    if notePart.indexOf(\"health:\") == 0 then\n                        bHealth = notePart[7:]\n                    end if\n                end for\n            end if\n            bType = \"owned\"\n            if b.hasIndex(\"notes\") and b.notes.indexOf(\"owned\") != null then\n                bType = \"owned\"\n            end if\n\n            isLast = i == bounces.len - 1\n            branch = \"      ├── \"\n            if isLast then\n                branch = \"      └── \"\n            end if\n\n            theme = ui.mediator.getExtension(\"themeManager\")\n            line = branch + \"[\" + str(i+1) + \"] \" + bIp + \"  \" + bType\n            if bHealth == \"healthy\" then\n                ui.print(line + \"  \" + theme.success(\"✓ healthy\"))\n            else if bHealth == \"dead_port\" then\n                ui.print(line + \"  \" + theme.error(\"✗ dead (port gone)\"))\n            else if bHealth == \"dead_creds\" then\n                ui.print(line + \"  \" + theme.warning(\"✗ dead (creds failed)\"))\n            else if bHealth == \"dead\" then\n                ui.print(line + \"  \" + theme.warning(\"✗ dead\"))\n            else\n                ui.print(line + \"  \" + theme.secondary(\"? unverified\"))\n            end if\n        end for\n        ui.print(\"\")\n        ui.separator()\n\n    // ── chain ─────────────────────────────────────────────────────────────\n    else if sub == \"chain\" then\n        bounces = bounceManager.listBounces()\n        if bounces.len == 0 then\n            return Error.New(\"No bounce points registered. Run: bounces update\", \"NO_BOUNCES\")\n        end if\n\n        // Parse optional \"max\" argument - use all available bounces\n        useMax = false\n        targetHops = 5\n        if params.hasIndex(\"subcommand2\") then\n            if params.subcommand2 == \"max\" then\n                useMax = true\n            else\n                parsed = params.subcommand2.val\n                if parsed > 0 then\n                    targetHops = parsed\n                end if\n            end if\n        end if\n\n        // Build pool: filter dead and deduplicate by IP\n        pool = []\n        seenPoolIps = []\n        for b in bounces\n            bHealth = \"unknown\"\n            if b.hasIndex(\"notes\") then\n                for np in b.notes.split(\" \")\n                    if np.indexOf(\"health:\") == 0 then\n                        bHealth = np[7:]\n                    end if\n                end for\n            end if\n            if bHealth == \"dead\" or bHealth == \"dead_port\" or bHealth == \"dead_creds\" then\n                continue\n            end if\n            bIp = \"\"\n            if b.hasIndex(\"public_ip\") then\n                bIp = b.public_ip\n            end if\n            if bIp.len == 0 then\n                continue\n            end if\n            alreadySeen = false\n            for sIp in seenPoolIps\n                if sIp == bIp then\n                    alreadySeen = true\n                end if\n            end for\n            if not alreadySeen then\n                pool.push(b)\n                seenPoolIps.push(bIp)\n            end if\n        end for\n\n        if pool.len == 0 then\n            return Error.New(\"No healthy bounce points available. Run: bounces verify\", \"NO_HEALTHY\")\n        end if\n\n        if useMax then\n            targetHops = pool.len\n        end if\n\n        ui.separator()\n        ui.highlight(\"BOUNCE CHAIN\")\n        ui.separator()\n        ui.print(\"\")\n        ui.info(\"Target hops: \" + str(targetHops) + \"  Available pool: \" + str(pool.len))\n        ui.print(\"\")\n\n        // Check AdminMonitor running locally\n        localShell = sessionManager.sessions[0].handler.shell.shell\n        psOutput = localShell.host_computer.show_procs\n        monitorRunning = false\n        if psOutput != null and typeof(psOutput) == \"string\" then\n            if psOutput.indexOf(\"AdminMonitor\") != null then\n                monitorRunning = true\n            end if\n        end if\n        if not monitorRunning then\n            ui.warning(\"AdminMonitor is not running.\")\n            monAnswer = user_input(\"  Launch AdminMonitor now? (yes/no): \")\n            if monAnswer.trim == \"yes\" or monAnswer.trim == \"y\" then\n                sessionManager.sessions[0].handler.shell.launch(\"/bin/AdminMonitor.exe\", \"\")\n                ui.success(\"AdminMonitor launched.\")\n            end if\n        end if\n\n        // Load metaxploit for admin check if needed in future\n        chainMeta = include_lib(\"/lib/metaxploit.so\")\n\n        // Progressive random chain - pick one hop at a time from remaining pool\n        hopsCompleted = 0\n        attempted = []\n        chainRecord = []\n        seed = floor(time * 1337)\n\n        while hopsCompleted < targetHops and pool.len > 0\n\n            // Pick a random bounce from remaining pool\n            seed = (seed * 7 + 13) % 99999\n            idx = seed % pool.len\n            b = pool[idx]\n            pool.remove(idx)\n\n            bIp   = \"\"\n            bPort = 22\n            if b.hasIndex(\"public_ip\") then\n                bIp = b.public_ip\n            end if\n            if bIp.len == 0 then\n                continue\n            end if\n            attempted.push(bIp)\n\n            ui.info(\"[\" + str(hopsCompleted + 1) + \"/\" + str(targetHops) + \"] Trying: \" + bIp + \"...\")\n\n            // Credential lookup - try current password then native_pass\n            bUser = \"root\"\n            bPass = \"\"\n            bNativePass = \"\"\n            bCreds = dbManager.findCredentialsByIp(bIp)\n            for bc in bCreds\n                if bc.username == \"root\" and bc.password.len > 0 then\n                    bPass = bc.password\n                end if\n                if bc.username == \"root\" and bc.hasIndex(\"native_pass\") and bc.native_pass.len > 0 then\n                    bNativePass = bc.native_pass\n                end if\n            end for\n            // Use native_pass if current is empty\n            if bPass.len == 0 and bNativePass.len > 0 then\n                bPass = bNativePass\n            end if\n\n            if bPass.len == 0 then\n                ui.warning(\"  No root credentials - skipping \" + bIp)\n                continue\n            end if\n\n            // Connect\n            currentHandler = sessionManager.currentSession.handler\n            sshResult = currentHandler.shell.shell.connect_service(bIp, bPort, bUser, bPass, \"ssh\")\n            if typeof(sshResult) != \"shell\" then\n                ui.warning(\"  Connection failed on \" + bIp + \" - skipping\")\n                bounceManager.setStatus(bIp, \"dead\")\n                continue\n            end if\n\n            newSession = sessionManager.addSession(sshResult, \"bounce@\" + bIp)\n            if newSession isa Error then\n                ui.warning(\"  Session error on \" + bIp + \": \" + newSession.message)\n                continue\n            end if\n            sessionManager.setCurrentSession(newSession)\n            hopsCompleted = hopsCompleted + 1\n            ui.success(\"  Hopped: \" + bIp + \" (\" + str(hopsCompleted) + \"/\" + str(targetHops) + \")\")\n            // Record hop for chain persistence\n            hopRecord = {}\n            hopRecord.ip   = bIp\n            hopRecord.port = bPort\n            hopRecord.user = bUser\n            hopRecord.pass = bPass\n            chainRecord.push(hopRecord)\n\n            // Open LogViewer on this hop so you can immediately clear the log manually\n            lvPath = \"\"\n            lvFile = newSession.handler.getFile(\"/usr/bin/LogViewer.exe\")\n            if not (lvFile isa Error) then\n                lvPath = \"/usr/bin/LogViewer.exe\"\n            end if\n            if lvPath.len == 0 then\n                lvFile = newSession.handler.getFile(\"/bin/LogViewer.exe\")\n                if not (lvFile isa Error) then\n                    lvPath = \"/bin/LogViewer.exe\"\n                end if\n            end if\n            if lvPath.len > 0 then\n                newSession.handler.shell.shell.launch(lvPath)\n                wait(2)\n                ui.info(\"  LogViewer opened on \" + bIp + \" - clear the log now\")\n            else\n                ui.dim(\"  LogViewer.exe not found on \" + bIp)\n            end if\n\n\n\n        end while\n\n        ui.print(\"\")\n        if hopsCompleted == 0 then\n            ui.warning(\"No bounces could be established. Try: bounces verify\")\n        else\n            // Save chain to config for restore\n            // Format: ip|port|user|pass;ip|port|user|pass;...\n            // Pipe and semicolon safe - Grey Hack passwords are alphanumeric\n            chainStr = \"\"\n            for cr in chainRecord\n                if chainStr.len > 0 then\n                    chainStr = chainStr + \";\"\n                end if\n                chainStr = chainStr + cr.ip + \"|\" + str(cr.port) + \"|\" + cr.user + \"|\" + cr.pass\n            end for\n            configManager.set(\"lastChain\", chainStr)\n            configManager.set(\"lastChainHops\", str(hopsCompleted))\n            dbManager.save()\n            if hopsCompleted < targetHops then\n                ui.warning(\"Completed \" + str(hopsCompleted) + \"/\" + str(targetHops) + \" hops (pool exhausted)\")\n            else\n                ui.success(\"Chain complete: \" + str(hopsCompleted) + \" hops\")\n            end if\n            ui.info(\"Now on: \" + sessionManager.currentSession.label)\n\n            // Open LogViewer on Nest (session 0) so you can clear its log too\n            pivotHandler = sessionManager.pivotSession.handler\n            nestLvPath = \"\"\n            nestLv = pivotHandler.getFile(\"/usr/bin/LogViewer.exe\")\n            if not (nestLv isa Error) then\n                nestLvPath = \"/usr/bin/LogViewer.exe\"\n            end if\n            if nestLvPath.len == 0 then\n                nestLv = pivotHandler.getFile(\"/bin/LogViewer.exe\")\n                if not (nestLv isa Error) then\n                    nestLvPath = \"/bin/LogViewer.exe\"\n                end if\n            end if\n            if nestLvPath.len > 0 then\n                pivotHandler.shell.shell.launch(nestLvPath)\n                ui.info(\"LogViewer opened on Nest - clear its log now\")\n            end if\n\n            ui.info(\"Run attack from here. Run leave to return to Nest. Run leave wipe to also attempt log cleanup.\")\n            ui.info(\"Chain saved - use: bounces restore  to rebuild if session interrupted.\")\n        end if\n        ui.separator()\n\n\n    // ── verify ────────────────────────────────────────────────────────────\n    else if sub == \"verify\" then\n        ui.separator()\n        ui.highlight(\"VERIFYING BOUNCE NETWORK\")\n        ui.separator()\n\n        bounces = bounceManager.listBounces()\n        if bounces.len == 0 then\n            ui.warning(\"No bounce points registered.\")\n            return\n        end if\n\n        healthy = 0\n        dead    = 0\n\n        for b in bounces\n            bIp  = \"\"\n            bPort = 22\n            if b.hasIndex(\"public_ip\") then\n                bIp = b.public_ip\n            end if\n            if bIp.len == 0 then\n                continue\n            end if\n\n            ui.info(\"Checking \" + bIp + \"...\")\n\n            // Port is up - confirm with credentials from DB\n            bPass = \"\"\n            bNativePass = \"\"\n            bCreds = dbManager.findCredentialsByIp(bIp)\n            for bc in bCreds\n                if bc.username == \"root\" and bc.password.len > 0 then\n                    bPass = bc.password\n                end if\n                if bc.username == \"root\" and bc.hasIndex(\"native_pass\") and bc.native_pass.len > 0 then\n                    bNativePass = bc.native_pass\n                end if\n            end for\n\n            if bPass.len == 0 and bNativePass.len == 0 then\n                bounceManager.setStatus(bIp, \"dead_creds\")\n                ui.warning(\"  \" + bIp + \" ✗ dead - port open but no root credentials in DB\")\n                dead = dead + 1\n                continue\n            end if\n\n            // Full SSH check - try current password then native_pass\n            currentHandler = sessionManager.currentSession.handler\n            rawShellV = currentHandler.shell.shell\n            testResult = null\n            usedPass = bPass\n            if bPass.len > 0 then\n                testResult = rawShellV.connect_service(bIp, bPort, \"root\", bPass, \"ssh\")\n            end if\n            if typeof(testResult) != \"shell\" and bNativePass.len > 0 and bNativePass != bPass then\n                ui.dim(\"  Trying native password...\")\n                testResult = rawShellV.connect_service(bIp, bPort, \"root\", bNativePass, \"ssh\")\n                usedPass = bNativePass\n            end if\n\n            if typeof(testResult) == \"shell\" then\n                bounceManager.setStatus(bIp, \"healthy\")\n                ui.success(\"  \" + bIp + \" ✓ healthy\")\n                healthy = healthy + 1\n                // If native_pass worked, update stored password in DB\n                if usedPass == bNativePass and bNativePass != bPass then\n                    ui.info(\"  Native password worked - updating DB\")\n                    credFix = {} ; credFix.type = \"system\" ; credFix.username = \"root\"\n                    credFix.password = bNativePass ; credFix.public_ip = bIp\n                    credFix.source = \"native\"\n                    dbManager.upsertCredential(credFix)\n                    dbManager.save()\n                end if\n            else\n                bounceManager.setStatus(bIp, \"dead_creds\")\n                ui.warning(\"  \" + bIp + \" ✗ dead - credentials rejected\")\n                dead = dead + 1\n\n                // ── Auto-reattack dead_creds bounce ──────────────────────\n                // Port is reachable but creds failed - try to re-exploit\n                // First check if admin is active (skip if so)\n                adminActive = false\n                metaVerify = include_lib(\"/lib/metaxploit.so\")\n                if metaVerify != null then\n                    adminNet = metaVerify.net_use(bIp, bPort)\n                    if adminNet != null then\n                        if adminNet.is_root_active_user == 1 then\n                            adminActive = true\n                            ui.warning(\"  \" + bIp + \" - admin active, skipping reattack\")\n                        end if\n                    end if\n                end if\n\n                if not adminActive then\n                    ui.info(\"  \" + bIp + \" - attempting auto-reattack...\")\n                    // Look up stored exploit data for this bounce\n                    bTargets = dbManager.findTarget(bIp)\n                    reattackSucceeded = false\n                    for bTgt in bTargets\n                        if reattackSucceeded then\n                            break\n                        end if\n                        if not bTgt.hasIndex(\"exploit_db\") then\n                            continue\n                        end if\n                        for bLibKey in bTgt.exploit_db.indexes\n                            if reattackSucceeded then\n                                break\n                            end if\n                            for bEx in bTgt.exploit_db[bLibKey]\n                                if reattackSucceeded then\n                                    break\n                                end if\n                                // Find port for this exploit\n                                bExPort = 0\n                                if bTgt.hasIndex(\"ports\") then\n                                    for bPr in bTgt.ports\n                                        lm = bPr.service + \"_\" + bPr.version\n                                        if bLibKey.indexOf(lm) != null then\n                                            bExPort = bPr.port\n                                        end if\n                                    end for\n                                end if\n                                if bExPort == 0 then\n                                    continue\n                                end if\n\n                                // Try the overflow\n                                bNet = metaVerify.net_use(bIp, bExPort)\n                                if not bNet then\n                                    continue\n                                end if\n                                bLib = bNet.dump_lib\n                                if not bLib then\n                                    continue\n                                end if\n\n                                // Generate fresh password for password-change exploits\n                                genPass = genRandomPass(12, bIp)\n\n                                bResult = bLib.overflow(bEx.address, bEx.exploit, genPass)\n                                if bResult == null or typeof(bResult) == \"string\" then\n                                    continue\n                                end if\n\n                                if typeof(bResult) == \"shell\" then\n                                    // Got a shell - update credentials and mark healthy\n                                    newPriv = \"\"\n                                    bComp = bResult.host_computer\n                                    if bComp != null then\n                                        // Change root password to our generated one\n                                        bComp.change_password(\"root\", genPass)\n                                        newPriv = \"root\"\n                                    end if\n                                    // Save new credential\n                                    bCredNew = {} ; bCredNew.type = \"system\" ; bCredNew.username = \"root\"\n                                    bCredNew.password = genPass ; bCredNew.public_ip = bIp\n                                    bCredNew.source = \"exploit_generated\"\n                                    dbManager.upsertCredential(bCredNew)\n                                    dbManager.save()\n                                    bounceManager.setStatus(bIp, \"healthy\")\n                                    ui.success(\"  \" + bIp + \" - reattack succeeded! Bounce restored.\")\n                                    dead = dead - 1\n                                    healthy = healthy + 1\n                                    reattackSucceeded = true\n\n                                else if bEx.hasIndex(\"privilege\") and bEx.privilege.len > 0 and bEx.privilege != \"none\" then\n                                    // Password-change exploit - try SSH with new password\n                                    bSshTry = rawShellV.connect_service(bIp, 22, bEx.privilege, genPass, \"ssh\")\n                                    if typeof(bSshTry) == \"shell\" then\n                                        bCredNew = {} ; bCredNew.type = \"system\" ; bCredNew.username = \"root\"\n                                        bCredNew.password = genPass ; bCredNew.public_ip = bIp\n                                        bCredNew.source = \"exploit_generated\"\n                                        dbManager.upsertCredential(bCredNew)\n                                        dbManager.save()\n                                        bounceManager.setStatus(bIp, \"healthy\")\n                                        ui.success(\"  \" + bIp + \" - reattack via password-change succeeded!\")\n                                        dead = dead - 1\n                                        healthy = healthy + 1\n                                        reattackSucceeded = true\n                                    end if\n                                end if\n                            end for\n                        end for\n                    end for\n\n                    if not reattackSucceeded then\n                        ui.dim(\"  \" + bIp + \" - reattack failed, bounce remains dead\")\n                    end if\n                end if\n                // ── End auto-reattack ─────────────────────────────────────\n            end if\n        end for\n\n        ui.print(\"\")\n        ui.info(\"Healthy: \" + str(healthy) + \"  Dead: \" + str(dead))\n        ui.separator()\n\n    // ── wipe ──────────────────────────────────────────────────────────────\n    else if sub == \"wipe\" then\n        ui.separator()\n        ui.highlight(\"WIPING BOUNCE LOGS\")\n        ui.separator()\n\n        bounces = bounceManager.listBounces()\n        if bounces.len == 0 then\n            ui.warning(\"No bounce points registered.\")\n            return\n        end if\n\n        // Originate from Nest (sessions[0]) for consistency with `harden`.\n        // The bounce machines are reached directly from Nest - no chain hop required.\n        wipeHandler = sessionManager.sessions[0].handler\n\n        for b in bounces\n            bIp  = \"\"\n            bPort = 22\n            if b.hasIndex(\"public_ip\") then\n                bIp = b.public_ip\n            end if\n            if bIp.len == 0 then\n                continue\n            end if\n\n            // Look up root credentials from credential DB\n            bUser = \"root\"\n            bPass = \"\"\n            bCreds2 = dbManager.findCredentialsByIp(bIp)\n            for bc2 in bCreds2\n                if bc2.username == \"root\" and bc2.password.len > 0 then\n                    bPass = bc2.password\n                end if\n            end for\n            if bPass.len == 0 then\n                ui.warning(\"  \" + bIp + \" - no root credentials\")\n                continue\n            end if\n\n            sshResult = wipeHandler.shell.shell.connect_service(bIp, bPort, bUser, bPass, \"ssh\")\n            if typeof(sshResult) != \"shell\" then\n                ui.warning(\"  \" + bIp + \" - could not connect\")\n                continue\n            end if\n            // Corrupt log using move trick - more effective than set_content\n            comp = sshResult.host_computer\n            if comp != null then\n                comp.touch(\"/var\", \"t\")\n                emptyFile = comp.File(\"/var/t\")\n                if emptyFile != null then\n                    moveResult = emptyFile.move(\"/var\", \"system.log\")\n                    if moveResult == 1 then\n                        ui.success(\"  \" + bIp + \" - log wiped\")\n                    else\n                        emptyFile.delete()\n                        ui.warning(\"  \" + bIp + \" - log wipe failed\")\n                    end if\n                else\n                    ui.warning(\"  \" + bIp + \" - could not create temp file\")\n                end if\n            else\n                ui.warning(\"  \" + bIp + \" - could not access computer\")\n            end if\n        end for\n        ui.separator()\n\n    // ── harden ───────────────────────────────────────────────────────────\n    else if sub == \"harden\" then\n        ui.separator()\n        ui.highlight(\"HARDENING BOUNCE NETWORK\")\n        ui.separator()\n\n        bounces = bounceManager.listBounces()\n        if bounces.len == 0 then\n            ui.warning(\"No bounce points registered. Run: bounces update\")\n            return\n        end if\n\n        metaHarden = include_lib(\"/lib/metaxploit.so\")\n        upgraded = 0\n        current  = 0\n        failed   = 0\n\n        for b in bounces\n            bIp  = \"\"\n            bPort = 22\n            if b.hasIndex(\"public_ip\") then\n                bIp = b.public_ip\n            end if\n            if bIp.len == 0 then\n                continue\n            end if\n\n            // Skip dead bounces\n            bHealth = \"unknown\"\n            if b.hasIndex(\"notes\") then\n                for np in b.notes.split(\" \")\n                    if np.indexOf(\"health:\") == 0 then\n                        bHealth = np[7:]\n                    end if\n                end for\n            end if\n            if bHealth == \"dead\" or bHealth == \"dead_port\" or bHealth == \"dead_creds\" then\n                ui.dim(\"  \" + bIp + \" - dead (\" + bHealth + \"), skipping\")\n                continue\n            end if\n\n            // Pre-flight admin check\n            preNet = null\n            if metaHarden != null then\n                preNet = metaHarden.net_use(bIp, bPort)\n            end if\n            if not (preNet isa Error) and preNet != null then\n                if preNet.is_root_active_user == 1 then\n                    ui.warning(\"  \" + bIp + \" - admin active, skipping\")\n                    continue\n                end if\n            end if\n\n            // Look up root credentials\n            bUser = \"root\"\n            bPass = \"\"\n            bCreds = dbManager.findCredentialsByIp(bIp)\n            for bc in bCreds\n                if bc.username == \"root\" and bc.password.len > 0 then\n                    bPass = bc.password\n                end if\n            end for\n            if bPass.len == 0 then\n                ui.warning(\"  \" + bIp + \" - no credentials, skipping\")\n                failed = failed + 1\n                continue\n            end if\n\n            // Connect via SSH\n            hardenFromHandler = sessionManager.sessions[0].handler\n            sshH = hardenFromHandler.shell.shell.connect_service(bIp, bPort, bUser, bPass, \"ssh\")\n            if typeof(sshH) != \"shell\" then\n                ui.warning(\"  \" + bIp + \" - could not connect\")\n                failed = failed + 1\n                continue\n            end if\n\n            // Check and upgrade libssh.so\n            ui.info(\"  Checking \" + bIp + \"...\")\n            apt = include_lib(\"/lib/aptclient.so\")\n            if apt == null then\n                ui.warning(\"  \" + bIp + \" - aptclient.so not available\")\n                failed = failed + 1\n                continue\n            end if\n\n            upgradeCheck = apt.check_upgrade(\"/lib/libssh.so\")\n            if upgradeCheck == 1 then\n                apt.install(\"libssh.so\", \"/lib\")\n                ui.success(\"  \" + bIp + \" - libssh.so upgraded ✓\")\n                upgraded = upgraded + 1\n            else if upgradeCheck == 0 then\n                ui.dim(\"  \" + bIp + \" - libssh.so already current\")\n                current = current + 1\n            else\n                ui.warning(\"  \" + bIp + \" - upgrade check failed: \" + str(upgradeCheck))\n                failed = failed + 1\n            end if\n\n            // Apply chmod -R o-rwx / for stealth hardening\n            hardenComp = sshH.host_computer\n            if hardenComp != null then\n                rootFolder = hardenComp.File(\"/\")\n                if not (rootFolder isa Error) then\n                    rootFolder.chmod(\"o-rwx\", true)\n                    ui.success(\"  \" + bIp + \" - permissions locked ✓\")\n                end if\n            end if\n\n            // Change root password and update credential DB\n            newPass = genRandomPass(12, bIp)\n\n            hardenComp2 = sshH.host_computer\n            if hardenComp2 != null then\n                pwResult = hardenComp2.change_password(\"root\", newPass)\n                if typeof(pwResult) != \"string\" or pwResult.len == 0 then\n                    ui.success(\"  \" + bIp + \" - root password changed ✓\")\n                    // Update credential DB with new password\n                    credUpdate = {}\n                    credUpdate.type      = \"system\"\n                    credUpdate.username  = \"root\"\n                    credUpdate.password  = newPass\n                    credUpdate.public_ip = bIp\n                    credUpdate.source    = \"hardened\"\n                    dbManager.upsertCredential(credUpdate)\n                    dbManager.save()\n                else\n                    ui.warning(\"  \" + bIp + \" - password change failed: \" + pwResult)\n                end if\n\n                // Wipe log after hardening\n                hardenLog = hardenComp2.File(\"/var/system.log\")\n                if not (hardenLog isa Error) then\n                    hardenLog.set_content(\"\")\n                end if\n            end if\n        end for\n\n        ui.print(\"\")\n        ui.info(\"Upgraded: \" + str(upgraded) + \"  Already current: \" + str(current) + \"  Failed: \" + str(failed))\n        ui.separator()\n\n    // ── clean ────────────────────────────────────────────────────────────\n    else if sub == \"reset\" then\n        resetIp = \"\"\n        if params.hasIndex(\"ip\") then\n            resetIp = params.ip\n        end if\n        if resetIp.len == 0 and params.hasIndex(\"publicip\") then\n            resetIp = params.publicip\n        end if\n        if resetIp.len == 0 then\n            ui.warning(\"Usage: bounces reset <ip>  - clears removed_bounce marker so build can re-add it\")\n            return\n        end if\n\n        targets = dbManager.findTarget(resetIp)\n        if targets.len == 0 then\n            ui.warning(\"No target found for: \" + resetIp)\n            return\n        end if\n\n        cleared = false\n        for t in targets\n            if t.hasIndex(\"notes\") and t.notes.indexOf(\"removed_bounce\") != null then\n                newNotes = t.notes.replace(\"removed_bounce\", \"\").trim\n                // Clean up double spaces\n                while newNotes.indexOf(\"  \") != null\n                    newNotes = newNotes.replace(\"  \", \" \")\n                end while\n                t.notes = newNotes.trim\n                dbManager.upsertTarget(t)\n                cleared = true\n            end if\n        end for\n\n        if cleared then\n            dbManager.save()\n            ui.success(\"Reset \" + resetIp + \" - run 'bounces update' to re-add to bounce network\")\n        else\n            ui.info(resetIp + \" has no removed_bounce marker - run 'bounces update' directly\")\n        end if\n\n    // ── add ───────────────────────────────────────────────────────────────\n    else if sub == \"add\" then\n        ui.separator()\n        ui.highlight(\"ADD BOUNCE POINT\")\n        ui.separator()\n        addIp   = user_input(\"  Public IP: \").trim\n        addPass = user_input(\"  Root password: \").trim\n        addLan  = user_input(\"  LAN IP (enter to skip): \").trim\n        addPort = 22\n        addPortStr = user_input(\"  SSH port (enter for 22): \").trim\n        if addPortStr.len > 0 and addPortStr.val > 0 then\n            addPort = addPortStr.val\n        end if\n\n        if not is_valid_ip(addIp) then\n            ui.warning(\"Invalid IP: \" + addIp)\n            return\n        end if\n        if addPass.len == 0 then\n            ui.warning(\"Password required\")\n            return\n        end if\n\n        // Verify connection before adding\n        ui.info(\"Verifying connection to \" + addIp + \"...\")\n        pivotShell = sessionManager.sessions[0].handler.shell.shell\n        testConn = pivotShell.connect_service(addIp, addPort, \"root\", addPass, \"ssh\")\n        if typeof(testConn) != \"shell\" then\n            ui.warning(\"Could not connect: \" + str(testConn))\n            addAnyway = user_input(\"  Add anyway? (yes/no): \").trim\n            if addAnyway != \"yes\" and addAnyway != \"y\" then\n                return\n            end if\n        else\n            ui.success(\"Connection verified\")\n        end if\n\n        nestIp = sessionManager.sessions[0].data.ip.public\n        bounceManager.addBounce(addIp, addLan, addPort, \"root\", addPass, \"owned\", nestIp)\n        bounceManager.setStatus(addIp, \"healthy\")\n        ui.success(\"Bounce point added manually: \" + addIp)\n        ui.separator()\n\n    // ── restore ────────────────────────────────────────────────────────────\n    else if sub == \"restore\" then\n        ui.separator()\n        ui.highlight(\"BOUNCE CHAIN RESTORE\")\n        ui.separator()\n\n        savedChain = configManager.get(\"lastChain\")\n        if savedChain isa Error then\n            ui.warning(\"No saved chain found (key missing). Run: bounces chain  first.\")\n            ui.dim(\"Error: \" + savedChain.message)\n            return\n        end if\n        if savedChain.len == 0 then\n            ui.warning(\"No saved chain found (empty). Run: bounces chain  first.\")\n            return\n        end if\n        savedHops = configManager.get(\"lastChainHops\")\n        if savedHops isa Error then\n            savedHops = \"?\"\n        end if\n\n        ui.info(\"Restoring \" + savedHops + \"-hop chain...\")\n        ui.print(\"\")\n\n        // Parse saved chain: ip|port|user|pass;ip|port|user|pass;...\n        chainHops = []\n        entries = savedChain.split(\";\")\n        for entry in entries\n            t = entry.trim()\n            if t.len == 0 then\n                continue\n            end if\n            parts = t.split(\"|\")\n            if parts.len >= 4 then\n                hop = {}\n                hop.ip   = parts[0]\n                hop.port = parts[1].val\n                hop.user = parts[2]\n                hop.pass = parts[3]\n                if hop.ip.len > 0 then\n                    chainHops.push(hop)\n                end if\n            end if\n        end for\n\n        if chainHops.len == 0 then\n            ui.warning(\"Could not parse saved chain. Run: bounces chain to rebuild.\")\n            return\n        end if\n\n        ui.info(\"Rebuilding \" + str(chainHops.len) + \"-hop chain:\")\n        for ch in chainHops\n            ui.dim(\"  \" + ch.ip + \":\" + str(ch.port))\n        end for\n        ui.print(\"\")\n\n        hopsRestored = 0\n        for hop in chainHops\n            bIp2   = hop.ip\n            bPort2 = hop.port\n            bUser2 = hop.user\n            bPass2 = hop.pass\n\n                        ui.info(\"[\" + str(hopsRestored + 1) + \"/\" + str(chainHops.len) + \"] Restoring: \" + bIp2 + \"...\")\n\n            currentHandler2 = sessionManager.currentSession.handler\n            sshResult2 = currentHandler2.shell.shell.connect_service(bIp2, bPort2, bUser2, bPass2, \"ssh\")\n            if typeof(sshResult2) != \"shell\" then\n                ui.warning(\"  Could not reconnect to \" + bIp2 + \" - chain broken at hop \" + str(hopsRestored + 1))\n                ui.info(\"  Try: bounces revive  to revive dead bounces then restore again\")\n                break\n            end if\n\n            newSession2 = sessionManager.addSession(sshResult2, \"bounce@\" + bIp2)\n            if newSession2 isa Error then\n                ui.warning(\"  Session error on \" + bIp2 + \": \" + newSession2.message)\n                break\n            end if\n            sessionManager.setCurrentSession(newSession2)\n            hopsRestored = hopsRestored + 1\n            ui.success(\"  Restored: \" + bIp2 + \" (\" + str(hopsRestored) + \"/\" + str(chainHops.len) + \")\")\n\n            // Wipe log\n            bounceComp2 = sshResult2.host_computer\n            if bounceComp2 != null then\n                logFile2 = bounceComp2.File(\"/var/system.log\")\n                if logFile2 != null and not (logFile2 isa Error) then\n                    logFile2.set_content(\"\")\n                    ui.success(\"  Log wiped\")\n                end if\n            end if\n        end for\n\n        ui.print(\"\")\n        if hopsRestored == chainHops.len then\n            ui.success(\"Chain fully restored: \" + str(hopsRestored) + \" hops\")\n        else\n            ui.warning(\"Partial restore: \" + str(hopsRestored) + \"/\" + str(chainHops.len) + \" hops\")\n        end if\n        ui.info(\"Now on: \" + sessionManager.currentSession.label)\n        ui.info(\"Run leave to return to Nest. Run leave wipe to also attempt log cleanup.\")\n        ui.separator()\n\n    // ── sweep ─────────────────────────────────────────────────────────────\n    else if sub == \"revive\" then\n        ui.separator()\n        ui.highlight(\"BOUNCE REVIVE\")\n        ui.separator()\n        ui.info(\"Checking dead bounces and ssh_default targets for reconnection...\")\n        ui.print(\"\")\n\n        meta = include_lib(\"/lib/metaxploit.so\")\n        if meta == null then\n            meta = include_lib(current_path + \"/metaxploit.so\")\n        end if\n\n        revived  = 0\n        skipped  = 0\n        failed   = 0\n\n        // Build candidate list:\n        // 1. All dead bounce records\n        // 2. All owned/exploited targets with ssh_default and stored root creds\n        candidates = []\n        seenIps    = []\n\n        // Dead bounces, plus any bounce that hasn't been verified this session\n        // (notes don't carry a health: marker - state is genuinely unknown).\n        allBounces = bounceManager.listBounces()\n        for b in allBounces\n            bHealth = bounceManager.getHealth(b)\n            if bHealth == \"dead\" or bHealth == \"dead_port\" or bHealth == \"dead_creds\" or bHealth == \"unknown\" then\n                bIp = \"\"\n                if b.hasIndex(\"public_ip\") then\n                    bIp = b.public_ip\n                end if\n                if bIp.len == 0 then\n                    continue\n                end if\n                alreadySeen = false\n                for s in seenIps\n                    if s == bIp then\n                        alreadySeen = true\n                    end if\n                end for\n                if not alreadySeen then\n                    entry = {} ; entry.ip = bIp ; entry.source = \"dead_bounce\"\n                    candidates.push(entry)\n                    seenIps.push(bIp)\n                end if\n            end if\n        end for\n\n        // Owned/exploited targets with ssh_default\n        allTargets = dbManager.allTargets()\n        for tgt in allTargets\n            tStatus = \"\"\n            if tgt.hasIndex(\"status\") then\n                tStatus = tgt.status\n            end if\n            if tStatus != \"owned\" and tStatus != \"exploited\" then\n                continue\n            end if\n            if not tgt.hasIndex(\"ssh_default\") or not tgt.ssh_default then\n                continue\n            end if\n            tIp = \"\"\n            if tgt.hasIndex(\"public_ip\") then\n                tIp = tgt.public_ip\n            end if\n            if tIp.len == 0 then\n                continue\n            end if\n            alreadySeen = false\n            for s in seenIps\n                if s == tIp then\n                    alreadySeen = true\n                end if\n            end for\n            if not alreadySeen then\n                entry = {} ; entry.ip = tIp ; entry.source = \"ssh_default\"\n                candidates.push(entry)\n                seenIps.push(tIp)\n            end if\n        end for\n\n        if candidates.len == 0 then\n            ui.info(\"No dead bounces or ssh_default targets to sweep.\")\n            return\n        end if\n\n        ui.info(\"Candidates: \" + str(candidates.len))\n        ui.print(\"\")\n\n        for candidate in candidates\n            cIp = candidate.ip\n            ui.info(\"Trying \" + cIp + \" (\" + candidate.source + \")...\")\n\n            // Quick port check first\n            if meta != null then\n                portCheck = meta.net_use(cIp, 22)\n                if not portCheck then\n                    ui.dim(\"  Port 22 unreachable - still down\")\n                    failed = failed + 1\n                    continue\n                end if\n                // Skip if admin is active\n                if portCheck.is_root_active_user == 1 then\n                    ui.warning(\"  Admin active - skipping\")\n                    skipped = skipped + 1\n                    continue\n                end if\n            end if\n\n            // Find root credentials\n            cPass     = \"\"\n            cNative   = \"\"\n            cCreds    = dbManager.findCredentialsByIp(cIp)\n            for cc in cCreds\n                if cc.username != \"root\" then\n                    continue\n                end if\n                if cc.password.len > 0 then\n                    cPass = cc.password\n                end if\n                if cc.hasIndex(\"native_pass\") and cc.native_pass.len > 0 then\n                    cNative = cc.native_pass\n                end if\n            end for\n\n            if cPass.len == 0 and cNative.len == 0 then\n                ui.dim(\"  No root credentials in DB - skipping\")\n                skipped = skipped + 1\n                continue\n            end if\n\n            // Try current password then native_pass\n            currentHandler = sessionManager.currentSession.handler\n            sshConn = null\n            if cPass.len > 0 then\n                sshConn = currentHandler.shell.shell.connect_service(cIp, 22, \"root\", cPass, \"ssh\")\n            end if\n            if typeof(sshConn) != \"shell\" and cNative.len > 0 and cNative != cPass then\n                ui.dim(\"  Trying native password...\")\n                sshConn = currentHandler.shell.shell.connect_service(cIp, 22, \"root\", cNative, \"ssh\")\n                // If native worked, update DB to use native as primary\n                if typeof(sshConn) == \"shell\" then\n                    credFix = {}\n                    credFix.type = \"system\" ; credFix.username = \"root\"\n                    credFix.password = cNative ; credFix.public_ip = cIp\n                    credFix.source = \"native\"\n                    dbManager.upsertCredential(credFix)\n                end if\n            end if\n\n            if typeof(sshConn) != \"shell\" then\n                ui.warning(\"  Could not connect - still dead\")\n                failed = failed + 1\n                continue\n            end if\n\n            // Conne",1)
m("/Corvid/source/commands_bounces.txt","cted - wipe log immediately using move trick\n            revivedComp = sshConn.host_computer\n            if revivedComp != null then\n                revivedComp.touch(\"/var\", \"t\")\n                revivedEmpty = revivedComp.File(\"/var/t\")\n                if revivedEmpty != null then\n                    revivedEmpty.move(\"/var\", \"system.log\")\n                end if\n            end if\n\n            // Update health status\n            bounceManager.setStatus(cIp, \"healthy\")\n            dbManager.save()\n\n            ui.success(\"  \" + cIp + \" is back online - revived ✓  (log wiped)\")\n            revived = revived + 1\n        end for\n\n        ui.print(\"\")\n        ui.info(\"Revived: \" + str(revived) + \"  Failed: \" + str(failed) + \"  Skipped: \" + str(skipped))\n        if revived > 0 then\n            ui.info(\"Run 'bounces update' to re-add revived machines to bounce network if needed\")\n        end if\n        ui.separator()\n\n    // ── remove ───────────────────────────────────────────────────────────\n    else if sub == \"remove\" then\n        removeIp = params.subcommand2.trim\n        if removeIp.len == 0 then\n            removeIp = user_input(\"  IP to remove from bounce pool: \").trim\n        end if\n        if removeIp.len == 0 then\n            return Error.New(\"IP required\", \"MISSING_PARAM\")\n        end if\n        existing = bounceManager.findBounce(removeIp)\n        if existing == null then\n            return Error.New(removeIp + \" is not in the bounce pool\", \"NOT_FOUND\")\n        end if\n        bounceManager.removeBounce(removeIp)\n        dbManager.save()\n        ui.success(\"Removed \" + removeIp + \" from bounce pool\")\n        ui.info(\"Run: bounces reset \" + removeIp + \"  to allow re-adding later\")\n\n    else\n        return Error.New(\"Unknown subcommand: \" + sub + \". Use: update / map / chain / verify / wipe / harden / reset / remove / add / revive / restore\", \"UNKNOWN_SUB\")\n    end if\nend function\ncommandManager.register(_cmd)\n",0)
m("/Corvid/source/commands_5.txt","// ============================================================\n// CORVID 2.0 | commands_5\n// Roost and platform commands.\n// roost: build, deploy, convert, list, pick, verify, nuke\n// platform: deploy, run, collect, clean\n// ============================================================\n\n// ── roost ──────────────────────────────────────────────────────────────\n_cmd = new Command\n_cmd.name = \"roost\"\n_cmd.description = \"Roost node management. Subcommands: build deploy convert list pick verify nuke sweep clean\"\n_cmd.parameters = [OptionsParameter.New({\"name\": \"subcommand\", \"required\": true, \"options\": {\"convert\": \"convert\", \"list\": \"list\", \"pick\": \"pick\", \"adopt\": \"adopt\", \"verify\": \"verify\", \"nuke\": \"nuke\", \"sweep\": \"sweep\", \"clean\": \"clean\"}}), StringParameter.New({\"name\": \"arg\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    dbManager      = mediator.getExtension(\"databaseManager\")\n    configManager  = mediator.getExtension(\"configManager\")\n    bounceManager  = mediator.getExtension(\"bounceManager\")\n    sub            = params.subcommand\n\n    // ── build ────────────────────────────────────────────────────────────\n\n    // ── deploy ───────────────────────────────────────────────────────────\n    if sub == \"convert\" then\n        ui.separator()\n        ui.highlight(\"CONVERTING FLOCK TO ROOST NODE\")\n        ui.separator()\n\n        // List current flock connections\n        meta = include_lib(\"/lib/metaxploit.so\")\n        if meta == null then\n            return Error.New(\"metaxploit.so not available\", \"NO_META\")\n        end if\n\n        shells = meta.rshell_server()\n        if shells == null or shells.len == 0 then\n            return Error.New(\"No active flock connections - run flock adopt first\", \"NO_RSHELL\")\n        end if\n\n        // Show available flock connections\n        for i in range(0, shells.len - 1)\n            sh = shells[i]\n            shIp = \"unknown\"\n            if typeof(sh) == \"shell\" then\n                comp = sh.host_computer\n                if comp != null then\n                    shIp = comp.public_ip + \" / \" + comp.local_ip\n                end if\n            end if\n            ui.info(\"  [\" + str(i) + \"]  \" + shIp)\n        end for\n\n        ui.print(\"\")\n        idxStr = user_input(\"  Convert which connection (0-\" + str(shells.len - 1) + \", enter to cancel): \").trim\n        if idxStr.len == 0 then\n            return\n        end if\n        idx = idxStr.val\n        if not shells.hasIndex(idx) then\n            return Error.New(\"Invalid index\", \"INVALID_IDX\")\n        end if\n\n        sh = shells[idx]\n        if typeof(sh) != \"shell\" then\n            return Error.New(\"Invalid shell object at index \" + str(idx), \"INVALID_SHELL\")\n        end if\n\n        comp = sh.host_computer\n        publicIp = comp.public_ip\n        lanIp = comp.local_ip\n\n        // Check we have root SSH credentials for this machine\n        rootPass = \"\"\n        creds = dbManager.findCredentialsByIp(publicIp)\n        for cred in creds\n            if cred.username == \"root\" and cred.type == \"system\" and cred.password.len > 0 then\n                rootPass = cred.password\n            end if\n        end for\n\n        if rootPass.len == 0 then\n            ui.warning(\"No root credentials found for \" + publicIp + \" in DB\")\n            ui.info(\"Run harvest on this machine first to save root password\")\n            manualPass = user_input(\"  Enter root password manually (enter to cancel): \").trim\n            if manualPass.len == 0 then\n                return\n            end if\n            rootPass = manualPass\n            // Save it\n            credData = {}\n            credData.type = \"system\" ; credData.username = \"root\"\n            credData.password = rootPass ; credData.public_ip = publicIp\n            credData.lan_ip = lanIp ; credData.source = \"manual\"\n            dbManager.upsertCredential(credData)\n        end if\n\n        // Verify SSH actually works with these creds\n        ui.info(\"Verifying SSH access to \" + publicIp + \"...\")\n        pivotShell = sessionManager.pivotSession.handler.shell.shell\n        sshTest = pivotShell.connect_service(publicIp, 22, \"root\", rootPass, \"ssh\")\n        if typeof(sshTest) != \"shell\" then\n            ui.warning(\"SSH verification failed - roost requires SSH root access\")\n            ui.info(\"Check port 22 is forwarded and root password is correct\")\n            proceed = user_input(\"  Register anyway without SSH verification? (yes/no): \").trim\n            if proceed != \"yes\" and proceed != \"y\" then\n                return\n            end if\n        else\n            ui.success(\"SSH root access confirmed ✓\")\n        end if\n\n        // Register in roost DB\n        procName = RoostManager.randomProcessName()\n        dbManager.roostDb.add(publicIp, lanIp, procName)\n\n        // Remove from bounce pool if present\n        bounceManager.removeBounce(publicIp)\n\n        // Adopt as current session\n        newSession = sessionManager.addSession(sh, \"roost@\" + publicIp)\n        if newSession isa Error then\n            return newSession\n        end if\n        sessionManager.setCurrentSession(newSession)\n\n        dbManager.save()\n        ui.success(\"Roost node registered: \" + publicIp)\n        ui.info(\"Process name: \" + procName)\n        ui.info(\"Now on: \" + sessionManager.currentSession.label)\n        ui.info(\"Run: leave  when done\")\n        ui.separator()\n\n    // ── list ─────────────────────────────────────────────────────────────\n    else if sub == \"list\" then\n        ui.separator()\n        ui.highlight(\"ROOST NODE POOL\")\n        ui.separator()\n\n        nodes = dbManager.roostDb.records\n        if nodes.len == 0 then\n            ui.warning(\"No roost nodes registered.\")\n            ui.info(\"Run: flock deploy  from a bounce session to add nodes\")\n            ui.separator()\n            return\n        end if\n\n        for node in nodes\n            statusColor = \"<color=#00ff00>\"\n            if node.status == ROOST_STATUS.DEAD then\n                statusColor = \"<color=#FF4444>\"\n            else if node.status == ROOST_STATUS.DORMANT then\n                statusColor = \"<color=#FFFC33>\"\n            end if\n            lastUsed = \"never\"\n            if node.last_used > 0 then\n                lastUsed = str(floor((time - node.last_used) / 60)) + \"m ago\"\n            end if\n            ui.print(\"  \" + node.public_ip + \"  [\" + node.lan_ip + \"]  \" + statusColor + node.status + \"</color>  proc:\" + node.process_name + \"  last:\" + lastUsed)\n        end for\n        ui.separator()\n\n    // ── adopt ─────────────────────────────────────────────────────────────\n    else if sub == \"adopt\" then\n        ui.separator()\n        ui.highlight(\"ROOST ADOPT — SELECT NODE\")\n        ui.separator()\n\n        active = dbManager.roostDb.listActive()\n        if active.len == 0 then\n            return Error.New(\"No active roost nodes. Run: flock deploy\", \"NO_NODES\")\n        end if\n\n        // Display numbered list\n        idx = 0\n        for node in active\n            lastUsed = \"never\"\n            if node.last_used > 0 then\n                lastUsed = str(floor((time - node.last_used) / 60)) + \"m ago\"\n            end if\n            ui.print(\"  [\" + str(idx) + \"]  \" + node.public_ip + \"  [\" + node.lan_ip + \"]  proc:\" + node.process_name + \"  last:\" + lastUsed)\n            idx = idx + 1\n        end for\n        ui.print(\"\")\n\n        answer = user_input(\"Select node (index or IP): \", false)\n        if answer == null or answer.trim == \"\" then\n            return\n        end if\n\n        // Resolve by index or IP\n        selectedNode = null\n        answerTrimmed = answer.trim\n        isNumeric = true\n        for ch in answerTrimmed\n            if \"0123456789\".indexOf(ch) == null then\n                isNumeric = false\n            end if\n        end for\n\n        if isNumeric then\n            nodeIdx = answerTrimmed.val\n            if nodeIdx >= 0 and nodeIdx < active.len then\n                selectedNode = active[nodeIdx]\n            end if\n        else\n            for node in active\n                if node.public_ip == answerTrimmed then\n                    selectedNode = node\n                    break\n                end if\n            end for\n        end if\n\n        if selectedNode == null then\n            return Error.New(\"No node found for: \" + answerTrimmed, \"NOT_FOUND\")\n        end if\n\n        // Hand off to shared adoption logic\n        adoptResult = roostManager.adoptNode(selectedNode, mediator)\n        if adoptResult isa Error then\n            return adoptResult\n        end if\n\n    // ── pick ─────────────────────────────────────────────────────────────\n    else if sub == \"pick\" then\n        ui.separator()\n        ui.highlight(\"PICKING ROOST NODE\")\n        ui.separator()\n\n        node = dbManager.roostDb.pickLeastUsed()\n        if node == null then\n            return Error.New(\"No active roost nodes. Run: flock deploy\", \"NO_NODES\")\n        end if\n\n        ui.info(\"Auto-selected: \" + node.public_ip + \" (least recently used)\")\n        adoptResult = roostManager.adoptNode(node, mediator)\n        if adoptResult isa Error then\n            return adoptResult\n        end if\n\n    // ── verify ───────────────────────────────────────────────────────────\n    else if sub == \"verify\" then\n        ui.separator()\n        ui.highlight(\"VERIFYING ROOST NODES\")\n        ui.separator()\n\n        nodes = dbManager.roostDb.records\n        if nodes.len == 0 then\n            ui.warning(\"No roost nodes registered.\")\n            ui.separator()\n            return\n        end if\n\n        meta = include_lib(\"/lib/metaxploit.so\")\n        shells = []\n        if meta != null then\n            s = meta.rshell_server()\n            if s != null then\n                shells = s\n            end if\n        end if\n\n        // Build set of connected IPs\n        connectedIps = []\n        for sh in shells\n            if typeof(sh) != \"shell\" then\n                continue\n            end if\n            comp = sh.host_computer\n            if comp != null then\n                connectedIps.push(comp.public_ip)\n            end if\n        end for\n\n        for node in nodes\n            if connectedIps.indexOf(node.public_ip) != null then\n                node.status = ROOST_STATUS.ACTIVE\n                ui.success(\"  \" + node.public_ip + \" - active\")\n            else\n                node.status = ROOST_STATUS.DEAD\n                ui.warning(\"  \" + node.public_ip + \" - dead (no flock connection)\")\n            end if\n        end for\n\n        dbManager.save()\n        ui.separator()\n\n    // ── nuke ─────────────────────────────────────────────────────────────\n    else if sub == \"nuke\" then\n        ui.separator()\n        ui.highlight(\"ROOST NUKE\")\n        ui.separator()\n\n        currentSession = sessionManager.currentSession\n        pivotSession   = sessionManager.pivotSession\n\n        if currentSession == pivotSession then\n            return Error.New(\"Cannot nuke Nest\", \"IS_PIVOT\")\n        end if\n\n        ip = currentSession.data.ip.public\n\n        // Find the roost node record\n        node = dbManager.roostDb.find(ip)\n        if node == null then\n            ui.warning(\"  \" + ip + \" not found in roost pool - attempting cleanup anyway\")\n        end if\n\n        handler = currentSession.handler\n        procName = \"\"\n        if node != null then\n            procName = node.process_name\n        end if\n\n        // Kill the roost process\n        if procName.len > 0 then\n            ui.info(\"Killing process: \" + procName)\n            procs = handler.showProcs()\n            if not (procs isa Error) then\n                for proc in procs\n                    if proc.hasIndex(\"COMMAND\") and proc.hasIndex(\"PID\") then\n                        if proc.COMMAND == procName then\n                            pid = proc.PID.val\n                            if pid > 0 then\n                                handler.shell.shell.host_computer.close_program(pid)\n                                ui.success(\"  Killed \" + procName + \" (PID \" + proc.PID + \")\")\n                            end if\n                        end if\n                    end if\n                end for\n            end if\n        end if\n\n        // Delete deployed files in /shiny\n        shinyDir = handler.getFile(\"/shiny\")\n        if not (shinyDir isa Error) then\n            kids = shinyDir.children()\n            if not (kids isa Error) then\n                for kid in kids\n                    if kid.owner() == handler.user then\n                        kid.delete()\n                        ui.success(\"  Deleted /shiny/\" + kid.name())\n                    end if\n                end for\n            end if\n        end if\n\n        // Delete roost-client binary\n        cbFile = handler.getFile(\"/root/roost-client\")\n        if not (cbFile isa Error) then\n            cbFile.delete()\n            ui.success(\"  Deleted /root/roost-client\")\n        end if\n\n        // Remove from roost pool\n        if node != null then\n            dbManager.roostDb.remove(ip)\n            dbManager.save()\n            ui.success(\"  Removed \" + ip + \" from roost pool\")\n        end if\n\n        // Leave this session via the standard back() path\n        ui.info(\"Backing out...\")\n        backResult = sessionManager.back()\n        if backResult isa Error then\n            ui.warning(\"Could not back out cleanly: \" + backResult.message)\n        end if\n\n        // Restore Nest's metaxploit as the current lib\n        libManager = mediator.getExtension(\"libManager\")\n        pivotMeta = libManager.getPivotLib(LIB_TYPES.METAXPLOIT)\n        if pivotMeta != null then\n            libManager.setCurrentLib(pivotMeta)\n        end if\n\n        ui.success(\"Roost node nuked. Now on: \" + sessionManager.currentSession.label)\n        ui.info(\"Manual LogViewer cleanup recommended on the nuked node.\")\n        ui.separator()\n\n    // ── sweep ────────────────────────────────────────────────────────────\n    else if sub == \"sweep\" then\n        ui.separator()\n        ui.highlight(\"ROOST REVIVAL SWEEP\")\n        ui.separator()\n\n        pivotHandler = sessionManager.pivotSession.handler\n        localShell   = pivotHandler.shell.shell\n\n        // ── Part 1: Revive dead roost nodes via flock ─────────────────────\n        ui.info(\"Checking dead roost nodes for reconnection...\")\n        nodes = dbManager.roostDb.records\n        meta = include_lib(\"/lib/metaxploit.so\")\n        shells = []\n        if meta != null then\n            s = meta.rshell_server()\n            if s != null then\n                shells = s\n            end if\n        end if\n\n        connectedIps = []\n        for sh in shells\n            if typeof(sh) != \"shell\" then\n                continue\n            end if\n            comp = sh.host_computer\n            if comp != null then\n                connectedIps.push(comp.public_ip)\n            end if\n        end for\n\n        revived = 0\n        stillDead = 0\n        alreadyOk = 0\n\n        for node in nodes\n            if node.status == ROOST_STATUS.ACTIVE then\n                alreadyOk = alreadyOk + 1\n                continue\n            end if\n            found = false\n            for cIp in connectedIps\n                if cIp == node.public_ip then\n                    found = true\n                end if\n            end for\n            if found then\n                node.status = ROOST_STATUS.ACTIVE\n                ui.success(\"  Revived: \" + node.public_ip)\n                revived = revived + 1\n            else\n                ui.dim(\"  Still dead: \" + node.public_ip)\n                stillDead = stillDead + 1\n            end if\n        end for\n\n        ui.info(\"Revived: \" + str(revived) + \"  Still dead: \" + str(stillDead) + \"  Active: \" + str(alreadyOk))\n        ui.print(\"\")\n\n        // ── Part 2: Scan owned targets for SSH+root eligibility ───────────\n        ui.info(\"Scanning owned targets for SSH/root eligibility...\")\n        allTargets = dbManager.allTargets()\n        activeRoostIps = []\n        for node in nodes\n            activeRoostIps.push(node.public_ip)\n        end for\n\n        candidates = 0\n        promoted = 0\n\n        for target in allTargets\n            targetIp = target.public_ip\n            if targetIp == null or targetIp.len == 0 then\n                continue\n            end if\n            // Skip if already a roost\n            alreadyRoost = false\n            for rIp in activeRoostIps\n                if rIp == targetIp then\n                    alreadyRoost = true\n                end if\n            end for\n            if alreadyRoost then\n                continue\n            end if\n            // Skip if not owned\n            if not target.hasIndex(\"status\") then\n                continue\n            end if\n            if target.status != \"owned\" and target.status != \"exploited\" then\n                continue\n            end if\n            // Check for root SSH credentials\n            targetCreds = dbManager.findCredentialsByIp(targetIp)\n            rootCred = null\n            for cred in targetCreds\n                if cred.username == \"root\" and cred.type == \"system\" then\n                    rootCred = cred\n                    break\n                end if\n            end for\n            if rootCred == null then\n                continue\n            end if\n            // Check if target has SSH port\n            hasSSH = false\n            if target.hasIndex(\"ports\") then\n                for port in target.ports\n                    if port.hasIndex(\"service\") and port.service == \"ssh\" then\n                        hasSSH = true\n                    end if\n                end for\n            end if\n            if not hasSSH then\n                continue\n            end if\n            candidates = candidates + 1\n            // Attempt SSH connection\n            ui.info(\"  Trying \" + targetIp + \"...\")\n            testShell = localShell.connect_service(targetIp, 22, \"root\", rootCred.password, \"ssh\")\n            if typeof(testShell) != \"shell\" then\n                ui.dim(\"  \" + targetIp + \" — SSH failed\")\n                continue\n            end if\n            // Eligible — add to roost pool\n            dbManager.roostDb.add(targetIp, target.lan_ip, \"\")\n            ui.success(\"  \" + targetIp + \" — added to roost pool\")\n            promoted = promoted + 1\n        end for\n\n        if revived > 0 or promoted > 0 then\n            dbManager.save()\n        end if\n\n        ui.print(\"\")\n        ui.info(\"New roost candidates found: \" + str(candidates))\n        ui.success(\"Added to roost pool: \" + str(promoted))\n        ui.separator()\n\n    // ── clean ────────────────────────────────────────────────────────────\n    else if sub == \"clean\" then\n        ui.separator()\n        ui.highlight(\"CLEANING DEAD ROOST NODES\")\n        ui.separator()\n\n        nodes = dbManager.roostDb.records\n        if nodes.len == 0 then\n            ui.info(\"No roost nodes registered.\")\n            ui.separator()\n            return\n        end if\n\n        // Collect dead node IPs\n        dead = []\n        for node in nodes\n            if node.status == ROOST_STATUS.DEAD then\n                dead.push(node.public_ip)\n            end if\n        end for\n\n        if dead.len == 0 then\n            ui.info(\"No dead nodes to clean.\")\n            ui.info(\"Run 'roost verify' first to update node statuses.\")\n            ui.separator()\n            return\n        end if\n\n        ui.info(\"Dead nodes found: \" + dead.join(\", \"))\n        ui.print(\"\")\n\n        // Offer to archive before removing\n        archiveAnswer = user_input(\"  Archive dead node IPs before removing? (yes/no): \").trim\n        if archiveAnswer == \"yes\" or archiveAnswer == \"y\" then\n            pivotHandler = sessionManager.pivotSession.handler\n            pivotComp = pivotHandler.shell.shell.host_computer\n\n            archivePath = \"/Corvid/Data/dead_roost.txt\"\n            archiveContent = \"\"\n            existingFile = pivotComp.File(archivePath)\n            if existingFile != null then\n                archiveContent = existingFile.get_content\n                if archiveContent == null then\n                    archiveContent = \"\"\n                end if\n            end if\n\n            if archiveContent.len > 0 then\n                archiveContent = archiveContent + char(10)\n            end if\n            archiveContent = archiveContent + dead.join(char(10))\n\n            dataDir = pivotHandler.getFile(\"/Corvid/Data\")\n            if dataDir isa Error then\n                pivotComp.create_folder(\"/Corvid\", \"Data\")\n            end if\n            pivotComp.touch(\"/Corvid/Data\", \"dead_roost.txt\")\n            archFile = pivotComp.File(archivePath)\n            if archFile != null then\n                archFile.set_content(archiveContent)\n                ui.success(\"Archived to \" + archivePath)\n            end if\n        end if\n\n        // Remove dead nodes from pool\n        kept = 0\n        for node in nodes\n            if node.status != ROOST_STATUS.DEAD then\n                kept = kept + 1\n            end if\n        end for\n\n        for dIp in dead\n            dbManager.roostDb.remove(dIp)\n        end for\n\n        dbManager.save()\n\n        ui.success(\"Removed: \" + str(dead.len) + \"  Kept: \" + str(kept))\n        if archiveAnswer == \"yes\" or archiveAnswer == \"y\" then\n            ui.info(\"View archive: cat /Corvid/Data/dead_roost.txt\")\n        end if\n        ui.separator()\n\n    end if\nend function\ncommandManager.register(_cmd)\n\n// ── platform ──────────────────────────────────────────────────────────────\n_cmd = new Command\n_cmd.name = \"platform\"\n_cmd.description = \"Attack platform management. Subcommands: deploy sleep status wipe attack routerattack build\"\n_cmd.parameters = [OptionsParameter.New({\"name\": \"subcommand\", \"required\": true, \"options\": {\"deploy\": \"deploy\", \"sleep\": \"sleep\", \"status\": \"status\", \"wipe\": \"wipe\", \"attack\": \"attack\", \"routerattack\": \"routerattack\", \"build\": \"build\"}}), StringParameter.New({\"name\": \"subcommand2\", \"required\": false, \"default\": \"\"}), StringParameter.New({\"name\": \"targetIp\", \"required\": false, \"default\": \"\"}), StringParameter.New({\"name\": \"lanIp\", \"required\": false, \"default\": \"\"})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui              = mediator.getExtension(\"corvidUi\")\n    sessionManager  = mediator.getExtension(\"sessionManager\")\n    dbManager       = mediator.getExtension(\"databaseManager\")\n    platformManager = mediator.getExtension(\"platformManager\")\n    sub             = params.subcommand\n\n    currentSession = sessionManager.currentSession\n    pivotSession   = sessionManager.pivotSession\n\n    // ── activate ─────────────────────────────────────────────────────────\n    if sub == \"deploy\" then\n        ui.separator()\n        ui.highlight(\"DEPLOYING ATTACK PLATFORM\")\n        ui.separator()\n        result = platformManager.activate()\n        if result isa Error then\n            return result\n        end if\n\n        // Pre-upload attack binaries to node so attacks don't need to upload each time\n        nodeHandler  = sessionManager.currentSession.handler\n        nodeShell    = nodeHandler.shell.shell\n        nodeComp     = nodeShell.host_computer\n        pivotHandler = pivotSession.handler\n        pivotShell   = pivotHandler.shell.shell\n\n        binNames = [\"node-attacker\", \"node-router\"]\n        for binName in binNames\n            existing = nodeComp.File(\"/shiny/\" + binName)\n            if existing != null then\n                ui.dim(\"  \" + binName + \" already on node\")\n                continue\n            end if\n            nestBin = pivotHandler.getFile(\"/Corvid/tools/\" + binName)\n            if nestBin isa Error then\n                ui.warning(\"  \" + binName + \" not found on Nest - run: platform build\")\n                continue\n            end if\n            scpRes = pivotShell.scp(\"/Corvid/tools/\" + binName, \"/shiny\", nodeShell)\n            if typeof(scpRes) == \"string\" and scpRes.len > 0 then\n                ui.warning(\"  Could not upload \" + binName + \": \" + scpRes)\n            else\n                ui.success(\"  Uploaded \" + binName + \" to node\")\n            end if\n        end for\n\n        ui.print(\"\")\n        ui.info(\"Attacks will now originate from: \" + platformManager.nodeIp)\n        ui.info(\"Run: platform sleep  to pause without cleaning\")\n        ui.info(\"Run: platform wipe   to clean and deactivate\")\n        ui.dim(\"Note: scan and build operations run on node hardware - may be slower than Nest\")\n        ui.separator()\n\n    // ── deactivate ───────────────────────────────────────────────────────\n    else if sub == \"sleep\" then\n        ui.separator()\n        platformManager.deactivate()\n        ui.info(\"Note: uploaded libs still on node - run: platform wipe  to remove them\")\n        ui.separator()\n\n    // ── status ───────────────────────────────────────────────────────────\n    else if sub == \"status\" then\n        ui.separator()\n        ui.highlight(\"PLATFORM STATUS\")\n        ui.separator()\n        if not platformManager.active then\n            ui.print(\"  Status     : inactive\")\n            ui.print(\"  Origin     : Nest (all attacks from your machine)\")\n        else\n            ui.print(\"  Status     : ACTIVE\")\n            ui.print(\"  Node       : \" + platformManager.nodeIp)\n            ui.print(\"  Meta path  : \" + platformManager.metaPath)\n            ui.print(\"  Crypto path: \" + platformManager.cryptoPath)\n            if platformManager.uploadedMeta then\n                ui.print(\"  Uploaded   : metaxploit.so\")\n            end if\n            if platformManager.uploadedCrypto then\n                ui.print(\"  Uploaded   : crypto.so\")\n            end if\n        end if\n        ui.separator()\n\n    // ── wipe ─────────────────────────────────────────────────────────────\n    else if sub == \"wipe\" then\n        ui.separator()\n        ui.highlight(\"WIPING PLATFORM NODE\")\n        ui.separator()\n        if not platformManager.active then\n            return Error.New(\"Platform not active - nothing to wipe\", \"NOT_ACTIVE\")\n        end if\n        ui.info(\"Removing uploaded files from \" + platformManager.nodeIp + \"...\")\n        platformManager.wipe()\n        ui.info(\"Node cleaned. Platform sleeping.\")\n        ui.separator()\n\n    // ── attack ───────────────────────────────────────────────────────────\n    else if sub == \"attack\" then\n        ui.separator()\n        ui.highlight(\"PLATFORM ATTACK\")\n        ui.separator()\n\n        if not platformManager.active then\n            return Error.New(\"Platform not active - run: platform deploy\", \"NOT_ACTIVE\")\n        end if\n\n        // Get target\n        targetIp = params.targetIp.trim\n        lanIp    = params.subcommand2.trim\n        if targetIp.len == 0 then\n            targetIp = user_input(\"  Target public IP: \").trim\n        end if\n        if targetIp.len == 0 then\n            return Error.New(\"Target IP required\", \"MISSING_PARAM\")\n        end if\n\n        // Get optional credentials - check params first then DB\n        jobUser = \"\"\n        jobPass = \"\"\n        if params.lanIp.trim.len > 0 then\n            // params: attack <ip> [lan] [user] [pass]\n            // reuse lanIp field for user, lanIp field... need rethink\n            // Actually handled via subcommand2=lanIp, targetIp=ip\n            // user and pass come from DB auto-populate below\n        end if\n\n        // Auto-populate credentials from DB if available\n        allCreds = dbManager.findCredentialsByIp(targetIp)\n        for c in allCreds\n            if c.type == \"system\" and c.username != \"root\" and c.password.len > 0 then\n                if jobUser.len == 0 then\n                    jobUser = c.username\n                    jobPass = c.password\n                end if\n            end if\n        end for\n        if lanIp.len > 0 then\n            lanCreds = dbManager.findCredentialsByIp(lanIp)\n            for c in lanCreds\n                if c.type == \"system\" and c.username != \"root\" and c.password.len > 0 then\n                    if jobUser.len == 0 then\n                        jobUser = c.username\n                        jobPass = c.password\n                    end if\n                end if\n            end for\n        end if\n\n        platformAttack(targetIp, lanIp, jobUser, jobPass, mediator, platformManager)\n\n    // ── routerattack ─────────────────────────────────────────────────────\n    else if sub == \"routerattack\" then\n        ui.separator()\n        ui.highlight(\"PLATFORM ROUTER ATTACK\")\n        ui.separator()\n\n        if not platformManager.active then\n            return Error.New(\"Platform not active - run: platform deploy\", \"NOT_ACTIVE\")\n        end if\n\n        targetIp = params.targetIp.trim\n        lanIp    = params.subcommand2.trim\n        if targetIp.len == 0 then\n            targetIp = user_input(\"  Router public IP: \").trim\n        end if\n        if targetIp.len == 0 then\n            return Error.New(\"Target IP required\", \"MISSING_PARAM\")\n        end if\n\n        // Try to auto-populate LAN IP from DB\n        if lanIp.len == 0 then\n            tgts = dbManager.findTarget(targetIp)\n            for tgt in tgts\n                if tgt.hasIndex(\"lan_ip\") and tgt.lan_ip.len > 0 then\n                    if lanIp.len == 0 then\n                        lanIp = tgt.lan_ip\n                    end if\n                end if\n            end for\n        end if\n\n        if lanIp.len == 0 then\n            ui.warning(\"No LAN IP found in DB for this target.\")\n            ui.info(\"The primary goal of a router attack is mail credentials\")\n            ui.info(\"and usernames from the LAN machine. Without a LAN IP,\")\n            ui.info(\"results will be limited to router-level access only.\")\n            ui.info(\"Run nmap on the public IP first to discover LAN machines.\")\n            ui.print(\"\")\n            lanIp = user_input(\"  LAN target IP (enter to continue without): \").trim\n        else\n            ui.info(\"LAN target auto-populated from DB: \" + lanIp)\n        end if\n\n        // Auto-populate root credentials from DB\n        jobUser = \"\"\n        jobPass = \"\"\n        allCreds = dbManager.findCredentialsByIp(targetIp)\n        for c in allCreds\n            if c.type == \"system\" and c.username == \"root\" and c.password.len > 0 then\n                if jobPass.len == 0 then\n                    jobUser = \"root\"\n                    jobPass = c.password\n                end if\n            end if\n        end for\n        if jobPass.len > 0 then\n            ui.info(\"Root credentials found in DB - will attempt GCO escalation\")\n        end if\n\n        platformRouterAttack(targetIp, lanIp, jobUser, jobPass, mediator, platformManager)\n\n    // ── build ────────────────────────────────────────────────────────────\n    else if sub == \"build\" then\n        ui.separator()\n        ui.highlight(\"BUILDING PLATFORM BINARIES\")\n        ui.separator()\n\n        pivotHandler = pivotSession.handler\n        pivotShell   = pivotHandler.shell.shell\n        pivotComp    = pivotShell.host_computer\n\n        // Ensure tools dir exists\n        toolsDir = pivotHandler.getFile(\"/Corvid/tools\")\n        if toolsDir isa Error then\n            pivotComp.create_folder(\"/Corvid\", \"tools\")\n        end if\n\n        // Build node-attacker\n        srcFile = pivotHandler.getFile(\"/Corvid/tools/node-attacker.src\")\n        if srcFile isa Error then\n            ui.warning(\"node-attacker.src not found - copy from Corvid source zip to /Corvid/tools/\")\n        else\n            ui.info(\"Compiling node-attacker.src...\")\n            buildResult = pivotShell.build(\"/Corvid/tools/node-attacker.src\", \"/Corvid/tools\")\n            if typeof(buildResult) == \"string\" and buildResult.len > 0 then\n                ui.warning(\"node-attacker build failed: \" + buildResult)\n            else\n                builtFile = pivotHandler.getFile(\"/Corvid/tools/node-attacker\")\n                if builtFile isa Error then\n                    ui.warning(\"node-attacker binary not found after build\")\n                else\n                    ui.success(\"node-attacker built at /Corvid/tools/node-attacker\")\n                end if\n            end if\n        end if\n\n        // Build node-router\n        routerSrc = pivotHandler.getFile(\"/Corvid/tools/node-router.src\")\n        if routerSrc isa Error then\n            ui.warning(\"node-router.src not found - copy from Corvid source zip to /Corvid/tools/\")\n        else\n            ui.info(\"Compiling node-router.src...\")\n            buildResult2 = pivotShell.build(\"/Corvid/tools/node-router.src\", \"/Corvid/tools\")\n            if typeof(buildResult2) == \"string\" and buildResult2.len > 0 then\n                ui.warning(\"node-router build failed: \" + buildResult2)\n            else\n                builtFile2 = pivotHandler.getFile(\"/Corvid/tools/node-router\")\n                if builtFile2 isa Error then\n                    ui.warning(\"node-router binary not found after build\")\n                else\n                    ui.success(\"node-router built at /Corvid/tools/node-router\")\n                end if\n            end if\n        end if\n\n        ui.info(\"Run: platform deploy  then: platform attack <ip>  or  platform routerattack <ip>\")\n        ui.separator()\n\n    end if\nend function\ncommandManager.register(_cmd)\n\n// ── dbsync ────────────────────────────────────────────────────────────────\n_cmd = new Command\n_cmd.name = \"dbsync\"\n_cmd.description = \"Sync DB files to/from another Corvid server. Subcommands: push pull\"\n_cmd.parameters = [OptionsParameter.New({\"name\": \"subcommand\", \"required\": true, \"options\": {\"push\": \"push\", \"pull\": \"pull\"}})]\n_cmd.permissions = {}\n_cmd.permissions.object = \"shell\"\n_cmd.permissions.privilege = \"root\"\n_cmd.callback = function(params, mediator)\n    ui             = mediator.getExtension(\"corvidUi\")\n    sessionManager = mediator.getExtension(\"sessionManager\")\n    sub            = params.subcommand\n\n    ui.separator()\n    if sub == \"push\" then\n        ui.highlight(\"DBSYNC PUSH  -  send local DB to remote server\")\n    else\n        ui.highlight(\"DBSYNC PULL  -  fetch remote DB to local incoming/\")\n    end if\n    ui.separator()\n\n    // Prompt for remote server details\n    remoteIp   = user_input(\"  Remote server IP: \").trim\n    remoteUser = user_input(\"  Username: \").trim\n    remotePass = user_input(\"  Password: \").trim\n\n    if remoteIp.len == 0 or remoteUser.len == 0 or remotePass.len == 0 then\n        return Error.New(\"IP, username and password are all required\", \"MISSING_PARAM\")\n    end if\n\n    // Connect to remote server\n    ui.info(\"Connecting to \" + remoteUser + \"@\" + remoteIp + \"...\")\n    pivotHandler = sessionManager.pivotSession.handler\n    conn = pivotHandler.shell.shell.connect_service(remoteIp, 22, remoteUser, remotePass, \"ssh\")\n    if typeof(conn) != \"shell\" then\n        return Error.New(\"Could not connect to \" + remoteIp + \" - check credentials\", \"CONNECT_FAILED\")\n    end if\n    ui.success(\"Connected\")\n\n    remoteComp = conn.host_computer\n\n    dbFiles = [\n        \"persons.json\",\n        \"orgs.json\",\n        \"credentials.json\",\n        \"targets.json\",\n        \"exploit-kb.json\",\n        \"roost.json\",\n    ]\n\n    localComp = pivotHandler.shell.shell.host_computer\n\n    // ── push: read local files, write to remote /Corvid/Data/incoming/ ────\n    if sub == \"push\" then\n        // Ensure incoming dir exists on remote\n        incomingDir = remoteComp.File(\"/Corvid/Data/incoming\")\n        if incomingDir == null then\n            remoteComp.create_folder(\"/Corvid/Data\", \"incoming\")\n        end if\n\n        transferred = 0\n        for fname in dbFiles\n            localFile = localComp.File(\"/Corvid/Data/\" + fname)\n            if localFile == null then\n                ui.dim(\"  \" + fname + \" - not found locally, skipping\")\n                continue\n            end if\n            content = localFile.get_content\n            if content == null or content.len == 0 then\n                ui.dim(\"  \" + fname + \" - empty, skipping\")\n                continue\n            end if\n            // Write to remote incoming dir\n            remoteComp.touch(\"/Corvid/Data/incoming\", fname)\n            remoteFile = remoteComp.File(\"/Corvid/Data/incoming/\" + fname)\n            if remoteFile == null then\n                ui.warning(\"  \" + fname + \" - could not create on remote\")\n                continue\n            end if\n            remoteFile.set_content(content)\n            ui.success(\"  \" + fname + \" -> remote /Corvid/Data/incoming/\")\n            transferred = transferred + 1\n        end for\n\n        ui.print(\"\")\n        ui.success(\"Pushed \" + str(transferred) + \"/\" + str(dbFiles.len) + \" files\")\n        ui.info(\"Run 'dbmerge' on the remote server to merge incoming files into its DB\")\n\n    // ── pull: read remote files, write to local /Corvid/Data/incoming/ ───\n    else\n        // Ensure local incoming dir exists\n        incomingDir = localComp.File(\"/Corvid/Data/incoming\")\n        if incomingDir == null then\n            localComp.create_folder(\"/Corvid/Data\", \"incoming\")\n        end if\n\n        transferred = 0\n        for fname in dbFiles\n            remoteFile = remoteComp.File(\"/Corvid/Data/\" + fname)\n            if remoteFile == null then\n                ui.dim(\"  \" + fname + \" - not found on remote, skipping\")\n                continue\n            end if\n            content = remoteFile.get_content\n            if content == null or content.len == 0 then\n                ui.dim(\"  \" + fname + \" - empty on remote, skipping\")\n                continue\n            end if\n            // Write to local incoming dir\n            localComp.touch(\"/Corvid/Data/incoming\", fname)\n            localFile = localComp.File(\"/Corvid/Data/incoming/\" + fname)\n            if localFile == null then\n                ui.warning(\"  \" + fname + \" - could not create locally\")\n                continue\n            end if\n            localFile.set_content(content)\n            ui.success(\"  remote \" + fname + \" -> /Corvid/Data/incoming/\")\n            transferred = transferred + 1\n        end for\n\n        ui.print(\"\")\n        ui.success(\"Pulled \" + str(transferred) + \"/\" + str(dbFiles.len) + \" files\")\n        ui.info(\"Run 'dbmerge' to merge incoming files into local DB\")\n    end if\n\n    ui.separator()\nend function\ncommandManager.register(_cmd)\n\n// ── dbmerge ───────────────────────────────────────────────────────────────\n_cmd = new Command\n_cmd.name = \"dbmerge\"\n_cmd.description = \"Merge DB files from /Corvid/Data/incoming/ into live DB\"\n_cmd.parameters = []\n_cmd.permissions = {}\n_cmd.permissions.object = \"file\"\n_cmd.permissions.privilege = \"guest\"\n_cmd.callback = function(params, mediator)\n    ui        = mediator.getExtension(\"corvidUi\")\n    dbManager = mediator.getExtension(\"databaseManager\")\n\n    ui.separator()\n    ui.highlight(\"DBMERGE  -  merging incoming DB files into live DB\")\n    ui.separator()\n\n    pivotHandler = mediator.getExtension(\"sessionManager\").pivotSession.handler\n    pivotComp    = pivotHandler.shell.shell.host_computer\n\n    incomingDir = pivotComp.File(\"/Corvid/Data/incoming\")\n    if incomingDir == null then\n        return Error.New(\"No incoming/ directory found - run dbsync push or pull first\", \"NO_INCOMING\")\n    end if\n\n    // ── Persons ───────────────────────────────────────────────────────────\n    personsFile = pivotComp.File(\"/Corvid/Data/incoming/persons.json\")\n    personsMerged = 0\n    if personsFile != null then\n        raw = personsFile.get_content\n        if raw != null and raw.len > 0 then\n            incoming = parse(raw)\n            if incoming != null then\n                // persons.json is a map keyed by id - iterate values\n                for kv in incoming\n                    rec = kv.value\n                    if typeof(rec) == \"map\" and rec.hasIndex(\"email\") then\n                        dbManager.upsertPerson(rec)\n                        personsMerged = personsMerged + 1\n                    end if\n                end for\n            end if\n        end if\n    end if\n    ui.success(\"Persons merged: \" + str(personsMerged))\n\n    // ── Orgs ──────────────────────────────────────────────────────────────\n    orgsFile = pivotComp.File(\"/Corvid/Data/incoming/orgs.json\")\n    orgsMerged = 0\n    if orgsFile != null then\n        raw = orgsFile.get_content\n        if raw != null and raw.len > 0 then\n            incoming = parse(raw)\n            if incoming != null then\n                for kv in incoming\n                    rec = kv.value\n                    if typeof(rec) == \"map\" and rec.hasIndex(\"domain\") then\n                        dbManager.upsertOrg(rec)\n                        orgsMerged = orgsMerged + 1\n                    end if\n                end for\n            end if\n        end if\n    end if\n    ui.success(\"Orgs merged: \" + str(orgsMerged))\n\n    // ── Credentials ───────────────────────────────────────────────────────\n    credsFile = pivotComp.File(\"/Corvid/Data/incoming/credentials.json\")\n    credsMerged = 0\n    if credsFile != null then\n        raw = credsFile.get_content\n        if raw != null and raw.len > 0 then\n            incoming = parse(raw)\n            if incoming != null then\n                for kv in incoming\n                    rec = kv.value\n                    if typeof(rec) == \"map\" and rec.hasIndex(\"type\") then\n                        dbManager.upsertCredential(rec)\n                        credsMerged = credsMerged + 1\n                    end if\n                end for\n            end if\n        end if\n    end if\n    ui.success(\"Credentials merged: \" + str(credsMerged))\n\n    // ── Targets ───────────────────────────────────────────────────────────\n    targetsFile = pivotComp.File(\"/Corvid/Data/incoming/targets.json\")\n    targetsMerged = 0\n    if targetsFile != null then\n        raw = targetsFile.get_content\n        if raw != null and raw.len > 0 then\n            incoming = parse(raw)\n            if incoming != null then\n                for kv in incoming\n                    rec = kv.value\n                    if typeof(rec) == \"map\" and rec.hasIndex(\"public_ip\") then\n                        dbManager.upsertTarget(rec)\n                        targetsMerged = targetsMerged + 1\n                    end if\n                end for\n            end if\n        end if\n    end if\n    ui.success(\"Targets merged: \" + str(targetsMerged))\n\n    // ── Exploit KB ────────────────────────────────────────────────────────\n    // KB records are merged directly - we don't call kbRecord() because\n    // that increments success_count. Instead we upsert raw records,\n    // respecting outcome priority: success > constraint_blocked > uncertain.\n    kbFile = pivotComp.File(\"/Corvid/Data/incoming/exploit-kb.json\")\n    kbMerged = 0\n    if kbFile != null then\n        raw = kbFile.get_content\n        if raw != null and raw.len > 0 then\n            incoming = parse(raw)\n            if incoming != null then\n                outcomeOrder = [\"uncertain\", \"constraint_blocked\", \"success\"]\n                kbObj = dbManager.getExploitKb()\n                for kv in incoming\n                    rec = kv.value\n                    if not (typeof(rec) == \"map\") then\n                        continue\n                    end if\n                    if not rec.hasIndex(\"lib_name\") then\n                        continue\n                    end if\n                    // Find existing record by iterating all KB records\n                    existRec = null\n                    allKbRecords = kbObj.db.all()\n                    for kr in allKbRecords\n                        if not kr.hasIndex(\"lib_name\") then\n                            continue\n                        end if\n                        if not kr.hasIndex(\"lib_version\") then\n                            continue\n                        end if\n                        if not kr.hasIndex(\"address\") then\n                            continue\n                        end if\n                        if not kr.hasIndex(\"exploit\") then\n                            continue\n                        end if\n                        if kr.lib_name == rec.lib_name and kr.lib_version == rec.lib_version and kr.address == rec.address and kr.exploit == rec.exploit then\n                            existRec = kr\n                            break\n                        end if\n                    end for\n                    if existRec != null then\n                        // Only upgrade outcome, never downgrade\n                        existOutcomeIdx    = outcomeOrder.indexOf(existRec.outcome)\n                        incomingOutcomeIdx = outcomeOrder.indexOf(rec.outcome)\n                        if existOutcomeIdx == null then\n                            existOutcomeIdx = 0\n                        end if\n                        if incomingOutcomeIdx == null then\n                            incomingOutcomeIdx = 0\n                        end if\n                        if incomingOutcomeIdx > existOutcomeIdx then\n                            existRec.outcome = rec.outcome\n                            if rec.hasIndex(\"rtype\") and rec.rtype.len > 0 then\n                                existRec.rtype = rec.rtype\n                            end if\n                            if rec.hasIndex(\"privilege\") and rec.privilege.len > 0 then\n                                existRec.privilege = rec.privilege\n                            end if\n                            kbObj.db.set(existRec.id, existRec)\n                            kbObj.db.dirty = true\n                        end if\n                        // Take higher success_count\n                        if rec.hasIndex(\"success_count\") and existRec.hasIndex(\"success_count\") then\n                            if rec.success_count > existRec.success_count then\n                                existRec.success_count = rec.success_count\n                            end if\n                        end if\n                    else\n                        // New KB entry - insert directly\n                        newId = kbObj.db.nextId(\"ek\")\n                        rec.id = newId\n                        kbObj.db.set(newId, rec)\n                        kbObj.db.dirty = true\n                        kbMerged = kbMerged + 1\n                    end if\n                end for\n            end if\n        end if\n    end if\n    ui.success(\"Exploit KB entries merged: \" + str(kbMerged))\n\n    // ── Roost pool ─────────────────────────────────────────────────────\n    roostFile = pivotComp.File(\"/Corvid/Data/incoming/roost.json\")\n    roostMerged = 0\n    if roostFile != null then\n        raw = roostFile.get_content\n        if raw != null and raw.len > 0 then\n            incoming = parse(raw)\n            if incoming != null and incoming isa list then\n                statusOrder = [\"dead\", \"dormant\", \"active\"]\n                for inNode in incoming\n                    if not (typeof(inNode) == \"map\") then\n                        continue\n                    end if\n                    if not inNode.hasIndex(\"public_ip\") then\n                        continue\n                    end if\n                    // Find existing node by public_ip\n                    existNode = dbManager.roostDb.find(inNode.public_ip)\n                    if existNode != null then\n                        // Take more advanced status\n                        existStatusIdx   = statusOrder.indexOf(existNode.status)\n                        incomingStatusIdx = statusOrder.indexOf(inNode.status)\n                        if existStatusIdx == null then\n                            existStatusIdx = 0\n                        end if\n                        if incomingStatusIdx == null then\n                            incomingStatusIdx = 0\n                        end if\n                        if incomingStatusIdx > existStatusIdx then\n                            existNode.status = inNode.status\n                        end if\n                        // Take most recent last_used\n                        i",1)
